        &self,
        _p: ArrayView1<f64>,
        _egrad: ArrayView1<f64>,
        _ehess_vp: ArrayViewMut1<f64>,
        _xi: ArrayView1<f64>,
    ) {
        // Identity: no Weingarten correction in flat space.
    }
    fn name(&self) -> &str {
        "Euclidean"
    }
}

