        return Err(HmcError::FirthUnsupported {
            reason: format!(
                "NUTS with Firth is only supported for {}; {} does not support it",
                LikelihoodFamily::BinomialLogit.pretty_name(),
                family.likelihood_family().pretty_name()
            ),
        });
    }

