   102	pub(crate) fn build_denested_partition_cells(
   103	    a: f64,
   104	    b: f64,
   105	    score_warp: Option<&crate::families::bernoulli_marginal_slope::DeviationRuntime>,
   106	    beta_h: Option<&Array1<f64>>,
   107	    link_dev: Option<&crate::families::bernoulli_marginal_slope::DeviationRuntime>,
   108	    beta_w: Option<&Array1<f64>>,
   109	    scale: f64,
   110	) -> Result<Vec<DenestedPartitionCell>, String> {
   111	    let score_breaks = score_warp
   112	        .map(|runtime| runtime.breakpoints().to_vec())
   113	        .unwrap_or_default();
   114	    let link_breaks = link_dev
   115	        .map(|runtime| runtime.breakpoints().to_vec())
   116	        .unwrap_or_default();
   117	
   118	    let mut cells = cubic_cell_kernel::build_denested_partition_cells_with_tails(
   119	        a,
   120	        b,
   121	        &score_breaks,
   122	        &link_breaks,
   123	        |z| {
   124	            if let (Some(runtime), Some(beta)) = (score_warp, beta_h) {
   125	                runtime.local_cubic_at(beta, z)
   126	            } else {
   127	                Ok(zero_local_span_cubic())
   128	            }
   129	        },
   130	        |u| {
   131	            if let (Some(runtime), Some(beta)) = (link_dev, beta_w) {
   132	                runtime.local_cubic_at(beta, u)
   133	            } else {
   134	                Ok(zero_local_span_cubic())
   135	            }
   136	        },
   137	    )?;
   138	    if scale != 1.0 {
   139	        for partition_cell in &mut cells {
   140	            partition_cell.cell.c0 *= scale;
   141	            partition_cell.cell.c1 *= scale;
   142	            partition_cell.cell.c2 *= scale;
   143	            partition_cell.cell.c3 *= scale;
   144	        }
   145	    }
   146	    Ok(cells)
   147	}
