    98	            | SurvivalLocationScaleError::InvalidConfiguration { reason }
    99	            | SurvivalLocationScaleError::ConstraintViolation { reason }
   100	            | SurvivalLocationScaleError::NumericalFailure { reason }
   101	            | SurvivalLocationScaleError::InternalInvariant { reason } => f.write_str(reason),
   102	        }
   103	    }
   104	}
