 14563	    fn exact_joint_block_designs_owned(
 14564	        &self,
 14565	        specs: Option<&[ParameterBlockSpec]>,
 14566	    ) -> Result<Option<(DesignMatrix, DesignMatrix)>, String> {
 14567	        let designs = if let (Some(x_t), Some(x_ls)) = (
 14568	            self.threshold_design.as_ref(),
 14569	            self.log_sigma_design.as_ref(),
 14570	        ) {
 14571	            Some((x_t.clone(), x_ls.clone()))
 14572	        } else if let Some(specs) = specs {
 14573	            if specs.len() != 2 {
 14574	                return Err(GamlssError::DimensionMismatch { reason: format!(
 14575	                    "BinomialLocationScaleFamily spec-aware operator path expects 2 specs, got {}",
 14576	                    specs.len()
 14577	                ) }.into());
 14578	            }
 14579	            Some((
 14580	                specs[Self::BLOCK_T].design.clone(),
 14581	                specs[Self::BLOCK_LOG_SIGMA].design.clone(),
 14582	            ))
 14583	        } else {
 14584	            None
 14585	        };
 14586	        let Some((x_t, x_ls)) = designs else {
 14587	            return Ok(None);
 14588	        };
 14589	        let n = self.y.len();
 14590	        if x_t.nrows() != n || x_ls.nrows() != n {
 14591	            return Err(GamlssError::DimensionMismatch { reason: format!(
 14592	                "BinomialLocationScaleFamily operator designs have row mismatch: y={}, threshold={}, log_sigma={}",
 14593	                n,
 14594	                x_t.nrows(),
 14595	                x_ls.nrows()
 14596	            ) }.into());
 14597	        }
 14598	        Ok(Some((x_t, x_ls)))
 14599	    }
