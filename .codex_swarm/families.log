    45	/// Typed error for the latent-survival / latent-binary family kernels and
    46	/// their fit-time and per-row validation helpers. Variants pick the semantic
    47	/// bucket while the inner `reason` carries the original byte-equivalent
    48	/// message so external callers that previously consumed `String` errors keep
    49	/// the same diagnostic text via `Display`.
    50	#[derive(Debug, Clone)]
    51	pub enum LatentSurvivalError {
    52	    /// The frailty spec supplied to a latent-survival or latent-binary
    53	    /// helper is incompatible (wrong variant, missing fixed sigma, non-finite
    54	    /// or negative fixed sigma).
    55	    InvalidFrailty { reason: String },
    56	    /// Per-row dataset validation failed: empty input, size mismatch across
    57	    /// the spec vectors, or invalid age / event / weight / unloaded-mass
    58	    /// values for an individual row.
    59	    InvalidDataset { reason: String },
    60	    /// A parameter-block state, eta vector, or directional-derivative
    61	    /// argument supplied to a family entry point has the wrong length.
    62	    BlockMismatch { reason: String },
    63	    /// A runtime numerical value (sigma, baseline hazard derivative, kernel
    64	    /// sum, event probability) became non-finite or out-of-domain.
    65	    NumericalFailure { reason: String },
    66	    /// The requested combination of time-block structure or event type is
    67	    /// not implemented (non-structural monotonicity, interval-censored rows
    68	    /// on the dynamic-derivative path).
    69	    UnsupportedConfiguration { reason: String },
    70	}
    71	
    72	impl std::fmt::Display for LatentSurvivalError {
    73	    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
    74	        match self {
    75	            LatentSurvivalError::InvalidFrailty { reason }
    76	            | LatentSurvivalError::InvalidDataset { reason }
    77	            | LatentSurvivalError::BlockMismatch { reason }
    78	            | LatentSurvivalError::NumericalFailure { reason }
    79	            | LatentSurvivalError::UnsupportedConfiguration { reason } => f.write_str(reason),
    80	        }
    81	    }
    82	}
