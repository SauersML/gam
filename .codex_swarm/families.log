   105	    /// `All` calls with `weight = 1.0` and `row_index ∈ 0..n_total`;
   106	    /// `Subsample` calls with each `WeightedOuterRow`'s `(index, weight)`.
   107	    #[inline]
   108	    pub fn par_for_each<F>(&self, n_total: usize, body: F)
   109	    where
   110	        F: Fn(usize, f64) + Send + Sync,
   111	    {
   112	        match self {
   113	            Self::All => {
