   107	    pub left: f64,
   108	    pub right: f64,
   109	    pub c0: f64,
   110	    pub c1: f64,
   111	    pub c2: f64,
   112	    pub c3: f64,
   113	}
   114	
   115	impl LocalSpanCubic {
   116	    #[inline]
   117	    pub fn evaluate(self, x: f64) -> f64 {
   118	        let t = x - self.left;
   119	        self.c0 + self.c1 * t + self.c2 * t * t + self.c3 * t * t * t
   120	    }
   121	
   122	    #[inline]
   123	    pub fn first_derivative(self, x: f64) -> f64 {
   124	        let t = x - self.left;
