   208	#[inline]
   209	fn worst_mode(
   210	    a: IntegratedExpectationMode,
   211	    b: IntegratedExpectationMode,
   212	) -> IntegratedExpectationMode {
   213	    if a.rank() >= b.rank() { a } else { b }
   214	}
