   216	// ─── Log-space kernel infrastructure ──────────────────────────────────────────
   217	//
   218	// The runtime kernel path stays in log-space until the final ratios are formed,
   219	// avoiding the overflow/underflow and cancellation problems that come from
   220	// exponentiating individual terms too early.
   221	
   222	/// Returns `log K_{k,m}(μ,σ)` directly, without exponentiation.
   223	///
   224	/// The value is always finite (or `NEG_INFINITY` when the kernel is zero), so
   225	/// it cannot overflow or underflow.
   226	#[inline]
   227	fn validate_kernel_inputs(m: f64, mu: f64, sigma: f64) -> Result<(), EstimationError> {
   228	    if !m.is_finite() || m < 0.0 {
   229	        return Err(EstimationError::InvalidInput(format!(
   230	            "lognormal kernel requires finite m >= 0, got {m}"
   231	        )));
   232	    }
   233	    if !mu.is_finite() || !sigma.is_finite() || sigma < 0.0 {
   234	        return Err(EstimationError::InvalidInput(format!(
   235	            "lognormal kernel requires finite mu and sigma >= 0, got mu={mu}, sigma={sigma}"
   236	        )));
   237	    }
   238	    Ok(())
   239	}
   240	
   241	#[inline]
   242	pub fn log_kernel_term(
   243	    quadctx: &QuadratureContext,
   244	    k: usize,
   245	    m: f64,
   246	    mu: f64,
   247	    sigma: f64,
   248	) -> Result<(f64, IntegratedExpectationMode), EstimationError> {
   249	    validate_kernel_inputs(m, mu, sigma)?;
   250	    let kf = k as f64;
   251	    let prefix = kf * mu + 0.5 * kf * kf * sigma * sigma;
   252	    if m == 0.0 {
   253	        return Ok((prefix, IntegratedExpectationMode::ExactClosedForm));
   254	    }
   255	    let shifted_mu = mu + kf * sigma * sigma + m.ln();
   256	    let (laplace, mode) = lognormal_laplace_unit_term_shared(quadctx, shifted_mu, sigma);
   257	    if laplace <= 0.0 {
   258	        return Ok((f64::NEG_INFINITY, mode));
   259	    }
   260	    Ok((prefix + laplace.ln(), mode))

