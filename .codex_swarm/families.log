  7752	fn ctn_penalty_scale_log_lambdas(
  7753	    penalties: &[PenaltyMatrix],
  7754	    likelihood_gram: &Array2<f64>,
  7755	) -> Array1<f64> {
  7756	    if penalties.is_empty() {
  7757	        return Array1::zeros(0);
  7758	    }
  7759	
  7760	    let likelihood_scale = matrix_diag_mean_abs(likelihood_gram).max(1.0e-8);
  7761	    Array1::from_iter(penalties.iter().map(|penalty| {
  7762	        let penalty_scale = penalty_diag_scale(penalty).max(1.0e-8);
  7763	        // Lower-bound the SEED log-lambda at 0 (i.e., λ ≥ 1) so we never
  7764	        // start the outer optimizer in the under-regularized regime where
  7765	        // the CTN inner is structurally rank-deficient (small-n / p > n).
  7766	        // The outer BFGS is free to step below 0 when there's enough data
  7767	        // to support it; only the cold-start is constrained. Without this
  7768	        // floor, ratios like n=64, p_resp×p_cov ≈ 200 produce a seed of
  7769	        // log_lambda ≈ -12 (λ ≈ 6e-6), which leaves the inner solve to
  7770	        // pick wild β coefficients and cascade into predict-time monotonicity
  7771	        // violations (h' < 0 on the response grid, observed as -1e15 spikes
  7772	        // in CI synthetic-biobank tests).
  7773	        (likelihood_scale / penalty_scale).ln().clamp(0.0, 12.0)
  7774	    }))
  7775	}
  7776	
  7777	fn penalty_diag_scale(penalty: &PenaltyMatrix) -> f64 {
  7778	    match penalty {
  7779	        PenaltyMatrix::Dense(matrix) => {
  7780	            matrix_diag_mean_abs(matrix).max(matrix_frobenius_rms(matrix))
  7781	        }
  7782	        PenaltyMatrix::KroneckerFactored { left, right } => {
  7783	            let diag_scale = matrix_diag_mean_abs(left) * matrix_diag_mean_abs(right);
  7784	            let frob_scale = matrix_frobenius_rms(left) * matrix_frobenius_rms(right);
  7785	            diag_scale.max(frob_scale)
  7786	        }
  7787	        PenaltyMatrix::Blockwise { local, .. } => {
  7788	            matrix_diag_mean_abs(local).max(matrix_frobenius_rms(local))
  7789	        }
  7790	        PenaltyMatrix::Labeled { inner, .. } => penalty_diag_scale(inner),
  7791	    }
  7792	}
  7793	
  7794	fn matrix_diag_mean_abs(matrix: &Array2<f64>) -> f64 {
  7795	    let d = matrix.nrows().min(matrix.ncols());
  7796	    if d == 0 {
  7797	        return 0.0;
  7798	    }
  7799	    matrix.diag().iter().map(|v| v.abs()).sum::<f64>() / d as f64
  7800	}
  7801	
  7802	fn matrix_frobenius_rms(matrix: &Array2<f64>) -> f64 {
  7803	    let d = matrix.nrows().max(1).min(matrix.ncols().max(1));
  7804	    (matrix.iter().map(|v| v * v).sum::<f64>() / d as f64).sqrt()
  7805	}
