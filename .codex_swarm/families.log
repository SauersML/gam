    13	/// Resolve a binomial-flavoured `LikelihoodSpec` from an `InverseLink`.
    14	/// Equivalent to `LikelihoodSpec { response: Binomial, link }` for the
    15	/// link variants that map to a binomial family. The "Identity falls back
    16	/// to logit" historical fallback used by `inverse_link_to_binomial_family`
    17	/// is preserved here for behavioral parity, but expressed as an explicit
    18	/// substitution of the link rather than a different family variant.
    19	#[inline]
    20	pub fn inverse_link_to_binomial_spec(link: &InverseLink) -> LikelihoodSpec {
    21	    let normalized = match link {
    22	        InverseLink::Standard(LinkFunction::Identity) => InverseLink::Standard(LinkFunction::Logit),
    23	        // Standard SAS / BetaLogistic without parameterized state historically
    24	        // mapped to the parameterized family variant; preserve that here by
    25	        // upgrading to a default-state parameterized link.
    26	        other => other.clone(),
    27	    };
    28	    LikelihoodSpec::new(ResponseFamily::Binomial, normalized)
    29	}
    30	
    31	/// Resolve the binomial-flavoured `LikelihoodFamily` implied by an
    32	/// `InverseLink`. Identity falls back to logit so historic callers that
    33	/// stored a raw link without family discriminator still round-trip.
    34	#[inline]
    35	pub fn inverse_link_to_binomial_family(link: &InverseLink) -> LikelihoodFamily {
    36	    match link {
    37	        InverseLink::Standard(LinkFunction::Log) => LikelihoodFamily::PoissonLog,
    38	        InverseLink::Standard(LinkFunction::Logit) => LikelihoodFamily::BinomialLogit,
    39	        InverseLink::Standard(LinkFunction::Probit) => LikelihoodFamily::BinomialProbit,
    40	        InverseLink::Standard(LinkFunction::CLogLog) => LikelihoodFamily::BinomialCLogLog,
    41	        InverseLink::Standard(LinkFunction::Sas) | InverseLink::Sas(_) => {
    42	            LikelihoodFamily::BinomialSas
    43	        }
    44	        InverseLink::Standard(LinkFunction::BetaLogistic) | InverseLink::BetaLogistic(_) => {
