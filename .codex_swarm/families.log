   179	/// A row-decomposable likelihood kernel with K primary scalars per row.
   180	///
   181	/// Implementors provide only:
   182	///   1. The analytic kernel (NLL + gradient + Hessian in K-dim primary space)
   183	///   2. The linear Jacobian wiring (coefficients ↔ primary scalars)
   184	///   3. Assembly helpers (quadratic pullback, diagonal accumulation)
   185	///   4. Higher-order contracted kernels for REML outer derivatives
   186	///
   187	/// All coefficient-space assembly (gradient, matvec, diagonal, dense Hessian,
   188	/// directional derivatives) is derived generically.
   189	pub trait RowKernel<const K: usize>: Send + Sync {
   190	    /// Number of observations.
   191	    fn n_rows(&self) -> usize;
   192	
   193	    /// Total number of coefficients (flat β dimension).
   194	    fn n_coefficients(&self) -> usize;
   195	
   196	    /// Evaluate the row kernel at the current β.
   197	    ///
   198	    /// Returns `(nll_i, ∇_i[K], H_i[K×K])` — the negative log-likelihood,
   199	    /// gradient, and Hessian in primary space for observation `row`.
   200	    fn row_kernel(&self, row: usize) -> Result<(f64, [f64; K], [[f64; K]; K]), String>;
   201	
   202	    /// Forward Jacobian action: Jᵢ · d_beta → K-dim primary direction.
   203	    fn jacobian_action(&self, row: usize, d_beta: &[f64]) -> [f64; K];
   204	
   205	    /// Adjoint Jacobian action: out += Jᵢᵀ · v.
   206	    ///
   207	    /// Accumulates into `out` (length = n_coefficients).
   208	    fn jacobian_transpose_action(&self, row: usize, v: &[f64; K], out: &mut [f64]);
   209	
   210	    /// Quadratic pullback: target += Jᵢᵀ · h · Jᵢ.
   211	    ///
   212	    /// Accumulates the K×K matrix `h` pulled back through the row Jacobian
   213	    /// into the dense p×p matrix `target`. Implementations should use
   214	    /// sparse-aware primitives (syr_row_into, row_outer_into, etc.) for
   215	    /// efficiency.
   216	    fn add_pullback_hessian(&self, row: usize, h: &[[f64; K]; K], target: &mut Array2<f64>);
   217	
   218	    /// Diagonal of quadratic form: diag += diag(Jᵢᵀ · h · Jᵢ).
   219	    ///
   220	    /// Accumulates into `diag` (length = n_coefficients). Implementations
   221	    /// should use squared_axpy_row_into / crossdiag_axpy_row_into for
   222	    /// efficiency with sparse designs.
   223	    fn add_diagonal_quadratic(&self, row: usize, h: &[[f64; K]; K], diag: &mut [f64]);
   224	
   225	    /// Third-order contracted derivative: `∂³ℓ_i / (∂p_a ∂p_b ∂[dir])`.
   226	    ///
   227	    /// Returns the K×K matrix of third derivatives contracted with one
