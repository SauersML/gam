    66	pub fn probit_frailty_scale(gaussian_frailty_sd: Option<f64>) -> f64 {
    67	    let sigma = gaussian_frailty_sd.unwrap_or(0.0);
    68	    if sigma <= 0.0 {
    69	        1.0
    70	    } else {
    71	        crate::families::lognormal_kernel::ProbitFrailtyScaleJet::from_log_sigma(sigma.ln()).s
    72	    }
    73	}
