  7854	/// Chunked weighted B^T diag(w) D product without materializing any
  7855	/// full rowwise-Kronecker intermediate.
  7856	///
  7857	/// Each chunk weights `D` rows in-place, then accumulates `B[chunk]^T · DW`
  7858	/// directly into `out` via a faer SIMD matmul with `Accum::Add`. This
  7859	/// eliminates the per-chunk `Array2` from the previous `out += &bl.t().dot(&dw)`
  7860	/// pattern (one allocation + one element-wise `+=` pass per chunk) and uses
  7861	/// the multi-threaded faer kernel instead of ndarray's serial dot.
  7862	fn chunked_weighted_bt_d(
  7863	    b: &Array2<f64>,
  7864	    weights: ndarray::ArrayView1<'_, f64>,
  7865	    d: &Array2<f64>,
  7866	    policy: &ResourcePolicy,
  7867	) -> Array2<f64> {
  7868	    use crate::faer_ndarray::{FaerArrayView, array2_to_matmut, matmul_parallelism};
  7869	    use faer::Accum;
  7870	    use faer::linalg::matmul::matmul;
  7871	
  7872	    let n = weights.len();
  7873	    let pb = b.ncols();
  7874	    let pd = d.ncols();
  7875	    let rows_per_chunk =
  7876	        crate::resource::rows_for_target_bytes(policy.row_chunk_target_bytes, pb + pd);
  7877	    let mut out = Array2::<f64>::zeros((pb, pd));
  7878	    if n == 0 || pb == 0 || pd == 0 {
  7879	        return out;
  7880	    }
  7881	    let mut out_view = array2_to_matmut(&mut out);
  7882	    let mut dw_buf = Array2::<f64>::zeros((rows_per_chunk.min(n), pd));
  7883	    for start in (0..n).step_by(rows_per_chunk) {
  7884	        let end = (start + rows_per_chunk).min(n);
  7885	        let rows = end - start;
  7886	        let bl = b.slice(s![start..end, ..]);
  7887	        let dl = d.slice(s![start..end, ..]);
  7888	        {
  7889	            let mut dw_slice = dw_buf.slice_mut(s![..rows, ..]);
  7890	            for local in 0..rows {
  7891	                let w = weights[start + local];
  7892	                let drow = dl.row(local);
  7893	                let mut wrow = dw_slice.row_mut(local);
  7894	                ndarray::Zip::from(&mut wrow)
  7895	                    .and(&drow)
  7896	                    .for_each(|dst, &src| *dst = w * src);
  7897	            }
  7898	        }
  7899	        let bl_view = FaerArrayView::new(&bl);
  7900	        let dw_slice = dw_buf.slice(s![..rows, ..]);
  7901	        let dw_view = FaerArrayView::new(&dw_slice);
  7902	        let par = matmul_parallelism(pb, pd, rows);
  7903	        matmul(
  7904	            out_view.as_mut(),
  7905	            Accum::Add,
  7906	            bl_view.as_ref().transpose(),
  7907	            dw_view.as_ref(),
  7908	            1.0,
  7909	            par,
  7910	        );
  7911	    }
  7912	    out
  7913	}
