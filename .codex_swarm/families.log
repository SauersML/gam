 15007	    ) -> Result<Option<Array2<f64>>, String> {
 15008	        // Exact first directional derivative D_beta H_L[u] of the joint
 15009	        // likelihood curvature.
 15010	        //
 15011	        // Write
 15012	        //
 15013	        //   t  = X_t beta_t,
 15014	        //   ls = X_ls beta_ls,
 15015	        //   s  = exp(-ls),
 15016	        //   q  = -t .* s.
 15017	        //
 15018	        // For a full coefficient-space direction
 15019	        //
 15020	        //   u = (u_t, u_ls),
 15021	        //   xi_t  = X_t u_t,
 15022	        //   xi_ls = X_ls u_ls,
 15023	        //
 15024	        // the induced q-direction is
 15025	        //
 15026	        //   alpha = D q[u] = -s .* xi_t - q .* xi_ls.
 15027	        //
 15028	        // The joint diagonal-working-curvature likelihood matrix is
 15029	        //
 15030	        //   H_L = J^T W J,
 15031	        //   J_t  = -diag(s) X_t,
 15032	        //   J_ls = -diag(q) X_ls.
 15033	        //
 15034	        // Differentiating once gives
 15035	        //
 15036	        //   D_beta H_L[u]
 15037	        //   = K[u]^T W J
 15038	        //     + J^T W K[u]
 15039	        //     + J^T diag(nu .* alpha) J,
 15040	        //
 15041	        // where
 15042	        //
 15043	        //   K_t[u]  = diag(s .* xi_ls) X_t,
 15044	        //   K_ls[u] = diag(s .* xi_t + q .* xi_ls) X_ls,
 15045	        //
 15046	        // and `nu = d'''(q)` is the third derivative of the scalar row loss.
 15047	        // This is exactly the joint curvature drift that enters the profiled
 15048	        // derivative through
 15049	        //
 15050	        //   dot H_k = A_k + D_beta H_L[u_k],
 15051	        //   dJ/drho_k
 15052	        //   = 0.5 beta^T A_k beta
 15053	        //     + 0.5 tr(H^{-1} dot H_k)
 15054	        //     - 0.5 tr(S^+ A_k).
 15055	        if block_states.len() != 2 {
