  4803	    //
  4804	    // For any scalar f(eta_t,eta_ls), directional derivative along
  4805	    // d eta = (d_eta_t, d_eta_ls) is
  4806	    //   dot{f} = f_t d_eta_t + f_ls d_eta_ls.
  4807	    //
  4808	    // Apply to q and its eta-partials:
  4809	    //   dot{q}      = q_t d_eta_t + q_ls d_eta_ls.
  4810	    //   dot{q_t}    = q_tt d_eta_t + q_tl d_eta_ls = q_tl d_eta_ls (q_tt=0).
  4811	    //   dot{q_ls}   = q_tl d_eta_t + q_ll d_eta_ls.
  4812	    //   dot{q_tt}   = 0.
  4813	    //   dot{q_tl}   = q_tl_ls d_eta_ls.
  4814	    //   dot{q_ll}   = q_tl_ls d_eta_t + q_ll_ls d_eta_ls.
  4815	    NonWiggleQDirectional {
  4816	        delta_q: q.q_t * d_eta_t + q.q_ls * d_eta_ls,
  4817	        delta_q_t: q.q_tl * d_eta_ls,
  4818	        delta_q_ls: q.q_tl * d_eta_t + q.q_ll * d_eta_ls,
  4819	        delta_q_tl: q.q_tl_ls * d_eta_ls,
  4820	        delta_q_ll: q.q_tl_ls * d_eta_t + q.q_ll_ls * d_eta_ls,
  4821	    }
