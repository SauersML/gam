  1049	impl LatentSurvivalRowJet {
  1050	    pub fn evaluate(
  1051	        quadctx: &QuadratureContext,
  1052	        row: &LatentSurvivalRow,
  1053	        mu: f64,
  1054	        sigma: f64,
  1055	    ) -> Result<Self, EstimationError> {
  1056	        row.validate()?;
  1057	        match row.event_type {
  1058	            LatentSurvivalEventType::RightCensored => Self::right_censored(quadctx, mu, sigma, row),
  1059	            LatentSurvivalEventType::ExactEvent => Self::exact_event(quadctx, mu, sigma, row),
  1060	            LatentSurvivalEventType::IntervalCensored => {
  1061	                Self::interval_censored(quadctx, mu, sigma, row)
  1062	            }
  1063	        }
  1064	    }
  1065	
  1066	    /// Right-censoring with loaded/unloaded mass decomposition.
  1067	    ///
  1068	    /// Full formula:
  1069	    ///   `ℓ = -M_U_exit + log K_{0,M_L_exit} + M_U_entry - log K_{0,M_L_entry}`
  1070	    ///
  1071	    /// When `mass_unloaded_exit == 0` and `mass_unloaded_entry == 0`, this
  1072	    /// falls back to the original formula using `mass_exit` / `mass_entry`.
  1073	    fn right_censored(
  1074	        quadctx: &QuadratureContext,
  1075	        mu: f64,
  1076	        sigma: f64,
  1077	        row: &LatentSurvivalRow,
  1078	    ) -> Result<Self, EstimationError> {
  1079	        let has_unloaded =
  1080	            row.mass_unloaded_exit.abs() > 1e-300 || row.mass_unloaded_entry.abs() > 1e-300;
