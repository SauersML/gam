 13949	impl CustomFamilyGenerative for PoissonLogFamily {
 13950	    fn generativespec(
 13951	        &self,
 13952	        block_states: &[ParameterBlockState],
 13953	    ) -> Result<GenerativeSpec, String> {
 13954	        let eta = &expect_single_block(block_states, "PoissonLogFamily")?.eta;
 13955	        let mean = gamlss_rowwise_map(eta.len(), |i| saturated_exp_eta(eta[i]));
 13956	        Ok(GenerativeSpec {
 13957	            mean,
 13958	            noise: NoiseModel::Poisson,
