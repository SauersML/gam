 14883	    /// Exact diagonal-block-only Hessians (h_tt, h_ll) used by `evaluate()`
 14884	    /// to populate per-block working sets without ever materializing the
 14885	    /// dense p×p joint matrix.
 14886	    fn exact_newton_block_diagonal_hessians_from_design_matrices(
 14887	        &self,
 14888	        block_states: &[ParameterBlockState],
 14889	        x_t: &DesignMatrix,
 14890	        x_ls: &DesignMatrix,
 14891	    ) -> Result<(Array2<f64>, Array2<f64>), String> {
 14892	        let (coeff_tt, _coeff_tl, coeff_ll) =
 14893	            self.exact_newton_joint_hessian_row_coefficients(block_states)?;
 14894	        let h_tt = xt_diag_x_design(x_t, &coeff_tt)?;
 14895	        let h_ll = xt_diag_x_design(x_ls, &coeff_ll)?;
 14896	        Ok((h_tt, h_ll))
 14897	    }
