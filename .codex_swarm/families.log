  7755	        // bounds the loglik below (−Σlog σ ≥ −n log b) and bounds 1/σ² by 1/b²,
  7756	        // so the previous `inv_s2.min(1e24)` cap is structurally unnecessary.
  7757	        let ln2pi = (2.0 * std::f64::consts::PI).ln();
