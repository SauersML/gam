   581	fn log_normal_cdf_diff(upper: f64, lower: f64) -> Result<f64, String> {
   582	    if !(upper.is_finite() && lower.is_finite()) {
   583	        return Err(TransformationNormalError::InvalidInput {
   584	            reason: format!("finite support endpoints required, got lower={lower}, upper={upper}"),
   585	        }
   586	        .into());
   587	    }
   588	    if upper <= lower {
   589	        return Err(TransformationNormalError::MonotonicityViolated { reason: format!(
   590	            "upper endpoint score must exceed lower endpoint score, got lower={lower:.6e}, upper={upper:.6e}"
   591	        ) }.into());
   592	    }
   593	    if lower > 0.0 {
   594	        return log_normal_cdf_diff(-lower, -upper);
   595	    }
   596	    let log_upper = normal_logcdf(upper);
   597	    let log_lower = normal_logcdf(lower);
   598	    let gap = log_upper - log_lower;
   599	    if !(gap.is_finite() && gap > 0.0) {
   600	        return Err(TransformationNormalError::NumericalFailure { reason: format!(
   601	            "normal CDF endpoint mass is not representable, lower={lower:.6e}, upper={upper:.6e}"
   602	        ) }.into());
   603	    }
   604	    let log_z = log_upper + log1mexp_positive(gap);
   605	    if !log_z.is_finite() {
   606	        return Err(TransformationNormalError::NumericalFailure {
   607	            reason: format!(
   608	                "normal CDF endpoint mass underflowed, lower={lower:.6e}, upper={upper:.6e}"
   609	            ),
   610	        }
   611	        .into());
   612	    }
   613	    Ok(log_z)
   614	}
