    70	// ── Typed errors ──────────────────────────────────────────────────────
    71	//
    72	// Categorizes the failure modes of the survival marginal-slope family so
    73	// callers can match on the kind without parsing strings. The `reason`
    74	// fields preserve the original `format!(...)` text byte-for-byte; the
    75	// `Display` impl prints just the reason, making `e.to_string()` identical
    76	// to the pre-migration `String` errors that flowed through `?`.
    77	#[derive(Debug, Clone)]
    78	pub enum SurvivalMarginalSlopeError {
    79	    /// Spec, data, or runtime configuration failed input validation
    80	    /// (finite/non-negative weights, derivative_guard > 0, supported
    81	    /// base_link, frailty constraints, missing block state, etc.).
    82	    InvalidInput { reason: String },
    83	    /// Lengths, row/column counts, basis widths, or coefficient block
    84	    /// sizes do not agree (covariance dim vs z, design rows vs n,
    85	    /// basis/beta length mismatch, post-update beta length, time
    86	    /// constraints A vs b, hessian_matvec dim mismatch, ...).
    87	    IncompatibleDimensions { reason: String },
    88	    /// A row's transformed time derivative or structural slack fell
    89	    /// below `derivative_guard` (`qd1 < guard`), violating the
    90	    /// monotonicity contract.
    91	    MonotonicityViolation { reason: String },
    92	    /// A numerical step produced a non-finite, non-positive, or
    93	    /// internally inconsistent quantity that downstream code cannot
    94	    /// consume (e.g. non-positive `D`, non-positive `chi1`, calibration
    95	    /// derivative disagrees with the direct evaluation, transformed
    96	    /// derivative not strictly positive).
    97	    NumericalFailure { reason: String },
    98	    /// An integration / outer-optimization step failed to converge to
    99	    /// the requested tolerance (intercept residual, REML outer loop).
   100	    IntegrationFailed { reason: String },
   101	    /// The requested combination of options is not implemented (non-
   102	    /// probit base link, flexible row calculus with K > 1, spatial psi
   103	    /// for unsupported block roles, ...).
   104	    UnsupportedConfiguration { reason: String },
   105	}
