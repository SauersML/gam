    75	pub(crate) fn probit_frailty_scale_multi_dir_jet(
    76	    gaussian_frailty_sd: Option<f64>,
    77	    missing_sigma_message: &str,
    78	    n_dirs: usize,
    79	    first_masks: &[usize],
    80	    second_masks: &[usize],
    81	) -> Result<MultiDirJet, String> {
    82	    let sigma = gaussian_frailty_sd.ok_or_else(|| missing_sigma_message.to_string())?;
    83	    let jet = crate::families::lognormal_kernel::ProbitFrailtyScaleJet::from_log_sigma(sigma.ln());
    84	    let mut coeffs = Vec::with_capacity(1 + first_masks.len() + second_masks.len());
    85	    coeffs.push((0usize, jet.s));
    86	    coeffs.extend(first_masks.iter().copied().map(|mask| (mask, jet.ds)));
    87	    coeffs.extend(second_masks.iter().copied().map(|mask| (mask, jet.d2s)));
    88	    Ok(MultiDirJet::with_coeffs(n_dirs, &coeffs))
    89	}
