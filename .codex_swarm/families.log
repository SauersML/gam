   138	// ─── Probit frailty scaling ──────────────────────────────────────────────────
   139	
   140	/// Probit frailty scaling factor s = 1/√(1+σ²) and its derivatives.
   141	///
   142	/// For Gaussian frailty on the final probit index:
   143	///   E[Φ(η + U)] = Φ(η · s)  where s = 1/√(1+σ²)
   144	///
   145	/// With t = log(σ), define α = σ²/(1+σ²).  Then:
   146	///   ∂_t s = -α·s
   147	///   ∂_{tt} s = α(3α-2)·s
   148	///   ∂_{ttt} s = α(-15α²+18α-4)·s
   149	///   ∂_{tttt} s = α(105α³-180α²+84α-8)·s
   150	#[derive(Clone, Copy, Debug)]
   151	pub struct ProbitFrailtyScale {
   152	    /// s = 1/√(1+σ²)
   153	    pub s: f64,
   154	}
   155	
   156	impl ProbitFrailtyScale {
   157	    pub fn new(sigma: f64) -> Self {
   158	        let sigma2 = sigma * sigma;
   159	        Self {
   160	            s: 1.0 / (1.0 + sigma2).sqrt(),
   161	        }
   162	    }
   163	}
   164	
   165	/// Probit frailty scaling factor **with** t-derivatives (t = log σ).
   166	///
   167	/// Provides exact closed-form derivatives of s = 1/√(1+σ²) with respect to
   168	/// t = log(σ) for learnable Gaussian-shift frailty in the marginal-slope
   169	/// families.  All formulas follow from the recurrence documented on
   170	/// [`ProbitFrailtyScale`]; the auxiliary quantity α = σ²/(1+σ²) keeps each
   171	/// expression compact.
   172	#[derive(Clone, Copy, Debug)]
   173	pub struct ProbitFrailtyScaleJet {
   174	    /// s = 1/√(1+σ²)
   175	    pub s: f64,
   176	    /// α = σ²/(1+σ²)  — shared auxiliary for all derivative levels.
   177	    pub alpha: f64,
   178	    /// ∂_t s = -α·s
   179	    pub ds: f64,
   180	    /// ∂_{tt} s = α(3α−2)·s
   181	    pub d2s: f64,
   182	}
   183	
   184	impl ProbitFrailtyScaleJet {
   185	    /// Build the jet from σ (not from t = log σ).
   186	    ///
   187	    /// At σ = 0 the jet degenerates to (s=1, α=0, ds=0, d2s=0), which is
   188	    /// correct: zero frailty means s ≡ 1 independent of t.
   189	    pub fn new(sigma: f64) -> Self {
   190	        let sigma2 = sigma * sigma;
   191	        let one_plus_sigma2 = 1.0 + sigma2;
   192	        let s = 1.0 / one_plus_sigma2.sqrt();
   193	        let alpha = sigma2 / one_plus_sigma2;
   194	        Self {
   195	            s,
   196	            alpha,
   197	            ds: -alpha * s,
   198	            d2s: alpha * (3.0 * alpha - 2.0) * s,
   199	        }
   200	    }
   201	
   202	    /// Build the jet from t = log(σ) directly.
   203	    pub fn from_log_sigma(log_sigma: f64) -> Self {
   204	        Self::new(log_sigma.exp())
   205	    }
   206	}
