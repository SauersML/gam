 14601	    fn exact_newton_joint_gradient_from_designs(
 14602	        &self,
 14603	        block_states: &[ParameterBlockState],
 14604	        x_t: &DesignMatrix,
 14605	        x_ls: &DesignMatrix,
 14606	    ) -> Result<ExactNewtonJointGradientEvaluation, String> {
 14607	        if block_states.len() != 2 {
 14608	            return Err(GamlssError::DimensionMismatch {
 14609	                reason: format!(
 14610	                    "BinomialLocationScaleFamily expects 2 blocks, got {}",
 14611	                    block_states.len()
 14612	                ),
 14613	            }
 14614	            .into());
 14615	        }
 14616	        let n = self.y.len();
 14617	        let eta_t = &block_states[Self::BLOCK_T].eta;
 14618	        let eta_ls = &block_states[Self::BLOCK_LOG_SIGMA].eta;
 14619	        if eta_t.len() != n
 14620	            || eta_ls.len() != n
 14621	            || self.weights.len() != n
 14622	            || x_t.nrows() != n
 14623	            || x_ls.nrows() != n
 14624	        {
 14625	            return Err(
 14626	                "BinomialLocationScaleFamily joint gradient input size mismatch".to_string(),
 14627	            );
 14628	        }
 14629	
 14630	        let core = binomial_location_scale_core(
 14631	            &self.y,
 14632	            &self.weights,
 14633	            eta_t,
 14634	            eta_ls,
 14635	            None,
 14636	            &self.link_kind,
 14637	        )?;
 14638	        let mut grad_eta_t_v = vec![0.0_f64; n];
 14639	        let mut grad_eta_ls_v = vec![0.0_f64; n];
 14640	        let y_slice = self.y.as_slice().expect("y must be contiguous");
 14641	        let w_slice = self.weights.as_slice().expect("weights must be contiguous");
 14642	        let q0_slice = core.q0.as_slice().expect("q0 must be contiguous");
 14643	        let sigma_slice = core.sigma.as_slice().expect("sigma must be contiguous");
 14644	        let mu_slice = core.mu.as_slice().expect("mu must be contiguous");
 14645	        let dmu_slice = core.dmu_dq.as_slice().expect("dmu_dq must be contiguous");
 14646	        let d2mu_slice = core
 14647	            .d2mu_dq2
 14648	            .as_slice()
 14649	            .expect("d2mu_dq2 must be contiguous");
 14650	        let d3mu_slice = core
 14651	            .d3mu_dq3
 14652	            .as_slice()
 14653	            .expect("d3mu_dq3 must be contiguous");
 14654	        let eta_t_slice = eta_t.as_slice().expect("eta_t must be contiguous");
 14655	        let link_kind = &self.link_kind;
 14656	        grad_eta_t_v
 14657	            .par_iter_mut()
 14658	            .zip(grad_eta_ls_v.par_iter_mut())
 14659	            .enumerate()
 14660	            .for_each(|(i, (g_t, g_ls))| {
 14661	                let (m1, _, _) = binomial_neglog_q_derivatives_dispatch(
 14662	                    y_slice[i],
 14663	                    w_slice[i],
 14664	                    q0_slice[i],
 14665	                    mu_slice[i],
 14666	                    dmu_slice[i],
 14667	                    d2mu_slice[i],
 14668	                    d3mu_slice[i],
 14669	                    link_kind,
 14670	                );
 14671	                let q0d = nonwiggle_q_derivs(eta_t_slice[i], sigma_slice[i]);
 14672	                *g_t = -m1 * q0d.q_t;
 14673	                *g_ls = -m1 * q0d.q_ls;
 14674	            });
 14675	        let grad_eta_t = Array1::from_vec(grad_eta_t_v);
 14676	        let grad_eta_ls = Array1::from_vec(grad_eta_ls_v);
 14677	        let grad_t = x_t.transpose_vector_multiply(&grad_eta_t);
 14678	        let grad_ls = x_ls.transpose_vector_multiply(&grad_eta_ls);
 14679	        let total = grad_t.len() + grad_ls.len();
 14680	        let mut gradient = Array1::<f64>::zeros(total);
 14681	        gradient.slice_mut(s![0..grad_t.len()]).assign(&grad_t);
 14682	        gradient.slice_mut(s![grad_t.len()..total]).assign(&grad_ls);
 14683	        Ok(ExactNewtonJointGradientEvaluation {
 14684	            log_likelihood: core.log_likelihood,
 14685	            gradient,
 14686	        })
 14687	    }
