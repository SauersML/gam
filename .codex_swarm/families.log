   157	const GAMLSS_ROWWISE_PAR_MIN_N: usize = 4096;
   158	const GAMLSS_PROJECTED_TRACE_TARGET_BYTES: usize = 32 * 1024 * 1024;
   159	const GAMLSS_PROJECTED_TRACE_MIN_CHUNK_ROWS: usize = 64;
