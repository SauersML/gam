 14899	    fn exact_newton_joint_hessian_from_designs(
 14900	        &self,
 14901	        block_states: &[ParameterBlockState],
 14902	        x_t: &Array2<f64>,
 14903	        x_ls: &Array2<f64>,
 14904	    ) -> Result<Option<Array2<f64>>, String> {
 14905	        // Exact joint coefficient-space Hessian for the probit, non-wiggle
 14906	        // location-scale family.
 14907	        //
 14908	        // At the fitted mode, the correct joint outer smoothing sensitivity is
 14909	        //
 14910	        //   H u_k = -g_k,
 14911	        //   g_k = A_k beta,
 14912	        //
 14913	        // so the solve must use the full joint working-curvature matrix `H`.
 14914	        // For this family the likelihood is coupled through
 14915	        //
 14916	        //   q = -eta_t * exp(-eta_ls),
 14917	        //
 14918	        // so the threshold and log-sigma blocks are not independent even if
 14919	        // the penalties are block-diagonal.
 14920	        //
 14921	        // Write for row i
 14922	        //
 14923	        //   t_i = x_i^T beta_t,
 14924	        //   s_i = z_i^T beta_ls,
 14925	        //   r_i = exp(-s_i),
 14926	        //   q_i = -t_i r_i,
 14927	        //   F_i(q) = -w_i [ y_i log Phi(q) + (1-y_i) log(1-Phi(q)) ].
 14928	        //
 14929	        // Let
 14930	        //
 14931	        //   m1_i = F_i'(q_i),
 14932	        //   m2_i = F_i''(q_i).
 14933	        //
 14934	        // The q-derivatives with respect to the two predictors are
 14935	        //
 14936	        //   q_t  = -r,
 14937	        //   q_ls = -q,
 14938	        //   q_tt = 0,
 14939	        //   q_t,ls = r,
 14940	        //   q_ls,ls = q.
 14941	        //
 14942	        // For any scalar-composition objective G(t,s)=F(q(t,s)), the Hessian
 14943	        // coefficients are
 14944	        //
 14945	        //   G_ab = m2 q_a q_b + m1 q_ab.
 14946	        //
 14947	        // Therefore the exact rowwise joint curvature in (eta_t, eta_ls) is
 14948	        //
 14949	        //   coeff_tt = m2 r^2,
 14950	        //   coeff_t,ls = r (m1 + q m2),
 14951	        //   coeff_ls,ls = q (m1 + q m2),
 14952	        //
 14953	        // and the full joint coefficient-space Hessian is assembled as
 14954	        //
 14955	        //   H_tt    = X_t^T diag(coeff_tt)    X_t,
 14956	        //   H_t,ls  = X_t^T diag(coeff_t,ls)  X_ls,
 14957	        //   H_ls,ls = X_ls^T diag(coeff_ls,ls) X_ls.
 14958	        //
 14959	        // The off-diagonal block is generally nonzero. That is exactly the
 14960	        // coupling term the broken blockwise outer-gradient path was dropping.
 14961	        let (coeff_tt, coeff_tl, coeff_ll) =
 14962	            self.exact_newton_joint_hessian_row_coefficients(block_states)?;
 14963	        let pt = x_t.ncols();
 14964	        let pls = x_ls.ncols();
 14965	
 14966	        let h_tt = xt_diag_x_dense(x_t, &coeff_tt)?;
 14967	        let h_tl = xt_diag_y_dense(x_t, &coeff_tl, x_ls)?;
 14968	        let h_ll = xt_diag_x_dense(x_ls, &coeff_ll)?;
 14969	        let total = pt + pls;
 14970	        let mut h = Array2::<f64>::zeros((total, total));
 14971	        h.slice_mut(s![0..pt, 0..pt]).assign(&h_tt);
 14972	        h.slice_mut(s![0..pt, pt..total]).assign(&h_tl);
 14973	        h.slice_mut(s![pt..total, pt..total]).assign(&h_ll);
 14974	        mirror_upper_to_lower(&mut h);
 14975	        Ok(Some(h))
 14976	    }
 14977	
 14978	    fn exact_newton_joint_hessian_from_design_matrices(
 14979	        &self,
 14980	        block_states: &[ParameterBlockState],
 14981	        x_t: &DesignMatrix,
 14982	        x_ls: &DesignMatrix,
 14983	    ) -> Result<Option<Array2<f64>>, String> {
 14984	        let (coeff_tt, coeff_tl, coeff_ll) =
 14985	            self.exact_newton_joint_hessian_row_coefficients(block_states)?;
 14986	        let pt = x_t.ncols();
 14987	        let pls = x_ls.ncols();
 14988	
 14989	        let h_tt = xt_diag_x_design(x_t, &coeff_tt)?;
 14990	        let h_tl = xt_diag_y_design(x_t, &coeff_tl, x_ls)?;
 14991	        let h_ll = xt_diag_x_design(x_ls, &coeff_ll)?;
 14992	        let total = pt + pls;
 14993	        let mut h = Array2::<f64>::zeros((total, total));
 14994	        h.slice_mut(s![0..pt, 0..pt]).assign(&h_tt);
 14995	        h.slice_mut(s![0..pt, pt..total]).assign(&h_tl);
 14996	        h.slice_mut(s![pt..total, pt..total]).assign(&h_ll);
 14997	        mirror_upper_to_lower(&mut h);
 14998	        Ok(Some(h))
 14999	    }
