  7759	        if let (Some(y_s), Some(w_s), Some(mu_s), Some(ls_s)) = (
  7760	            self.y.as_slice_memory_order(),
  7761	            self.weights.as_slice_memory_order(),
  7762	            etamu.as_slice_memory_order(),
  7763	            eta_log_sigma.as_slice_memory_order(),
