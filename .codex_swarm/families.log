   162	fn gamlss_projected_trace_chunk_rows(
   163	    rank: usize,
   164	    projected_channel_count: usize,
   165	    gram_column_count: usize,
   166	) -> usize {
   167	    let per_row_values = rank
   168	        .saturating_mul(projected_channel_count.max(1))
   169	        .saturating_add(gram_column_count.max(1))
   170	        .max(1);
   171	    let per_row_bytes = per_row_values.saturating_mul(std::mem::size_of::<f64>());
   172	    let rows = GAMLSS_PROJECTED_TRACE_TARGET_BYTES / per_row_bytes.max(1);
   173	    rows.clamp(
   174	        GAMLSS_PROJECTED_TRACE_MIN_CHUNK_ROWS,
   175	        GAMLSS_PROJECTED_TRACE_MAX_CHUNK_ROWS,
   176	    )
   177	}
