 14798	    /// Compute the rowwise joint curvature coefficients (D_tt, D_tl, D_ll)
 14799	    /// shared by the dense joint Hessian path and the matrix-free workspace.
 14800	    fn exact_newton_joint_hessian_row_coefficients(
 14801	        &self,
 14802	        block_states: &[ParameterBlockState],
 14803	    ) -> Result<(Array1<f64>, Array1<f64>, Array1<f64>), String> {
 14804	        if block_states.len() != 2 {
 14805	            return Err(GamlssError::DimensionMismatch {
 14806	                reason: format!(
 14807	                    "BinomialLocationScaleFamily expects 2 blocks, got {}",
 14808	                    block_states.len()
 14809	                ),
 14810	            }
 14811	            .into());
 14812	        }
 14813	        let n = self.y.len();
 14814	        let eta_t = &block_states[Self::BLOCK_T].eta;
 14815	        let eta_ls = &block_states[Self::BLOCK_LOG_SIGMA].eta;
 14816	        if eta_t.len() != n || eta_ls.len() != n || self.weights.len() != n {
 14817	            return Err(GamlssError::DimensionMismatch {
 14818	                reason: "BinomialLocationScaleFamily input size mismatch".to_string(),
 14819	            }
 14820	            .into());
 14821	        }
 14822	
 14823	        let core = binomial_location_scale_core(
 14824	            &self.y,
 14825	            &self.weights,
 14826	            eta_t,
 14827	            eta_ls,
 14828	            None,
 14829	            &self.link_kind,
 14830	        )?;
 14831	        let mut coeff_tt = vec![0.0_f64; n];
 14832	        let mut coeff_tl = vec![0.0_f64; n];
 14833	        let mut coeff_ll = vec![0.0_f64; n];
 14834	        let y_slice = self.y.as_slice().expect("y must be contiguous");
 14835	        let w_slice = self.weights.as_slice().expect("weights must be contiguous");
 14836	        let q0_slice = core.q0.as_slice().expect("q0 must be contiguous");
 14837	        let sigma_slice = core.sigma.as_slice().expect("sigma must be contiguous");
 14838	        let dsigma_slice = core
 14839	            .dsigma_deta
 14840	            .as_slice()
 14841	            .expect("dsigma_deta must be contiguous");
 14842	        let mu_slice = core.mu.as_slice().expect("mu must be contiguous");
 14843	        let dmu_slice = core.dmu_dq.as_slice().expect("dmu_dq must be contiguous");
 14844	        let d2mu_slice = core
 14845	            .d2mu_dq2
 14846	            .as_slice()
 14847	            .expect("d2mu_dq2 must be contiguous");
 14848	        let d3mu_slice = core
 14849	            .d3mu_dq3
 14850	            .as_slice()
 14851	            .expect("d3mu_dq3 must be contiguous");
 14852	        let link_kind = &self.link_kind;
 14853	        coeff_tt
 14854	            .par_iter_mut()
 14855	            .zip(coeff_tl.par_iter_mut())
 14856	            .zip(coeff_ll.par_iter_mut())
 14857	            .enumerate()
 14858	            .for_each(|(i, ((c_tt, c_tl), c_ll))| {
 14859	                let q = q0_slice[i];
 14860	                let r = 1.0 / sigma_slice[i];
 14861	                let kappa = dsigma_slice[i] / sigma_slice[i];
 14862	                let (m1, m2, _) = binomial_neglog_q_derivatives_dispatch(
 14863	                    y_slice[i],
 14864	                    w_slice[i],
 14865	                    q,
 14866	                    mu_slice[i],
 14867	                    dmu_slice[i],
 14868	                    d2mu_slice[i],
 14869	                    d3mu_slice[i],
 14870	                    link_kind,
 14871	                );
 14872	                *c_tt = m2 * r * r;
 14873	                *c_tl = kappa * r * (m1 + q * m2);
 14874	                *c_ll = kappa * kappa * q * (m1 + q * m2);
 14875	            });
 14876	        Ok((
 14877	            Array1::from_vec(coeff_tt),
 14878	            Array1::from_vec(coeff_tl),
 14879	            Array1::from_vec(coeff_ll),
 14880	        ))
 14881	    }
