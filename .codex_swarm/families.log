   130	
   131	impl PenaltyBlocks {
   132	    pub fn new(blocks: Vec<PenaltyBlock>) -> Self {
   133	        Self { blocks }
   134	    }
   135	
   136	    pub fn gradient(&self, beta: &Array1<f64>) -> Array1<f64> {
   137	        let mut grad = Array1::zeros(beta.len());
   138	        for block in &self.blocks {
   139	            if block.lambda == 0.0 {
   140	                continue;
   141	            }
   142	            let b = beta.slice(ndarray::s![block.range.clone()]);
   143	            let g = block.matrix.dot(&b);
   144	            let mut dst = grad.slice_mut(ndarray::s![block.range.clone()]);
   145	            dst += &(block.lambda * g);
   146	        }
   147	        grad
   148	    }
   149	
   150	    pub fn hessian(&self, dim: usize) -> Array2<f64> {
   151	        let mut h = Array2::zeros((dim, dim));
   152	        self.addhessian_inplace(&mut h);
   153	        h
   154	    }
   155	
   156	    pub fn deviance(&self, beta: &Array1<f64>) -> f64 {
   157	        let mut value = 0.0;
   158	        for block in &self.blocks {
   159	            if block.lambda == 0.0 {
   160	                continue;
   161	            }
   162	            let b = beta.slice(ndarray::s![block.range.clone()]);
   163	            value += 0.5 * block.lambda * b.dot(&block.matrix.dot(&b));
   164	        }
   165	        value
   166	    }
   167	
   168	    pub fn addhessian_inplace(&self, h: &mut Array2<f64>) {
   169	        for block in &self.blocks {
   170	            if block.lambda == 0.0 {
   171	                continue;
   172	            }
   173	            let start = block.range.start;
   174	            let end = block.range.end;
   175	            h.slice_mut(ndarray::s![start..end, start..end])
   176	                .scaled_add(block.lambda, &block.matrix);
   177	        }
   178	    }
   179	}
