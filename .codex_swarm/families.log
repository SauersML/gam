   139	// ---------------------------------------------------------------------------
   140	// Overflow-safe arithmetic for the survival exact-Newton chain
   141	// ---------------------------------------------------------------------------
   142	//
   143	// The survival location-scale model computes inv_sigma = exp(-eta_ls) and
   144	// multiplies it through many intermediate quantities (q0, qdot, g, ...).
   145	// When eta_ls is very negative (sigma → 0, distribution very concentrated),
   146	// exp(-eta_ls) can overflow to inf, poisoning downstream sums with NaN via
   147	// inf * 0 or inf - inf patterns.
   148	//
   149	// The protection strategy is layered:
   150	//
   151	//   Layer 1 – `exp_neg_stable`: cap the exp argument at +500 (one-sided)
   152	//     so inv_sigma ≤ exp(500) ≈ 1.4e217, preventing overflow at the
   153	//     source.  Underflow (exp(-x) → 0 for large positive x) is allowed
   154	//     because it is the mathematically correct limit.  Products like
   155	//     inv_sigma * eta_t stay finite for any eta_t below ~1e91.
   156	//
   157	//   Layer 2 – `survival_q0_from_eta`: uses log-space arithmetic to detect
   158	//     when |eta_t * inv_sigma| would exceed the clamp ceiling and saturates
   159	//     to ±MAX instead of overflowing.
   160	//
   161	//   Layer 3 – factorized time-derivative algebra and compensated subtraction:
   162	//     the base dq/dt chain is evaluated as exp(-eta_ls) * (eta_t*eta_ls' - eta_t')
   163	//     so the shared exp(-eta_ls) factor is applied only once, and
   164	//     d_eta/dt = d_raw + qdot is formed with a compensated sum that
   165	//     carries an explicit roundoff bound into the monotonicity gate.
   166	//
   167	//   Layer 4 – `safe_product` / `safe_sum2` plus `exact_row_kernel`: the generic
   168	//     arithmetic guards still clamp inf products to MAX/MIN and map
   169	//     inf + (-inf) → 0 as defense in depth, and the row kernel splits the old
   170	//     `!g.is_finite()` hard error
   171	//     into NaN (hard error for genuinely bad data) and ±inf (clamped to MAX
   172	//     so the monotonicity guard can apply).
   173	//
   174	// The invariant: no NaN ever reaches the solver; all overflow paths saturate
   175	// to large finite values that the monotonicity floor and penalty then control.
   176	// ---------------------------------------------------------------------------
   177	
   178	/// Maximum exponent argument for overflow-safe exp in the survival chain.
   179	/// exp(500) ≈ 1.4e217 leaves ~91 orders of magnitude of headroom before
   180	/// reaching MAX ≈ 1.8e308, sufficient for any reasonable multiplicative chain.
   181	const EXP_NEG_STABLE_MAX_ARG: f64 = 500.0;
   182	
   183	/// Overflow-safe exp(-x): guards against overflow when x is very negative
   184	/// (i.e. exp(-x) very large) by capping the exponent at +500, but allows
   185	/// natural IEEE 754 underflow to 0.0 when x is very positive.
   186	///
   187	/// The one-sided guard is critical: for x = 701 the correct value is
   188	/// exp(-701) ≈ 5e-305 (essentially zero), NOT exp(-500) ≈ 7e-218.
   189	/// A two-sided clamp would return the latter, which is ~1e87× too large
   190	/// and destroys far-tail exact derivatives.
   191	#[inline]
   192	fn exp_neg_stable(x: f64) -> f64 {
   193	    (-x).min(EXP_NEG_STABLE_MAX_ARG).exp()
   194	}
   195	
   196	#[inline]
   197	fn exp_sigma_inverse_from_eta_scalar(eta: f64) -> f64 {
   198	    exp_neg_stable(eta)
   199	}
   200	
   201	/// Layer 3 defense: clamp products that overflow to ±inf back to ±MAX.
   202	/// With layer 1 (exp_neg_stable) active this should not trigger in normal
   203	/// operation; it guards against edge cases where two independently large
   204	/// (but sub-overflow) factors multiply to exceed MAX.
   205	#[inline]
   206	fn safe_product(lhs: f64, rhs: f64) -> f64 {
   207	    if lhs == 0.0 || rhs == 0.0 {
   208	        0.0
   209	    } else {
   210	        let v = lhs * rhs;
   211	        if v == f64::INFINITY {
   212	            f64::MAX
   213	        } else if v == f64::NEG_INFINITY {
   214	            f64::MIN
   215	        } else {
   216	            v
   217	        }
   218	    }
   219	}
   220	
   221	/// Layer 3 defense: when a + b produces NaN from inf + (-inf), return 0.
   222	///
   223	/// In the survival chain, g = d_raw + qdot1 where both terms scale as
   224	/// inv_sigma × (something).  When inv_sigma is very large, both terms
   225	/// overflow independently even though their sum is finite.  Mapping
   226	/// the cancellation to 0 is conservative: it says "the correction is
   227	/// negligible", and the monotonicity guard in exact_row_kernel will floor
   228	/// g upward if needed.
   229	#[inline]
   230	fn safe_sum2(a: f64, b: f64) -> f64 {
   231	    let sum = a + b;
   232	    if sum.is_nan() {
   233	        if a == 0.0 {
   234	            return b;
   235	        } else if b == 0.0 {
   236	            return a;
   237	        }
   238	        if (a == f64::INFINITY && b == f64::NEG_INFINITY)
   239	            || (a == f64::NEG_INFINITY && b == f64::INFINITY)
   240	        {
   241	            return 0.0;
   242	        }
   243	        sum
   244	    } else {
   245	        sum
   246	    }
   247	}
   248	
   249	#[inline]
   250	fn safe_sum3(a: f64, b: f64, c: f64) -> f64 {
   251	    safe_sum2(safe_sum2(a, b), c)
   252	}
   253	
   254	#[inline]
   255	fn safe_product3(a: f64, b: f64, c: f64) -> f64 {
   256	    let mut factors = [a, b, c];
   257	    factors.sort_by(|lhs, rhs| lhs.abs().total_cmp(&rhs.abs()));
   258	    safe_product(safe_product(factors[0], factors[1]), factors[2])
   259	}
