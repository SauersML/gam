 14049	    fn diagonalworking_weights_directional_derivative(
 14050	        &self,
 14051	        block_states: &[ParameterBlockState],
 14052	        block_idx: usize,
 14053	        d_eta: &Array1<f64>,
 14054	    ) -> Result<Option<Array1<f64>>, String> {
 14055	        if block_idx != Self::BLOCK_ETA {
 14056	            return Ok(None);
 14057	        }
 14058	        let eta = &expect_single_block(block_states, "GammaLogFamily")?.eta;
 14059	        let n = self.y.len();
 14060	        if eta.len() != n || self.weights.len() != n || d_eta.len() != n {
 14061	            return Err(GamlssError::DimensionMismatch {
 14062	                reason: "GammaLogFamily input size mismatch".to_string(),
 14063	            }
 14064	            .into());
 14065	        }
 14066	        if !self.shape.is_finite() || self.shape <= 0.0 {
 14067	            return Err(GamlssError::NonFinite {
 14068	                reason: "GammaLogFamily shape must be finite and > 0".to_string(),
 14069	            }
 14070	            .into());
 14071	        }
 14072	
 14073	        let mut dw = Array1::<f64>::zeros(n);
 14074	        for i in 0..n {
 14075	            let yi = self.y[i];
 14076	            if !yi.is_finite() || yi <= 0.0 {
 14077	                return Err(GamlssError::InvalidInput {
 14078	                    reason: format!("GammaLogFamily requires positive finite y; found y[{i}]={yi}"),
 14079	                }
 14080	                .into());
 14081	            }
 14082	            let e_raw = eta[i];
 14083	            let e = e_raw.clamp(-ETA_HARD_CLAMP, ETA_HARD_CLAMP);
 14084	            if self.weights[i] == 0.0 || e != e_raw {
 14085	                dw[i] = 0.0;
 14086	                continue;
 14087	            }
 14088	            let m = safe_exp(e).max(MIN_WEIGHT);
 14089	            let observed_weight = self.weights[i] * self.shape * yi / m;
 14090	            // d/dη [prior_weight * shape * y / exp(η)] = -W_obs.
 14091	            // If the positive floor is active, match the evaluated local piece.
 14092	            if observed_weight <= MIN_WEIGHT {
 14093	                dw[i] = 0.0;
 14094	            } else {
 14095	                dw[i] = -observed_weight * d_eta[i];
 14096	            }
 14097	        }
 14098	        Ok(Some(dw))
 14099	    }
