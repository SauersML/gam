  4790	/// Directional derivatives along (d_eta_t, d_eta_ls):
  4791	/// delta_q = q_t d_eta_t + q_ls d_eta_ls
  4792	/// delta_q_t = q_tl d_eta_ls
  4793	/// delta_q_ls = q_tl d_eta_t + q_ll d_eta_ls
  4794	/// delta_q_tt = 0
