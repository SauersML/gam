 15105	        let d_h_tt = xt_diag_x_dense(x_t, &coeff_tt)?;
 15106	        let d_h_tl = xt_diag_y_dense(x_t, &coeff_tl, x_ls)?;
 15107	        let d_h_ll = xt_diag_x_dense(x_ls, &coeff_ll)?;
