  1607	fn binomial_location_scale_link_eta_from_probability(
  1608	    link_kind: &InverseLink,
  1609	    probability: f64,
  1610	) -> Result<f64, String> {
  1611	    let target = probability.clamp(1e-6, 1.0 - 1e-6);
  1612	    match link_kind {
  1613	        InverseLink::Standard(LinkFunction::Logit) => Ok((target / (1.0 - target)).ln()),
  1614	        InverseLink::Standard(LinkFunction::Probit) => standard_normal_quantile(target)
  1615	            .map_err(|err| format!("failed to invert probit warm-start probability: {err}")),
  1616	        InverseLink::Standard(LinkFunction::CLogLog) => Ok((-((1.0 - target).ln())).ln()),
  1617	        other => Err(GamlssError::UnsupportedConfiguration { reason: format!(
  1618	            "binomial location-scale warm start requires logit, probit, or cloglog link, got {other:?}"
  1619	        ) }.into()),
  1620	    }
  1621	}
