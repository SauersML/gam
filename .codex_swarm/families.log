    24	/// exact pre-refactor error-string shapes so log expectations are unchanged.
    25	#[derive(Clone, Debug)]
    26	pub enum MonotoneRootError {
    27	    /// `eval(a)` returned an inner error message at the bracketing / refine step.
    28	    EvalFailed {
    29	        label: String,
    30	        a: f64,
    31	        source: String,
    32	    },
    33	    /// `eval(a)` returned a non-finite tuple component (f, f', or f'').
    34	    NonFiniteEval {
    35	        label: String,
    36	        a: f64,
    37	        f: f64,
    38	        fp: f64,
    39	        fpp: f64,
    40	    },
    41	    /// Derivative at the initial / current point is zero or non-finite —
    42	    /// monotonicity hypothesis violated.
    43	    DegenerateDerivative { label: String, a: f64, fp: f64 },
    44	    /// Bracketing failed to find a sign change within `max_bracket_iters`.
    45	    BracketingExhausted {
    46	        label: String,
    47	        iters: usize,
    48	        a_lo: f64,
    49	        a_hi: f64,
    50	    },
    51	    /// Newton refinement did not meet `convergence_tol` within `max_refine_iters`.
    52	    RefinementDidNotConverge {
    53	        label: String,
    54	        iters: usize,
    55	        last_residual: f64,
    56	    },
    57	}
    58	
    59	/// Internal: which exact textual shape a given error site emitted.
    60	/// These are folded into the enum variants above via Display so callers see
    61	/// byte-identical strings to the pre-refactor format!() output.
    62	impl MonotoneRootError {
    63	    fn exact_root_degenerate(label: &str, a: f64, fp: f64) -> Self {
    64	        // Tagged via `iters = usize::MAX` to select the "exact root" Display arm.
    65	        MonotoneRootError::RefinementDidNotConverge {
    66	            label: format!("__EXACT_ROOT__{label}"),
    67	            iters: usize::MAX,
    68	            last_residual: a,
    69	        }
    70	        // (fp is intentionally unused; we only need the label+a for the message)
    71	        .with_fp_hint(fp)
    72	    }
    73	
    74	    fn converged_root_degenerate(label: &str, a: f64) -> Self {
    75	        MonotoneRootError::RefinementDidNotConverge {
    76	            label: format!("__CONVERGED__{label}"),
    77	            iters: 0,
    78	            last_residual: a,
    79	        }
    80	    }
    81	
    82	    fn analytic_bracket_invalid(label: &str, lo: f64, hi: f64) -> Self {
    83	        MonotoneRootError::BracketingExhausted {
    84	            label: format!("__ANALYTIC_INVALID__{label}"),
    85	            iters: 0,
    86	            a_lo: lo,
    87	            a_hi: hi,
    88	        }
    89	    }
    90	
    91	    fn analytic_bracket_no_straddle(label: &str, f_lo: f64, f_hi: f64) -> Self {
    92	        MonotoneRootError::BracketingExhausted {
    93	            label: format!("__ANALYTIC_NOSTRADDLE__{label}"),
    94	            iters: 0,
    95	            a_lo: f_lo,
    96	            a_hi: f_hi,
    97	        }
    98	    }
    99	
   100	    fn search_exhausted(label: &str, step_sign: f64, a_init: f64) -> Self {
   101	        MonotoneRootError::BracketingExhausted {
   102	            label: format!("__SEARCH__{label}"),
   103	            iters: 0,
   104	            a_lo: a_init,
   105	            a_hi: step_sign,
   106	        }
   107	    }
   108	
   109	    fn with_fp_hint(self, _fp: f64) -> Self {
   110	        self
   111	    }
   112	}
