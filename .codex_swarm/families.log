 13943	impl CustomFamily for PoissonLogFamily {
 13944	    fn evaluate(&self, block_states: &[ParameterBlockState]) -> Result<FamilyEvaluation, String> {
 13945	        evaluate_log_link_diagonal_irls(self, block_states)
 13946	    }
 13947	}
