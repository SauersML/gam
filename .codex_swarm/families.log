   210	
   211	/// The time block has one beta vector but THREE design matrices (entry, exit,
   212	/// derivative-at-exit). The ParameterBlockSpec uses the exit design as its
   213	/// "official" design, so block_states[0].eta = design_exit @ beta + offset_exit.
   214	/// This eta is NOT used in the likelihood computation — row_neglog_directional
   215	/// recomputes all 3 linear predictors from beta_time directly. The exit-design
   216	/// eta exists only to satisfy the CustomFamily/PIRLS interface; ExactNewton
   217	/// blocks do not use eta for working response/weights.
   218	#[derive(Clone)]
   219	struct SurvivalMarginalSlopeFamily {
   220	    n: usize,
   221	    event: Arc<Array1<f64>>,
   222	    weights: Arc<Array1<f64>>,
   223	    z: Arc<Array2<f64>>,
   224	    score_covariance: MarginalSlopeCovariance,
   225	    gaussian_frailty_sd: Option<f64>,
   226	    derivative_guard: f64,
   227	    /// Time block: 3 designs sharing one beta vector.
   228	    /// Stored as DesignMatrix to support sparse local-support bases at
   229	    /// biobank scale (B-spline/I-spline rows have only degree+1 nonzeros).
   230	    design_entry: DesignMatrix,
   231	    design_exit: DesignMatrix,
   232	    design_derivative_exit: DesignMatrix,
   233	    offset_entry: Arc<Array1<f64>>,
   234	    offset_exit: Arc<Array1<f64>>,
   235	    derivative_offset_exit: Arc<Array1<f64>>,
   236	    /// Baseline covariate block: contributes additively to q0 and q1, but not qd1.
   237	    marginal_design: DesignMatrix,
   238	    /// Log-slope block: standard single design.
   239	    logslope_design: DesignMatrix,
   240	    logslope_surface_ranges: Vec<std::ops::Range<usize>>,
   241	    score_warp: Option<DeviationRuntime>,
   242	    link_dev: Option<DeviationRuntime>,
   243	    time_linear_constraints: Option<LinearInequalityConstraints>,
   244	    time_wiggle_knots: Option<Array1<f64>>,
   245	    time_wiggle_degree: Option<usize>,
   246	    time_wiggle_ncols: usize,
   247	    /// Per-row cache of the previous PIRLS iter's converged intercepts. Two
   248	    /// slots per row: `[entry_q0, exit_q1]`. Across consecutive PIRLS
   249	    /// iterations β changes only a little, so the previously-converged `a` is
   250	    /// an excellent initial guess for the calibration root and typically lets
   251	    /// the solver finish in ~1–2 iterations versus the rigid closed-form seed
   252	    /// which can be many bracket-expansion steps away. Slots are initialised
   253	    /// to `NaN` (sentinel for "not yet solved") and overwritten with the
   254	    /// converged intercept on every successful call.
   255	    ///
   256	    /// Set to `None` for unit-test fixtures that build a
   257	    /// `SurvivalMarginalSlopeFamily` directly without running the full fit
   258	    /// pipeline; production paths go through `make_family` which initialises
   259	    /// the cache to length-`n`. When `None`, the solver behaves exactly as it
   260	    /// did before the warm-start machinery was added (closed-form rigid seed).

