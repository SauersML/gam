  7807	/// Weighted cross-product of two rowwise-Kronecker designs, kept strictly
  7808	/// factored: output block (a, c) equals `B^T diag(w_i A_{ia} C_{ic}) D`.
  7809	fn factored_weighted_cross(
  7810	    a: &Array2<f64>,
  7811	    b: &Array2<f64>,
  7812	    weights: ndarray::ArrayView1<'_, f64>,
  7813	    c: &Array2<f64>,
  7814	    d: &Array2<f64>,
  7815	    policy: &ResourcePolicy,
  7816	) -> Result<Array2<f64>, String> {
  7817	    let n = weights.len();
  7818	    if a.nrows() != n || b.nrows() != n || c.nrows() != n || d.nrows() != n {
  7819	        return Err(TransformationNormalError::InvalidInput {
  7820	            reason: format!(
  7821	                "factored_weighted_cross row mismatch: weights={n}, a={}, b={}, c={}, d={}",
  7822	                a.nrows(),
  7823	                b.nrows(),
  7824	                c.nrows(),
  7825	                d.nrows()
  7826	            ),
  7827	        }
  7828	        .into());
  7829	    }
  7830	    let pa = a.ncols();
  7831	    let pc = c.ncols();
  7832	    let pb = b.ncols();
  7833	    let pd = d.ncols();
  7834	
  7835	    let mut out = Array2::<f64>::zeros((pa * pb, pc * pd));
  7836	    let mut pair_weights = Array1::<f64>::zeros(n);
  7837	
  7838	    for ia in 0..pa {
  7839	        let a_col = a.column(ia);
  7840	        for ic in 0..pc {
  7841	            let c_col = c.column(ic);
  7842	            for r in 0..n {
  7843	                pair_weights[r] = weights[r] * a_col[r] * c_col[r];
  7844	            }
  7845	            let block = chunked_weighted_bt_d(b, pair_weights.view(), d, policy);
  7846	            let mut slice = out.slice_mut(s![ia * pb..(ia + 1) * pb, ic * pd..(ic + 1) * pd]);
  7847	            slice.assign(&block);
  7848	        }
  7849	    }
  7850	
  7851	    Ok(out)
  7852	}
