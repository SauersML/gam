    65	/// Typed errors emitted by the survival location-scale family pipeline.
    66	///
    67	/// Each variant carries a pre-formatted `reason` string so `Display` is
    68	/// byte-equivalent to the original `format!(...)` outputs the module used
    69	/// before the typed-error migration. The category split lets callers
    70	/// pattern-match on the failure kind without dragging the string apart.
    71	#[derive(Debug, Clone)]
    72	pub enum SurvivalLocationScaleError {
    73	    /// Row/column/length disagreement between vectors, matrices, designs,
    74	    /// penalty blocks, or coefficient/parameter dimensions.
    75	    DimensionMismatch { reason: String },
    76	    /// Spec-level validation: tolerances, iteration caps, knot-vector
    77	    /// lengths, time intervals, weight values, or missing/contradictory
    78	    /// configuration fields the user supplied.
    79	    InvalidConfiguration { reason: String },
    80	    /// Structural constraint violated at runtime: monotonicity guards,
    81	    /// lower bounds on coefficients, nonnegativity, derivative-basis
    82	    /// sign, or values outside an allowed semantic range.
    83	    ConstraintViolation { reason: String },
    84	    /// A numerical step produced a non-finite or out-of-domain value
    85	    /// downstream code cannot consume (NaN products, invalid pdf,
    86	    /// survival probability out of (0,1], etc.).
    87	    NumericalFailure { reason: String },
    88	    /// Internal invariant about pipeline state (empty block markers,
    89	    /// unexpected ranks, schema/state inconsistencies surfaced from
    90	    /// inner helpers).
    91	    InternalInvariant { reason: String },
    92	}
    93	
    94	impl std::fmt::Display for SurvivalLocationScaleError {
    95	    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
    96	        match self {
