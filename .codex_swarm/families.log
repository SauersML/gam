   114	impl std::fmt::Display for MonotoneRootError {
   115	    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
   116	        match self {
   117	            MonotoneRootError::EvalFailed { source, .. } => f.write_str(source),
   118	            MonotoneRootError::NonFiniteEval { label, a, .. } => {
   119	                write!(f, "{label}: non-finite evaluation at a={a:.6}")
   120	            }
   121	            MonotoneRootError::DegenerateDerivative { label, a, .. } => {
   122	                write!(
   123	                    f,
   124	                    "{label}: initial derivative is zero or non-finite at a={a:.6}"
   125	                )
   126	            }
   127	            MonotoneRootError::BracketingExhausted {
   128	                label, a_lo, a_hi, ..
   129	            } => {
   130	                if let Some(real_label) = label.strip_prefix("__ANALYTIC_INVALID__") {
   131	                    write!(
   132	                        f,
   133	                        "{real_label}: invalid analytic bracket [{a_lo:.6}, {a_hi:.6}]"
   134	                    )
   135	                } else if let Some(real_label) = label.strip_prefix("__ANALYTIC_NOSTRADDLE__") {
   136	                    let f_lo = a_lo;
   137	                    let f_hi = a_hi;
   138	                    write!(
   139	                        f,
   140	                        "{real_label}: analytic bracket does not straddle root (f_lo={f_lo:.3e}, f_hi={f_hi:.3e})"
   141	                    )
   142	                } else if let Some(real_label) = label.strip_prefix("__SEARCH__") {
   143	                    let step_sign = *a_hi;
   144	                    let a_init = *a_lo;
   145	                    write!(
   146	                        f,
   147	                        "{real_label}: failed to bracket root (searched {step_sign:+.0} from a={a_init:.6})"
   148	                    )
   149	                } else {
   150	                    write!(
   151	                        f,
   152	                        "{label}: failed to bracket root (a_lo={a_lo:.6}, a_hi={a_hi:.6})"
   153	                    )
   154	                }
   155	            }
   156	            MonotoneRootError::RefinementDidNotConverge {
   157	                label,
   158	                last_residual,
   159	                ..
   160	            } => {
   161	                if let Some(real_label) = label.strip_prefix("__EXACT_ROOT__") {
   162	                    let a = last_residual;
   163	                    write!(
   164	                        f,
   165	                        "{real_label}: zero or non-finite derivative at exact root a={a:.6}"
   166	                    )
   167	                } else if let Some(real_label) = label.strip_prefix("__CONVERGED__") {
   168	                    let a = last_residual;
   169	                    write!(
   170	                        f,
   171	                        "{real_label}: zero or non-finite derivative at converged root a={a:.6}"
   172	                    )
   173	                } else {
   174	                    write!(
   175	                        f,
   176	                        "{label}: refinement did not converge (last residual={last_residual:.3e})"
   177	                    )
   178	                }
   179	            }
   180	        }
   181	    }
   182	}
