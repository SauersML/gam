    28	// ── Row selector ─────────────────────────────────────────────────────
    29	//
    30	// `RowSet` is the contract every outer-only assembly path uses to declare
    31	// *which* rows participate in this evaluation and *how* they should be
    32	// weighted. Two shapes:
    33	//
    34	// * `All` — iterate `0..n_total`, every row contributes with weight 1.0.
    35	//   The full-data behaviour every kernel had before subsampling existed.
    36	// * `Subsample { rows, n_full }` — iterate the pre-built
    37	//   `WeightedOuterRow` list, each row's `weight` is its Horvitz–Thompson
    38	//   inverse-inclusion scale so partial sums remain unbiased estimators
    39	//   of the full-data sum.
    40	//
    41	// The type lives here (alongside the `RowKernel` trait) so every
    42	// `row_kernel_*` assembly function can pattern-match on it without
    43	// importing the marginal-slope crate. Inner-PIRLS and final covariance
    44	// passes always run on the full data; only outer score/gradient hot
    45	// loops consume a non-`All` `RowSet`.
    46	//
    47	// Threading `RowSet` through every `row_kernel_*` function is Agent C's
    48	// job — this module exposes only the type definition and basic
    49	// constructors used by the κ-staging schedule in `smooth.rs`.
    50	#[derive(Clone)]
    51	pub enum RowSet {
    52	    All,
    53	    Subsample {
    54	        rows: Arc<Vec<crate::families::marginal_slope_shared::WeightedOuterRow>>,
    55	        n_full: usize,
    56	    },
    57	}
