   116	/// (`detect_logit_instability`, `Unstable` PIRLS status). For
   117	/// composed-link μ, derivatives `dμ/dq` etc. are NOT zeroed when the
   118	/// floor is hit; they carry the legitimate gradient signal of the
   119	/// outer link and zeroing them would create a phantom flat region that
   120	/// the optimizer would converge to as a stationary point.
   121	const MIN_PROB: f64 = 1e-10;
   122	const MIN_DERIV: f64 = 1e-8;
   123	/// Lower clamp on POSITIVE working weights `w_i = (dμ/dη)² / V(μ_i)`
   124	/// to keep `Xᵀ W X` numerically representable. Strictly numerical:
   125	/// `w` enters subsequent dense matrix products and a true zero (which
   126	/// happens when `dμ/dη = 0` at saturation, e.g. logistic μ → 0 with
   127	/// `dμ/dη = μ(1-μ)`) is harmless but a denormal `w` propagates as
   128	/// inf/NaN through `XᵀWX` because `w * (x_i x_j)` underflows
   129	/// non-uniformly. `floor_positiveweight` returns 0 for non-finite or
   130	/// non-positive inputs (so saturation correctly drops the row from
   131	/// the inner Newton system); the floor only fires for *strictly
   132	/// positive* tiny weights. The 1e-12 magnitude is chosen so that
   133	/// `1e-12 · max|x|² · n` stays comfortably above `f64::MIN_POSITIVE`
   134	/// at biobank scale.
   135	const MIN_WEIGHT: f64 = 1e-12;
   136	/// Hard symmetric clamp on η used by the Poisson / Gaussian / Gamma working-
   137	/// model log-likelihood loops to keep `exp(η)` and `log(σ)` finite under the
   138	/// IRLS step. Hoisted out of each loop so all three families share the same
   139	/// numerical regime.
   140	const ETA_HARD_CLAMP: f64 = 30.0;
   141	
   142	/// Saturated `exp(η)` used by every log-link mean reconstruction in this
   143	/// module: clamp η into `[−ETA_HARD_CLAMP, ETA_HARD_CLAMP]` so `exp` stays
   144	/// finite, then floor at `MIN_WEIGHT` so downstream divisions never see
   145	/// exact zero. Centralising the formula here means a tolerance change
   146	/// propagates to all three families (Poisson / Gaussian / Gamma) without
   147	/// risk of one path drifting.
   148	#[inline]
   149	fn saturated_exp_eta(eta: f64) -> f64 {
   150	    eta.clamp(-ETA_HARD_CLAMP, ETA_HARD_CLAMP)
   151	        .exp()
   152	        .max(MIN_WEIGHT)
   153	}
