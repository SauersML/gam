   207	
   208	    fn split_time_eta<'a>(
   209	        &self,
   210	        block_states: &'a [ParameterBlockState],
   211	    ) -> Result<
   212	        (
   213	            ArrayView1<'a, f64>,
   214	            ArrayView1<'a, f64>,
   215	            ArrayView1<'a, f64>,
   216	            &'a Array1<f64>,
   217	        ),
   218	        LatentSurvivalError,
   219	    > {
   220	        let expected_blocks = if self.latent_sd_fixed.is_some() { 2 } else { 3 };
   221	        if block_states.len() != expected_blocks {
   222	            return Err(LatentSurvivalError::BlockMismatch {
   223	                reason: format!(
   224	                    "LatentSurvivalFamily expects {expected_blocks} blocks, got {}",
   225	                    block_states.len(),
   226	                ),
   227	            });
   228	        }
   229	        let n = self.event_target.len();
   230	        let eta_time = &block_states[Self::BLOCK_TIME].eta;
   231	        let eta_mean = &block_states[Self::BLOCK_MEAN].eta;
   232	        if eta_time.len() != 3 * n {
   233	            return Err(LatentSurvivalError::BlockMismatch {
   234	                reason: format!(
   235	                    "latent survival time eta length mismatch: got {}, expected {}",
   236	                    eta_time.len(),
   237	                    3 * n
   238	                ),
   239	            });
   240	        }
   241	        if eta_mean.len() != n || self.weights.len() != n {
   242	            return Err(LatentSurvivalError::BlockMismatch {
   243	                reason: "latent survival mean eta dimension mismatch".to_string(),
   244	            });
   245	        }
   246	        Ok((
   247	            eta_time.slice(s![0..n]),
   248	            eta_time.slice(s![n..2 * n]),
   249	            eta_time.slice(s![2 * n..3 * n]),
   250	            eta_mean,
   251	        ))
   252	    }
   253	
   254	    fn latent_sd(&self, block_states: &[ParameterBlockState]) -> Result<f64, LatentSurvivalError> {
   255	        if let Some(sigma) = self.latent_sd_fixed {
   256	            return Ok(sigma);
   257	        }
   258	        let eta = *block_states
   259	            .get(Self::BLOCK_LOG_SIGMA)
   260	            .and_then(|state| state.eta.get(0))
   261	            .ok_or_else(|| LatentSurvivalError::BlockMismatch {
   262	                reason: "latent survival learnable log_sigma block is missing".to_string(),
   263	            })?;
   264	        let sigma = exp_sigma_from_eta_scalar(eta);
   265	        if !(sigma.is_finite() && sigma > 0.0) {
   266	            return Err(LatentSurvivalError::NumericalFailure {
   267	                reason: format!(
   268	                    "latent survival learnable sigma became invalid: log_sigma={eta}, sigma={sigma}"
   269	                ),
   270	            });
   271	        }
   272	        Ok(sigma)
   273	    }
   274	}
