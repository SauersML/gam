 13991	impl LogLinkDiagonalIrlsFamily for GammaLogFamily {
 13992	    fn family_label(&self) -> &'static str {
 13993	        "GammaLogFamily"
 13994	    }
 13995	    fn y(&self) -> &Array1<f64> {
 13996	        &self.y
 13997	    }
 13998	    fn prior_weights(&self) -> &Array1<f64> {
 13999	        &self.weights
 14000	    }
 14001	    fn validate_self(&self) -> Result<(), String> {
 14002	        if !self.shape.is_finite() || self.shape <= 0.0 {
 14003	            return Err(GamlssError::NonFinite {
 14004	                reason: "GammaLogFamily shape must be finite and > 0".to_string(),
 14005	            }
 14006	            .into());
 14007	        }
 14008	        Ok(())
 14009	    }
 14010	    fn validate_yi(&self, yi: f64, idx: usize) -> Result<(), String> {
 14011	        if !yi.is_finite() || yi <= 0.0 {
 14012	            return Err(GamlssError::InvalidInput {
 14013	                reason: format!("GammaLogFamily requires positive finite y; found y[{idx}]={yi}"),
 14014	            }
 14015	            .into());
 14016	        }
 14017	        Ok(())
 14018	    }
 14019	    #[inline]
 14020	    fn row_kernel(&self, yi: f64, _e_clamped: f64, m: f64, prior_w: f64) -> DiagonalIrlsRow {
 14021	        // Gamma(shape=k, scale=mu/k), dropping eta-independent constants.
 14022	        let log_lik_increment = prior_w * (-self.shape * (yi / m + m.ln()));
 14023	        // Gamma with log mean is non-canonical. Use the exact observed
 14024	        // η-space curvature -d²ℓ/dη² = prior_w * shape * y / μ, not the
 14025	        // Fisher weight prior_w * shape, so diagonal REML/LAML Hessians
 14026	        // use the true Laplace curvature instead of a PQL/Fisher surrogate.
 14027	        let observed_weight = prior_w * self.shape * yi / m;
 14028	        let score = prior_w * self.shape * (yi / m - 1.0);
 14029	        // Mirror the pre-extraction formula z = e + score / w_floored exactly;
 14030	        // the driver applies MIN_WEIGHT *before* writing w[i], but the old
 14031	        // code divided by the already-floored w[i] for non-degenerate rows,
 14032	        // and the floor only activates on the degenerate `observed_weight <=
 14033	        // MIN_WEIGHT` tail. Reproduce that branch here to preserve bitwise
 14034	        // step shape on every row that used to hit the floor.
 14035	        let w_floored = observed_weight.max(MIN_WEIGHT);
 14036	        DiagonalIrlsRow {
 14037	            log_lik_increment,
 14038	            observed_weight,
 14039	            working_step: score / w_floored,
 14040	        }
 14041	    }
 14042	}
