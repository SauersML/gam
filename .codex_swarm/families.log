 14535	    fn exact_joint_dense_block_designs<'a>(
 14536	        &'a self,
 14537	        specs: Option<&'a [ParameterBlockSpec]>,
 14538	    ) -> Result<Option<(Cow<'a, Array2<f64>>, Cow<'a, Array2<f64>>)>, String> {
 14539	        // The non-wiggle family is structurally capable of exact joint outer
 14540	        // rho-derivatives whenever the realized threshold and log-sigma
 14541	        // designs are available somewhere. Prefer cached family designs when
 14542	        // present, but allow the outer hyper code to recover the exact same
 14543	        // joint path from the realized `specs`.
 14544	        //
 14545	        // This is not a convenience fallback. The coupled profiled derivative
 14546	        // is defined in terms of the joint mode system
 14547	        //
 14548	        //   H u_k = -A_k beta,
 14549	        //
 14550	        // so if the block specs already determine the realized joint
 14551	        // curvature, forcing the code back onto a blockwise surrogate just
 14552	        // because the family did not cache duplicate dense designs would be
 14553	        // mathematically wrong.
 14554	        if self.threshold_design.is_some() && self.log_sigma_design.is_some() {
 14555	            return self.dense_block_designs().map(Some);
 14556	        }
 14557	        if let Some(specs) = specs {
 14558	            return self.dense_block_designs_fromspecs(specs).map(Some);
 14559	        }
 14560	        Ok(None)
 14561	    }
