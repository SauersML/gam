 13812	/// Per-row IRLS contribution that a single-parameter log-link family must
 13813	/// produce. The shared driver `evaluate_log_link_diagonal_irls` consumes
 13814	/// these and assembles the full `FamilyEvaluation` so the three pieces of
 13815	/// code that previously lived inside each family — size validation, per-row
 13816	/// y validation + η clamping + saturated `exp`, the active-clamp w/z guard,
 13817	/// and the final return — exist in exactly one place.
 13818	struct DiagonalIrlsRow {
 13819	    /// Weighted contribution to ℓ at this row.
 13820	    log_lik_increment: f64,
 13821	    /// Unfloored observed Hessian weight (the driver applies `MIN_WEIGHT`).
 13822	    observed_weight: f64,
 13823	    /// Per-row Newton step on the working response: `z = e + working_step`.
 13824	    /// Each family computes this with its own (score, denominator); the
 13825	    /// driver only handles the active-clamp / zero-weight guard.
 13826	    working_step: f64,
 13827	}
 13828	
 13829	/// Trait implemented by single-block log-link families that share the
 13830	/// diagonal IRLS structure (Poisson, Gamma). Each impl is responsible only
 13831	/// for the family-specific math: validating `y[i]` and producing the
 13832	/// per-row triple `(ℓ_increment, observed_weight, working_step)`.
 13833	trait LogLinkDiagonalIrlsFamily {
 13834	    /// Short, human-readable name used in size-mismatch errors.
 13835	    fn family_label(&self) -> &'static str;
 13836	
 13837	    /// Read access to the shared (y, prior weights) buffers.
 13838	    fn y(&self) -> &Array1<f64>;
 13839	    fn prior_weights(&self) -> &Array1<f64>;
 13840	
 13841	    /// Optional pre-loop validation hook for parameters outside the
 13842	    /// (y, weights, eta) triple (e.g. Gamma shape > 0).
 13843	    fn validate_self(&self) -> Result<(), String> {
 13844	        Ok(())
 13845	    }
 13846	
 13847	    /// Validate `y[i]` and return an error message if rejected. Default
 13848	    /// implementation enforces only finiteness; concrete families override
 13849	    /// to add domain constraints.
 13850	    fn validate_yi(&self, yi: f64, idx: usize) -> Result<(), String>;
 13851	
 13852	    /// Family-specific per-row math; `m = saturated_exp_eta(eta_clamped)`
 13853	    /// is computed by the driver and handed in.
 13854	    fn row_kernel(&self, yi: f64, e_clamped: f64, m: f64, prior_w: f64) -> DiagonalIrlsRow;
 13855	}
 13856	
 13857	/// Shared IRLS driver for [`LogLinkDiagonalIrlsFamily`]. Centralises the
 13858	/// size-check, η-clamp, saturated-exp, active-clamp guard, ll accumulation,
 13859	/// and `FamilyEvaluation` assembly so all log-link families with the diagonal
 13860	/// structure (Poisson, Gamma) cannot drift apart numerically.
 13861	fn evaluate_log_link_diagonal_irls<F: LogLinkDiagonalIrlsFamily + ?Sized>(
 13862	    family: &F,
 13863	    block_states: &[ParameterBlockState],
 13864	) -> Result<FamilyEvaluation, String> {
 13865	    let label = family.family_label();
 13866	    let eta = &expect_single_block(block_states, label)?.eta;
 13867	    let y = family.y();
 13868	    let prior_weights = family.prior_weights();
 13869	    let n = y.len();
 13870	    if eta.len() != n || prior_weights.len() != n {
 13871	        return Err(GamlssError::DimensionMismatch {
 13872	            reason: format!("{label} input size mismatch"),
 13873	        }
 13874	        .into());
 13875	    }
 13876	    family.validate_self()?;
 13877	
 13878	    let mut ll = 0.0;
 13879	    let mut z = Array1::<f64>::zeros(n);
 13880	    let mut w = Array1::<f64>::zeros(n);
 13881	
 13882	    for i in 0..n {
 13883	        let yi = y[i];
 13884	        family.validate_yi(yi, i)?;
 13885	        let e_raw = eta[i];
 13886	        let e = e_raw.clamp(-ETA_HARD_CLAMP, ETA_HARD_CLAMP);
 13887	        let active_clamp = e != e_raw;
 13888	        let m = saturated_exp_eta(e_raw);
 13889	        let prior_w = prior_weights[i];
 13890	        let row = family.row_kernel(yi, e, m, prior_w);
 13891	        ll += row.log_lik_increment;
 13892	        if prior_w == 0.0 || active_clamp {
 13893	            w[i] = 0.0;
 13894	            z[i] = e_raw;
 13895	        } else {
 13896	            w[i] = floor_positiveweight(row.observed_weight, MIN_WEIGHT);
 13897	            z[i] = e + row.working_step;
 13898	        }
 13899	    }
 13900	
 13901	    Ok(FamilyEvaluation {
 13902	        log_likelihood: ll,
 13903	        blockworking_sets: vec![BlockWorkingSet::diagonal_checked(z, w)?],
 13904	    })
 13905	}
