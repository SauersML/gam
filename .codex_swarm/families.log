   564	            d3: wr3 - 3.0 * wr1 * wr2 + 2.0 * wr1 * wr1 * wr1,
   565	            d4: wr4 - 4.0 * wr1 * wr3 - 3.0 * wr2 * wr2 + 12.0 * wr1 * wr1 * wr2
   566	                - 6.0 * wr1.powi(4),
   567	            mode: overall_mode,
   568	        })
   569	    }
   570	
   571	    /// Evaluate for a single positive kernel term (fast path).
   572	    ///
   573	    /// Computes `log(K_{k,m})` and its μ-derivatives from exact recurrences,
   574	    /// entirely in log-space.
   575	    pub fn single_term(
   576	        quadctx: &QuadratureContext,
   577	        k: usize,
   578	        m: f64,
   579	        mu: f64,
   580	        sigma: f64,
   581	    ) -> Result<Self, EstimationError> {
   582	        let max_k_needed = k + 4;
   583	        let lb = log_kernel_bundle(quadctx, m, mu, sigma, max_k_needed)?;
   584	        Ok(Self::from_log_value_and_ratios(
   585	            lb.get(k),
   586	            kernel_ratio_jet(&lb, k, m, 4),
   587	            lb.mode,
   588	        ))
   589	    }
   590	
   591	    /// Evaluate `log(Σ a_j K_j)` and its μ-derivatives for a small signed sum.
   592	    ///
   593	    /// All terms share the same `(μ, σ)`.  Both the value and derivative
   594	    /// ratios are computed entirely in log-space.  The runtime latent-survival
   595	    /// rows in this repo are almost always one-term or two-term sums, so those
   596	    /// cases stay on dedicated stack paths; the heap-backed logic below is only
   597	    /// for genuinely longer symbolic sums:
   598	    ///
   599	    /// 1. Per-term log-magnitudes `log|a_j| + log K_{k_j,m_j}` and signs.
   600	    /// 2. Sign-aware log-sum-exp to get `log|S|` and `sign(S)`.
   601	    /// 3. Importance weights `w_j = a_j K_j / S` formed in log-space.
   602	    /// 4. Weighted ratio sums `R_n = Σ w_j · (∂ⁿK_j / K_j)` for the
   603	    ///    final log-derivatives.
   604	    pub fn evaluate(
   605	        quadctx: &QuadratureContext,
   606	        terms: &[KernelSumTerm],
   607	        mu: f64,
   608	        sigma: f64,
   609	    ) -> Result<Self, EstimationError> {
   610	        assert!(!terms.is_empty(), "KernelSumJet requires at least one term");
   611	
   612	        // Fast path for single term.
   613	        if terms.len() == 1 {
   614	            let t = &terms[0];
   615	            if t.coeff <= 0.0 {
   616	                // Negative or zero coefficient: the sum is non-positive, so
   617	                // log(sum) is undefined.  Return −∞ (impossible observation),
   618	                // matching the general path's sign_s ≤ 0 branch.
   619	                return Ok(Self::non_positive(
   620	                    IntegratedExpectationMode::ExactClosedForm,
   621	                ));
   622	            }
   623	            let jet = Self::single_term(quadctx, t.k, t.m, mu, sigma)?;
   624	            return Ok(Self {
   625	                value: t.coeff.ln() + jet.value,
   626	                d1: jet.d1,
   627	                d2: jet.d2,
   628	                d3: jet.d3,
   629	                d4: jet.d4,
   630	                mode: jet.mode,
   631	            });
   632	        }
   633	        if terms.len() == 2 {
   634	            return Self::evaluate_two_terms(quadctx, terms[0], terms[1], mu, sigma);
   635	        }
   636	
   637	        let max_k_needed = terms.iter().map(|t| t.k).max().unwrap_or(0) + 4;
   638	
   639	        // Build log-bundles for each unique mass.
   640	        let mut log_bundles: Vec<(f64, LogLognormalKernelBundle)> = Vec::with_capacity(2);
   641	        let mut overall_mode = IntegratedExpectationMode::ExactClosedForm;
   642	        for term in terms {
   643	            if !log_bundles
   644	                .iter()
   645	                .any(|(m, _)| (*m - term.m).abs() < 1e-300)
   646	            {
   647	                let b = log_kernel_bundle(quadctx, term.m, mu, sigma, max_k_needed)?;
   648	                overall_mode = worst_mode(overall_mode, b.mode);
   649	                log_bundles.push((term.m, b));
   650	            }
   651	        }
   652	
   653	        let get_lb = |m: f64| -> &LogLognormalKernelBundle {
   654	            &log_bundles
   655	                .iter()
   656	                .find(|(bm, _)| (*bm - m).abs() < 1e-300)
   657	                .unwrap()
   658	                .1
   659	        };
   660	
   661	        // Per-term: log magnitude, sign, and ratio jet.
   662	        let mut log_mags: Vec<f64> = Vec::with_capacity(terms.len());
   663	        let mut signs: Vec<f64> = Vec::with_capacity(terms.len());
   664	        let mut ratios: Vec<[f64; 5]> = Vec::with_capacity(terms.len());
   665	        for term in terms {
   666	            let lb = get_lb(term.m);
   667	            log_mags.push(term.coeff.abs().ln() + lb.get(term.k));
   668	            signs.push(term.coeff.signum());
   669	            ratios.push(kernel_ratio_jet(lb, term.k, term.m, 4));
   670	        }
   671	
   672	        // Sign-aware log-sum-exp: compute log|S| and sign(S).
   673	        let (log_s, sign_s) = signed_log_sum_exp(&log_mags, &signs);
   674	
   675	        if !log_s.is_finite() || sign_s <= 0.0 {
   676	            // Sum is zero or negative — degenerate row.
   677	            return Ok(Self::non_positive(overall_mode));
   678	        }
   679	
   680	        // Importance weights w_j = sign(S) · sign(a_j) · exp(log|a_j K_j| − log|S|).
   681	        // When S > 0 and all terms have well-defined kernels, Σ w_j = 1.
   682	        let mut wr1 = 0.0;
   683	        let mut wr2 = 0.0;
   684	        let mut wr3 = 0.0;
   685	        let mut wr4 = 0.0;
   686	        for i in 0..terms.len() {
   687	            let w = sign_s * signs[i] * (log_mags[i] - log_s).exp();
   688	            wr1 += w * ratios[i][1];
   689	            wr2 += w * ratios[i][2];
   690	            wr3 += w * ratios[i][3];
   691	            wr4 += w * ratios[i][4];
   692	        }
   693	
   694	        Ok(Self {
   695	            value: log_s,
   696	            d1: wr1,
   697	            d2: wr2 - wr1 * wr1,
   698	            d3: wr3 - 3.0 * wr1 * wr2 + 2.0 * wr1 * wr1 * wr1,
   699	            d4: wr4 - 4.0 * wr1 * wr3 - 3.0 * wr2 * wr2 + 12.0 * wr1 * wr1 * wr2
   700	                - 6.0 * wr1.powi(4),
   701	            mode: overall_mode,
   702	        })
   703	    }
   704	}
