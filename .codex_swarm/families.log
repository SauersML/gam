  7915	/// Chunked weighted `B^T diag(w) D` product where `B` and `D` are
  7916	/// operator-backed `DesignMatrix` instances. Materializes only one row chunk
  7917	/// at a time using the operator's `row_chunk` primitive, so neither factor's
  7918	/// full dense form ever lives in memory.
  7919	///
  7920	/// Each chunk's contribution accumulates into `out` via a faer SIMD matmul
  7921	/// with `Accum::Add` rather than `out += &bl.t().dot(&dw)`. This drops one
  7922	/// `Array2` allocation per chunk and routes the inner GEMM through faer's
  7923	/// multi-threaded kernel with a work-aware parallelism choice.
  7924	fn chunked_weighted_bt_d_designmatrix(
  7925	    b: &DesignMatrix,
  7926	    weights: ndarray::ArrayView1<'_, f64>,
  7927	    d: &DesignMatrix,
  7928	    policy: &ResourcePolicy,
  7929	) -> Result<Array2<f64>, String> {
  7930	    use crate::faer_ndarray::{FaerArrayView, array2_to_matmut, matmul_parallelism};
  7931	    use faer::Accum;
  7932	    use faer::linalg::matmul::matmul;
  7933	
  7934	    let n = weights.len();
  7935	    let pb = b.ncols();
  7936	    let pd = d.ncols();
  7937	    let rows_per_chunk =
  7938	        crate::resource::rows_for_target_bytes(policy.row_chunk_target_bytes, pb + pd);
  7939	    let mut out = Array2::<f64>::zeros((pb, pd));
  7940	    if n == 0 || pb == 0 || pd == 0 {
  7941	        return Ok(out);
  7942	    }
  7943	    let mut out_view = array2_to_matmut(&mut out);
  7944	    for start in (0..n).step_by(rows_per_chunk) {
  7945	        let end = (start + rows_per_chunk).min(n);
  7946	        let rows = end - start;
  7947	        let bl = b.try_row_chunk(start..end).map_err(|e| e.to_string())?;
  7948	        let mut dw = d.try_row_chunk(start..end).map_err(|e| e.to_string())?;
  7949	        for local in 0..rows {
  7950	            let w = weights[start + local];
  7951	            if w != 1.0 {
  7952	                let mut wrow = dw.row_mut(local);
  7953	                wrow.mapv_inplace(|v| w * v);
  7954	            }
  7955	        }
  7956	        let bl_view = FaerArrayView::new(&bl);
  7957	        let dw_view = FaerArrayView::new(&dw);
  7958	        let par = matmul_parallelism(pb, pd, rows);
  7959	        matmul(
  7960	            out_view.as_mut(),
  7961	            Accum::Add,
  7962	            bl_view.as_ref().transpose(),
  7963	            dw_view.as_ref(),
  7964	            1.0,
  7965	            par,
  7966	        );
  7967	    }
  7968	    Ok(out)
  7969	}
