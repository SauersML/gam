  1010	/// Row-level log-likelihood and μ-derivatives for the latent survival model.
  1011	///
  1012	/// The conditional model is:
  1013	///   `Λ(a | U) = B(a) · exp(U)`,  `U ~ N(μ, σ²)`
  1014	///
  1015	/// All likelihoods reduce to algebra on `K_{k,m}(μ, σ)`.
  1016	#[derive(Clone, Copy, Debug)]
  1017	pub struct LatentSurvivalRowJet {
  1018	    pub log_lik: f64,
  1019	    pub score: f64,
  1020	    pub neg_hessian: f64,
  1021	    pub d3: f64,
  1022	    pub score_log_sigma: f64,
  1023	    pub neg_hessian_log_sigma: f64,
  1024	}
  1025	
  1026	#[inline]
  1027	fn log_sigma_score_from_log_sum(jet: &LogKernelSumJet, sigma: f64) -> f64 {
  1028	    let sigma2 = sigma * sigma;
  1029	    sigma2 * (jet.d2 + jet.d1 * jet.d1)
  1030	}
  1031	
  1032	#[inline]
  1033	fn log_sigma_neg_hessian_from_log_sum(jet: &LogKernelSumJet, sigma: f64) -> f64 {
  1034	    let sigma2 = sigma * sigma;
  1035	    let sigma4 = sigma2 * sigma2;
  1036	    let d1 = jet.d1;
  1037	    let d2 = jet.d2;
  1038	    let d3 = jet.d3;
  1039	    let d4 = jet.d4;
  1040	    let s2_over_s = d2 + d1 * d1;
  1041	    // For S = Σ a_j K_j, D = σ ∂_σ, and D S = σ² S_μμ:
  1042	    // D² log S = 2σ² (S''/S) + σ⁴ (S''''/S - (S''/S)²).
  1043	    // Express the final parenthesized term directly in log-derivatives to
  1044	    // avoid the larger cancellation in `r4 - r2²`.
  1045	    let s4_over_s_minus_s2_sq = d4 + 4.0 * d1 * d3 + 2.0 * d2 * d2 + 4.0 * d1 * d1 * d2;
  1046	    -(2.0 * sigma2 * s2_over_s + sigma4 * s4_over_s_minus_s2_sq)
  1047	}
