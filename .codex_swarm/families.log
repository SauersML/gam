  7579	    fn coefficient_hessian_cost(&self, specs: &[ParameterBlockSpec]) -> u64 {
  7580	        // Operator-aware: when the unified evaluator picks the matrix-free
  7581	        // joint Hessian path (see `use_joint_matrix_free_path`), the workspace
  7582	        // applies the joint Hessian via row-streaming Khatri-Rao matvecs at
  7583	        // O(n · (p_t + p_ℓ)) per Hv, never building the dense (p_t + p_ℓ)²
  7584	        // matrix. Report the operator work model so diagnostics and
  7585	        // first-order-only policies reflect the representation that actually
  7586	        // runs.
  7587	        let n = self.y.len() as u64;
  7588	        let p_total: u64 = specs
  7589	            .iter()
  7590	            .map(|s| s.design.ncols() as u64)
  7591	            .fold(0u64, |a, p| a.saturating_add(p));
  7592	        if crate::custom_family::use_joint_matrix_free_path(p_total as usize, n as usize) {
  7593	            n.saturating_mul(p_total)
  7594	        } else {
  7595	            crate::custom_family::joint_coupled_coefficient_hessian_cost(n, specs)
  7596	        }
  7597	    }
