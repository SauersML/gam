   162	pub(crate) fn observed_denested_cell_partials(
   163	    z_obs: f64,
   164	    a: f64,
   165	    b: f64,
   166	    score_warp: Option<&crate::families::bernoulli_marginal_slope::DeviationRuntime>,
   167	    beta_h: Option<&Array1<f64>>,
   168	    link_dev: Option<&crate::families::bernoulli_marginal_slope::DeviationRuntime>,
   169	    beta_w: Option<&Array1<f64>>,
   170	    scale: f64,
   171	) -> Result<ObservedDenestedCellPartials, String> {
   172	    let zero_score_span = zero_local_span_cubic();
   173	    let zero_link_span = zero_local_span_cubic();
   174	    let u_obs = a + b * z_obs;
   175	    let score_span_obs = if let (Some(runtime), Some(beta_h)) = (score_warp, beta_h) {
   176	        runtime.local_cubic_at(beta_h, z_obs)?
   177	    } else {
   178	        zero_score_span
   179	    };
   180	    let link_span_obs = if let (Some(runtime), Some(beta_w)) = (link_dev, beta_w) {
   181	        runtime.local_cubic_at(beta_w, u_obs)?
   182	    } else {
   183	        zero_link_span
   184	    };
   185	    let coeff = scale_coeff4(
   186	        cubic_cell_kernel::denested_cell_coefficients(score_span_obs, link_span_obs, a, b),
   187	        scale,
   188	    );
   189	    let (dc_da_raw, dc_db_raw) =
   190	        cubic_cell_kernel::denested_cell_coefficient_partials(score_span_obs, link_span_obs, a, b);
   191	    let (dc_daa_raw, dc_dab_raw, dc_dbb_raw) =
   192	        cubic_cell_kernel::denested_cell_second_partials(score_span_obs, link_span_obs, a, b);
   193	    let (dc_daaa, dc_daab, dc_dabb, dc_dbbb) =
   194	        cubic_cell_kernel::denested_cell_third_partials(link_span_obs);
   195	    Ok(ObservedDenestedCellPartials {
   196	        coeff,
   197	        dc_da: scale_coeff4(dc_da_raw, scale),
   198	        dc_db: scale_coeff4(dc_db_raw, scale),
   199	        dc_daa: scale_coeff4(dc_daa_raw, scale),
   200	        dc_dab: scale_coeff4(dc_dab_raw, scale),
   201	        dc_dbb: scale_coeff4(dc_dbb_raw, scale),
   202	        dc_daaa: scale_coeff4(dc_daaa, scale),
   203	        dc_daab: scale_coeff4(dc_daab, scale),
   204	        dc_dabb: scale_coeff4(dc_dabb, scale),
   205	        dc_dbbb: scale_coeff4(dc_dbbb, scale),
   206	    })
   207	}
