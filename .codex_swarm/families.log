 14361	impl<F: BinomialLocationScaleJointPsiFamily> BinomialLocationScaleJointPsiWorkspace<F> {
 14362	    fn new(
 14363	        family: F,
 14364	        block_states: Vec<ParameterBlockState>,
 14365	        specs: &[ParameterBlockSpec],
 14366	        derivative_blocks: Vec<Vec<CustomFamilyBlockPsiDerivative>>,
 14367	    ) -> Result<Self, String> {
 14368	        let Some((x_t, x_ls)) = family.ws_exact_joint_dense_block_designs(Some(specs))? else {
 14369	            return Err(GamlssError::UnsupportedConfiguration {
 14370	                reason: format!(
 14371	                    "{} exact joint psi workspace requires dense block designs",
 14372	                    F::LABEL,
 14373	                ),
 14374	            }
 14375	            .into());
 14376	        };
 14377	        let x_t = shared_dense_arc(x_t.as_ref());
 14378	        let x_ls = shared_dense_arc(x_ls.as_ref());
 14379	        let psi_dim = derivative_blocks.iter().map(Vec::len).sum();
 14380	        Ok(Self {
 14381	            family,
 14382	            block_states,
 14383	            derivative_blocks,
 14384	            x_t,
 14385	            x_ls,
 14386	            psi_directions: ExactNewtonJointPsiDirectCache::new(psi_dim),
 14387	        })
 14388	    }
