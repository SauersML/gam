 15078	                reason: format!(
 15079	                    "BinomialLocationScaleFamily joint d_beta length mismatch: got {}, expected {}",
 15080	                    d_beta_flat.len(),
 15081	                    pt + pls
 15082	                ),
 15083	            }
 15084	            .into());
 15085	        }
 15086	        let d_eta_t = fast_av(x_t, &d_beta_flat.slice(s![0..pt]));
 15087	        let d_eta_ls = fast_av(x_ls, &d_beta_flat.slice(s![pt..pt + pls]));
 15088	        let core = binomial_location_scale_core(
 15089	            &self.y,
 15090	            &self.weights,
 15091	            eta_t,
 15092	            eta_ls,
 15093	            None,
 15094	            &self.link_kind,
 15095	        )?;
