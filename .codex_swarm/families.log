 14347	/// Joint exact-Newton ψ workspace shared by `BinomialLocationScaleFamily` and
 14348	/// `BinomialLocationScaleWiggleFamily`. The two families plug in via
 14349	/// `BinomialLocationScaleJointPsiFamily`; the struct holds the dense block
 14350	/// designs + per-ψ direction cache and routes every workspace call through
 14351	/// trait dispatch.
 14352	struct BinomialLocationScaleJointPsiWorkspace<F: BinomialLocationScaleJointPsiFamily> {
 14353	    family: F,
 14354	    block_states: Vec<ParameterBlockState>,
 14355	    derivative_blocks: Vec<Vec<CustomFamilyBlockPsiDerivative>>,
 14356	    x_t: Arc<Array2<f64>>,
 14357	    x_ls: Arc<Array2<f64>>,
 14358	    psi_directions: ExactNewtonJointPsiDirectCache<BinomialLocationScaleJointPsiDirection>,
 14359	}
