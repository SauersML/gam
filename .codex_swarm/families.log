    83	/// or `.into()` at the boundary without per-callsite `.map_err`.
    84	#[derive(Debug, Clone)]
    85	pub enum TransformationNormalError {
    86	    /// Shape/length/dimension/contract violations on inputs to a routine
    87	    /// (e.g. response/covariate row mismatch, beta length mismatch,
    88	    /// wrong number of blocks, malformed configuration parameters).
    89	    InvalidInput { reason: String },
    90	    /// A required covariate design or weight configuration cannot support
    91	    /// the routine — empty design, zero total weight, residual variance
    92	    /// not representable, warm-start coefficients all non-finite.
    93	    DesignDegenerate { reason: String },
    94	    /// A numeric intermediate (response transform, derivative,
    95	    /// log-likelihood, weight, offset, gradient component, calibration
    96	    /// quantity) came out non-finite or non-positive where positive
    97	    /// finite is required.
    98	    NonFinite { reason: String },
    99	    /// The fitted monotone transform's derivative dropped to or below
   100	    /// zero, or the response endpoint ordering required by the latent
   101	    /// score (lower < h < upper) was not satisfied at evaluation time.
   102	    MonotonicityViolated { reason: String },
   103	    /// A numerical step that maps through the standard-normal CDF
