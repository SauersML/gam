     1	//! Shared, allocation-free lookup of bitmask set-partitions used by the
     2	//! multi-directional jet `compose_unary` (Faà di Bruno) routines in the
     3	//! marginal-slope and latent-survival families.
     4	//!
     5	//! Each entry `partitions(mask)` is the list of all set-partitions of the bits
     6	//! of `mask`, with each partition represented as a `Vec<usize>` of disjoint
     7	//! sub-masks whose bitwise OR equals `mask`. Total memory is bounded by the
     8	//! Bell numbers up to `B(MAX_DIRS) = 4140` for `MAX_DIRS=8`. The 8-direction
     9	//! cap covers the bernoulli marginal-slope rigid path's full uncontracted
    10	//! fourth-tensor jet (`[e_q, e_g, e_q, e_g, e_q, e_g, e_q, e_g]`); no caller
    11	//! currently needs more directions. Cache is computed lazily on first use.
    12	use std::sync::OnceLock;
    13	use std::sync::atomic::{AtomicU64, Ordering};
    14	
    15	pub static COMPOSE_UNARY_CALLS: AtomicU64 = AtomicU64::new(0);
    16	pub static MUL_CALLS: AtomicU64 = AtomicU64::new(0);
    17	pub static ROW_NEGLOG_CALLS: AtomicU64 = AtomicU64::new(0);
    18	
    19	const MAX_DIRS: usize = 8;
    20	const TABLE_LEN: usize = 1usize << MAX_DIRS;
    21	
    22	static CACHE: OnceLock<Vec<Vec<Vec<usize>>>> = OnceLock::new();
    23	
    24	fn build_partitions(mask: usize) -> Vec<Vec<usize>> {
    25	    if mask == 0 {
    26	        return vec![Vec::new()];
    27	    }
    28	    let first = mask & mask.wrapping_neg();
    29	    let rest = mask ^ first;
    30	    let mut out = Vec::new();
    31	    let mut subset = rest;
    32	    loop {
    33	        let block = first | subset;
    34	        for mut remainder in build_partitions(rest ^ subset) {
    35	            remainder.push(block);
    36	            out.push(remainder);
    37	        }
    38	        if subset == 0 {
    39	            break;
    40	        }
    41	        subset = (subset - 1) & rest;
    42	    }
    43	    out
    44	}
    45	
    46	/// Returns the precomputed list of set-partitions for `mask`.
    47	///
    48	/// Supports masks in `0..=(1 << MAX_DIRS) - 1` (i.e. up to six-direction
    49	/// jet machinery). Panics if `mask` is out of range.
    50	pub fn partitions(mask: usize) -> &'static [Vec<usize>] {
    51	    let table = CACHE.get_or_init(|| (0..TABLE_LEN).map(build_partitions).collect());
    52	    &table[mask]
    53	}
