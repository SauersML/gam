   209	pub(crate) fn add_two_surface_psi_outer(
   210	    block_i: usize,
   211	    psi_row_i: &Array1<f64>,
   212	    block_j: usize,
   213	    psi_row_j: &Array1<f64>,
   214	    alpha: f64,
   215	    marginal_block: usize,
   216	    logslope_block: usize,
   217	    h_mm: &mut Array2<f64>,
   218	    h_gg: &mut Array2<f64>,
   219	    h_mg: &mut Array2<f64>,
   220	) {
   221	    if alpha == 0.0 {
   222	        return;
   223	    }
   224	    let col_i = psi_row_i.view().insert_axis(Axis(1));
   225	    let row_j = psi_row_j.view().insert_axis(Axis(0));
   226	
   227	    if block_i == block_j {
   228	        let col_j = psi_row_j.view().insert_axis(Axis(1));
   229	        let row_i = psi_row_i.view().insert_axis(Axis(0));
   230	        let target = match block_i {
   231	            b if b == marginal_block => h_mm,
   232	            b if b == logslope_block => h_gg,
   233	            _ => return,
   234	        };
   235	        ndarray::linalg::general_mat_mul(alpha, &col_i, &row_j, 1.0, target);
   236	        ndarray::linalg::general_mat_mul(alpha, &col_j, &row_i, 1.0, target);
   237	    } else {
   238	        let (marginal_row, logslope_row) = if block_i == marginal_block {
   239	            (psi_row_i, psi_row_j)
   240	        } else {
   241	            (psi_row_j, psi_row_i)
   242	        };
   243	        let m_col = marginal_row.view().insert_axis(Axis(1));
   244	        let g_row = logslope_row.view().insert_axis(Axis(0));
   245	        ndarray::linalg::general_mat_mul(alpha, &m_col, &g_row, 1.0, h_mg);
   246	    }
   247	}
