 13917	    fn validate_yi(&self, yi: f64, idx: usize) -> Result<(), String> {
 13918	        if !yi.is_finite() || yi < 0.0 {
 13919	            return Err(GamlssError::InvalidInput {
 13920	                reason: format!(
 13921	                    "PoissonLogFamily requires non-negative finite y; found y[{idx}]={yi}"
 13922	                ),
 13923	            }
 13924	            .into());
 13925	        }
 13926	        Ok(())
 13927	    }
 13928	    #[inline]
 13929	    fn row_kernel(&self, yi: f64, e_clamped: f64, m: f64, prior_w: f64) -> DiagonalIrlsRow {
 13930	        // Drop log(y!) constant in objective.
 13931	        let log_lik_increment = prior_w * (yi * e_clamped - m);
 13932	        let dmu = m.max(MIN_DERIV);
 13933	        let var = m.max(MIN_PROB);
 13934	        DiagonalIrlsRow {
 13935	            log_lik_increment,
 13936	            observed_weight: prior_w * (dmu * dmu / var),
 13937	            // (yi - m)/dmu, identical to the previous direct expression.
 13938	            working_step: (yi - m) / signedwith_floor(dmu, MIN_DERIV),
 13939	        }
 13940	    }
 13941	}
