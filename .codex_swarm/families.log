 14483	    fn dense_block_designs(&self) -> Result<(Cow<'_, Array2<f64>>, Cow<'_, Array2<f64>>), String> {
 14484	        let threshold_design = self.threshold_design.as_ref().ok_or_else(|| {
 14485	            "BinomialLocationScaleFamily exact path is missing threshold design".to_string()
 14486	        })?;
 14487	        let log_sigma_design = self.log_sigma_design.as_ref().ok_or_else(|| {
 14488	            "BinomialLocationScaleFamily exact path is missing log-sigma design".to_string()
 14489	        })?;
 14490	        let xt = match threshold_design.as_dense_ref() {
 14491	            Some(d) => Cow::Borrowed(d),
 14492	            None => Cow::Owned(
 14493	                threshold_design
 14494	                    .try_to_dense_with_policy(
 14495	                        &self.policy.material_policy(),
 14496	                        "BinomialLocationScale dense_block_designs threshold",
 14497	                    )
 14498	                    .map_err(|e| e.to_string())?
 14499	                    .as_ref()
 14500	                    .clone(),
 14501	            ),
 14502	        };
 14503	        let x_ls = match log_sigma_design.as_dense_ref() {
 14504	            Some(d) => Cow::Borrowed(d),
 14505	            None => Cow::Owned(
 14506	                log_sigma_design
 14507	                    .try_to_dense_with_policy(
 14508	                        &self.policy.material_policy(),
 14509	                        "BinomialLocationScale dense_block_designs log_sigma",
 14510	                    )
 14511	                    .map_err(|e| e.to_string())?
 14512	                    .as_ref()
 14513	                    .clone(),
 14514	            ),
 14515	        };
 14516	        Ok((xt, x_ls))
 14517	    }
