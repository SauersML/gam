        let p = matrices[0].nrows();
        let p_i32 = to_i32(p)?;
        let k_i32 = to_i32(k)?;
        let entries_per_matrix = p.checked_mul(p)?;
        let total_doubles = k.checked_mul(entries_per_matrix)?;
