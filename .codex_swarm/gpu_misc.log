            let solve_status = (self.solver.dpotrs)(
                self.handle,
                CUBLAS_FILL_LOWER,
                p_i32,
                nrhs_i32,
                a_dev.ptr,
                p_i32,
                rhs_dev.ptr,
                p_i32,
                info_dev.ptr,
