  1009	                    knotview,
  1010	                    eval_kind,
  1011	                    num_basis_functions,
  1012	                    &mut scratch,
  1013	                    &mut values,
  1014	                    |col_j, v| row_slice[col_j] = v,
  1015	                );
  1016	            }
  1017	        }
