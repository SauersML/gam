 14109	            //              + 2 ζ(3) + π²/6 - 2
 14110	            const ZETA3: f64 = 1.2020569031595942853997381615114499907649862923404988817922;
 14111	            let li3_u = trilog_unit(u);
 14112	            let li2_one_minus_u = dilog_unit(one_minus_u);
 14113	            let li2_u = dilog_unit(u);
 14114	            (-2.0 * li3_u - li2_one_minus_u + u.ln() * li2_u + 2.0 * ZETA3 + pi2_6 - 2.0) / four_pi
