 10083	fn normalize_penalty(matrix: &Array2<f64>) -> (Array2<f64>, f64) {
 10084	    let norm = matrix.iter().map(|v| v * v).sum::<f64>().sqrt().max(1e-12);
 10085	    (matrix.mapv(|v| v / norm), norm)
 10086	}
