   250	fn penalty_from_root_faer(root: &Mat<f64>) -> Mat<f64> {
   251	    let cols = root.ncols();
   252	    let mut full = Mat::<f64>::zeros(cols, cols);
   253	    let root_ref = root.as_ref();
   254	    let root_t = root_ref.transpose();
   255	    matmul(
   256	        full.as_mut(),
   257	        Accum::Replace,
   258	        root_t,
   259	        root_ref,
   260	        1.0,
   261	        Par::Seq,
   262	    );
   263	    sanitize_symmetric_faer(&full)
   264	}
