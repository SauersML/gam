   613	/// Result of the stable reparameterization algorithm from Wood (2011) Appendix B
   614	#[derive(Clone)]
   615	pub struct ReparamResult {
   616	    /// Penalty matrix in TRANSFORMED coefficient coordinates.
   617	    ///
   618	    /// This must be compatible with `beta_transformed` and `X_transformed = X * Qs`.
   619	    pub s_transformed: Array2<f64>,
   620	    /// Log-determinant of the penalty matrix (stable computation)
   621	    pub log_det: f64,
   622	    /// First derivatives of log-determinant w.r.t. log-smoothing parameters
   623	    pub det1: Array1<f64>,
   624	    /// Orthogonal transformation matrix Qs
   625	    pub qs: Array2<f64>,
   626	    /// Canonical penalties in the TRANSFORMED coordinate frame.
   627	    /// The single source of truth for penalty roots in the transformed frame.
   628	    /// Downstream consumers use these for block-local `PenaltyCoordinate`
   629	    /// construction, TK correction, and ext-coord paths.
   630	    pub canonical_transformed: Vec<CanonicalPenalty>,
   631	    /// Lambda-dependent penalty square root in TRANSFORMED coordinates (rank x p matrix).
   632	    /// This is used for applying the actual penalty in the least squares solve.
   633	    pub e_transformed: Array2<f64>,
   634	    /// Truncated eigenvectors (p × m where m = p - structural_rank).
   635	    ///
   636	    /// Coordinate frame note:
   637	    /// - This matrix is stored in the TRANSFORMED coefficient frame (post-`Qs`),
   638	    ///   i.e. it is compatible with `canonical_transformed`, `beta_transformed`,
   639	    ///   and transformed Hessians without additional coordinate mapping.
   640	    ///
   641	    /// These vectors span the structural null space used by positive-part
   642	    /// log-determinant conventions.
   643	    pub u_truncated: Array2<f64>,
   644	    /// The rho-independent shrinkage ridge magnitude that was added to each
   645	    /// eigenvalue of the penalized block. Zero means no shrinkage was applied.
   646	    pub penalty_shrinkage_ridge: f64,
   647	}
