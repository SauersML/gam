   420	fn dense_transpose_matvec_view(matrix: &Array2<f64>, vector: ArrayView1<'_, f64>) -> Array1<f64> {
   421	    let n = matrix.nrows();
   422	    let p = matrix.ncols();
   423	    let row_major_slices = if matrix.is_standard_layout() {
   424	        match (matrix.as_slice(), vector.as_slice()) {
   425	            (Some(x), Some(v)) => Some((x, v)),
   426	            _ => None,
   427	        }
   428	    } else {
   429	        None
   430	    };
   431	    if (n as u64) * (p as u64) < DENSE_ROW_PARALLEL_MIN_NP {
   432	        let mut out = Array1::<f64>::zeros(p);
   433	        if let Some((x, v)) = row_major_slices {
   434	            let out_slice = out.as_slice_mut().expect("zeros are contiguous");
   435	            for i in 0..n {
   436	                let vi = v[i];
   437	                if vi == 0.0 {
   438	                    continue;
   439	                }
   440	                let row = &x[i * p..i * p + p];
   441	                for j in 0..p {
   442	                    out_slice[j] += row[j] * vi;
   443	                }
   444	            }
   445	        } else {
   446	            for i in 0..n {
   447	                let vi = vector[i];
   448	                if vi == 0.0 {
   449	                    continue;
   450	                }
   451	                for j in 0..p {
   452	                    out[j] += matrix[[i, j]] * vi;
   453	                }
   454	            }
   455	        }
   456	        return out;
   457	    }
   458	    if let Some((x, v)) = row_major_slices {
   459	        return (0..n)
   460	            .into_par_iter()
   461	            .fold(
   462	                || Array1::<f64>::zeros(p),
   463	                |mut acc, i| {
   464	                    let vi = v[i];
   465	                    if vi != 0.0 {
   466	                        let row = &x[i * p..i * p + p];
   467	                        let acc_slice = acc.as_slice_mut().expect("zeros are contiguous");
   468	                        for j in 0..p {
   469	                            acc_slice[j] += row[j] * vi;
   470	                        }
   471	                    }
   472	                    acc
   473	                },
   474	            )
   475	            .reduce(
   476	                || Array1::<f64>::zeros(p),
   477	                |mut a, b| {
   478	                    a += &b;
   479	                    a
   480	                },
   481	            );
   482	    }
   483	    (0..n)
   484	        .into_par_iter()
   485	        .fold(
   486	            || Array1::<f64>::zeros(p),
   487	            |mut acc, i| {
   488	                let vi = vector[i];
   489	                if vi != 0.0 {
   490	                    for j in 0..p {
   491	                        acc[j] += matrix[[i, j]] * vi;
   492	                    }
   493	                }
   494	                acc
   495	            },
   496	        )
   497	        .reduce(
   498	            || Array1::<f64>::zeros(p),
   499	            |mut a, b| {
   500	                a += &b;
   501	                a
   502	            },
   503	        )
   504	}
