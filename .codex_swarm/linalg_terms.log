    57	pub fn dense_to_sparse(
    58	    matrix: &Array2<f64>,
    59	    tol: f64,
    60	) -> Result<SparseColMat<usize, f64>, EstimationError> {
    61	    let nrows = matrix.nrows();
    62	    let ncols = matrix.ncols();
    63	    // Direct column-major CSC construction.  Three-pass: count nnz per
    64	    // column in parallel, perform the prefix sum serially, then fill each
    65	    // deterministic column slice in parallel.  Columns are still traversed
    66	    // in order and rows are written in ascending order within each column,
    67	    // preserving the same canonical CSC ordering as the previous serial
    68	    // implementation without requiring a triplet sort/dedup pass.
    69	    let counts: Vec<usize> = (0..ncols)
    70	        .into_par_iter()
    71	        .map(|col| {
    72	            let mut count = 0usize;
    73	            for row in 0..nrows {
    74	                if matrix[[row, col]].abs() > tol {
    75	                    count += 1;
    76	                }
    77	            }
    78	            count
    79	        })
    80	        .collect();
    81	    let col_ptr = prefix_sum_counts(&counts);
    82	    let nnz = col_ptr[ncols];
    83	    let mut row_idx = vec![0usize; nnz];
    84	    let mut values = vec![0.0; nnz];
    85	    fill_dense_to_sparse_columns(matrix, tol, 0, ncols, &col_ptr, &mut row_idx, &mut values);
    86	    let symbolic = SymbolicSparseColMat::<usize>::new_checked(nrows, ncols, col_ptr, None, row_idx);
    87	    Ok(SparseColMat::<usize, f64>::new(symbolic, values))
    88	}
