   236	    for i in 0..rows {
   237	        for j in 0..cols {
   238	            let val = sanitized[(i, j)];
   239	            if !val.is_finite() {
   240	                sanitized[(i, j)] = 0.0;
   241	            } else if val.abs() < tiny {
   242	                sanitized[(i, j)] = 0.0;
   243	            }
   244	        }
   245	    }
   246	
   247	    sanitized
   248	}
