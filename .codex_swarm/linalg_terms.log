  7951	) -> Result<(f64, f64, f64, f64), BasisError> {
  7952	    if !r.is_finite() || r < 0.0 {
  7953	        return Err(BasisError::InvalidInput(
  7954	            "Matérn kernel distance must be finite and non-negative".to_string(),
  7955	        ));
  7956	    }
  7957	    if !length_scale.is_finite() || length_scale <= 0.0 {
  7958	        return Err(BasisError::InvalidInput(
  7959	            "Matérn length_scale must be finite and positive".to_string(),
  7960	        ));
  7961	    }
  7962	
  7963	    // Full derivation used by collocation operators:
  7964	    //   phi(r) = P_nu(a) exp(-a), a=sr, s=sqrt(2nu)/length_scale.
  7965	    // For nu>=3/2 we use closed-form phi'(r)/r polynomials with finite r->0 limit.
  7966	    // For nu=1/2:
  7967	    //   phi'(r)/r = -kappa exp(-kappa r)/r,
  7968	    // which is genuinely singular at r=0 and must not be regularized here.
  7969	    // Closed forms used below (a = s r, E = exp(-a)):
  7970	    // nu=1/2:
  7971	    //   phi'    = -s E
  7972	    //   phi''   =  s^2 E
  7973	    //   phi'/r  diverges as -s/r (regularized via r floor).
  7974	    // nu=3/2:
  7975	    //   phi'    = -s E a
  7976	    //   phi''   =  s^2 E (a-1)
  7977	    //   phi'/r  = -s^2 E.
  7978	    // nu=5/2:
  7979	    //   phi'    = -(s/3) E a(a+1)
  7980	    //   phi''   =  (s^2/3) E (a^2-a-1)
  7981	    //   phi'/r  = -(s^2/3) E (a+1).
  7982	    // nu=7/2:
  7983	    //   phi'    = -(s/15) E a(a^2+3a+3)
  7984	    //   phi''   =  (s^2/15) E (a^3-3a-3)
  7985	    //   phi'/r  = -(s^2/15) E (a^2+3a+3).
  7986	    // nu=9/2:
  7987	    //   phi'    = -(s/105) E a(a^3+6a^2+15a+15)
  7988	    //   phi''   =  (s^2/105) E (a^4+2a^3-3a^2-15a-15)
  7989	    //   phi'/r  = -(s^2/105) E (a^3+6a^2+15a+15).
  7990	    let (phi, phi_r, phi_rr, phi_r_over_r) = match nu {
  7991	        MaternNu::Half => {
  7992	            let s = 1.0 / length_scale;
  7993	            let a = s * r;
  7994	            let e = (-a).exp();
  7995	            let phi = e;
  7996	            let phi_r = -s * e;
  7997	            let phi_rr = s * s * e;
