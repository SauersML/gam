  1664	fn periodic_spline_spacings(
  1665	    sites: ArrayView1<'_, f64>,
  1666	    options: PeriodicSpline1DOptions,
  1667	) -> Vec<f64> {
  1668	    let n = sites.len();
  1669	    (0..n)
  1670	        .map(|i| {
  1671	            let next = if i + 1 == n {
  1672	                sites[0] + options.period
  1673	            } else {
  1674	                sites[i + 1]
  1675	            };
  1676	            next - sites[i]
  1677	        })
  1678	        .collect()
  1679	}
