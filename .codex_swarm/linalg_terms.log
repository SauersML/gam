   767	#[inline]
   768	fn dense_transpose_weighted_response(
   769	    matrix: &Array2<f64>,
   770	    weights: &Array1<f64>,
   771	    y: &Array1<f64>,
   772	    row_scale: Option<&Array1<f64>>,
   773	) -> Array1<f64> {
   774	    let p = matrix.ncols();
   775	    let n = matrix.nrows();
   776	    let mut out = Array1::<f64>::zeros(p);
   777	    if matrix.is_standard_layout() {
   778	        if let (Some(x), Some(w), Some(yslice)) =
   779	            (matrix.as_slice(), weights.as_slice(), y.as_slice())
   780	        {
   781	            let scale_slice = row_scale.and_then(|s| s.as_slice());
   782	            let out_slice = out.as_slice_mut().expect("zeros are contiguous");
   783	            for i in 0..n {
   784	                let mut scaled = yslice[i] * w[i].max(0.0);
   785	                if let Some(s) = scale_slice {
   786	                    scaled *= s[i];
   787	                } else if let Some(scale) = row_scale {
   788	                    scaled *= scale[i];
   789	                }
   790	                if scaled == 0.0 {
   791	                    continue;
   792	                }
   793	                let row = &x[i * p..i * p + p];
   794	                for j in 0..p {
   795	                    out_slice[j] += row[j] * scaled;
   796	                }
   797	            }
   798	            return out;
   799	        }
   800	    }
   801	    for i in 0..n {
   802	        let mut scaled = y[i] * weights[i].max(0.0);
   803	        if let Some(scale) = row_scale {
   804	            scaled *= scale[i];
   805	        }
   806	        if scaled == 0.0 {
   807	            continue;
   808	        }
   809	        for j in 0..p {
   810	            out[j] += matrix[[i, j]] * scaled;
   811	        }
   812	    }
   813	    out
   814	}
