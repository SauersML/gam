 19932	fn monomial_exponents(dimension: usize, max_total_degree: usize) -> Vec<Vec<usize>> {
 19933	    fn recurse(
 19934	        axis: usize,
 19935	        remaining_degree: usize,
 19936	        current: &mut [usize],
 19937	        out: &mut Vec<Vec<usize>>,
 19938	    ) {
 19939	        if axis + 1 == current.len() {
 19940	            current[axis] = remaining_degree;
 19941	            out.push(current.to_vec());
 19942	            return;
 19943	        }
 19944	        for exponent in (0..=remaining_degree).rev() {
 19945	            current[axis] = exponent;
 19946	            recurse(axis + 1, remaining_degree - exponent, current, out);
 19947	        }
 19948	    }
 19949	
 19950	    if dimension == 0 {
 19951	        return vec![Vec::new()];
 19952	    }
 19953	
 19954	    let mut out = Vec::new();
 19955	    let mut current = vec![0usize; dimension];
 19956	    for total_degree in 0..=max_total_degree {
 19957	        recurse(0, total_degree, &mut current, &mut out);
 19958	    }
 19959	    out
 19960	}
