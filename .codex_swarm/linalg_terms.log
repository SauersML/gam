   699	/// Compute A^T * diag(W) * B using streaming chunks.
   700	#[inline]
   701	pub fn fast_xt_diag_y<S1: Data<Elem = f64>, S2: Data<Elem = f64>, S3: Data<Elem = f64>>(
   702	    x: &ArrayBase<S1, Ix2>,
   703	    w: &ArrayBase<S2, Ix1>,
   704	    y: &ArrayBase<S3, Ix2>,
   705	) -> Array2<f64> {
   706	    use faer::Accum;
   707	    use faer::linalg::matmul::matmul;
   708	    use ndarray::{ShapeBuilder, s};
   709	
   710	    let (n, q) = y.dim();
   711	    let px = x.ncols();
   712	    debug_assert_eq!(n, w.len(), "Y rows must match W length");
   713	    debug_assert_eq!(n, x.nrows(), "X rows must match Y rows");
   714	    if n == 0 || px == 0 || q == 0 {
   715	        return Array2::<f64>::zeros((px, q));
   716	    }
   717	    if let Some(out) = crate::gpu::try_fast_xt_diag_y(x, w, y) {
   718	        return out;
   719	    }
   720	    if !should_use_faer_matmul(px, q, n) {
   721	        let w_y = Array2::from_shape_fn((n, q), |(i, j)| w[i] * y[[i, j]]);
   722	        return x.t().dot(&w_y);
   723	    }
   724	
   725	    // Streaming: only allocate chunk_rows × q for the weighted Y slice.
   726	    const TARGET_BYTES: usize = 8 * 1024 * 1024;
   727	    const MIN_ROWS: usize = 512;
   728	    const MAX_ROWS: usize = 131_072;
   729	    let total_cols = px + q;
   730	    let chunk_rows = (TARGET_BYTES / (total_cols.max(1) * 8))
   731	        .clamp(MIN_ROWS, MAX_ROWS)
   732	        .min(n);
   733	
   734	    let mut result = Array2::<f64>::zeros((px, q).f());
   735	    // Row-major wy_chunk — same rationale as fast_xt_diag_x: stride-1
   736	    // writes alongside stride-1 reads from a row-major Y.
   737	    let mut wy_chunk = Array2::<f64>::zeros((chunk_rows, q));
   738	    let mut out_view = array2_to_matmut(&mut result);
   739	
   740	    let y_is_row_major = y.is_standard_layout();
   741	    let w_slice_opt = w.as_slice();
   742	
   743	    for start in (0..n).step_by(chunk_rows) {
   744	        let rows = (n - start).min(chunk_rows);
   745	        {
   746	            let chunk_slice = wy_chunk
   747	                .as_slice_mut()
   748	                .expect("row-major chunk is contiguous");
   749	            if y_is_row_major && let (Some(y_all), Some(w_all)) = (y.as_slice(), w_slice_opt) {
   750	                for local in 0..rows {
   751	                    let src = start + local;
   752	                    let wi = w_all[src];
   753	                    let src_off = src * q;
   754	                    let dst_off = local * q;
   755	                    let src_row = &y_all[src_off..src_off + q];
   756	                    let dst_row = &mut chunk_slice[dst_off..dst_off + q];
   757	                    for col in 0..q {
   758	                        dst_row[col] = src_row[col] * wi;
   759	                    }
   760	                }
   761	            } else {
   762	                let y_slice = y.slice(s![start..start + rows, ..]);
   763	                for local in 0..rows {
   764	                    let wi = w[start + local];
   765	                    let yrow = y_slice.row(local);
   766	                    let dst_off = local * q;
   767	                    let dst_row = &mut chunk_slice[dst_off..dst_off + q];
   768	                    for (col, yij) in yrow.iter().enumerate() {
   769	                        dst_row[col] = yij * wi;
   770	                    }
   771	                }
   772	            }
   773	        }
   774	        let x_slice = x.slice(s![start..start + rows, ..]);
   775	        let wy_slice = wy_chunk.slice(s![0..rows, ..]);
   776	        let x_view = FaerArrayView::new(&x_slice);
   777	        let wy_view = FaerArrayView::new(&wy_slice);
   778	        let par = matmul_parallelism(px, q, rows);
   779	        matmul(
   780	            out_view.as_mut(),
   781	            Accum::Add,
   782	            x_view.as_ref().transpose(),
   783	            wy_view.as_ref(),
   784	            1.0,
   785	            par,
   786	        );
   787	    }
   788	
   789	    result
   790	}
