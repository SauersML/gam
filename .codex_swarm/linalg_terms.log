   393	fn robust_eighwith_policy<M, V, E, Validate, Sanitize, EigCall, MapErr>(
   394	    matrix: &M,
   395	    context: &str,
   396	    validate_input: Validate,
   397	    sanitize: Sanitize,
   398	    mut eig_call: EigCall,
   399	    map_error: MapErr,
   400	) -> Result<(Vec<f64>, V), EstimationError>
   401	where
   402	    Validate: Fn(&M, &str) -> Result<(), EstimationError>,
   403	    Sanitize: Fn(&M) -> M,
   404	    EigCall: FnMut(&M) -> Result<(Vec<f64>, V), E>,
   405	    MapErr: Fn(E, &str) -> EstimationError,
   406	{
   407	    validate_input(matrix, context)?;
   408	
   409	    // The sanitize step only enforces exact symmetry by averaging M and M^T and
   410	    // zeros sub-eps noise; it never adds a diagonal ridge. Adding ridge changes
   411	    // the matrix being decomposed, which silently changes the optimisation
   412	    // objective downstream. If eigh genuinely fails on a finite symmetric input,
   413	    // surface the error instead of mutating the spectrum.
   414	    let candidate = sanitize(matrix);
   415	    match eig_call(&candidate) {
   416	        Ok((mut eigenvalues, eigenvectors)) => {
   417	            classify_eigenvalues_strict(&mut eigenvalues, context)?;
   418	            Ok((eigenvalues, eigenvectors))
   419	        }
   420	        Err(err) => Err(map_error(err, context)),

