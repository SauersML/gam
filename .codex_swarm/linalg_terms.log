   870	
   871	    fn dense_nbytes(&self) -> Result<usize, String> {
   872	        self.matrix
   873	            .nrows()
   874	            .checked_mul(self.matrix.ncols())
   875	            .and_then(|cells| cells.checked_mul(std::mem::size_of::<f64>()))
   876	            .ok_or_else(|| {
   877	                format!(
   878	                    "dense size overflow for sparse design {}x{}",
   879	                    self.matrix.nrows(),
   880	                    self.matrix.ncols()
   881	                )
   882	            })
   883	    }
   884	
   885	    fn materialize_dense_arc(&self) -> Arc<Array2<f64>> {
   886	        let mut out = Array2::<f64>::zeros((self.matrix.nrows(), self.matrix.ncols()));
   887	        let (symbolic, values) = self.matrix.parts();
   888	        let col_ptr = symbolic.col_ptr();
   889	        let row_idx = symbolic.row_idx();
   890	        for col in 0..self.matrix.ncols() {
   891	            let start = col_ptr[col];
   892	            let end = col_ptr[col + 1];
   893	            for idx in start..end {
   894	                out[[row_idx[idx], col]] += values[idx];
   895	            }
   896	        }
   897	        Arc::new(out)
   898	    }
   899	
   900	    pub fn try_to_dense_arc(&self, context: &str) -> Result<Arc<Array2<f64>>, String> {
   901	        let dense_bytes = self.dense_nbytes()?;
   902	        if dense_bytes > MAX_SPARSE_TO_DENSE_BYTES {
   903	            let gib = dense_bytes as f64 / (1024.0 * 1024.0 * 1024.0);
   904	            return Err(MatrixError::DensificationRefused {
   905	                reason: format!(
   906	                    "{context}: refusing to densify sparse design {}x{} (~{gib:.2} GiB); use sparse or matrix-free code",
   907	                    self.matrix.nrows(),
   908	                    self.matrix.ncols(),
   909	                ),
   910	            }
   911	            .into());
   912	        }
   913	        if dense_bytes <= MAX_PERSISTENT_SPARSE_DENSE_CACHE_BYTES {
   914	            Ok(self
   915	                .dense_cache
   916	                .get_or_init(|| self.materialize_dense_arc())
   917	                .clone())
   918	        } else {
   919	            Ok(self.materialize_dense_arc())
   920	        }
   921	    }
   922	
   923	    pub fn to_dense_arc(&self) -> Arc<Array2<f64>> {
   924	        self.try_to_dense_arc("SparseDesignMatrix::to_dense_arc")
   925	            .unwrap_or_else(|msg| {
   926	                let bt = std::backtrace::Backtrace::force_capture();
   927	                panic!("{msg}\nbacktrace:\n{bt}")
   928	            })
   929	    }
   930	
   931	    pub fn to_csr_arc(&self) -> Option<Arc<SparseRowMat<usize, f64>>> {
   932	        if let Some(cached) = self.csr_cache.get() {
   933	            return Some(cached.clone());
   934	        }
   935	        let csr = self.matrix.as_ref().to_row_major().ok()?;
   936	        let arc = Arc::new(csr);
   937	        self.csr_cache.set(arc.clone()).ok();
   938	        Some(arc)
   939	    }
   940	}
