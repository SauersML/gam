  8048	            (phi, phi_r, phi_rr, ratio)
  8049	        }
  8050	    };
  8051	
  8052	    if !phi.is_finite() || !phi_r.is_finite() || !phi_rr.is_finite() || !phi_r_over_r.is_finite() {
  8053	        return Err(BasisError::InvalidInput(format!(
  8054	            "non-finite Matérn radial derivatives at r={r}, length_scale={length_scale}, nu={nu:?}"
