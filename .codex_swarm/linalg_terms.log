 21150	///
 21151	/// These provide the "center" of support for each basis function and are used
 21152	/// for geometric constraints that don't depend on observed data. A key property
 21153	/// is that a linear function f(x) = a + bx has B-spline coefficients c_j = a + b·G_j,
 21154	/// so constraining coefficients to be orthogonal to [1, G] removes linear functions
 21155	/// from the representable space.
 21156	///
 21157	/// # Arguments
 21158	/// * `knot_vector` - Full knot vector including boundary repetitions
 21159	/// * `degree` - B-spline degree (typically 3 for cubic)
 21160	///
 21161	/// # Returns
 21162	/// Array of Greville abscissae, one per basis function (length = n_knots - degree - 1)
 21163	///
 21164	/// # Errors
 21165	/// Returns error if knot vector is too short or Greville abscissae are degenerate.
 21166	pub fn compute_greville_abscissae(
 21167	    knot_vector: &Array1<f64>,
 21168	    degree: usize,
 21169	) -> Result<Array1<f64>, BasisError> {
 21170	    let n_knots = knot_vector.len();
 21171	    if degree == 0 {
 21172	        // For degree 0, Greville abscissae are knot midpoints
 21173	        let n_basis = n_knots.saturating_sub(1);
 21174	        if n_basis == 0 {
 21175	            return Err(BasisError::InsufficientColumnsForConstraint { found: 0 });
 21176	        }
 21177	        let mut g = Array1::<f64>::zeros(n_basis);
 21178	        for j in 0..n_basis {
 21179	            g[j] = 0.5 * (knot_vector[j] + knot_vector[j + 1]);
 21180	        }
 21181	        return Ok(g);
 21182	    }
 21183	
 21184	    // Number of basis functions: k = n_knots - degree - 1
 21185	    if n_knots <= degree + 1 {
 21186	        return Err(BasisError::InsufficientColumnsForConstraint {
 21187	            found: n_knots.saturating_sub(degree + 1),
 21188	        });
 21189	    }
 21190	    let n_basis = n_knots - degree - 1;
 21191	
 21192	    let mut g = Array1::<f64>::zeros(n_basis);
 21193	    let d_inv = 1.0 / (degree as f64);
 21194	
 21195	    for j in 0..n_basis {
 21196	        // G_j = (1/d) × Σ_{k=1}^{d} t_{j+k}
 21197	        let mut sum = 0.0;
 21198	        for k in 1..=degree {
 21199	            sum += knot_vector[j + k];
 21200	        }
 21201	        g[j] = sum * d_inv;
 21202	    }
 21203	
 21204	    // Check for degeneracy (all Greville abscissae equal)
 21205	    let g_min = g.iter().cloned().fold(f64::INFINITY, f64::min);
 21206	    let g_max = g.iter().cloned().fold(f64::NEG_INFINITY, f64::max);
 21207	    if (g_max - g_min) < 1e-10 {
 21208	        return Err(BasisError::DegenerateKnots);
 21209	    }
 21210	
 21211	    Ok(g)
 21212	}
