  1506	            return Err(BasisError::InvalidInput(format!(
  1507	                "unsupported periodic spline derivative order {derivative_order}; only 0, 1, and 2 are supported"
  1508	            )));
  1509	        }
  1510	        if u.iter().any(|v| !v.is_finite()) {
  1511	            return Err(BasisError::InvalidInput(
  1512	                "periodic spline evaluation points must be finite".to_string(),
  1513	            ));
  1514	        }
  1515	
  1516	        let n = self.sites.len();
  1517	        let d = self.ambient_dim();
  1518	        let mut out = Array2::<f64>::zeros((u.len(), d));
  1519	        for (row, &raw) in u.iter().enumerate() {
  1520	            let x_wrapped = wrap_periodic_spline_coordinate(raw, self.options);
  1521	            let i = periodic_spline_interval_index(self.sites.view(), x_wrapped);
  1522	            let j = if i + 1 == n { 0 } else { i + 1 };
  1523	            let x_i = self.sites[i];
  1524	            let h = if i + 1 == n {
  1525	                self.sites[0] + self.options.period - x_i
  1526	            } else {
  1527	                self.sites[i + 1] - x_i
  1528	            };
