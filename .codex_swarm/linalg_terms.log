   424	pub(crate) fn robust_eigh_faer(
   425	    matrix: &Mat<f64>,
   426	    side: Side,
   427	    context: &str,
   428	) -> Result<(Vec<f64>, Mat<f64>), EstimationError> {
   429	    robust_eighwith_policy(
   430	        matrix,
   431	        context,
   432	        |mat, ctx| {
   433	            let (rows, cols) = mat.as_ref().shape();
   434	            for i in 0..rows {
   435	                for j in 0..cols {
   436	                    let val = mat[(i, j)];
   437	                    if !val.is_finite() {
   438	                        let max_abs = mat_max_abs_element(mat.as_ref());
   439	                        return Err(EstimationError::InvalidInput(format!(
   440	                            "{} contains non-finite entries (max finite magnitude {:.3e})",
   441	                            ctx, max_abs
   442	                        )));
   443	                    }
   444	                }
   445	            }
   446	            Ok(())
   447	        },
   448	        sanitize_symmetric_faer,
   449	        |candidate| {
   450	            let eig = candidate.as_ref().self_adjoint_eigen(side)?;
   451	            let diag = eig.S();
   452	            let mut eigenvalues = Vec::with_capacity(diag.dim());
   453	            for idx in 0..diag.dim() {
   454	                eigenvalues.push(diag[idx]);
   455	            }
   456	
   457	            let vectors_ref = eig.U();
   458	            let mut eigenvectors = Mat::<f64>::zeros(vectors_ref.nrows(), vectors_ref.ncols());
   459	            for i in 0..vectors_ref.nrows() {
   460	                for j in 0..vectors_ref.ncols() {
   461	                    eigenvectors[(i, j)] = vectors_ref[(i, j)];
   462	                }
   463	            }
   464	            Ok((eigenvalues, eigenvectors))
   465	        },
   466	        |err, _ctx| {
   467	            EstimationError::EigendecompositionFailed(FaerLinalgError::SelfAdjointEigen(err))
   468	        },
   469	    )
   470	}
