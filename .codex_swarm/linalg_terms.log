   689	            );
   690	        }
   691	    }
   692	
   693	    // Mirror the accumulated lower triangle into the upper triangle so callers
   694	    // see the full symmetric matrix.
   695	    mirror_lower_to_upper(&mut result);
   696	    result
   697	}
