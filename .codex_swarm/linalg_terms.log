   988	                            x,
   989	                            degree,
   990	                            knotview,
   991	                            eval_kind,
   992	                            num_basis_functions,
   993	                            scratch,
   994	                            values,
   995	                            |col_j, v| row_slice[col_j] = v,
   996	                        );
   997	                    },
   998	                );
   999	        } else {
  1000	            let mut scratch = BasisEvalScratch::new(degree);
  1001	            let mut values = vec![0.0; support];
