  1568	fn validate_periodic_spline_1d_options(options: PeriodicSpline1DOptions) -> Result<(), BasisError> {
  1569	    if !options.period.is_finite() || options.period <= 0.0 {
  1570	        return Err(BasisError::InvalidInput(format!(
  1571	            "periodic spline period must be finite and positive; got {}",
  1572	            options.period
  1573	        )));
  1574	    }
  1575	    if !options.origin.is_finite() {
  1576	        return Err(BasisError::InvalidInput(
  1577	            "periodic spline origin must be finite".to_string(),
  1578	        ));
  1579	    }
  1580	    if !options.duplicate_tolerance.is_finite() || options.duplicate_tolerance < 0.0 {
  1581	        return Err(BasisError::InvalidInput(
  1582	            "periodic spline duplicate_tolerance must be finite and non-negative".to_string(),
  1583	        ));
  1584	    }
  1585	    Ok(())
  1586	}
