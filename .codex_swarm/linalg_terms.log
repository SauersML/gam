   711	fn evaluate_splines_derivative_sparse_intowith_lower(
   712	    x: f64,
   713	    degree: usize,
   714	    knotview: ArrayView1<f64>,
   715	    values: &mut [f64],
   716	    basis_scratch: &mut internal::BsplineScratch,
   717	    lowervalues: &mut [f64],
   718	    lower_scratch: &mut internal::BsplineScratch,
   719	) -> usize {
   720	    let num_basis = knotview.len().saturating_sub(degree + 1);
