   619	pub fn solve_spd_pcg<F>(
   620	    apply: F,
   621	    rhs: &Array1<f64>,
   622	    preconditioner_diag: &Array1<f64>,
   623	    rel_tol: f64,
   624	    max_iter: usize,
   625	) -> Option<Array1<f64>>
   626	where
   627	    F: Fn(&Array1<f64>) -> Array1<f64>,
   628	{
   629	    solve_spd_pcg_with_info(apply, rhs, preconditioner_diag, rel_tol, max_iter)
   630	        .map(|(solution, _)| solution)
   631	}
   632	
   633	/// Write-into variant of `solve_spd_pcg_with_info` that takes an apply closure
   634	/// of the form `Fn(&Array1<f64>, &mut Array1<f64>)` so the matvec can write into
   635	/// a caller-owned buffer. This eliminates the per-iteration `Array1::<f64>`
   636	/// allocation for the matvec result that the legacy closure-returning variant
   637	/// forces. See commit 83369abb for the analogous penalty-vector elimination.
   638	pub fn solve_spd_pcg_with_info_into<F>(
   639	    apply: F,
   640	    rhs: &Array1<f64>,
   641	    preconditioner_diag: &Array1<f64>,
   642	    rel_tol: f64,
   643	    max_iter: usize,
   644	) -> Option<(Array1<f64>, PcgSolveInfo)>
   645	where
   646	    F: Fn(&Array1<f64>, &mut Array1<f64>),
   647	{
   648	    let p = rhs.len();
   649	    if p == 0 || preconditioner_diag.len() != p || max_iter == 0 {
   650	        return None;
   651	    }
   652	    let rhs_norm = rhs.dot(rhs).sqrt();
   653	    if !rhs_norm.is_finite() {
   654	        return None;
   655	    }
   656	    if rhs_norm == 0.0 {
   657	        return Some((
   658	            Array1::<f64>::zeros(p),
   659	            PcgSolveInfo {
   660	                iterations: 0,
   661	                converged: true,
   662	                relative_residual_norm: 0.0,
   663	                initial_residual_norm: 0.0,
   664	                final_residual_norm: 0.0,
   665	                residual_reduction: 0.0,
   666	                condition_estimate: None,
   667	            },
   668	        ));
   669	    }
   670	
   671	    let tol = rel_tol.max(1e-12) * rhs_norm.max(1.0);
   672	    let mut x = Array1::<f64>::zeros(p);
   673	    let mut r = rhs.clone();
   674	    let mut diagnostics = PcgDiagnostics::new(rhs_norm);
   675	
   676	    if preconditioner_diag
   677	        .iter()
   678	        .any(|&m| !m.is_finite() || m <= 0.0)
   679	    {
   680	        return None;
   681	    }
   682	    let mut inv_m = Array1::<f64>::zeros(p);
   683	    Zip::from(&mut inv_m)
   684	        .and(preconditioner_diag)
   685	        .par_for_each(|inv, &m| {
   686	            *inv = 1.0 / m.max(1e-12);
   687	        });
   688	
   689	    let mut z = Array1::<f64>::zeros(p);
   690	    Zip::from(&mut z)
   691	        .and(&r)
   692	        .and(&inv_m)
   693	        .par_for_each(|zi, &ri, &im| {
   694	            *zi = ri * im;
   695	        });
   696	    let mut p_dir = z.clone();
   697	    let mut rz_old = r.dot(&z);
   698	    if !rz_old.is_finite() || rz_old <= 0.0 {
   699	        return None;
   700	    }
   701	
   702	    // Reusable matvec scratch (filled by `apply`).
   703	    let mut ap = Array1::<f64>::zeros(p);
   704	
   705	    for iter in 0..max_iter {
   706	        apply(&p_dir, &mut ap);
   707	        if ap.len() != p {
   708	            return None;
   709	        }
   710	        let denom = p_dir.dot(&ap);
   711	        if !denom.is_finite() || denom <= 0.0 {
   712	            return None;
   713	        }
   714	        let alpha = rz_old / denom;
   715	        if !alpha.is_finite() {
   716	            return None;
   717	        }
   718	        x.scaled_add(alpha, &p_dir);
   719	        r.scaled_add(-alpha, &ap);
   720	        if (iter + 1) % 32 == 0 {
   721	            // Periodic residual refresh: r <- rhs - A x. Reuse `ap` as scratch
   722	            // for A x to avoid an extra allocation.
   723	            apply(&x, &mut ap);
   724	            if ap.len() != p {
   725	                return None;
   726	            }
   727	            r.assign(rhs);
   728	            r.scaled_add(-1.0, &ap);
   729	        }
   730	        let r_norm = r.dot(&r).sqrt();
   731	        if r_norm.is_finite() && r_norm <= tol {
   732	            diagnostics.push_iteration(alpha, None, r_norm);
   733	            return x
   734	                .iter()
   735	                .all(|v| v.is_finite())
   736	                .then_some((x, diagnostics.info(iter + 1, true, rhs_norm, r_norm)));
   737	        }
   738	        Zip::from(&mut z)
   739	            .and(&r)
   740	            .and(&inv_m)
   741	            .par_for_each(|zi, &ri, &im| {
   742	                *zi = ri * im;
   743	            });
   744	        let rz_new = r.dot(&z);
   745	        if !rz_new.is_finite() || rz_new <= 0.0 {
   746	            return None;
   747	        }
   748	        let beta = rz_new / rz_old;
   749	        if !beta.is_finite() {
   750	            return None;
   751	        }
   752	        diagnostics.push_iteration(alpha, Some(beta), r_norm);
   753	        Zip::from(&mut p_dir).and(&z).par_for_each(|pi, &zi| {
   754	            *pi = zi + beta * *pi;
   755	        });
   756	        rz_old = rz_new;
   757	    }
   758	    None
   759	}
