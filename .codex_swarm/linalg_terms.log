 10088	pub(crate) fn closed_form_anisotropic_pair_value_with_powers(
 10089	    q: usize,
 10090	    m: usize,
 10091	    s: usize,
 10092	    kappa: f64,
 10093	    eta_raw: &[f64],
 10094	    powers: &closed_form_penalty::AnisoMetricPowers,
 10095	    r: &[f64],
 10096	    diagonal_epsilon: f64,
 10097	) -> f64 {
 10098	    assert_eq!(
 10099	        eta_raw.len(),
 10100	        r.len(),
 10101	        "closed_form_anisotropic_pair_value_with_powers: eta/r dimension mismatch"
 10102	    );
 10103	    let j_prefactor = eta_raw.iter().sum::<f64>().exp();
 10104	    if r.iter().all(|&value| value == 0.0) {
 10105	        // Exact distributional diagonal first. In the convergent spectral
 10106	        // strip the radial pointwise chain is singular at R=0, but the
 10107	        // self-pair integral is finite and has a Gamma/Beta closed form.
 10108	        // Outside that strip, odd-d hybrid Taylor covers the smooth pointwise
 10109	        // diagonal; epsilon regularization is only the final non-convergent
 10110	        // diagonal convention.
 10111	        if let Some(bundle) =
 10112	            closed_form_penalty::analytic_self_pair_bundle(q, m, s, kappa, eta_raw)
 10113	        {
 10114	            return bundle.value;
 10115	        }
 10116	        let mut r_eps_buf = vec![0.0_f64; r.len()];
 10117	        if !r_eps_buf.is_empty() {
 10118	            r_eps_buf[0] = diagonal_epsilon * eta_raw[0].exp();
 10119	        }
 10120	        return j_prefactor
 10121	            * closed_form_penalty::anisotropic_duchon_penalty_radial_with_powers(
 10122	                q, m, s as f64, kappa, eta_raw, powers, &r_eps_buf,
 10123	            );
 10124	    }
 10125	
 10126	    j_prefactor
 10127	        * closed_form_penalty::anisotropic_duchon_penalty_radial_with_powers(
 10128	            q, m, s as f64, kappa, eta_raw, powers, r,
 10129	        )
 10130	}
