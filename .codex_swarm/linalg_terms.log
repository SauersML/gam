  1230	fn is_effectively_uniform_knot_geometry(knot_vector: &Array1<f64>, degree: usize) -> bool {
  1231	    if knot_vector.len() <= degree + 2 {
  1232	        return true;
  1233	    }
  1234	
  1235	    let min_k = knot_vector[0];
  1236	    let max_k = knot_vector[knot_vector.len() - 1];
  1237	    let scale = (max_k - min_k).abs().max(1.0);
  1238	    let tol = 1e-10 * scale;
  1239	
  1240	    // Any repeated interior knot (beyond clamped boundaries) implies irregular geometry.
  1241	    let mut left = 0usize;
  1242	    while left + 1 < knot_vector.len() && (knot_vector[left + 1] - min_k).abs() <= tol {
  1243	        left += 1;
  1244	    }
  1245	    let mut right = knot_vector.len() - 1;
  1246	    while right > 0 && (knot_vector[right - 1] - max_k).abs() <= tol {
  1247	        right -= 1;
  1248	    }
  1249	    if right > left + 1 {
  1250	        for i in (left + 1)..=right {
  1251	            if (knot_vector[i] - knot_vector[i - 1]).abs() <= tol {
  1252	                return false;
  1253	            }
  1254	        }
  1255	    }
  1256	
  1257	    let mut breakpoints = Vec::<f64>::with_capacity(knot_vector.len());
  1258	    for &k in knot_vector {
  1259	        if breakpoints
  1260	            .last()
  1261	            .map(|last| (k - *last).abs() > tol)
  1262	            .unwrap_or(true)
  1263	        {
  1264	            breakpoints.push(k);
  1265	        }
  1266	    }
  1267	
  1268	    if breakpoints.len() <= 2 {
  1269	        return true;
  1270	    }
  1271	
  1272	    let h0 = breakpoints[1] - breakpoints[0];
  1273	    for i in 2..breakpoints.len() {
  1274	        let hi = breakpoints[i] - breakpoints[i - 1];
  1275	        if (hi - h0).abs() > 1e-8 * scale {
  1276	            return false;
  1277	        }
  1278	    }
  1279	    true
  1280	}
