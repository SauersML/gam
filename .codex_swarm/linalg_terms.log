   338	/// Strict spectral classifier used as a final guard on penalty eigendecompositions.
   339	///
   340	/// Penalty matrices fed to the GAM solver are required to be PSD by construction.
   341	/// This routine snaps roundoff-zero eigenvalues to exact zero, accepts strictly
   342	/// positive eigenvalues, and rejects materially-indefinite or non-finite spectra
   343	/// with a hard error rather than silently rewriting them. The previous behaviour
   344	/// (mass-zeroing negative or non-finite eigenvalues) hid construction bugs and
   345	/// changed the optimisation objective downstream.
   346	///
   347	/// `C_EPS_P_FACTOR = 64` chooses the multiplier `c` in
   348	/// `tol = c * eps_machine * p * scale`: 64 absorbs the rounding accumulated in a
   349	/// symmetric eigendecomposition of a moderate-dimension matrix while still
   350	/// rejecting the 1e-12 * scale magnitudes that previously slipped through.
   351	fn classify_eigenvalues_strict(
   352	    eigenvalues: &mut [f64],
   353	    context: &str,
   354	) -> Result<(), EstimationError> {
   355	    const C_EPS_P_FACTOR: f64 = 64.0;
   356	    let p = eigenvalues.len();
   357	
   358	    let mut scale = 0.0_f64;
   359	    for (idx, &val) in eigenvalues.iter().enumerate() {
   360	        if !val.is_finite() {
   361	            return Err(EstimationError::PenaltySpectrumNonFinite {
   362	                context: context.to_string(),
   363	                index: idx,
   364	                value: val,
   365	            });
   366	        }
   367	        scale = scale.max(val.abs());
   368	    }
   369	
   370	    // p * eps captures the rounding floor of a symmetric eigendecomposition of a
   371	    // p-dimensional matrix; multiplying by `scale` lifts the floor to the actual
   372	    // magnitude of the spectrum. The constant `C_EPS_P_FACTOR` provides headroom
   373	    // for the residual rounding in subsequent matmuls.
   374	    let tolerance =
   375	        (C_EPS_P_FACTOR * f64::EPSILON * (p.max(1) as f64) * scale).max(f64::MIN_POSITIVE);
   376	
   377	    for (idx, val) in eigenvalues.iter_mut().enumerate() {
   378	        if val.abs() <= tolerance {
   379	            *val = 0.0;
   380	        } else if *val < 0.0 {
   381	            return Err(EstimationError::PenaltySpectrumIndefinite {
   382	                context: context.to_string(),
   383	                index: idx,
   384	                value: *val,
   385	                tolerance,
   386	                scale,
   387	            });
   388	        }
   389	    }
   390	    Ok(())
   391	}
