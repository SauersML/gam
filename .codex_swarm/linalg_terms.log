  1118	impl SimplicialFactor {
  1119	    /// Reconstruct the original-order dense SPD matrix represented by this
  1120	    /// permuted sparse Cholesky factor.
  1121	    ///
  1122	    /// The simplicial factor stores `L` for `P H Pᵀ = L Lᵀ`, with
  1123	    /// `perm_inv[original] = permuted`. We first assemble the dense permuted
  1124	    /// product and then map rows/columns back to the caller's coordinate order.
  1125	    fn assemble_h_dense_original_order(&self) -> Result<Array2<f64>, EstimationError> {
  1126	        if self.perm_inv.len() != self.n {
  1127	            return Err(EstimationError::InvalidInput(format!(
  1128	                "simplicial factor permutation length {} does not match dimension {}",
  1129	                self.perm_inv.len(),
  1130	                self.n
  1131	            )));
  1132	        }
  1133	        let mut h_permuted = Array2::<f64>::zeros((self.n, self.n));
  1134	        for col in 0..self.n {
  1135	            let start = self.l_col_ptr[col];
  1136	            let end = self.l_col_ptr[col + 1];
  1137	            for left_idx in start..end {
  1138	                let left_row = self.l_row_idx[left_idx];
  1139	                let left_value = self.l_values[left_idx];
  1140	                if !left_value.is_finite() {
  1141	                    return Err(EstimationError::InvalidInput(format!(
  1142	                        "simplicial factor has non-finite L entry at value index {left_idx}"
  1143	                    )));
  1144	                }
  1145	                for right_idx in start..end {
  1146	                    let right_row = self.l_row_idx[right_idx];
  1147	                    let right_value = self.l_values[right_idx];
  1148	                    h_permuted[[left_row, right_row]] += left_value * right_value;
  1149	                }
  1150	            }
  1151	        }
  1152	
  1153	        let mut h_original = Array2::<f64>::zeros((self.n, self.n));
  1154	        for i in 0..self.n {
  1155	            let pi = self.perm_inv[i];
  1156	            if pi >= self.n {
  1157	                return Err(EstimationError::InvalidInput(format!(
  1158	                    "simplicial factor permutation maps row {i} to out-of-bounds index {pi}"
  1159	                )));
  1160	            }
  1161	            for j in 0..self.n {
  1162	                let pj = self.perm_inv[j];
  1163	                if pj >= self.n {
  1164	                    return Err(EstimationError::InvalidInput(format!(
  1165	                        "simplicial factor permutation maps column {j} to out-of-bounds index {pj}"
  1166	                    )));
  1167	                }
  1168	                let value = h_permuted[[pi, pj]];
  1169	                if !value.is_finite() {
  1170	                    return Err(EstimationError::InvalidInput(
  1171	                        "dense reconstruction from sparse Cholesky produced non-finite values"
  1172	                            .to_string(),
  1173	                    ));
  1174	                }
  1175	                h_original[[i, j]] = value;
  1176	            }
  1177	        }
  1178	        Ok(h_original)
  1179	    }
  1180	}
