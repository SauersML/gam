  1244	        for row in (0..n).rev() {
  1245	            let col_start = col_ptr[row];
  1246	            let col_end = col_ptr[row + 1];
  1247	            let mut sum = forward[row];
  1248	            let l_rr = l_values[col_start];
  1249	            for idx in (col_start + 1)..col_end {
  1250	                let lower_row = row_idx[idx];
  1251	                sum -= l_values[idx] * solution[lower_row];
  1252	            }
