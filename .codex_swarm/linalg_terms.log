   278	        for (idx, &ev) in evals.iter().enumerate() {
   279	            if !ev.is_finite() || ev <= 0.0 {
   280	                return Err(format!(
   281	                    "ClosedFormPenaltyOperator expected SPD S+λI, eigenvalue {idx} is {ev:.3e}"
   282	                ));
   283	            }
