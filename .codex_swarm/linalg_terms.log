   194	/// Compute A^T * A using faer's SIMD-optimized GEMM.
   195	/// This is MUCH faster than ndarray's .t().dot() for matrices where n > ~100.
   196	///
   197	/// For a matrix A of shape (n, p), this computes the (p, p) result.
   198	/// Uses zero-copy view when possible, falls back to copy for non-contiguous arrays.
   199	#[inline]
   200	pub fn fast_ata<S: Data<Elem = f64>>(a: &ArrayBase<S, Ix2>) -> Array2<f64> {
   201	    let p = a.ncols();
   202	    let mut out = Array2::<f64>::zeros((p, p));
