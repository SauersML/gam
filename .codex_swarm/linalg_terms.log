 20175	/// Pick Duchon parameters for the TPS auto-promotion at infeasible (d, k).
 20176	/// Returns `Some((nullspace_order, power))` when a hybrid-Duchon spec exists
 20177	/// satisfying the collocation gate `2(p + s) > d + max_op` for max_op = 2
 20178	/// (default operator penalties: mass + tension + stiffness). The hybrid
 20179	/// kernel (Matern-blended) sidesteps the pure-Duchon `2s < d` gate, leaving
 20180	/// only the collocation/spectral-existence condition.
 20181	///
 20182	/// Strategy: prefer Linear nullspace (M' = d+1) so the polynomial trend
 20183	/// retains the affine span; fall back to Zero (M' = 1) when k < d+1. The
 20184	/// smallest admissible s in each case gives the most TPS-like behavior
 20185	/// (largest spectral roughness for a given polynomial nullspace).
 20186	fn duchon_thin_plate_fallback_params(
 20187	    dimension: usize,
 20188	    num_centers: usize,
 20189	) -> Option<(DuchonNullspaceOrder, usize)> {
 20190	    let d = dimension;
 20191	    let max_op = 2usize; // mass + tension + stiffness collocation
 20192	    for (order, p, m_poly) in [
 20193	        (DuchonNullspaceOrder::Linear, 2usize, d + 1),
 20194	        (DuchonNullspaceOrder::Zero, 1usize, 1usize),
 20195	    ] {
 20196	        if num_centers < m_poly {
 20197	            continue;
 20198	        }
 20199	        // Smallest integer s with 2(p + s) > d + max_op.
 20200	        let target = d + max_op;
 20201	        let s_min = if 2 * p > target {
 20202	            0
 20203	        } else {
 20204	            (target - 2 * p) / 2 + 1
 20205	        };
 20206	        return Some((order, s_min));
 20207	    }
 20208	    None
 20209	}
