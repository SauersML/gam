    86	impl ClosedFormPenaltyOperator {
    87	    /// Build an operator with the same closed-form parameters that
    88	    /// `basis::closed_form_operator_penalty_in_total_basis` consumes.
    89	    pub fn new(
    90	        centers: ArrayView2<'_, f64>,
    91	        q: usize,
    92	        m: usize,
    93	        s: usize,
    94	        kappa: f64,
    95	        aniso_log_scales: Option<&[f64]>,
    96	        kernel_nullspace: Option<&Array2<f64>>,
    97	        polynomial_block_cols: usize,
    98	        outer_identifiability: Option<&Array2<f64>>,
    99	    ) -> Self {
   100	        let d = centers.ncols();
   101	        let eta_raw: Vec<f64> = if let Some(eta) = aniso_log_scales {
   102	            assert_eq!(
   103	                eta.len(),
   104	                d,
   105	                "ClosedFormPenaltyOperator::new: eta dimension mismatch"
   106	            );
   107	            eta.to_vec()
   108	        } else {
   109	            vec![0.0_f64; d]
   110	        };
