  1480	/// Lambda-independent reparameterization invariants derived from penalty structure.
  1481	#[derive(Clone)]
  1482	struct SubspaceSplit {
  1483	    q_pen: Array2<f64>,
  1484	    q_null: Array2<f64>,
  1485	}
  1486	
  1487	impl SubspaceSplit {
  1488	    fn identity(p: usize) -> Self {
  1489	        Self {
  1490	            q_pen: Array2::zeros((p, 0)),
  1491	            q_null: Array2::eye(p),
  1492	        }
  1493	    }
  1494	
  1495	    fn from_ordered_qs(
  1496	        qs: &Mat<f64>,
  1497	        penalized_rank: usize,
  1498	        p: usize,
  1499	    ) -> Result<Self, EstimationError> {
  1500	        if qs.nrows() != p || qs.ncols() != p {
  1501	            return Err(EstimationError::LayoutError(format!(
  1502	                "Invalid Q basis dimensions: expected {p}x{p}, got {}x{}",
  1503	                qs.nrows(),
  1504	                qs.ncols()
  1505	            )));
  1506	        }
  1507	        if penalized_rank > p {
  1508	            return Err(EstimationError::LayoutError(format!(
  1509	                "Invalid penalized rank {penalized_rank} for p={p}"
  1510	            )));
  1511	        }
  1512	
  1513	        let null_count = p - penalized_rank;
  1514	        let mut q_pen = Array2::<f64>::zeros((p, penalized_rank));
  1515	        let mut q_null = Array2::<f64>::zeros((p, null_count));
  1516	        for i in 0..p {
  1517	            for j in 0..penalized_rank {
  1518	                q_pen[(i, j)] = qs[(i, j)];
  1519	            }
  1520	            for j in 0..null_count {
  1521	                q_null[(i, j)] = qs[(i, penalized_rank + j)];
  1522	            }
  1523	        }
  1524	
  1525	        Ok(Self { q_pen, q_null })
  1526	    }
  1527	
  1528	    fn rank(&self) -> usize {
  1529	        self.q_pen.ncols()
  1530	    }
  1531	
  1532	    fn p(&self) -> usize {
  1533	        self.q_pen.nrows()
  1534	    }
  1535	
  1536	    fn compose_qs(&self) -> Array2<f64> {
  1537	        let p = self.p();
  1538	        let rank = self.rank();
  1539	        let null_count = self.q_null.ncols();
  1540	        let mut qs = Array2::<f64>::zeros((p, p));
  1541	        for i in 0..p {
  1542	            for j in 0..rank {
  1543	                qs[(i, j)] = self.q_pen[(i, j)];
  1544	            }
  1545	            for j in 0..null_count {
  1546	                qs[(i, rank + j)] = self.q_null[(i, j)];
  1547	            }
  1548	        }
  1549	        qs
  1550	    }
  1551	}
