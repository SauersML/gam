   133	#[inline]
   134	fn should_use_faer_matmul(m: usize, n: usize, k: usize) -> bool {
   135	    // Small, centralized dispatch policy:
   136	    // - stay on ndarray for tiny products to avoid setup overhead,
   137	    // - switch to faer GEMM/GEMV for moderate+ sizes.
   138	    const MIN_DIM: usize = 32;
   139	    const MIN_FLOP_SCALE: usize = 64 * 64;
   140	    (m >= MIN_DIM || n >= MIN_DIM || k >= MIN_DIM)
   141	        && m.saturating_mul(n).saturating_mul(k) >= MIN_FLOP_SCALE
   142	}
   143	
   144	#[inline]
   145	pub(crate) fn matmul_parallelism(m: usize, n: usize, k: usize) -> Par {
   146	    // Prefer a work-based policy over per-dimension thresholds.
   147	    // Tall/skinny products (e.g. N x p with large N, modest p) should still
   148	    // parallelize when total work is high.
   149	    const PAR_MIN_FLOP_SCALE: usize = 2_000_000;
   150	    const PAR_MIN_LONG_DIM: usize = 256;
   151	    let flop_scale = m.saturating_mul(n).saturating_mul(k);
   152	    let long_dim = m.max(n).max(k);
   153	    if flop_scale >= PAR_MIN_FLOP_SCALE && long_dim >= PAR_MIN_LONG_DIM {
   154	        get_global_parallelism()
   155	    } else {
   156	        Par::Seq
   157	    }
   158	}
