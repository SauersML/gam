  8205	                + (3.0 / 7.0) * a * a
  8206	                + (2.0 / 21.0) * a * a * a
  8207	                + (1.0 / 105.0) * a * a * a * a)
  8208	                * e;
  8209	            let q = -(s * s / 105.0) * (a * a * a + 6.0 * a * a + 15.0 * a + 15.0) * e;
  8210	            let t = (s * s * s * s / 105.0) * (a * a + 3.0 * a + 3.0) * e;
  8211	            (phi, q, t)
  8212	        }
  8213	    };
  8214	
  8215	    if !phi.is_finite() || !q.is_finite() || !t.is_finite() {
  8216	        return Err(BasisError::InvalidInput(format!(
  8217	            "non-finite Matérn aniso radial scalars at r={r}, length_scale={length_scale}, nu={nu:?}"
  8218	        )));
  8219	    }
  8220	    Ok((phi, q, t))
  8221	}
  8222	
  8223	/// Extended radial scalars for exact per-axis eta_a derivatives of the Matérn
  8224	/// operator collocation matrices D1 (gradient) and D2 (full Hessian).
  8225	///
  8226	/// Returns `(phi, q, t, dt_dr, d2t_dr2)` where:
  8227	///   - phi   = φ(r)                  (kernel value)
  8228	///   - q     = φ'(r)/r               (used in D₁)
  8229	///   - t     = (phi''(r) - q) / r^2  (Hessian mixed-curvature scalar)
  8230	///   - dt_dr = dt/dr                 (needed for second eta-derivatives)
  8231	///   - d2t_dr2 = d2t/dr2             (needed for second eta-derivatives)
  8232	///
  8233	/// At r = 0 (center collision), the function returns zeros for all quantities
  8234	/// that would be multiplied by s_a (which also vanishes at collision).
  8235	///
  8236	/// For ν = 1/2 and ν = 3/2 where t and/or dt_dr diverge at r = 0, the
  8237	/// collision entries are safe because D₁ and D₂ derivatives at coincident
  8238	/// centers vanish via s_a = 0.
  8239	fn matern_aniso_extended_radial_scalars(
  8240	    r: f64,
  8241	    length_scale: f64,
  8242	    nu: MaternNu,
  8243	) -> Result<(f64, f64, f64, f64, f64), BasisError> {
  8244	    if !r.is_finite() || r < 0.0 {
  8245	        return Err(BasisError::InvalidInput(
  8246	            "Matérn extended radial scalar distance must be finite and non-negative".to_string(),
  8247	        ));
  8248	    }
  8249	    if !length_scale.is_finite() || length_scale <= 0.0 {
  8250	        return Err(BasisError::InvalidInput(
  8251	            "Matérn length_scale must be finite and positive".to_string(),
  8252	        ));
  8253	    }
  8254	
  8255	    match nu {
  8256	        // ----------------------------------------------------------------
  8257	        // ν = 1/2:  φ = exp(-a), a = r / ℓ, s = 1/ℓ
  8258	        //   q = -s·E/r  (diverges at r=0)
  8259	        //   t = (s²E - q) / r²  (diverges at r=0)
  8260	        //   At r=0 all products with s_a vanish, so return 0 for dt_dr, d2t_dr2.
  8261	        // ----------------------------------------------------------------
  8262	        MaternNu::Half => {
  8263	            let s = 1.0 / length_scale;
  8264	            let a = s * r;
  8265	            let e = (-a).exp();
  8266	            let phi = e;
  8267	            if r < 1e-14 {
  8268	                // Collision: q diverges but s_a = 0 ⇒ products vanish.
  8269	                return Ok((phi, 0.0, 0.0, 0.0, 0.0));
  8270	            }
  8271	            let q = -s * e / r;
  8272	            let phi_rr = s * s * e;
  8273	            let t = (phi_rr - q) / (r * r);
  8274	            // t' from: t = f/r² where f = φ'' - q.
  8275	            //   f'  = φ''' - q' = -s³E - t·r   (since q' = t·r)
  8276	            //   t'  = (f' - 2t·r) / r²  = (-s³E - 3t·r) / r²
  8277	            let dt_dr = (-s * s * s * e - 3.0 * t * r) / (r * r);
  8278	            // t'' from: t' = g/r² where g = -s³E - 3tr.
  8279	            //   g' = s⁴E - 3(t'r + t)
  8280	            //   t'' = (g' - 2t'r) / r² = (s⁴E - 3t'r - 3t - 2t'r) / r²
  8281	            //        = (s⁴E - 5t'r - 3t) / r²
  8282	            let d2t_dr2 = (s.powi(4) * e - 5.0 * dt_dr * r - 3.0 * t) / (r * r);
  8283	            Ok((phi, q, t, dt_dr, d2t_dr2))
  8284	        }
  8285	        // ----------------------------------------------------------------
  8286	        // ν = 3/2:  φ = (1 + a)E, a = √3·r/ℓ, s = √3/ℓ
  8287	        //   q  = -s²E         (finite at r=0)
  8288	        //   t  = s³E/r        (diverges at r=0)
  8289	        //   dt/dr = s³E(-sr - 1)/r²  (diverges at r=0)
  8290	        //   At r=0, s_a = 0 so all products vanish.
  8291	        // ----------------------------------------------------------------
  8292	        MaternNu::ThreeHalves => {
  8293	            let s = 3.0_f64.sqrt() / length_scale;
  8294	            let a = s * r;
  8295	            let e = (-a).exp();
  8296	            let phi = (1.0 + a) * e;
  8297	            let q = -s * s * e;
  8298	            if r < 1e-14 {
  8299	                return Ok((phi, q, 0.0, 0.0, 0.0));
  8300	            }
  8301	            let t = s * s * s * e / r;
  8302	            // dt/dr: d/dr [s³ E / r] = s³ [-s E r - E] / r² = -s³ E (sr + 1) / r²
  8303	            let dt_dr = -s * s * s * e * (a + 1.0) / (r * r);
  8304	            // d²t/dr²: d/dr [-s³ E (a+1) / r²]
  8305	            //   = -s³ [(-s E)(a+1)r² + s E r² - 2r E(a+1)] / r⁴ ... expand
  8306	            // Let g(r) = -s³ E (a+1) / r²
  8307	            // g'(r) = -s³ [E'(a+1) + E·s] / r² + 2s³ E(a+1) / r³
  8308	            //       = -s³ [-sE(a+1) + sE] / r² + 2s³ E(a+1) / r³
  8309	            //       = -s³ · sE[-a-1+1] / r² + 2s³ E(a+1) / r³
  8310	            //       = s⁴ a E / r² + 2s³ E(a+1) / r³
  8311	            //       = s³ E [s a r + 2(a+1)] / r³
  8312	            let d2t_dr2 = s * s * s * e * (s * a * r + 2.0 * (a + 1.0)) / (r * r * r);
  8313	            Ok((phi, q, t, dt_dr, d2t_dr2))
  8314	        }
  8315	        // ----------------------------------------------------------------
  8316	        // ν = 5/2:  φ = (1 + a + a²/3)E, a = √5·r/ℓ, s = √5/ℓ
  8317	        //   q = -(s²/3)(a+1)E
  8318	        //   t = (s⁴/3)E
  8319	        //   dt/dr = -(s⁵/3)E
  8320	        //   d²t/dr² = (s⁶/3)E
  8321	        // ----------------------------------------------------------------
  8322	        MaternNu::FiveHalves => {
  8323	            let s = 5.0_f64.sqrt() / length_scale;
  8324	            let a = s * r;
  8325	            let e = (-a).exp();
  8326	            let phi = (1.0 + a + (a * a) / 3.0) * e;
  8327	            let q = -(s * s / 3.0) * (a + 1.0) * e;
  8328	            let t = (s * s * s * s / 3.0) * e;
  8329	            let dt_dr = -(s * s * s * s * s / 3.0) * e;
  8330	            let d2t_dr2 = (s.powi(6) / 3.0) * e;
  8331	            Ok((phi, q, t, dt_dr, d2t_dr2))
  8332	        }
  8333	        // ----------------------------------------------------------------
  8334	        // ν = 7/2:  φ = (1 + a + (2/5)a² + (1/15)a³)E
  8335	        //   q = -(s²/15)(a² + 3a + 3)E
  8336	        //   t = (s⁴/15)(a + 1)E
  8337	        //   dt/dr = -(s⁵/15)aE
  8338	        //   d²t/dr² = (s⁶/15)(a - 1)E
  8339	        // ----------------------------------------------------------------
  8340	        MaternNu::SevenHalves => {
  8341	            let s = 7.0_f64.sqrt() / length_scale;
  8342	            let a = s * r;
  8343	            let e = (-a).exp();
  8344	            let phi = (1.0 + a + (2.0 / 5.0) * a * a + (1.0 / 15.0) * a * a * a) * e;
  8345	            let q = -(s * s / 15.0) * (a * a + 3.0 * a + 3.0) * e;
  8346	            let t = (s * s * s * s / 15.0) * (a + 1.0) * e;
  8347	            let dt_dr = -(s.powi(5) / 15.0) * a * e;
  8348	            let d2t_dr2 = (s.powi(6) / 15.0) * (a - 1.0) * e;
  8349	            Ok((phi, q, t, dt_dr, d2t_dr2))
  8350	        }
  8351	        // ----------------------------------------------------------------
  8352	        // ν = 9/2:  φ = (1 + a + (3/7)a² + (2/21)a³ + (1/105)a⁴)E
  8353	        //   q = -(s²/105)(a³ + 6a² + 15a + 15)E
  8354	        //   t = (s⁴/105)(a² + 3a + 3)E
  8355	        //   dt/dr = -(s⁵/105)a(a + 1)E
  8356	        //   d²t/dr² = (s⁶/105)(a² - a - 1)E
  8357	        // ----------------------------------------------------------------
  8358	        MaternNu::NineHalves => {
  8359	            let s = 9.0_f64.sqrt() / length_scale;
  8360	            let a = s * r;
  8361	            let e = (-a).exp();
  8362	            let phi = (1.0
  8363	                + a
  8364	                + (3.0 / 7.0) * a * a
  8365	                + (2.0 / 21.0) * a * a * a
  8366	                + (1.0 / 105.0) * a * a * a * a)
  8367	                * e;
  8368	            let q = -(s * s / 105.0) * (a * a * a + 6.0 * a * a + 15.0 * a + 15.0) * e;
  8369	            let t = (s * s * s * s / 105.0) * (a * a + 3.0 * a + 3.0) * e;
  8370	            let dt_dr = -(s.powi(5) / 105.0) * a * (a + 1.0) * e;
  8371	            let d2t_dr2 = (s.powi(6) / 105.0) * (a * a - a - 1.0) * e;
  8372	            Ok((phi, q, t, dt_dr, d2t_dr2))
  8373	        }
  8374	    }
  8375	}
  8376	
  8377	#[inline(always)]
  8378	fn hessian_operator_entry(
  8379	    q: f64,
  8380	    t: f64,
  8381	    h_b: f64,
  8382	    h_c: f64,
  8383	    w_b: f64,
  8384	    w_c: f64,
  8385	    axis_b: usize,
  8386	    axis_c: usize,
  8387	) -> f64 {
  8388	    let diagonal = if axis_b == axis_c { w_b * q } else { 0.0 };
  8389	    diagonal + (w_b * h_b) * (w_c * h_c) * t
  8390	}
  8391	
  8392	#[inline(always)]
  8393	fn hessian_operator_eta_entry(
  8394	    q: f64,
  8395	    t: f64,
  8396	    t_r: f64,
  8397	    r: f64,
  8398	    s_a: f64,
  8399	    h_b: f64,
  8400	    h_c: f64,
  8401	    w_b: f64,
  8402	    w_c: f64,
  8403	    axis_a: usize,
  8404	    axis_b: usize,
  8405	    axis_c: usize,
  8406	) -> f64 {
  8407	    let a_is_b = usize::from(axis_a == axis_b) as f64;
  8408	    let a_is_c = usize::from(axis_a == axis_c) as f64;
  8409	    let q_a = t * s_a;
  8410	    let t_a = if r > 1e-14 { t_r * s_a / r } else { 0.0 };
  8411	    let diagonal = if axis_b == axis_c {
  8412	        w_b * (2.0 * a_is_b * q + q_a)
  8413	    } else {
  8414	        0.0
  8415	    };
  8416	    let mixed_multiplier = 2.0 * a_is_b + 2.0 * a_is_c;
  8417	    diagonal + (w_b * h_b) * (w_c * h_c) * (mixed_multiplier * t + t_a)
  8418	}
  8419	
  8420	#[inline(always)]
  8421	fn hessian_operator_eta2_entry(
  8422	    q: f64,
  8423	    t: f64,
  8424	    t_r: f64,
  8425	    t_rr: f64,
  8426	    r: f64,
  8427	    s_a: f64,
  8428	    h_b: f64,
  8429	    h_c: f64,
  8430	    w_b: f64,
  8431	    w_c: f64,
  8432	    axis_a: usize,
  8433	    axis_b: usize,
  8434	    axis_c: usize,
  8435	) -> f64 {
  8436	    let a_is_b = usize::from(axis_a == axis_b) as f64;
  8437	    let a_is_c = usize::from(axis_a == axis_c) as f64;
  8438	    let q_a = t * s_a;
  8439	    let q_aa = if r > 1e-14 {
  8440	        t_r * s_a * s_a / r + 2.0 * t * s_a
  8441	    } else {
  8442	        0.0
  8443	    };
  8444	    let t_a = if r > 1e-14 { t_r * s_a / r } else { 0.0 };
  8445	    let t_aa = if r > 1e-14 {
  8446	        ((t_rr * r - t_r) / (r * r * r)) * s_a * s_a + 2.0 * t_r * s_a / r
  8447	    } else {
  8448	        0.0
  8449	    };
  8450	    let diagonal = if axis_b == axis_c {
  8451	        w_b * (4.0 * a_is_b * q + 4.0 * a_is_b * q_a + q_aa)
  8452	    } else {
  8453	        0.0
  8454	    };
  8455	    let mixed_multiplier = 2.0 * a_is_b + 2.0 * a_is_c;
  8456	    diagonal
  8457	        + (w_b * h_b)
  8458	            * (w_c * h_c)
  8459	            * (mixed_multiplier * mixed_multiplier * t + 2.0 * mixed_multiplier * t_a + t_aa)
  8460	}
  8461	
  8462	#[inline(always)]
  8463	fn hessian_operator_eta_cross_entry(
  8464	    _q: f64,
  8465	    t: f64,
  8466	    t_r: f64,
  8467	    t_rr: f64,
  8468	    r: f64,
  8469	    s_i: f64,
  8470	    s_j: f64,
  8471	    h_b: f64,
  8472	    h_c: f64,
  8473	    w_b: f64,
  8474	    w_c: f64,
  8475	    axis_i: usize,
  8476	    axis_j: usize,
  8477	    axis_b: usize,
  8478	    axis_c: usize,
  8479	) -> f64 {
  8480	    debug_assert_ne!(axis_i, axis_j);
  8481	    let i_is_b = usize::from(axis_i == axis_b) as f64;
  8482	    let i_is_c = usize::from(axis_i == axis_c) as f64;
  8483	    let j_is_b = usize::from(axis_j == axis_b) as f64;
  8484	    let j_is_c = usize::from(axis_j == axis_c) as f64;
  8485	    let q_i = t * s_i;
  8486	    let q_j = t * s_j;
  8487	    let q_ij = if r > 1e-14 { t_r * s_i * s_j / r } else { 0.0 };
  8488	    let t_i = if r > 1e-14 { t_r * s_i / r } else { 0.0 };
  8489	    let t_j = if r > 1e-14 { t_r * s_j / r } else { 0.0 };
  8490	    let t_ij = if r > 1e-14 {
  8491	        ((t_rr * r - t_r) / (r * r * r)) * s_i * s_j
  8492	    } else {
  8493	        0.0
  8494	    };
  8495	    let diagonal = if axis_b == axis_c {
  8496	        w_b * (2.0 * i_is_b * q_j + 2.0 * j_is_b * q_i + q_ij)
  8497	    } else {
  8498	        0.0
  8499	    };
  8500	    let m_i = 2.0 * i_is_b + 2.0 * i_is_c;
  8501	    let m_j = 2.0 * j_is_b + 2.0 * j_is_c;
  8502	    diagonal + (w_b * h_b) * (w_c * h_c) * (m_i * m_j * t + m_i * t_j + m_j * t_i + t_ij)
  8503	}
