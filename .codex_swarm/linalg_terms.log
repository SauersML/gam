 14122	/// Spectral Legendre-series evaluation of the Sobolev kernel
 14123	/// `K_m^{Sobolev}(γ) = (1/4π) Σ_{l ≥ 1} (2l+1) · [l(l+1)]^{-m} · P_l(cos γ)`.
 14124	/// Used as the m=4 closed-form path and as cross-validation for m=1, 2, 3.
 14125	#[inline]
 14126	fn wahba_sphere_kernel_sobolev_spectral(cos_gamma: f64, m: usize) -> f64 {
 14127	    let l_max = match m {
 14128	        1 => 4096_usize, // l^{-1} terms — needs many for far-from-1 γ
 14129	        2 => 256,
 14130	        3 => 128,
 14131	        _ => 96,
 14132	    };
 14133	    let x = cos_gamma.clamp(-1.0, 1.0);
 14134	    let m_i = m as i32;
 14135	    let four_pi = 4.0 * std::f64::consts::PI;
 14136	    let mut p_l_minus_1 = 1.0_f64;
 14137	    let mut p_l = x;
 14138	    let mut sum = 3.0 * p_l / (four_pi * 2.0_f64.powi(m_i));
 14139	    for l in 1..l_max {
 14140	        let p_l_plus_1 =
 14141	            ((2 * l + 1) as f64 * x * p_l - (l as f64) * p_l_minus_1) / ((l + 1) as f64);
 14142	        let ell = (l + 1) as f64;
 14143	        let eigen = (ell * (ell + 1.0)).powi(m_i);
 14144	        let weight = (2.0 * ell + 1.0) / four_pi;
 14145	        sum += weight * p_l_plus_1 / eigen;
 14146	        p_l_minus_1 = p_l;
 14147	        p_l = p_l_plus_1;
 14148	    }
 14149	    sum
 14150	}
