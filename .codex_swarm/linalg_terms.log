  1542	                    0 => {
  1543	                        a * y_i
  1544	                            + b * y_j
  1545	                            + ((a * a * a - a) * m_i + (b * b * b - b) * m_j) * h * h / 6.0
  1546	                    }
  1547	                    1 => {
  1548	                        (y_j - y_i) / h
  1549	                            + ((-3.0 * a * a + 1.0) * m_i + (3.0 * b * b - 1.0) * m_j) * h / 6.0
  1550	                    }
