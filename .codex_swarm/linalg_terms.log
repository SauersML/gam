   263	    /// Exact `log det(S' + λI)`.
   264	    /// `S'` is rank-deficient under typical constraints (kernel/polynomial
   265	    /// nullspace), so the regularization `λ > 0` is mandatory.
   266	    pub fn log_det_plus_lambda_i(&self, lambda: f64) -> Result<f64, String> {
   267	        assert!(lambda > 0.0, "log_det_plus_lambda_i requires λ > 0");
