  7744	#[inline(always)]
  7745	fn matern_kernel_from_distance(r: f64, length_scale: f64, nu: MaternNu) -> Result<f64, BasisError> {
  7746	    if !r.is_finite() || r < 0.0 {
  7747	        return Err(BasisError::InvalidInput(
  7748	            "Matérn kernel distance must be finite and non-negative".to_string(),
  7749	        ));
  7750	    }
  7751	    if !length_scale.is_finite() || length_scale <= 0.0 {
  7752	        return Err(BasisError::InvalidInput(
  7753	            "Matérn length_scale must be finite and positive".to_string(),
  7754	        ));
  7755	    }
  7756	
  7757	    // Parameterization used here:
  7758	    //   x = r / length_scale
  7759	    //   a = sqrt(2ν) * x
  7760	    // and the half-integer Matérn closed forms are in terms of `a`:
  7761	    //   ν=1/2: exp(-a)
  7762	    //   ν=3/2: (1+a) exp(-a)
  7763	    //   ν=5/2: (1+a+a^2/3) exp(-a)
  7764	    // (for ν=1/2, a=x since sqrt(2ν)=1).
  7765	    let x = r / length_scale;
  7766	    let k = match nu {
  7767	        MaternNu::Half => stable_nonnegative_poly_times_exp_neg(x, &[1.0]),
  7768	        MaternNu::ThreeHalves => {
  7769	            let a = 3.0_f64.sqrt() * x;
  7770	            stable_nonnegative_poly_times_exp_neg(a, &[1.0, 1.0])
  7771	        }
  7772	        MaternNu::FiveHalves => {
  7773	            let a = 5.0_f64.sqrt() * x;
  7774	            stable_nonnegative_poly_times_exp_neg(a, &[1.0, 1.0, 1.0 / 3.0])
  7775	        }
  7776	        MaternNu::SevenHalves => {
  7777	            let a = 7.0_f64.sqrt() * x;
  7778	            stable_nonnegative_poly_times_exp_neg(a, &[1.0, 1.0, 2.0 / 5.0, 1.0 / 15.0])
  7779	        }
  7780	        MaternNu::NineHalves => {
  7781	            let a = 9.0_f64.sqrt() * x;
  7782	            stable_nonnegative_poly_times_exp_neg(
  7783	                a,
  7784	                &[1.0, 1.0, 3.0 / 7.0, 2.0 / 21.0, 1.0 / 105.0],
  7785	            )
  7786	        }
  7787	    };
  7788	    Ok(k)
  7789	}
