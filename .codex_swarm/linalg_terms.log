   638	pub fn solve_sparse_spdmulti<S>(
   639	    factor: &SparseExactFactor,
   640	    rhs: &ArrayBase<S, Ix2>,
   641	) -> Result<Array2<f64>, EstimationError>
   642	where
   643	    S: Data<Elem = f64>,
   644	{
   645	    if rhs.nrows() != factor.n {
   646	        return Err(EstimationError::InvalidInput(format!(
   647	            "sparse SPD multi-solve row mismatch: rhs has {}, factor has {}",
   648	            rhs.nrows(),
   649	            factor.n
   650	        )));
   651	    }
   652	    let rhsview = FaerArrayView::new(rhs);
   653	    let out = factor.factor.solve(rhsview.as_ref());
   654	    let mut result = Array2::<f64>::zeros(rhs.raw_dim());
   655	    for i in 0..rhs.nrows() {
   656	        for j in 0..rhs.ncols() {
   657	            let value = out[(i, j)];
   658	            if !value.is_finite() {
   659	                return Err(EstimationError::InvalidInput(
   660	                    "sparse SPD multi-solve produced non-finite values".to_string(),
   661	                ));
   662	            }
   663	            result[[i, j]] = value;
   664	        }
   665	    }
   666	    Ok(result)
   667	}
   668	
   669	pub fn solve_sparse_spdmulti_rows<S>(
   670	    factor: &SparseExactFactor,
   671	    rhs: &ArrayBase<S, Ix2>,
   672	    row_start: usize,
   673	    row_end: usize,
   674	) -> Result<Array2<f64>, EstimationError>
   675	where
   676	    S: Data<Elem = f64>,
   677	{
   678	    if rhs.nrows() != factor.n {
   679	        return Err(EstimationError::InvalidInput(format!(
   680	            "sparse SPD multi-solve row mismatch: rhs has {}, factor has {}",
   681	            rhs.nrows(),
   682	            factor.n
   683	        )));
   684	    }
   685	    if row_start > row_end || row_end > factor.n {
   686	        return Err(EstimationError::InvalidInput(format!(
   687	            "sparse SPD selected rows out of bounds: row_start={}, row_end={}, factor={}",
   688	            row_start, row_end, factor.n
   689	        )));
   690	    }
   691	    let rhsview = FaerArrayView::new(rhs);
   692	    let out = factor.factor.solve(rhsview.as_ref());
   693	    let mut result = Array2::<f64>::zeros((row_end - row_start, rhs.ncols()));
   694	    for i in row_start..row_end {
   695	        for j in 0..rhs.ncols() {
   696	            let value = out[(i, j)];
   697	            if !value.is_finite() {
   698	                return Err(EstimationError::InvalidInput(
   699	                    "sparse SPD selected-row solve produced non-finite values".to_string(),
   700	                ));
   701	            }
   702	            result[[i - row_start, j]] = value;
   703	        }
   704	    }
   705	    Ok(result)
   706	}
