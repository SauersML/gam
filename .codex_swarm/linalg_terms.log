   511	#[inline]
   512	fn dense_diag_gram_view(matrix: &Array2<f64>, weights: ArrayView1<'_, f64>) -> Array1<f64> {
   513	    let p = matrix.ncols();
   514	    let n = matrix.nrows();
   515	    let large = (n as u64) * (p as u64) >= DENSE_ROW_PARALLEL_MIN_NP;
   516	    let parallel = large && rayon::current_thread_index().is_none();
   517	    // Fast path: if the matrix is row-major contiguous, read each row as a
   518	    // slice and avoid n*p bounds-checked indexing.
   519	    if matrix.is_standard_layout() {
   520	        if let (Some(x), Some(w)) = (matrix.as_slice(), weights.as_slice()) {
   521	            if parallel {
   522	                return (0..n)
   523	                    .into_par_iter()
   524	                    .fold(
   525	                        || vec![0.0_f64; p],
   526	                        |mut acc, i| {
   527	                            let wi = w[i].max(0.0);
   528	                            if wi != 0.0 {
   529	                                let row = &x[i * p..i * p + p];
   530	                                for j in 0..p {
   531	                                    let xij = row[j];
   532	                                    acc[j] += wi * xij * xij;
   533	                                }
   534	                            }
   535	                            acc
   536	                        },
   537	                    )
   538	                    .reduce(
   539	                        || vec![0.0_f64; p],
   540	                        |mut a, b| {
   541	                            for (av, bv) in a.iter_mut().zip(b) {
   542	                                *av += bv;
   543	                            }
   544	                            a
   545	                        },
   546	                    )
   547	                    .into();
   548	            }
   549	            let mut diag = Array1::<f64>::zeros(p);
   550	            let diag_slice = diag.as_slice_mut().expect("zeros are contiguous");
   551	            for i in 0..n {
   552	                let wi = w[i].max(0.0);
   553	                if wi == 0.0 {
   554	                    continue;
   555	                }
   556	                let row = &x[i * p..i * p + p];
   557	                for j in 0..p {
   558	                    let xij = row[j];
   559	                    diag_slice[j] += wi * xij * xij;
   560	                }
   561	            }
   562	            return diag;
   563	        }
   564	    }
   565	    let mut diag = Array1::<f64>::zeros(p);
   566	    for i in 0..n {
   567	        let wi = weights[i].max(0.0);
   568	        if wi == 0.0 {
   569	            continue;
   570	        }
   571	        for j in 0..p {
   572	            let xij = matrix[[i, j]];
   573	            diag[j] += wi * xij * xij;
   574	        }
   575	    }
   576	    diag
   577	}
