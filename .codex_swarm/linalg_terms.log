 22224	fn validate_mspline_normalization_spans(
 22225	    knot_vector: ArrayView1<f64>,
 22226	    degree: usize,
 22227	) -> Result<(), BasisError> {
 22228	    let num_basis = knot_vector.len().saturating_sub(degree + 1);
 22229	    for i in 0..num_basis {
 22230	        let span = knot_vector[i + degree + 1] - knot_vector[i];
 22231	        if span <= 1e-12 {
 22232	            return Err(BasisError::InvalidInput(format!(
 22233	                "invalid M-spline normalization span at i={i}: t[i+degree+1]-t[i]={span:.3e} must be > 0"
 22234	            )));
 22235	        }
 22236	    }
 22237	    Ok(())
 22238	}
