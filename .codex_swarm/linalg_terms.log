    28	impl PenaltyRepresentation {
    29	    fn block_dimension(&self) -> usize {
    30	        match self {
    31	            PenaltyRepresentation::Dense(matrix) => matrix.nrows(),
    32	            PenaltyRepresentation::Banded { bands, offsets } => {
    33	                let mut dim = 0usize;
    34	                for (band, &offset) in bands.iter().zip(offsets.iter()) {
    35	                    let len = band.len();
    36	                    let extent = if offset >= 0 {
    37	                        len + offset as usize
    38	                    } else {
    39	                        len + (-offset) as usize
    40	                    };
    41	                    dim = dim.max(extent);
    42	                }
    43	                dim
    44	            }
    45	            PenaltyRepresentation::Kronecker { left, right } => left.nrows() * right.nrows(),
    46	        }
    47	    }
    48	
    49	    fn to_block_dense(&self) -> Array2<f64> {
    50	        match self {
    51	            PenaltyRepresentation::Dense(matrix) => matrix.clone(),
    52	            PenaltyRepresentation::Banded { bands, offsets } => {
    53	                let dim = self.block_dimension();
    54	                let mut dense = Array2::zeros((dim, dim));
    55	                let positive_offsets: HashSet<usize> = offsets
    56	                    .iter()
    57	                    .filter_map(|&off| (off >= 0).then_some(off as usize))
    58	                    .collect();
    59	                for (band, &offset) in bands.iter().zip(offsets.iter()) {
