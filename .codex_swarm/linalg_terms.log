  1272	/// Canonicalize a batch of penalty specs, dropping zero-rank penalties.
  1273	/// Returns (active_penalties, active_nullspace_dims).
  1274	pub fn canonicalize_penalty_specs(
  1275	    specs: &[crate::estimate::PenaltySpec],
  1276	    nullspace_dims: &[usize],
  1277	    p: usize,
  1278	    context: &str,
  1279	) -> Result<(Vec<CanonicalPenalty>, Vec<usize>), EstimationError> {
  1280	    if specs.len() != nullspace_dims.len() {
  1281	        return Err(EstimationError::InvalidInput(format!(
  1282	            "{context}: nullspace_dims length mismatch: penalties={}, nullspace_dims={}",
  1283	            specs.len(),
  1284	            nullspace_dims.len()
  1285	        )));
  1286	    }
  1287	
  1288	    let mut active = Vec::with_capacity(specs.len());
  1289	    let mut active_nullspace = Vec::with_capacity(specs.len());
  1290	    for (idx, spec) in specs.iter().enumerate() {
  1291	        if let Some(canonical) = canonicalize_penalty_spec(spec, p, idx, context)? {
  1292	            active_nullspace.push(nullspace_dims[idx]);
  1293	            active.push(canonical);
  1294	        }
  1295	    }
  1296	    Ok((active, active_nullspace))
  1297	}
