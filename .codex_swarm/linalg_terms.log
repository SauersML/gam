   955	/// Trait for dense-backed design operators that avoid eager materialization.
   956	///
   957	/// Implement this trait for structured designs (multi-channel, rowwise-Kronecker,
   958	/// etc.) that can perform matvecs and Gram-matrix assembly without forming the
   959	/// full dense matrix. Wrap implementations in `DenseDesignMatrix::Lazy(Arc<..>)`
   960	/// to integrate them with the rest of the codebase while keeping the top-level
   961	/// `DesignMatrix` split strictly `Dense | Sparse`.
   962	pub trait DenseDesignOperator: LinearOperator + Send + Sync {
   963	    fn compute_xtwy(&self, weights: &Array1<f64>, y: &Array1<f64>) -> Result<Array1<f64>, String> {
   964	        // Default: X'(w ⊙ y) via apply_transpose.
   965	        let n = self.nrows();
   966	        if weights.len() != n || y.len() != n {
   967	            return Err(format!(
   968	                "DenseDesignOperator::compute_xtwy dimension mismatch: weights={}, y={}, nrows={}",
   969	                weights.len(),
   970	                y.len(),
   971	                n
   972	            ));
   973	        }
   974	        let mut wy = Array1::<f64>::zeros(n);
   975	        ndarray::Zip::from(&mut wy)
   976	            .and(weights)
   977	            .and(y)
   978	            .par_for_each(|o, &w, &yi| *o = w.max(0.0) * yi);
   979	        Ok(self.apply_transpose(&wy))
   980	    }
   981	
   982	    fn quadratic_form_diag(&self, middle: &Array2<f64>) -> Result<Array1<f64>, String> {
   983	        // Default: diag(X M X') computed in chunks via row_chunk — avoids
   984	        // materializing the full n×p dense matrix at once.
   985	        if middle.nrows() != self.ncols() || middle.ncols() != self.ncols() {
   986	            return Err(format!(
   987	                "DenseDesignOperator::quadratic_form_diag dimension mismatch: {}x{} vs expected {}x{}",
   988	                middle.nrows(),
   989	                middle.ncols(),
   990	                self.ncols(),
   991	                self.ncols()
   992	            ));
   993	        }
   994	        let n = self.nrows();
   995	        let mut out = Array1::<f64>::zeros(n);
   996	        // Process in chunks to bound memory: ~8 MB working set.
   997	        let chunk_size = (8 * 1024 * 1024 / (self.ncols().max(1) * 8 * 2))
   998	            .max(16)
   999	            .min(n.max(1));
  1000	        let mut start = 0;
  1001	        while start < n {
  1002	            let end = (start + chunk_size).min(n);
  1003	            let x_chunk = self.try_row_chunk(start..end).map_err(|e| e.to_string())?;
  1004	            let xm_chunk = fast_ab(&x_chunk, middle);
  1005	            let mut chunk_out = out.slice_mut(ndarray::s![start..end]);
  1006	            ndarray::Zip::from(&mut chunk_out)
  1007	                .and(x_chunk.rows())
  1008	                .and(xm_chunk.rows())
  1009	                .par_for_each(|o, xr, xmr| *o = xr.dot(&xmr).max(0.0));
  1010	            start = end;
  1011	        }
  1012	        Ok(out)
  1013	    }
  1014	
  1015	    /// Fill a dense row chunk without materializing the full matrix.
  1016	    /// Required: every implementor must provide row-local access here.
  1017	    fn row_chunk_into(
  1018	        &self,
  1019	        rows: Range<usize>,
  1020	        out: ArrayViewMut2<'_, f64>,
  1021	    ) -> Result<(), MatrixMaterializationError>;
  1022	
  1023	    /// Extract a dense row chunk without materializing the full matrix.
  1024	    /// Non-panicking owned-chunk API built on top of `row_chunk_into`.
  1025	    fn try_row_chunk(&self, rows: Range<usize>) -> Result<Array2<f64>, MatrixMaterializationError> {
  1026	        let mut out = Array2::<f64>::zeros((rows.end - rows.start, self.ncols()));
  1027	        self.row_chunk_into(rows, out.view_mut())?;
  1028	        Ok(out)
  1029	    }
  1030	
  1031	    /// Borrow dense storage when this operator already owns it.
  1032	    fn as_dense_ref(&self) -> Option<&Array2<f64>> {
  1033	        None
  1034	    }
  1035	
  1036	    /// Batched column extraction: returns an `nrows × cols.len()` dense block
  1037	    /// whose k-th column is `apply(e_{cols[k]})`.
  1038	    ///
  1039	    /// Default impl loops over columns and applies a unit vector per call. Operator
  1040	    /// types like `ReparamOperator` that can express the batch as a single GEMM
  1041	    /// (`X · Qs[:, cols]`) should override this — it avoids re-walking the inner
  1042	    /// matvec for every column.
  1043	    fn apply_columns(&self, cols: &[usize]) -> Array2<f64> {
  1044	        let n = self.nrows();
  1045	        let p = self.ncols();
  1046	        let mut out = Array2::<f64>::zeros((n, cols.len()));
  1047	        let mut e = Array1::<f64>::zeros(p);
  1048	        for (k, &j) in cols.iter().enumerate() {
  1049	            assert!(
  1050	                j < p,
  1051	                "DenseDesignOperator::apply_columns: column index {j} out of bounds (ncols={p})"
  1052	            );
  1053	            e[j] = 1.0;
  1054	            let col = self.apply(&e);
  1055	            e[j] = 0.0;
  1056	            out.column_mut(k).assign(&col);
  1057	        }
  1058	        out
  1059	    }
  1060	
  1061	    /// Materialize the full dense matrix. Operators that exist precisely to
  1062	    /// avoid materialization should still support this for fallback paths,
  1063	    /// diagnostics, and prediction.
  1064	    fn to_dense(&self) -> Array2<f64>;
  1065	
  1066	    fn estimated_dense_bytes(&self) -> usize {
  1067	        self.nrows()
  1068	            .saturating_mul(self.ncols())
  1069	            .saturating_mul(std::mem::size_of::<f64>())
  1070	    }
  1071	
  1072	    fn try_to_dense_with_policy(
  1073	        &self,
  1074	        policy: &MaterializationPolicy,
  1075	        context: &'static str,
  1076	    ) -> Result<Arc<Array2<f64>>, MatrixMaterializationError> {
  1077	        let bytes = self.estimated_dense_bytes();
  1078	        if !policy.allow_operator_materialization {
  1079	            return Err(MatrixMaterializationError::Forbidden {
  1080	                context,
  1081	                mode: crate::resource::DerivativeStorageMode::AnalyticOperatorRequired,
  1082	            });
  1083	        }
  1084	        if bytes > policy.max_single_dense_bytes {
  1085	            return Err(MatrixMaterializationError::TooLarge {
  1086	                context,
  1087	                nrows: self.nrows(),
  1088	                ncols: self.ncols(),
  1089	                bytes,
  1090	                limit_bytes: policy.max_single_dense_bytes,
  1091	            });
  1092	        }
  1093	        dense_operator_to_dense_by_chunks(self).map(Arc::new)
  1094	    }
  1095	
  1096	    /// Shared dense materialization via the required row-chunk API.
  1097	    ///
  1098	    /// This deliberately does not fall back through `to_dense()`: operator-backed
  1099	    /// designs can be biobank-scale, and their chunked row path is the bounded
  1100	    /// memory materialization contract. Implementations that already own an
  1101	    /// `Arc<Array2<_>>` should override this to return it directly.
  1102	    fn to_dense_arc(&self) -> Arc<Array2<f64>> {
  1103	        Arc::new(
  1104	            dense_operator_to_dense_by_chunks(self)
  1105	                .expect("DenseDesignOperator::to_dense_arc: row-chunk materialization failed"),
  1106	        )
  1107	    }
  1108	}
