   731	    let start_col =
   732	        internal::evaluate_splines_sparse_into(x_eval, degree, knotview, values, basis_scratch);
   733	    if degree == 0 {
   734	        values.fill(0.0);
   735	        return start_col;
   736	    }
   737	
   738	    let lower_degree = degree - 1;
   739	    let lower_support = lower_degree + 1;
   740	    if lowervalues.len() != lower_support {
   741	        return start_col;
   742	    }
   743	
   744	    let start_lower = internal::evaluate_splines_sparse_into(
   745	        x_eval,
   746	        lower_degree,
   747	        knotview,
   748	        lowervalues,
   749	        lower_scratch,
   750	    );
   751	
   752	    values.fill(0.0);
   753	    for offset in 0..=degree {
   754	        let i = start_col + offset;
   755	        let left_idx = i as isize - start_lower as isize;
   756	        let right_idx = (i + 1) as isize - start_lower as isize;
   757	        let left = if left_idx >= 0 && (left_idx as usize) < lower_support {
   758	            lowervalues[left_idx as usize]
   759	        } else {
   760	            0.0
   761	        };
   762	        let right = if right_idx >= 0 && (right_idx as usize) < lower_support {
   763	            lowervalues[right_idx as usize]
   764	        } else {
   765	            0.0
   766	        };
