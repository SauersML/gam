 20248	#[inline(always)]
 20249	fn thin_plate_kernel_psi_triplet_from_distance(
 20250	    distance: f64,
 20251	    length_scale: f64,
 20252	    dimension: usize,
 20253	) -> Result<(f64, f64, f64), BasisError> {
 20254	    if !distance.is_finite() || distance < 0.0 {
 20255	        return Err(BasisError::InvalidInput(
 20256	            "thin-plate kernel distance must be finite and non-negative".to_string(),
 20257	        ));
 20258	    }
 20259	    if !length_scale.is_finite() || length_scale <= 0.0 {
 20260	        return Err(BasisError::InvalidInput(
 20261	            "thin-plate length_scale must be finite and positive".to_string(),
 20262	        ));
 20263	    }
 20264	
 20265	    // ThinPlate psi-derivative convention:
 20266	    // the optimizer uses psi = log(kappa) = -log(length_scale), so the scaled
 20267	    // radial argument is
 20268	    //   r(psi) = ||x - c|| / length_scale = ||x - c|| * exp(psi).
 20269	    //
 20270	    // Therefore
 20271	    //   dr/dpsi     = r
 20272	    //   d²r/dpsi²   = r
 20273	    //
 20274	    // and for any TPS radial kernel phi(r),
 20275	    //   d phi / dpsi       = phi_r(r) * r
 20276	    //   d²phi / dpsi²      = phi_rr(r) * r² + phi_r(r) * r.
 20277	    //
 20278	    // This is exactly the chain rule requested by the math spec, translated to
 20279	    // the code's stored inverse-length-scale parameterization.
 20280	    let scaled_distance = distance / length_scale;
 20281	    let (value, radial_first, radial_second) =
 20282	        thin_plate_kernel_triplet_from_scaled_distance(scaled_distance, dimension)?;
 20283	    let psi = radial_first * scaled_distance;
 20284	    let psi_psi = radial_second * scaled_distance * scaled_distance + psi;
 20285	    Ok((value, psi, psi_psi))
 20286	}
