   969	        eval_kind: BasisEvalKind,
   970	        num_basis_functions: usize,
   971	        support: usize,
   972	        use_parallel: bool,
   973	    ) -> Result<Self::Output, BasisError> {
   974	        let mut basis_matrix = Array2::zeros((data.len(), num_basis_functions));
   975	
   976	        if let (true, Some(data_slice)) = (use_parallel, data.as_slice()) {
   977	            basis_matrix
   978	                .axis_iter_mut(Axis(0))
   979	                .into_par_iter()
   980	                .zip(data_slice.par_iter().copied())
   981	                .for_each_init(
   982	                    || (BasisEvalScratch::new(degree), vec![0.0; support]),
   983	                    |(scratch, values), (mut row, x)| {
   984	                        let row_slice = row
   985	                            .as_slice_mut()
   986	                            .expect("basis matrix rows should be contiguous");
