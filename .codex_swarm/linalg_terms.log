 21368	    /// Generates the full knot vector with clamped boundary knots.
 21369	    ///
 21370	    /// Standard B-spline construction: boundary values are repeated (degree + 1) times
 21371	    /// to ensure the basis functions are well-supported across the entire data domain.
 21372	    /// This prevents "ghost" basis functions with support mostly outside the data range,
 21373	    /// which would create near-zero columns in the design matrix and ill-conditioned systems.
 21374	    pub(super) fn generate_full_knot_vector(
 21375	        data_range: (f64, f64),
 21376	        num_internal_knots: usize,
 21377	        degree: usize,
 21378	    ) -> Result<Array1<f64>, BasisError> {
 21379	        let (minval, maxval) = data_range;
 21380	
 21381	        // Double-check for degenerate range - this should be caught by the public function
 21382	        // but we add it here as a defensive measure
 21383	        if minval == maxval {
 21384	            return Err(BasisError::DegenerateRange(num_internal_knots));
 21385	        }
 21386	
 21387	        let h = (maxval - minval) / (num_internal_knots as f64 + 1.0);
 21388	        let total_knots = num_internal_knots + 2 * (degree + 1);
 21389	
 21390	        let mut knots = Vec::with_capacity(total_knots);
 21391	
 21392	        // Clamped start: repeat minval (degree + 1) times
 21393	        for _ in 0..=degree {
 21394	            knots.push(minval);
 21395	        }
 21396	
 21397	        // Internal knots: uniformly spaced
 21398	        for i in 1..=num_internal_knots {
 21399	            knots.push(minval + i as f64 * h);
 21400	        }
 21401	
 21402	        // Clamped end: repeat maxval (degree + 1) times
 21403	        for _ in 0..=degree {
 21404	            knots.push(maxval);
 21405	        }
 21406	
 21407	        Ok(Array::from_vec(knots))
 21408	    }
