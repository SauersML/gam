   225	    /// Materialize the underlying matrix as `Array2<f64>`. Cheap for `Dense`
   226	    /// (clone), and may be expensive for `Operator` (full assembly), but is
   227	    /// always the same numerical result as the operator's matvec contract.
   228	    pub fn to_dense(&self) -> Array2<f64> {
   229	        match self {
   230	            PenaltyForm::Dense(m) => m.clone(),
   231	            PenaltyForm::Operator(op) => op.as_dense(),
   232	        }
   233	    }
   234	}
