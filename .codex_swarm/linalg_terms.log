   289	    /// Materialize the full constrained operator as a dense `Array2` for
   290	    /// callers that explicitly request a matrix or for validation against
   291	    /// `closed_form_operator_penalty_in_total_basis`. Uses the internal
   292	    /// cache: the first call builds, subsequent calls clone from the cache.
   293	    pub fn dense_form(&self) -> Array2<f64> {
   294	        self.ensure_dense().clone()
   295	    }
   296	
   297	    /// Internal builder. Do not call directly — go through `ensure_dense` so
   298	    /// the result is cached.
   299	    fn build_dense(&self) -> Array2<f64> {
   300	        // Build raw K×K kernel block via the existing dense path so we share
   301	        // its cancellation-detector logic for small κ.
   302	        let g_raw = closed_form_anisotropic_pair_block(
   303	            self.centers.view(),
   304	            self.q,
   305	            self.m,
   306	            self.s,
   307	            self.kappa,
   308	            if self.eta_raw.iter().all(|&e| e == 0.0) {
   309	                None
   310	            } else {
   311	                Some(self.eta_raw.as_slice())
   312	            },
   313	        );
   314	        let kernel_cols = self
   315	            .kernel_nullspace
   316	            .as_ref()
   317	            .map(|z| z.ncols())
   318	            .unwrap_or_else(|| self.centers.nrows());
   319	        let g_kernel = match &self.kernel_nullspace {
   320	            Some(z) => {
   321	                let zt_g = fast_atb(z, &g_raw);
   322	                fast_ab(&zt_g, z)
   323	            }
   324	            None => g_raw,
   325	        };
   326	        let total_pre = kernel_cols + self.polynomial_block_cols;
   327	        let g_padded = if self.polynomial_block_cols == 0 {
   328	            g_kernel
   329	        } else {
   330	            let mut padded = Array2::<f64>::zeros((total_pre, total_pre));
   331	            padded
   332	                .slice_mut(ndarray::s![0..kernel_cols, 0..kernel_cols])
   333	                .assign(&g_kernel);
   334	            padded
   335	        };
   336	        match &self.outer_identifiability {
   337	            Some(t) => {
   338	                let tt_g = fast_atb(t, &g_padded);
   339	                fast_ab(&tt_g, t)
   340	            }
   341	            None => g_padded,
   342	        }
   343	    }
   344	
   345	    fn raw_pair_matvec(&self, v: ArrayView1<'_, f64>) -> Array1<f64> {
   346	        assert_eq!(
   347	            v.len(),
   348	            self.centers.nrows(),
   349	            "ClosedFormPenaltyOperator::raw_pair_matvec: input dim mismatch"
   350	        );
   351	        let k = self.centers.nrows();
   352	        let d = self.centers.ncols();
   353	        let rows: Vec<f64> = (0..k)
   354	            .into_par_iter()
   355	            .map(|i| {
   356	                let mut r: SmallVec<[f64; 16]> = SmallVec::with_capacity(d);
   357	                r.resize(d, 0.0);
   358	                let mut sum = 0.0_f64;
   359	                let mut correction = 0.0_f64;
   360	                for j in 0..k {
   361	                    for axis in 0..d {
   362	                        r[axis] = self.centers[[i, axis]] - self.centers[[j, axis]];
   363	                    }
   364	                    let gij = closed_form_anisotropic_pair_value_with_powers(
   365	                        self.q,
   366	                        self.m,
   367	                        self.s,
   368	                        self.kappa,
   369	                        &self.eta_raw,
   370	                        &self.eta_metric_powers,
   371	                        r.as_slice(),
   372	                        self.diagonal_epsilon,
   373	                    );
   374	                    let y = gij * v[j] - correction;
   375	                    let next = sum + y;
   376	                    correction = (next - sum) - y;
   377	                    sum = next;
   378	                }
   379	                sum
   380	            })
   381	            .collect();
   382	        Array1::from_vec(rows)
   383	    }
   384	}
