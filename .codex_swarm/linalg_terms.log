  1588	fn wrap_periodic_spline_coordinate(x: f64, options: PeriodicSpline1DOptions) -> f64 {
  1589	    options.origin + (x - options.origin).rem_euclid(options.period)
  1590	}
  1591	
  1592	fn coalesce_periodic_spline_samples(
  1593	    u: ArrayView1<'_, f64>,
  1594	    y: ArrayView2<'_, f64>,
  1595	    options: PeriodicSpline1DOptions,
  1596	) -> Result<(Array1<f64>, Array2<f64>), BasisError> {
  1597	    let mut rows = u
  1598	        .iter()
  1599	        .enumerate()
  1600	        .map(|(i, &ui)| {
  1601	            (
  1602	                wrap_periodic_spline_coordinate(ui, options),
  1603	                y.row(i).to_vec(),
  1604	            )
  1605	        })
  1606	        .collect::<Vec<_>>();
  1607	    rows.sort_by(|a, b| a.0.partial_cmp(&b.0).unwrap_or(std::cmp::Ordering::Equal));
  1608	
  1609	    let tol = options
  1610	        .duplicate_tolerance
  1611	        .max(64.0 * f64::EPSILON * options.period.abs());
  1612	    let d = y.ncols();
  1613	    let mut sites = Vec::<f64>::new();
  1614	    let mut values = Vec::<Vec<f64>>::new();
  1615	    let mut counts = Vec::<usize>::new();
  1616	
  1617	    for (site, value) in rows {
  1618	        if let Some(last_site) = sites.last_mut()
  1619	            && (site - *last_site).abs() <= tol
  1620	        {
  1621	            let count = *counts.last().expect("group count exists") as f64;
  1622	            let target = values.last_mut().expect("group value exists");
  1623	            for col in 0..d {
  1624	                target[col] = (target[col] * count + value[col]) / (count + 1.0);
  1625	            }
  1626	            *last_site = (*last_site * count + site) / (count + 1.0);
  1627	            *counts.last_mut().expect("group count exists") += 1;
  1628	            continue;
  1629	        }
  1630	        sites.push(site);
  1631	        values.push(value);
  1632	        counts.push(1);
  1633	    }
  1634	
  1635	    if sites.len() >= 2 {
  1636	        let first = sites[0];
  1637	        let last_idx = sites.len() - 1;
  1638	        let last_equivalent = sites[last_idx] - options.period;
  1639	        if (first - last_equivalent).abs() <= tol {
  1640	            let first_count = counts[0] as f64;
  1641	            let last_count = counts[last_idx] as f64;
  1642	            let total = first_count + last_count;
  1643	            for col in 0..d {
  1644	                values[0][col] =
  1645	                    (values[0][col] * first_count + values[last_idx][col] * last_count) / total;
  1646	            }
  1647	            counts[0] += counts[last_idx];
  1648	            sites.remove(last_idx);
  1649	            values.remove(last_idx);
  1650	            counts.remove(last_idx);
  1651	        }
  1652	    }
  1653	
  1654	    let n = sites.len();
  1655	    let flat = values.into_iter().flatten().collect::<Vec<_>>();
  1656	    let values = Array2::from_shape_vec((n, d), flat).map_err(|e| {
  1657	        BasisError::InvalidInput(format!(
  1658	            "failed to construct periodic spline value matrix: {e}"
  1659	        ))
  1660	    })?;
  1661	    Ok((Array1::from_vec(sites), values))
  1662	}
