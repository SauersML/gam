 22174	fn create_mspline_sparse(
 22175	    data: ArrayView1<f64>,
 22176	    knot_vector: ArrayView1<f64>,
 22177	    degree: usize,
 22178	) -> Result<SparseColMat<usize, f64>, BasisError> {
 22179	    validate_knots_for_degree(knot_vector, degree)?;
 22180	    validate_mspline_normalization_spans(knot_vector, degree)?;
 22181	    let nrows = data.len();
 22182	    let ncols = knot_vector.len() - degree - 1;
 22183	    let mut scratch = internal::BsplineScratch::new(degree);
 22184	    let support = degree + 1;
 22185	    let mut local = vec![0.0; support];
 22186	    let left = knot_vector[degree];
 22187	    let right = knot_vector[ncols];
 22188	    let order = (degree + 1) as f64;
 22189	    let mut scales = vec![0.0; ncols];
 22190	    for i in 0..ncols {
 22191	        let span = knot_vector[i + degree + 1] - knot_vector[i];
 22192	        scales[i] = order / span;
 22193	    }
 22194	
 22195	    let mut triplets: Vec<Triplet<usize, usize, f64>> =
 22196	        Vec::with_capacity(nrows.saturating_mul(support));
 22197	    for (row_i, &x) in data.iter().enumerate() {
 22198	        if x < left || x > right {
 22199	            continue;
 22200	        }
 22201	        let start = internal::evaluate_splines_sparse_into(
 22202	            x,
 22203	            degree,
 22204	            knot_vector,
 22205	            &mut local,
 22206	            &mut scratch,
 22207	        );
 22208	        for (offset, &b) in local.iter().enumerate() {
 22209	            let col = start + offset;
 22210	            if col >= ncols {
 22211	                continue;
 22212	            }
 22213	            let v = b * scales[col];
 22214	            if v.abs() > 0.0 {
 22215	                triplets.push(Triplet::new(row_i, col, v));
 22216	            }
 22217	        }
 22218	    }
 22219	
 22220	    SparseColMat::try_new_from_triplets(nrows, ncols, &triplets)
 22221	        .map_err(|e| BasisError::SparseCreation(format!("{e:?}")))
 22222	}
