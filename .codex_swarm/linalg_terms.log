   581	/// Computes the Kronecker product A ⊗ B for penalty matrix construction.
   582	/// This is used to create tensor product penalties that enforce smoothness
   583	/// in multiple dimensions for interaction terms.
   584	pub fn kronecker_product(a: &Array2<f64>, b: &Array2<f64>) -> Array2<f64> {
   585	    let (arows, a_cols) = a.dim();
   586	    let (brows, b_cols) = b.dim();
   587	    if arows == 0 || a_cols == 0 || brows == 0 || b_cols == 0 {
   588	        return Array2::zeros((arows * brows, a_cols * b_cols));
   589	    }
   590	    let mut result = Array2::zeros((arows * brows, a_cols * b_cols));
   591	
   592	    result
   593	        .axis_chunks_iter_mut(Axis(0), brows)
   594	        .into_par_iter()
   595	        .enumerate()
   596	        .for_each(|(i, mut row_block)| {
   597	            let arow = a.row(i);
   598	            let col_chunks = row_block.axis_chunks_iter_mut(Axis(1), b_cols);
   599	            for (j, mut block) in col_chunks.into_iter().enumerate() {
   600	                let aval = arow[j];
   601	                if aval == 0.0 {
   602	                    continue;
   603	                }
   604	                for (dest, &src) in block.iter_mut().zip(b.iter()) {
   605	                    *dest = aval * src;
   606	                }
   607	            }
   608	        });
   609	
   610	    result
   611	}
