   566	fn compose_qs_from_split(q_pen: &Mat<f64>, q_null: &Mat<f64>, p: usize) -> Mat<f64> {
   567	    let rank = q_pen.ncols();
   568	    let null_count = q_null.ncols();
   569	    let mut qs = Mat::<f64>::zeros(p, p);
   570	    for i in 0..p {
   571	        for j in 0..rank {
   572	            qs[(i, j)] = q_pen[(i, j)];
   573	        }
   574	        for j in 0..null_count {
   575	            qs[(i, rank + j)] = q_null[(i, j)];
   576	        }
   577	    }
   578	    qs
   579	}
