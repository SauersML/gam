   612	    // Streaming chunked: peak allocation is chunk_rows × p instead of n × p.
   613	    // Compute Xᵀ·diag(W)·X as Xᵀ·(W·X) to preserve sign on W; the prior
   614	    // sqrt(max(0, w))-then-Gram form clipped negative weights to zero, which
   615	    // corrupted observed-Hessian assembly when any block had n > a (e.g. heavy
   616	    // residuals under the logb σ link).
   617	    const TARGET_BYTES: usize = 8 * 1024 * 1024;
   618	    const MIN_ROWS: usize = 512;
   619	    const MAX_ROWS: usize = 131_072;
   620	    let chunk_rows = (TARGET_BYTES / (p.max(1) * 8))

