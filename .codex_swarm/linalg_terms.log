    85	
    86	impl EngineLayoutBuilder {
    87	    pub fn new() -> Self {
    88	        Self {
    89	            next_col: 0,
    90	            next_penalty: 0,
    91	            terms: Vec::new(),
    92	        }
    93	    }
    94	
    95	    pub fn with_offsets(start_col: usize, start_penalty: usize) -> Self {
    96	        Self {
    97	            next_col: start_col,
    98	            next_penalty: start_penalty,
    99	            terms: Vec::new(),
   100	        }
   101	    }
   102	
   103	    pub fn push_term(&mut self, spec: EngineTermSpec) -> Result<usize, LayoutBuildError> {
   104	        if spec.width == 0 {
   105	            return Err(LayoutBuildError::new(
   106	                "term width must be positive for layout construction",
   107	            ));
   108	        }
   109	
   110	        let penalties = match spec.penaltyspec {
   111	            PenaltySpec::None => Vec::new(),
   112	            PenaltySpec::New { count } => {
   113	                if count == 0 {
   114	                    return Err(LayoutBuildError::new(
   115	                        "new-penalty spec must request at least one penalty",
   116	                    ));
   117	                }
   118	                let start = self.next_penalty;
   119	                self.next_penalty += count;
   120	                (start..start + count).collect()
   121	            }
   122	            PenaltySpec::Existing(indices) => {
   123	                if indices.is_empty() {
   124	                    return Err(LayoutBuildError::new(
   125	                        "existing-penalty spec must provide at least one index",
   126	                    ));
   127	                }
   128	                let next_penalty = indices
   129	                    .iter()
   130	                    .copied()
   131	                    .max()
   132	                    .and_then(|idx| idx.checked_add(1))
   133	                    .ok_or_else(|| {
   134	                        LayoutBuildError::new(
   135	                            "existing penalty index would overflow layout penalty count",
   136	                        )
   137	                    })?;
   138	                self.next_penalty = self.next_penalty.max(next_penalty);
   139	                indices
   140	            }
   141	        };
   142	
   143	        let col_range = self.next_col..self.next_col + spec.width;
   144	        self.next_col += spec.width;
   145	        self.terms.push(EngineTerm {
   146	            kind: spec.kind,
   147	            col_range,
   148	            penalty_indices: penalties,
   149	        });
   150	        Ok(self.terms.len() - 1)
   151	    }
   152	
   153	    pub fn build(self) -> EngineLayout {
   154	        assert!(
   155	            self.terms
   156	                .iter()
   157	                .flat_map(|term| term.penalty_indices.iter())
   158	                .all(|&idx| idx < self.next_penalty)
   159	        );
   160	        EngineLayout {
   161	            terms: self.terms,
   162	            total_coeffs: self.next_col,
   163	            num_penalties: self.next_penalty,
   164	        }
   165	    }
   166	}
