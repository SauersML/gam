   905	                        let wab_off = local * pb;
   906	                        let wbb_off = local * pb;
   907	                        let waa_row = &mut waa_chunk[waa_off..waa_off + pa];
   908	                        for col in 0..pa {
   909	                            waa_row[col] = xa_row[col] * waa_i;
   910	                        }
   911	                        let wab_row = &mut wab_chunk[wab_off..wab_off + pb];
   912	                        let wbb_row = &mut wbb_chunk[wbb_off..wbb_off + pb];
   913	                        for col in 0..pb {
   914	                            let xij = xb_row[col];
   915	                            wab_row[col] = xij * wab_i;
   916	                            wbb_row[col] = xij * wbb_i;
   917	                        }
   918	                    }
   919	                } else {
   920	                    for local in 0..rows {
   921	                        let i = start + local;
   922	                        let waa_i = w_aa[i];
   923	                        let wab_i = w_ab[i];
   924	                        let wbb_i = w_bb[i];
   925	                        let waa_off = local * pa;
   926	                        let wab_off = local * pb;
   927	                        let wbb_off = local * pb;
   928	                        let waa_row = &mut waa_chunk[waa_off..waa_off + pa];
   929	                        let xa_row = xa_slice.row(local);
   930	                        for (col, xij) in xa_row.iter().enumerate() {
