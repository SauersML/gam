  2112	/// Build a cyclic discrete-difference penalty `D' D` with wrap-around rows.
  2113	pub fn create_cyclic_difference_penalty_matrix(
  2114	    num_basis: usize,
  2115	    order: usize,
  2116	) -> Result<Array2<f64>, BasisError> {
  2117	    if order == 0 {
  2118	        return Ok(Array2::<f64>::eye(num_basis));
  2119	    }
  2120	    if num_basis == 0 || num_basis < order + 1 {
  2121	        return Err(BasisError::InvalidInput(format!(
  2122	            "cyclic difference penalty requires num_basis >= order + 1; got num_basis={num_basis}, order={order}"
  2123	        )));
  2124	    }
  2125	    let mut d = Array2::<f64>::zeros((num_basis, num_basis));
  2126	    for row in 0..num_basis {
  2127	        for j in 0..=order {
  2128	            let sign = if (order - j) % 2 == 0 { 1.0 } else { -1.0 };
  2129	            d[[row, (row + j) % num_basis]] = sign * binomial_f64(order, j);
  2130	        }
  2131	    }
  2132	    Ok(fast_ata(&d))
  2133	}
