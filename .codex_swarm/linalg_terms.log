   207	            .kernel_nullspace
   208	            .as_ref()
   209	            .map(|z| z.ncols())
   210	            .unwrap_or_else(|| self.centers.nrows());
   211	        let pre_kernel = pre.slice(ndarray::s![0..kernel_cols]);
   212	        let raw_input = match &self.kernel_nullspace {
   213	            Some(z) => z.dot(&pre_kernel),
   214	            None => pre_kernel.to_owned(),
   215	        };
   216	        let raw_output = self.raw_pair_matvec(raw_input.view());
   217	        let kernel_output = match &self.kernel_nullspace {
   218	            Some(z) => z.t().dot(&raw_output),
   219	            None => raw_output,
   220	        };
   221	        let total_pre = kernel_cols + self.polynomial_block_cols;
   222	        let mut projected = Array1::<f64>::zeros(total_pre);
   223	        projected
   224	            .slice_mut(ndarray::s![0..kernel_cols])
   225	            .assign(&kernel_output);
   226	        let final_output = match &self.outer_identifiability {
   227	            Some(t) => t.t().dot(&projected),
   228	            None => projected,
   229	        };
   230	        out.assign(&final_output);
   231	    }
   232	
   233	    /// Diagonal `S[i,i]` for i in 0..dim. In the raw layout this is the
   234	    /// analytic self-pair repeated K times. With constraint composition the
   235	    /// diagonal is *not* the K-space diagonal; we extract it via
   236	    /// `e_i^T S' e_i = matvec(e_i)[i]`.
   237	    pub fn diag(&self) -> Array1<f64> {
   238	        let n = self.dim();
   239	        if self.is_raw_layout() {
   240	            return Array1::from_elem(n, self.raw_diagonal_value());
   241	        }
   242	        // Read the diagonal directly off the cached dense form. This is the
