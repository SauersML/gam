 21421	        if data.iter().any(|x| !x.is_finite()) {
 21422	            return Err(BasisError::InvalidInput(
 21423	                "quantile knot placement requires finite data".to_string(),
 21424	            ));
 21425	        }
 21426	
 21427	        let mut sorted: Vec<f64> = data.iter().copied().collect();
 21428	        sorted.sort_by(f64::total_cmp);
 21429	        let minval = sorted[0];
 21430	        let maxval = *sorted.last().unwrap_or(&minval);
 21431	        if minval == maxval {
 21432	            return Err(BasisError::DegenerateRange(num_internal_knots));
 21433	        }
 21434	        let scale = (maxval - minval).abs().max(1.0);
 21435	        let tol = 1e-12 * scale;
 21436	
 21437	        let total_knots = num_internal_knots + 2 * (degree + 1);
 21438	        let mut knots = Vec::with_capacity(total_knots);
 21439	        for _ in 0..=degree {
 21440	            knots.push(minval);
 21441	        }
 21442	
 21443	        if num_internal_knots > 0 {
 21444	            let mut support = Vec::with_capacity(sorted.len());
 21445	            let mut last: Option<f64> = None;
 21446	            for &x in &sorted {
 21447	                if x <= minval + tol || x >= maxval - tol {
 21448	                    continue;
 21449	                }
 21450	                if last.map(|prev| (x - prev).abs() <= tol).unwrap_or(false) {
 21451	                    continue;
 21452	                }
 21453	                support.push(x);
 21454	                last = Some(x);
 21455	            }
 21456	            if support.is_empty() {
 21457	                return Err(BasisError::InvalidInput(format!(
 21458	                    "quantile knot placement requires distinct interior support between {:.6e} and {:.6e}",
 21459	                    minval, maxval
 21460	                )));
 21461	            }
 21462	            let n = support.len();
 21463	            let mut prev_q = minval;
 21464	            for j in 1..=num_internal_knots {
 21465	                let p = j as f64 / (num_internal_knots + 1) as f64;
 21466	                let pos = p * (n.saturating_sub(1) as f64);
 21467	                let lo = pos.floor() as usize;
 21468	                let hi = pos.ceil() as usize;
 21469	                let frac = pos - lo as f64;
 21470	                let q = if lo == hi {
 21471	                    support[lo]
 21472	                } else {
 21473	                    support[lo] * (1.0 - frac) + support[hi] * frac
 21474	                };
 21475	                let q = q.clamp(minval, maxval);
 21476	                if q <= prev_q + tol || q >= maxval - tol {
 21477	                    return Err(BasisError::InvalidInput(format!(
 21478	                        "quantile knot placement produced a non-interior knot at index {}: {:.6e}",
 21479	                        j - 1,
 21480	                        q
 21481	                    )));
 21482	                }
 21483	                knots.push(q);
 21484	                prev_q = q;
 21485	            }
 21486	        }
 21487	
 21488	        for _ in 0..=degree {
 21489	            knots.push(maxval);
 21490	        }
 21491	
 21492	        Ok(Array::from_vec(knots))
 21493	    }
 21494	
 21495	    /// Evaluates all B-spline basis functions at a single point `x`.
 21496	    /// This uses a numerically stable implementation of the Cox-de Boor algorithm,
 21497	    /// based on Algorithm A2.2 from "The NURBS Book" by Piegl and Tiller.
 21498	    ///
 21499	    /// For x outside the spline domain [t_degree, tnum_basis], we apply constant
 21500	    /// boundary extrapolation by clamping x to the nearest boundary before running
 21501	    /// Cox-de Boor recursion.
 21502	    #[inline]
 21503	    pub(super) fn evaluate_splines_at_point_into(
 21504	        x: f64,
 21505	        degree: usize,
 21506	        knots: ArrayView1<f64>,
 21507	        basisvalues: &mut [f64],
 21508	        scratch: &mut BsplineScratch,
 21509	    ) {
 21510	        match degree {
 21511	            3 => evaluate_splines_at_point_fixed::<3>(x, knots, basisvalues, scratch),
 21512	            2 => evaluate_splines_at_point_fixed::<2>(x, knots, basisvalues, scratch),
 21513	            1 => evaluate_splines_at_point_fixed::<1>(x, knots, basisvalues, scratch),
 21514	            _ => evaluate_splines_at_point_dynamic(x, degree, knots, basisvalues, scratch),
 21515	        }
 21516	    }
 21517	
 21518	    #[inline]
 21519	    fn evaluate_spline_local_values(
 21520	        x: f64,
 21521	        degree: usize,
 21522	        knots: ArrayView1<f64>,
 21523	        scratch: &mut BsplineScratch,
 21524	    ) -> (usize, usize) {
 21525	        let num_knots = knots.len();
 21526	        let num_basis = num_knots - degree - 1;
 21527	
 21528	        scratch.ensure_degree(degree);
 21529	        scratch.n.fill(0.0);
 21530	        scratch.left.fill(0.0);
 21531	        scratch.right.fill(0.0);
 21532	
 21533	        let x_eval = x.clamp(knots[degree], knots[num_basis]);
 21534	
 21535	        let mu = {
 21536	            if x_eval >= knots[num_basis] {
 21537	                num_basis - 1
 21538	            } else if x_eval < knots[degree] {
 21539	                degree
 21540	            } else {
 21541	                // Binary search to replace the linear scan
 21542	                //   while span < num_basis && x_eval >= knots[span + 1] { span += 1; }
 21543	                // The loop counts how many of knots[degree+1..=num_basis] are
 21544	                // `<= x_eval`, so `partition_point(|&k| k <= x_eval)` on that
 21545	                // slice gives the same offset from `degree`.
 21546	                let slice = knots
 21547	                    .as_slice()
 21548	                    .expect("B-spline knot vector is contiguous");
 21549	                degree + slice[degree + 1..=num_basis].partition_point(|&k| k <= x_eval)
 21550	            }
 21551	        };
 21552	
 21553	        let left = &mut scratch.left;
 21554	        let right = &mut scratch.right;
 21555	        let n = &mut scratch.n;
 21556	
 21557	        n[0] = 1.0;
 21558	
 21559	        for d in 1..=degree {
 21560	            left[d] = x_eval - knots[mu + 1 - d];
 21561	            right[d] = knots[mu + d] - x_eval;
 21562	
 21563	            let mut saved = 0.0;
 21564	            for r in 0..d {
 21565	                let den = right[r + 1] + left[d - r];
 21566	                let temp = if den.abs() > 1e-12 { n[r] / den } else { 0.0 };
 21567	                n[r] = saved + right[r + 1] * temp;
 21568	                saved = left[d - r] * temp;
 21569	            }
 21570	            n[d] = saved;
 21571	        }
 21572	
 21573	        (mu, num_basis)
 21574	    }
 21575	
 21576	    #[inline]
 21577	    fn evaluate_splines_at_point_fixed<const DEGREE: usize>(
 21578	        x: f64,
 21579	        knots: ArrayView1<f64>,
 21580	        basisvalues: &mut [f64],
 21581	        scratch: &mut BsplineScratch,
 21582	    ) {
 21583	        let (mu, num_basis) = evaluate_spline_local_values(x, DEGREE, knots, scratch);
 21584	        assert_eq!(basisvalues.len(), num_basis);
 21585	        let n = &scratch.n;
 21586	        basisvalues.fill(0.0);
 21587	        for i in 0..=DEGREE {
 21588	            let gi = mu as isize + i as isize - DEGREE as isize;
 21589	            if gi >= 0 {
 21590	                let global_idx = gi as usize;
 21591	                if global_idx < num_basis {
 21592	                    basisvalues[global_idx] = n[i];
 21593	                }
 21594	            }
 21595	        }
 21596	    }
 21597	
 21598	    #[inline]
 21599	    fn evaluate_splines_at_point_dynamic(
 21600	        x: f64,
 21601	        degree: usize,
 21602	        knots: ArrayView1<f64>,
 21603	        basisvalues: &mut [f64],
 21604	        scratch: &mut BsplineScratch,
 21605	    ) {
 21606	        let (mu, num_basis) = evaluate_spline_local_values(x, degree, knots, scratch);
 21607	        assert_eq!(basisvalues.len(), num_basis);
 21608	        let n = &scratch.n;
 21609	        basisvalues.fill(0.0);
 21610	        for i in 0..=degree {
 21611	            let gi = mu as isize + i as isize - degree as isize;
 21612	            if gi >= 0 {
 21613	                let global_idx = gi as usize;
 21614	                if global_idx < num_basis {
 21615	                    basisvalues[global_idx] = n[i];
 21616	                }
 21617	            }
 21618	        }
 21619	    }
 21620	
 21621	    /// Evaluates only the non-zero B-spline basis values at a single point `x`.
 21622	    /// Returns the start column for the contiguous support.
 21623	    #[inline]
 21624	    pub(super) fn evaluate_splines_sparse_into(
 21625	        x: f64,
 21626	        degree: usize,
 21627	        knots: ArrayView1<f64>,
 21628	        values: &mut [f64],
 21629	        scratch: &mut BsplineScratch,
 21630	    ) -> usize {
 21631	        let (mu, _) = evaluate_spline_local_values(x, degree, knots, scratch);
 21632	        assert_eq!(values.len(), degree + 1);
 21633	        let n = &scratch.n;
 21634	        for i in 0..=degree {
 21635	            values[i] = n[i];
 21636	        }
 21637	
 21638	        mu.saturating_sub(degree)
 21639	    }
 21640	
 21641	    #[cfg(test)]
 21642	    pub(super) fn evaluate_splines_at_point(
 21643	        x: f64,
 21644	        degree: usize,
 21645	        knots: ArrayView1<f64>,
 21646	    ) -> Array1<f64> {
 21647	        let num_knots = knots.len();
 21648	        let num_basis = num_knots - degree - 1;
 21649	        let mut basisvalues = Array1::zeros(num_basis);
 21650	        let mut scratch = BsplineScratch::new(degree);
 21651	        evaluate_splines_at_point_into(
 21652	            x,
 21653	            degree,
 21654	            knots,
 21655	            basisvalues
 21656	                .as_slice_mut()
 21657	                .expect("basis row should be contiguous"),
 21658	            &mut scratch,
 21659	        );
 21660	        basisvalues
 21661	    }
 21662	}
