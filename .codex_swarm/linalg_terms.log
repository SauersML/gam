   808	impl std::fmt::Debug for CanonicalPenalty {
   809	    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
   810	        f.debug_struct("CanonicalPenalty")
   811	            .field(
   812	                "root",
   813	                &format_args!("{}×{}", self.root.nrows(), self.root.ncols()),
   814	            )
   815	            .field("col_range", &self.col_range)
   816	            .field("total_dim", &self.total_dim)
   817	            .field("nullity", &self.nullity)
   818	            .field(
   819	                "local",
   820	                &format_args!("{}×{}", self.local.nrows(), self.local.ncols()),
   821	            )
   822	            .field("prior_mean_len", &self.prior_mean.len())
   823	            .field("positive_eigenvalues", &self.positive_eigenvalues)
   824	            .field("op", &self.op.as_ref().map(|o| o.dim()))
   825	            .finish()
