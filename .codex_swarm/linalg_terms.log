   273	
   274	impl<'a> DenseRightProductView<'a> {
   275	    pub fn new(base: &'a Array2<f64>) -> Self {
   276	        Self {
   277	            base,
   278	            first: None,
   279	            second: None,
   280	        }
   281	    }
   282	
   283	    pub fn with_factor(mut self, factor: &'a Array2<f64>) -> Self {
   284	        if self.first.is_none() {
   285	            self.first = Some(factor);
   286	        } else if self.second.is_none() {
   287	            self.second = Some(factor);
   288	        } else {
   289	            panic!("DenseRightProductView supports at most two right factors");
   290	        }
   291	        self
   292	    }
   293	
   294	    pub fn with_optional_factor(self, factor: Option<&'a Array2<f64>>) -> Self {
