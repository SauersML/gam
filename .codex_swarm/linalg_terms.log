   405	// Lightweight aggregate profiler: count calls and accumulate per-stage time
   406	// across the whole fit, then dump once at the end. Avoids per-call eprintln
   407	// stderr-lock overhead that would dominate the very thing we're measuring.
   408	//
   409	// SAFETY/CORRECTNESS: temporary scaffolding for the symbolic-Cholesky-reuse
   410	// perf investigation. Atomics are used so the counters work across threads.
   411	use std::sync::atomic::{AtomicU64, Ordering};
   412	pub static PROF_FAC_COUNT: AtomicU64 = AtomicU64::new(0);
   413	pub static PROF_FAC_TOTAL_NS: AtomicU64 = AtomicU64::new(0);
   414	pub static PROF_FAC_CHOL_NS: AtomicU64 = AtomicU64::new(0);
   415	pub static PROF_FAC_LOGDET_NS: AtomicU64 = AtomicU64::new(0);
   416	pub static PROF_FAC_CANON_NS: AtomicU64 = AtomicU64::new(0);
   417	
   418	pub fn prof_fac_dump_and_reset(label: &str) {
   419	    let calls = PROF_FAC_COUNT.swap(0, Ordering::SeqCst);
   420	    let total_ns = PROF_FAC_TOTAL_NS.swap(0, Ordering::SeqCst);
   421	    let chol_ns = PROF_FAC_CHOL_NS.swap(0, Ordering::SeqCst);
   422	    let logdet_ns = PROF_FAC_LOGDET_NS.swap(0, Ordering::SeqCst);
   423	    let canon_ns = PROF_FAC_CANON_NS.swap(0, Ordering::SeqCst);
   424	    eprintln!(
   425	        "[PROF-AGG {label}] factorize_sparse_spd calls={calls} total={:.3}s canon={:.3}s chol={:.3}s logdet={:.3}s",
   426	        total_ns as f64 / 1e9,
   427	        canon_ns as f64 / 1e9,
   428	        chol_ns as f64 / 1e9,
   429	        logdet_ns as f64 / 1e9,
   430	    );
   431	}
   432	
   433	pub fn factorize_sparse_spd(
   434	    h: &SparseColMat<usize, f64>,
   435	) -> Result<SparseExactFactor, EstimationError> {
   436	    // Canonicalize to symmetric-upper storage before factorization.
   437	    //
   438	    // Math contract:
   439	    // - If callers pass upper-only storage, values are preserved.
   440	    // - If callers pass full symmetric storage, paired (i,j)/(j,i) entries are averaged.
   441	    // - If callers pass lower-only storage, it is mirrored into upper.
   442	    //
   443	    // This prevents off-diagonal double counting in paths that interpret input as
   444	    // symmetric-upper and makes the sparse factor path robust to caller encoding.
   445	    let t_start = std::time::Instant::now();
   446	    let n_input = h.ncols();
   447	    let canon_t = std::time::Instant::now();
   448	    let h_upper = canonicalize_sparse_symmetric_upper(h, ZERO_TOL)?;
   449	    PROF_FAC_CANON_NS.fetch_add(canon_t.elapsed().as_nanos() as u64, Ordering::Relaxed);
   450	    let chol_t = std::time::Instant::now();
   451	    let factor = h_upper.as_ref().sp_cholesky(Side::Upper).map_err(|_| {
   452	        EstimationError::ModelIsIllConditioned {
   453	            condition_number: f64::INFINITY,
   454	        }
   455	    })?;
   456	    PROF_FAC_CHOL_NS.fetch_add(chol_t.elapsed().as_nanos() as u64, Ordering::Relaxed);
   457	    // Keep an explicit simplicial LLᵀ factor in addition to faer's solver
   458	    // object. The raw L is needed by callers that must reconstruct H in a
   459	    // changed basis, such as active-constraint tangent projection.
   460	    let logdet_t = std::time::Instant::now();
   461	    let simplicial = factorize_simplicial_canonical_upper(&h_upper)?;
   462	    let logdet = simplicial.logdet;
   463	    PROF_FAC_LOGDET_NS.fetch_add(logdet_t.elapsed().as_nanos() as u64, Ordering::Relaxed);
   464	    let elapsed_ms = t_start.elapsed().as_secs_f64() * 1000.0;
   465	    PROF_FAC_COUNT.fetch_add(1, Ordering::Relaxed);
   466	    PROF_FAC_TOTAL_NS.fetch_add(t_start.elapsed().as_nanos() as u64, Ordering::Relaxed);
   467	    if elapsed_ms > 100.0 {
   468	        log::info!(
   469	            "[sparse-chol] factorize_sparse_spd | n={} | {:.1}ms",
   470	            n_input,
   471	            elapsed_ms
   472	        );
   473	    }
   474	    Ok(SparseExactFactor {
   475	        factor,
   476	        simplicial: Arc::new(simplicial),
   477	        n: h_upper.ncols(),
   478	        logdet,
   479	    })
   480	}
   481	
   482	fn canonicalize_sparse_symmetric_upper(
   483	    matrix: &SparseColMat<usize, f64>,
   484	    tol: f64,
   485	) -> Result<SparseColMat<usize, f64>, EstimationError> {
   486	    if matrix.nrows() != matrix.ncols() {
   487	        return Err(EstimationError::InvalidInput(format!(
   488	            "sparse SPD factorization requires square matrix, got {}x{}",
   489	            matrix.nrows(),
   490	            matrix.ncols()
   491	        )));
   492	    }
   493	
   494	    #[derive(Default, Clone, Copy)]
   495	    struct PairAccum {
   496	        upper_sum: f64,
   497	        upper_count: usize,
   498	        lower_sum: f64,
   499	        lower_count: usize,
   500	    }
   501	
   502	    let mut accum: BTreeMap<(usize, usize), PairAccum> = BTreeMap::new();
   503	    let (symbolic, values) = matrix.parts();
   504	    let col_ptr = symbolic.col_ptr();
   505	    let row_idx = symbolic.row_idx();
   506	
   507	    for col in 0..matrix.ncols() {
   508	        let start = col_ptr[col];
   509	        let end = col_ptr[col + 1];
   510	        for idx in start..end {
   511	            let row = row_idx[idx];
   512	            let value = values[idx];
   513	            let (r, c, is_upper) = if row <= col {
   514	                (row, col, true)
   515	            } else {
   516	                (col, row, false)
   517	            };
   518	            let slot = accum.entry((r, c)).or_default();
   519	            if is_upper {
   520	                slot.upper_sum += value;
   521	                slot.upper_count += 1;
   522	            } else {
   523	                slot.lower_sum += value;
   524	                slot.lower_count += 1;
   525	            }
   526	        }
   527	    }
   528	
   529	    let mut triplets = Vec::<Triplet<usize, usize, f64>>::new();
   530	    for ((row, col), slot) in accum {
   531	        let value = if row == col {
   532	            let count = slot.upper_count + slot.lower_count;
   533	            if count == 0 {
   534	                0.0
   535	            } else {
   536	                (slot.upper_sum + slot.lower_sum) / (count as f64)
   537	            }
   538	        } else {
   539	            let upper_avg = if slot.upper_count > 0 {
   540	                Some(slot.upper_sum / (slot.upper_count as f64))
   541	            } else {
   542	                None
   543	            };
   544	            let lower_avg = if slot.lower_count > 0 {
   545	                Some(slot.lower_sum / (slot.lower_count as f64))
   546	            } else {
   547	                None
   548	            };
   549	            match (upper_avg, lower_avg) {
   550	                (Some(u), Some(l)) => 0.5 * (u + l),
   551	                (Some(u), None) => u,
   552	                (None, Some(l)) => l,
   553	                (None, None) => 0.0,
   554	            }
   555	        };
   556	
   557	        if value.abs() > tol {
   558	            triplets.push(Triplet::new(row, col, value));
   559	        }
   560	    }
   561	
   562	    SparseColMat::try_new_from_triplets(matrix.nrows(), matrix.ncols(), &triplets).map_err(|_| {
   563	        EstimationError::InvalidInput(
   564	            "failed to canonicalize sparse matrix to symmetric-upper CSC".to_string(),
   565	        )
   566	    })
   567	}
