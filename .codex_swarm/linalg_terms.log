   326	pub(crate) fn addridge(matrix: &Array2<f64>, ridge: f64) -> Array2<f64> {
   327	    if ridge <= 0.0 {
   328	        return matrix.clone();
   329	    }
   330	    let mut regularized = matrix.clone();
   331	    let n = regularized.nrows();
   332	    for i in 0..n {
   333	        regularized[[i, i]] += ridge;
   334	    }
   335	    regularized
   336	}
