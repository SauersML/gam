   383	pub fn sparse_symmetric_upper_matvec_public<S: Data<Elem = f64>>(
   384	    matrix: &SparseColMat<usize, f64>,
   385	    vector: &ArrayBase<S, Ix1>,
   386	) -> Array1<f64> {
   387	    let mut out = Array1::<f64>::zeros(matrix.nrows());
   388	    let (symbolic, values) = matrix.parts();
   389	    let col_ptr = symbolic.col_ptr();
   390	    let row_idx = symbolic.row_idx();
   391	    for col in 0..matrix.ncols() {
   392	        let x_col = vector[col];
   393	        for idx in col_ptr[col]..col_ptr[col + 1] {
   394	            let row = row_idx[idx];
   395	            let value = values[idx];
   396	            out[row] += value * x_col;
   397	            if row != col {
   398	                out[col] += value * vector[row];
   399	            }
   400	        }
   401	    }
   402	    out
   403	}
