  1116	fn generate_basis_internal<S: BasisStorage>(
  1117	    data: ArrayView1<f64>,
  1118	    knotview: ArrayView1<f64>,
  1119	    degree: usize,
  1120	    eval_kind: BasisEvalKind,
  1121	) -> Result<S::Output, BasisError> {
  1122	    let num_basis_functions = knotview.len().saturating_sub(degree + 1);
  1123	    let support = degree + 1;
  1124	    // Parallel dispatch heuristic:
  1125	    // Lower degrees have cheaper per-row evaluation and need larger batches to
  1126	    // amortize Rayon scheduling overhead. Cubic+ rows are costlier, so parallel
  1127	    // wins earlier.
  1128	    let par_threshold = match degree {
  1129	        0 | 1 => 512,
  1130	        2 | 3 => 128,
  1131	        _ => 64,
  1132	    };
  1133	    let use_parallel = data.len() >= par_threshold && data.as_slice().is_some();
  1134	    S::build(
  1135	        data,
  1136	        knotview,
  1137	        degree,
  1138	        eval_kind,
  1139	        num_basis_functions,
  1140	        support,
  1141	        use_parallel,
  1142	    )
  1143	}
