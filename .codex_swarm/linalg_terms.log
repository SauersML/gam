 14211	/// Evaluate the Wahba sphere reproducing kernel at a single `cos γ`. The
 14212	/// choice of underlying RKHS — Sobolev or pseudo-spline — is selected by
 14213	/// `kernel`. Both options are positive-definite on S² for every supported
 14214	/// `penalty_order ∈ {1, 2, 3, 4}`.
 14215	#[inline]
 14216	fn wahba_sphere_kernel_from_cos_kind(
 14217	    cos_gamma: f64,
 14218	    penalty_order: usize,
 14219	    kernel: SphereWahbaKernel,
 14220	) -> Result<f64, BasisError> {
 14221	    if !(1..=4).contains(&penalty_order) {
