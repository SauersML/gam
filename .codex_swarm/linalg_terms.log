  1282	/// Selects Greville abscissae for difference-penalty scaling when knot geometry is non-uniform.
  1283	///
  1284	/// For regular, uniformly spaced breakpoint grids this returns `None` to preserve
  1285	/// classical P-spline integer-difference penalties. For irregular grids (including
  1286	/// repeated interior knots), this returns `Some(Greville)` so divided-difference
  1287	/// scaling is applied by [`create_difference_penalty_matrix`].
  1288	pub fn penalty_greville_abscissae_for_knots(
  1289	    knot_vector: &Array1<f64>,
  1290	    degree: usize,
  1291	) -> Result<Option<Array1<f64>>, BasisError> {
  1292	    if is_effectively_uniform_knot_geometry(knot_vector, degree) {
  1293	        Ok(None)
  1294	    } else {
  1295	        Ok(Some(compute_greville_abscissae(knot_vector, degree)?))
  1296	    }
  1297	}
