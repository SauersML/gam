 20169	/// constraint `P(C)^T α = 0` is overdetermined and the basis collapses.
 20170	#[inline(always)]
 20171	fn d_canonical_tps_infeasible(dimension: usize, num_centers: usize) -> bool {
 20172	    num_centers < thin_plate_polynomial_basis_dimension(dimension)
 20173	}
