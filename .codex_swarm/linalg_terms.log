   982	/// Detect and report structurally identical (or near-identical) penalty pairs
   983	/// in the canonical bundle.
   984	///
   985	/// Two penalties `S_i`, `S_j` with the same `col_range` are compared by their
   986	/// matrix cosine:
   987	///
   988	///     cos(S_i, S_j) = tr(S_i S_j) / sqrt(tr(S_i^2) * tr(S_j^2))
   989	///
   990	/// Because `local` is symmetric, `tr(A·B) = sum_{r,c} A[r,c] * B[r,c]` — i.e.,
   991	/// the Frobenius inner product. Pairs with different `col_range` cannot be
   992	/// functionally identical and are skipped.
   993	///
   994	/// Logging policy:
   995	/// - `cos > 1 - 1e-8` → `log::warn!` with `[PENALTY-REDUNDANCY]`. Every such
   996	///   pair is emitted because it represents a structural model error (the LAML
   997	///   cost has a Z₂-symmetric saddle that ARC's cubic regularization will
   998	///   happily converge to under first-order stationarity).
   999	/// - `0.99 < cos ≤ 1 - 1e-8` → `log::info!` with `[PENALTY-SIMILARITY]`.
  1000	///   At biobank scale (`k > 64`) only the top-3 highest-cosine such pairs are
  1001	///   logged to bound log volume.
  1002	///
  1003	/// Returns `Vec<(i, j, cos)>` for the **redundant** pairs (cos > 1 - 1e-8),
  1004	/// primarily to make this function unit-testable without a log capture.
  1005	///
  1006	/// Performance: this is O(k² · block_dim²); intended to be called exactly
  1007	/// once per fit (e.g. from `RemlState::newwith_offset_shared`).
  1008	pub fn report_penalty_pair_redundancy(canonical: &[CanonicalPenalty]) -> Vec<(usize, usize, f64)> {
  1009	    const REDUNDANCY_THRESHOLD: f64 = 1.0 - 1e-8;
  1010	    const SIMILARITY_THRESHOLD: f64 = 0.99;
  1011	    const BIOBANK_K_THRESHOLD: usize = 64;
  1012	    const TOP_SIMILARITY_PAIRS: usize = 3;
  1013	
  1014	    let k = canonical.len();
  1015	    let mut redundant: Vec<(usize, usize, f64)> = Vec::new();
  1016	    let mut similar: Vec<(usize, usize, f64)> = Vec::new();
  1017	
  1018	    // Pre-compute tr(S_i^2) = sum of squares of S_i entries (Frobenius norm
  1019	    // squared). `local` is symmetric, so this equals tr(S_i^T S_i) = tr(S_i^2).
  1020	    let trace_sq: Vec<f64> = canonical
  1021	        .iter()
  1022	        .map(|p| p.local.iter().map(|&v| v * v).sum::<f64>())
  1023	        .collect();
  1024	
  1025	    for i in 0..k {
  1026	        if trace_sq[i] == 0.0 {
  1027	            continue;
  1028	        }
  1029	        for j in (i + 1)..k {
  1030	            if trace_sq[j] == 0.0 {
  1031	                continue;
  1032	            }
  1033	            // Different col_range → cannot be functionally identical by
  1034	            // construction (the block-local matrices live in disjoint or
  1035	            // mismatched parameter subspaces).
  1036	            if canonical[i].col_range != canonical[j].col_range {
  1037	                continue;
  1038	            }
  1039	            // Shapes must match — they do when col_range matches because
  1040	            // `local` is `block_dim × block_dim` and `block_dim = col_range.len()`.
  1041	            debug_assert_eq!(canonical[i].local.dim(), canonical[j].local.dim());
  1042	
  1043	            let inner: f64 = canonical[i]
  1044	                .local
  1045	                .iter()
  1046	                .zip(canonical[j].local.iter())
  1047	                .map(|(&a, &b)| a * b)
  1048	                .sum();
  1049	            let denom = (trace_sq[i] * trace_sq[j]).sqrt();
  1050	            if denom == 0.0 {
  1051	                continue;
  1052	            }
  1053	            let cos = inner / denom;
  1054	
  1055	            if cos > REDUNDANCY_THRESHOLD {
  1056	                redundant.push((i, j, cos));
  1057	            } else if cos > SIMILARITY_THRESHOLD {
  1058	                similar.push((i, j, cos));
  1059	            }
  1060	        }
  1061	    }
  1062	
  1063	    // Always emit every redundancy — these are structural model errors.
  1064	    for &(i, j, cos) in &redundant {
  1065	        log::warn!(
  1066	            "[PENALTY-REDUNDANCY] penalties i={i} j={j} are structurally identical \
  1067	             (cos={cos:.6}) — model is over-parameterized along their antisymmetric \
  1068	             direction; expect a Z₂-symmetric saddle in the LAML cost. Consider \
  1069	             re-specifying (e.g. anisotropic→isotropic for spatial smoothers with \
  1070	             weak axis signal)."
  1071	        );
  1072	    }
  1073	
  1074	    // Cap similarity log volume at biobank scale.
  1075	    if k > BIOBANK_K_THRESHOLD && similar.len() > TOP_SIMILARITY_PAIRS {
  1076	        similar.sort_by(|a, b| b.2.partial_cmp(&a.2).unwrap_or(std::cmp::Ordering::Equal));
  1077	        similar.truncate(TOP_SIMILARITY_PAIRS);
  1078	    }
  1079	    for (i, j, cos) in similar {
  1080	        log::info!(
  1081	            "[PENALTY-SIMILARITY] penalties i={i} j={j} are near-identical \
  1082	             (cos={cos:.6}) — outer Hessian may be ill-conditioned along their \
  1083	             antisymmetric direction."
  1084	        );
  1085	    }
  1086	
  1087	    redundant
  1088	}
  1089	
  1090	/// Canonicalize a single `PenaltySpec` into a `CanonicalPenalty` by computing
  1091	/// the block-local eigendecomposition and extracting the root.
  1092	///
  1093	/// This is O(block_dim^3) instead of O(p^3) for block-local penalties.
  1094	/// Returns `None` if the penalty has rank zero (should be dropped).
  1095	pub fn canonicalize_penalty_spec(
  1096	    spec: &crate::estimate::PenaltySpec,
  1097	    p: usize,
  1098	    idx: usize,
  1099	    context: &str,
  1100	) -> Result<Option<CanonicalPenalty>, EstimationError> {
  1101	    use crate::estimate::PenaltySpec;
  1102	
  1103	    let (local_matrix, col_range, prior_mean_spec, hint, op) = match spec {
  1104	        PenaltySpec::Block {
  1105	            local,
  1106	            col_range,
  1107	            prior_mean,
  1108	            structure_hint,
  1109	            op,
  1110	        } => {
  1111	            let bd = col_range.len();
  1112	            if local.nrows() != bd || local.ncols() != bd {
  1113	                return Err(EstimationError::InvalidInput(format!(
  1114	                    "{context}: block penalty {idx} local matrix must be {bd}x{bd}, got {}x{}",
  1115	                    local.nrows(),
  1116	                    local.ncols()
  1117	                )));
  1118	            }
  1119	            if col_range.end > p {
  1120	                return Err(EstimationError::InvalidInput(format!(
  1121	                    "{context}: block penalty {idx} col_range {}..{} exceeds p={p}",
  1122	                    col_range.start, col_range.end
  1123	                )));
  1124	            }
  1125	            (
  1126	                local.view(),
  1127	                col_range.clone(),
  1128	                prior_mean,
  1129	                structure_hint.as_ref(),
  1130	                op.clone(),
  1131	            )
  1132	        }
  1133	        PenaltySpec::Dense(m) => {
  1134	            if m.nrows() != p || m.ncols() != p {
  1135	                return Err(EstimationError::InvalidInput(format!(
  1136	                    "{context}: dense penalty {idx} must be {p}x{p}, got {}x{}",
  1137	                    m.nrows(),
  1138	                    m.ncols()
  1139	                )));
  1140	            }
  1141	            (
  1142	                m.view(),
  1143	                0..p,
  1144	                &crate::estimate::CoefficientPriorMean::Zero,
  1145	                None,
  1146	                None,
  1147	            )
  1148	        }
  1149	        PenaltySpec::DenseWithMean { matrix, prior_mean } => {
  1150	            if matrix.nrows() != p || matrix.ncols() != p {
  1151	                return Err(EstimationError::InvalidInput(format!(
  1152	                    "{context}: dense penalty {idx} must be {p}x{p}, got {}x{}",
  1153	                    matrix.nrows(),
  1154	                    matrix.ncols()
  1155	                )));
  1156	            }
  1157	            (matrix.view(), 0..p, prior_mean, None, None)
  1158	        }
  1159	    };
  1160	
  1161	    let block_dim = col_range.len();
  1162	    let prior_mean = prior_mean_spec.evaluate(block_dim, &format!("{context}: penalty {idx}"))?;
  1163	
  1164	    // ── Ridge fast path: closed-form, no eigendecomposition ──
  1165	    if let Some(PenaltyStructureHint::Ridge(scale)) = hint {
  1166	        if *scale <= 0.0 {
  1167	            return Ok(None);
  1168	        }
  1169	        let sqrt_scale = scale.sqrt();
  1170	        let mut root = Array2::zeros((block_dim, block_dim));
  1171	        for i in 0..block_dim {
  1172	            root[[i, i]] = sqrt_scale;
  1173	        }
  1174	        // Ridge penalties are diagonal ⟹ already symmetric, but symmetrize
  1175	        // for consistency with the generic path.
  1176	        let local_owned = local_matrix.to_owned();
  1177	        let local_sym = (&local_owned + &local_owned.t()) * 0.5;
  1178	        return Ok(Some(CanonicalPenalty {
  1179	            root,
  1180	            col_range,
  1181	            total_dim: p,
  1182	            nullity: 0,
  1183	            local: local_sym,
  1184	            prior_mean,
  1185	            positive_eigenvalues: vec![*scale; block_dim],
  1186	            op,
  1187	        }));
  1188	    }
  1189	
  1190	    // ── Kronecker fast path: single per-factor eigendecomposition ──
  1191	    if let Some(PenaltyStructureHint::Kronecker(factors)) = hint {
  1192	        let decomps =
  1193	            match decompose_kronecker_factors(factors, &format!("{context} penalty {idx}"))? {
  1194	                None => return Ok(None),
  1195	                Some(d) => d,
  1196	            };
  1197	        let (positive_eigenvalues, nullity) = kronecker_eigenvalues(&decomps, block_dim);
  1198	        if positive_eigenvalues.is_empty() {
  1199	            return Ok(None);
  1200	        }
  1201	        let root = assemble_kronecker_root_local(&decomps);
  1202	        let local_owned = local_matrix.to_owned();
  1203	        let local_sym = (&local_owned + &local_owned.t()) * 0.5;
  1204	        return Ok(Some(CanonicalPenalty {
  1205	            root,
  1206	            col_range,
  1207	            total_dim: p,
  1208	            nullity,
  1209	            local: local_sym,
  1210	            prior_mean,
  1211	            positive_eigenvalues,
  1212	            op,
  1213	        }));
  1214	    }
  1215	
  1216	    // ── Generic block-local path: eigendecompose at O(block_dim³) ──
  1217	    let local_owned = local_matrix.to_owned();
  1218	    let analysis = analyze_penalty_block(&local_owned).map_err(|err| {
  1219	        EstimationError::InvalidInput(format!(
  1220	            "{context}: penalty canonicalization failed at index {idx}: {err}"
  1221	        ))
  1222	    })?;
  1223	
  1224	    if analysis.rank == 0 {
  1225	        log::debug!(
  1226	            "Dropped inactive penalty block idx={idx} reason={}",
  1227	            if analysis.iszero {
  1228	                "ZeroMatrix"
  1229	            } else {
  1230	                "NumericalRankZero"
  1231	            }
  1232	        );
  1233	        return Ok(None);
  1234	    }
  1235	
  1236	    // Reuse eigendecomposition from analyze_penalty_block — no double eigendecomp.
  1237	    let tolerance = analysis.tol;
  1238	    let rank_k = analysis.rank;
  1239	
  1240	    let mut root = Array2::zeros((rank_k, block_dim));
  1241	    let mut positive_eigenvalues = Vec::with_capacity(rank_k);
  1242	    let mut row_idx = 0;
  1243	    for (i, &eigenval) in analysis.eigenvalues.iter().enumerate() {
  1244	        if eigenval > tolerance {
  1245	            let sqrt_eigenval = eigenval.sqrt();
  1246	            let eigenvec = analysis.eigenvectors.column(i);
  1247	            root.row_mut(row_idx).assign(&(&eigenvec * sqrt_eigenval));
  1248	            positive_eigenvalues.push(eigenval);
  1249	            row_idx += 1;
  1250	        }
  1251	    }
  1252	
  1253	    // Store the PSD reconstruction R^T R rather than the raw symmetrised input so
  1254	    // the cached `local` matches the rank truncation embedded in `root`. Closed-
  1255	    // form Duchon kernels at high d can leave |O(1)| negative eigenvalues in the
  1256	    // symmetrised input that the canonical root drops; keeping them in `local`
  1257	    // poisons the balanced-sum eigendecomposition and breaks the q_pen / q_null
  1258	    // invariant that downstream stages require.
  1259	    let local = root.t().dot(&root);
  1260	    Ok(Some(CanonicalPenalty {
  1261	        root,
  1262	        col_range,
  1263	        total_dim: p,
  1264	        nullity: analysis.nullity,
  1265	        local,
  1266	        prior_mean,
  1267	        positive_eigenvalues,
  1268	        op,
  1269	    }))
  1270	}
