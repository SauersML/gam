   278	#[cfg(debug_assertions)]
   279	fn orthogonal_similarity_transform_faer(
   280	    matrix: &Mat<f64>,
   281	    block_dim: usize,
   282	    orthogonal: &Mat<f64>,
   283	) -> Mat<f64> {
   284	    let matrix_block = matrix.as_ref().submatrix(0, 0, block_dim, block_dim);
   285	    let cols = orthogonal.ncols();
   286	    let mut temp = Mat::<f64>::zeros(block_dim, cols);
   287	    matmul(
   288	        temp.as_mut(),
   289	        Accum::Replace,
   290	        matrix_block,
   291	        orthogonal.as_ref(),
   292	        1.0,
   293	        Par::Seq,
   294	    );
   295	    let mut rotated = Mat::<f64>::zeros(cols, cols);
   296	    matmul(
   297	        rotated.as_mut(),
   298	        Accum::Replace,
   299	        orthogonal.transpose(),
   300	        temp.as_ref(),
   301	        1.0,
   302	        Par::Seq,
   303	    );
   304	    symmetrize_faer_matrix_in_place(&mut rotated);
   305	    rotated
   306	}
   307	
   308	fn trace_penalty_in_orthogonal_basis(
   309	    matrix: &Mat<f64>,
   310	    block_dim: usize,
   311	    orthogonal: &Mat<f64>,
   312	    rotated_eigenvalues: &[f64],
   313	    delta: f64,
   314	) -> f64 {
   315	    let matrix_block = matrix.as_ref().submatrix(0, 0, block_dim, block_dim);
   316	    let cols = orthogonal.ncols();
   317	    debug_assert!(rotated_eigenvalues.len() >= cols);
   318	    let mut projected = Mat::<f64>::zeros(block_dim, cols);
   319	    matmul(
   320	        projected.as_mut(),
   321	        Accum::Replace,
   322	        matrix_block,
   323	        orthogonal.as_ref(),
   324	        1.0,
   325	        Par::Seq,
   326	    );
   327	    let mut trace = KahanSum::default();
   328	    for l in 0..cols {
   329	        let mut diag_ll = KahanSum::default();
   330	        for i in 0..block_dim {
   331	            diag_ll.add(orthogonal[(i, l)] * projected[(i, l)]);
   332	        }
   333	        trace.add(diag_ll.sum() / (rotated_eigenvalues[l] + delta));
   334	    }
   335	    trace.sum()
   336	}
