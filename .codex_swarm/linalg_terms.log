   207	/// Compute A^T * A into a pre-allocated output buffer.
   208	/// `out` must be shaped (p, p) where A is (n, p).
   209	#[inline]
   210	pub fn fast_ata_into<S: Data<Elem = f64>>(a: &ArrayBase<S, Ix2>, out: &mut Array2<f64>) {
   211	    use faer::Accum;
   212	    use faer::linalg::matmul::triangular::{BlockStructure, matmul as tri_matmul};
   213	
   214	    let (n, p) = a.dim();
   215	    debug_assert_eq!(out.nrows(), p, "output rows must match p");
   216	    debug_assert_eq!(out.ncols(), p, "output cols must match p");
   217	
   218	    if !should_use_faer_matmul(p, p, n) {
   219	        out.assign(&a.t().dot(a));
   220	        return;
   221	    }
   222	
   223	    let mut outview = array2_to_matmut(out);
   224	
   225	    let aview = FaerArrayView::new(a);
   226	    let a_ref = aview.as_ref();
   227	    let a_t = a_ref.transpose();
   228	    let par = matmul_parallelism(p, p, n);
   229	    // A^T * A is symmetric; write only the lower triangle then mirror.
   230	    tri_matmul(
   231	        outview.as_mut(),
   232	        BlockStructure::TriangularLower,
   233	        Accum::Replace,
   234	        a_t,
   235	        BlockStructure::Rectangular,
   236	        a_ref,
   237	        BlockStructure::Rectangular,
   238	        1.0,
   239	        par,
   240	    );
   241	    mirror_lower_to_upper(out);
   242	}
