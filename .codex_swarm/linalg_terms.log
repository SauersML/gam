 22061	/// Zero-allocation version: pass pre-allocated buffers for lower_basis and scratch.
 22062	/// - `lower_basis`: length = knot_vector.len() - degree
 22063	/// - `lower_scratch`: BsplineScratch for degree-1
 22064	pub fn evaluate_bspline_derivative_scalar_into(
 22065	    x: f64,
 22066	    knot_vector: ArrayView1<f64>,
 22067	    degree: usize,
 22068	    out: &mut [f64],
 22069	    lower_basis: &mut [f64],
 22070	    lower_scratch: &mut internal::BsplineScratch,
 22071	) -> Result<(), BasisError> {
 22072	    validate_knots_for_degree(knot_vector, degree)?;
 22073	
 22074	    let num_basis = knot_vector.len() - degree - 1;
 22075	    if out.len() != num_basis {
 22076	        return Err(BasisError::InvalidKnotVector(format!(
 22077	            "Output buffer length {} does not match number of basis functions {}",
 22078	            out.len(),
 22079	            num_basis
 22080	        )));
 22081	    }
 22082	
 22083	    let num_basis_lower = knot_vector.len() - degree;
 22084	    if lower_basis.len() < num_basis_lower {
 22085	        return Err(BasisError::InvalidKnotVector(format!(
 22086	            "lower_basis buffer too small: {} < {}",
 22087	            lower_basis.len(),
 22088	            num_basis_lower
 22089	        )));
 22090	    }
 22091	
 22092	    // Fill lower basis with zeros
 22093	    for v in lower_basis.iter_mut().take(num_basis_lower) {
 22094	        *v = 0.0;
 22095	    }
 22096	
 22097	    let x_eval = one_sided_derivative_eval_point(x, knot_vector, degree);
 22098	
 22099	    // Evaluate lower-degree (k-1) basis functions
 22100	    internal::evaluate_splines_at_point_into(
 22101	        x_eval,
 22102	        degree - 1,
 22103	        knot_vector,
 22104	        &mut lower_basis[..num_basis_lower],
 22105	        lower_scratch,
 22106	    );
 22107	
 22108	    // Apply derivative formula: B'_{i,k}(x) = k * (B_{i,k-1}/(t_{i+k}-t_i) - B_{i+1,k-1}/(t_{i+k+1}-t_{i+1}))
 22109	    let k = degree as f64;
 22110	    for i in 0..num_basis {
 22111	        let denom_left = knot_vector[i + degree] - knot_vector[i];
 22112	        let denom_right = knot_vector[i + degree + 1] - knot_vector[i + 1];
 22113	
 22114	        let left_term = if denom_left.abs() > 1e-12 && i < num_basis_lower {
 22115	            lower_basis[i] / denom_left
 22116	        } else {
 22117	            0.0
 22118	        };
 22119	
 22120	        let right_term = if denom_right.abs() > 1e-12 && (i + 1) < num_basis_lower {
 22121	            lower_basis[i + 1] / denom_right
 22122	        } else {
 22123	            0.0
 22124	        };
 22125	
 22126	        out[i] = k * (left_term - right_term);
 22127	    }
 22128	
 22129	    Ok(())
 22130	}
