   115	/// Factorize a symmetric system with LLT -> LDLT -> LBLT fallback.
   116	#[inline]
   117	pub fn factorize_symmetricwith_fallback(
   118	    matrix: MatRef<'_, f64>,
   119	    side: Side,
   120	) -> Result<FaerSymmetricFactor, FaerLinalgError> {
   121	    if let Ok(llt) = FaerLlt::new(matrix, side) {
   122	        return Ok(FaerSymmetricFactor::Llt(llt));
   123	    }
   124	    let ldlt_err = match FaerLdlt::new(matrix, side) {
   125	        Ok(ldlt) => return Ok(FaerSymmetricFactor::Ldlt(ldlt)),
   126	        Err(err) => err,
   127	    };
   128	    let lblt = catch_unwind(AssertUnwindSafe(|| FaerLblt::new(matrix, side)))
   129	        .map_err(|_| FaerLinalgError::Ldlt(ldlt_err))?;
   130	    Ok(FaerSymmetricFactor::Lblt(lblt))
   131	}
