   876	pub fn build_sparse_penalty_blocks_from_canonical(
   877	    penalties: &[crate::construction::CanonicalPenalty],
   878	    p: usize,
   879	) -> Result<Option<Vec<SparsePenaltyBlock>>, EstimationError> {
   880	    if penalties.is_empty() {
   881	        return Ok(Some(Vec::new()));
   882	    }
   883	
   884	    // Check for overlapping ranges.
   885	    let mut sorted_ranges: Vec<(usize, usize, usize)> = penalties
   886	        .iter()
   887	        .enumerate()
   888	        .map(|(i, cp)| (i, cp.col_range.start, cp.col_range.end))
   889	        .collect();
   890	    sorted_ranges.sort_by_key(|&(_, start, _)| start);
   891	    for pair in sorted_ranges.windows(2) {
   892	        let (_, _, end_left) = pair[0];
   893	        let (_, start_right, _) = pair[1];
   894	        if end_left > start_right {
   895	            return Ok(None);
   896	        }
   897	    }
   898	
   899	    use rayon::prelude::*;
   900	
   901	    // `par_iter()` over a slice is indexed, and Rayon preserves the input
   902	    // sequence when collecting into a `Vec`, so the final blocks remain in
   903	    // canonical penalty order even though each block is built independently.
   904	    let block_results: Vec<Result<SparsePenaltyBlock, EstimationError>> = penalties
   905	        .par_iter()
   906	        .enumerate()
   907	        .map(|(term_index, cp)| {
   908	            let p_start = cp.col_range.start;
   909	            let p_end = cp.col_range.end;
   910	            let s_k_block_dense = cp.local_penalty();
   911	            let s_k_sparse = embed_dense_block_to_sparse_symmetric_upper(
   912	                &s_k_block_dense,
   913	                p_start,
   914	                p,
   915	                ZERO_TOL,
   916	            )?;
   917	
   918	            let mut s_k_block_upper_entries = Vec::<(usize, usize, f64)>::new();
   919	            for col in 0..s_k_block_dense.ncols() {
   920	                for row in 0..=col {
   921	                    let value = s_k_block_dense[[row, col]];
   922	                    if value.abs() > ZERO_TOL {
   923	                        s_k_block_upper_entries.push((row, col, value));
   924	                    }
   925	                }
   926	            }
   927	
   928	            Ok(SparsePenaltyBlock {
   929	                term_index,
   930	                p_start,
   931	                p_end,
   932	                positive_eigenvalues: Arc::new(cp.positive_eigenvalues.clone()),
   933	                block_support_strict: true,
   934	                s_k_sparse,
   935	                s_k_block_dense: Arc::new(s_k_block_dense),
   936	                s_k_block_upper_entries: Arc::new(s_k_block_upper_entries),
   937	            })
   938	        })
   939	        .collect();
   940	
   941	    let blocks = block_results.into_iter().collect::<Result<Vec<_>, _>>()?;
   942	    Ok(Some(blocks))
   943	}
