 20129	#[inline(always)]
 20130	fn thin_plate_kernel_from_dist2(dist2: f64, dimension: usize) -> Result<f64, BasisError> {
 20131	    if !dist2.is_finite() || dist2 < 0.0 {
 20132	        return Err(BasisError::InvalidInput(
 20133	            "thin-plate kernel distance must be finite and non-negative".to_string(),
 20134	        ));
 20135	    }
 20136	    if dist2 == 0.0 {
 20137	        return Ok(0.0);
 20138	    }
 20139	    match dimension {
 20140	        // For d≤3, the minimum penalty order m=2 (biharmonic) suffices.
 20141	        // Hand-optimized closed forms avoid the overhead of the general evaluator.
 20142	        //   d=1:  r^3
 20143	        //   d=2:  r^2 log(r)
 20144	        //   d=3: -r
 20145	        1 => Ok(dist2 * dist2.sqrt()),
 20146	        2 => Ok(0.5 * dist2 * dist2.ln()),
 20147	        3 => Ok(-dist2.sqrt()),
 20148	        _ => {
 20149	            // General case: choose the smallest penalty order m with 2m > d,
 20150	            // i.e. m = floor(d/2) + 1, and evaluate via the Duchon polyharmonic
 20151	            // kernel which handles arbitrary (m, d) combinations.
 20152	            let m = dimension / 2 + 1;
 20153	            let r = dist2.sqrt();
 20154	            Ok(polyharmonic_kernel(r, (m) as f64, dimension))
 20155	        }
 20156	    }
 20157	}
