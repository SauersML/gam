 14152	// ============================================================================
 14153	// Wahba 1981 pseudo-spline closed forms (mgcv `bs="sos"` compatible).
 14154	// ============================================================================
 14155	//
 14156	// These polynomials in
 14157	//   w = (1 − cos γ) / 2 = sin²(γ/2)
 14158	//   c = 2 sin(γ/2)
 14159	//   a = ln(1 + 1 / sin(γ/2))
 14160	// are the reproducing kernels for the RKHS with Legendre weights
 14161	//   a_l = 2 / [(l+1)(l+2) ··· (l+m+1)]   (l ≥ 1)
 14162	// (decay rate `l^{−(m+1)}`, different from the Sobolev kernel's
 14163	// `l^{−2m}`). The forms are a verbatim port of mgcv's `makeR()` function
 14164	// and are bit-compatible with `bs="sos"` in R.
 14165	
 14166	#[inline]
 14167	fn wahba_sphere_kernel_pseudo_from_cos(cos_gamma: f64, m: usize) -> f64 {
 14168	    let cg = cos_gamma.clamp(-1.0, 1.0);
 14169	    let z = (1.0 - cg).max(f64::EPSILON * 1.0e-4);
 14170	    let w = 0.5 * z;
 14171	    let c0 = w.sqrt();
 14172	    let a = (1.0 + 1.0 / c0).ln();
 14173	    let c = 2.0 * c0;
 14174	    let two_pi = 2.0 * std::f64::consts::PI;
 14175	    match m {
 14176	        1 => {
 14177	            let q1 = 2.0 * a * w - c + 1.0;
 14178	            (q1 - 0.5) / two_pi
 14179	        }
 14180	        2 => {
 14181	            let w2 = w * w;
 14182	            let q2 = a * (6.0 * w2 - 2.0 * w) - 3.0 * c * w + 3.0 * w + 0.5;
 14183	            (q2 / 2.0 - 1.0 / 6.0) / two_pi
 14184	        }
 14185	        3 => {
 14186	            let w2 = w * w;
 14187	            let w3 = w2 * w;
 14188	            let q3 = (a * (60.0 * w3 - 36.0 * w2) + 30.0 * w2 + c * (8.0 * w - 30.0 * w2)
 14189	                - 3.0 * w
 14190	                + 1.0)
 14191	                / 3.0;
 14192	            (q3 / 6.0 - 1.0 / 24.0) / two_pi
 14193	        }
 14194	        _ => {
 14195	            // m = 4 (and any future m): use the explicit q_4 form from
 14196	            // mgcv `makeR`. q_4 / 24 − 1 / 120, divided by 2π.
 14197	            let w2 = w * w;
 14198	            let w3 = w2 * w;
 14199	            let w4 = w3 * w;
 14200	            let q4 = a * (70.0 * w4 - 60.0 * w3 + 6.0 * w2)
 14201	                + 35.0 * w3 * (1.0 - c)
 14202	                + c * 55.0 * w2 / 3.0
 14203	                - 12.5 * w2
 14204	                - w / 3.0
 14205	                + 0.25;
 14206	            (q4 / 24.0 - 1.0 / 120.0) / two_pi
 14207	        }
 14208	    }
 14209	}
