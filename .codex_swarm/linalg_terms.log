   162	            && self.outer_identifiability.is_none()
   163	    }
   164	
   165	    fn raw_diagonal_value(&self) -> f64 {
   166	        let mut r0: SmallVec<[f64; 16]> = SmallVec::with_capacity(self.centers.ncols());
   167	        r0.resize(self.centers.ncols(), 0.0);
