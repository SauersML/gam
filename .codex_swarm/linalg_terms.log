   101	fn dense_operator_to_dense_by_chunks<O: DenseDesignOperator + ?Sized>(
   102	    op: &O,
   103	) -> Result<Array2<f64>, MatrixMaterializationError> {
   104	    let n = op.nrows();
   105	    let p = op.ncols();
   106	    let chunk_rows = dense_materialization_chunk_rows(n, p);
   107	    let mut out = Array2::<f64>::zeros((n, p));
   108	    for start in (0..n).step_by(chunk_rows) {
   109	        let end = (start + chunk_rows).min(n);
   110	        let slice = out.slice_mut(s![start..end, ..]);
   111	        op.row_chunk_into(start..end, slice)?;
   112	    }
   113	    Ok(out)
   114	}
