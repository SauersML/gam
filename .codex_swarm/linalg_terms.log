 19912	fn polynomial_block_from_order(
 19913	    points: ArrayView2<'_, f64>,
 19914	    order: DuchonNullspaceOrder,
 19915	) -> Array2<f64> {
 19916	    let n = points.nrows();
 19917	    let d = points.ncols();
 19918	    match order {
 19919	        DuchonNullspaceOrder::Zero => Array2::<f64>::ones((n, 1)),
 19920	        DuchonNullspaceOrder::Linear => {
 19921	            let mut poly = Array2::<f64>::zeros((n, d + 1));
 19922	            poly.column_mut(0).fill(1.0);
 19923	            for c in 0..d {
 19924	                poly.column_mut(c + 1).assign(&points.column(c));
 19925	            }
 19926	            poly
 19927	        }
 19928	        DuchonNullspaceOrder::Degree(degree) => monomial_basis_block(points, degree),
 19929	    }
 19930	}
