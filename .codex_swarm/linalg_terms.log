 22132	fn create_mspline_dense(
 22133	    data: ArrayView1<f64>,
 22134	    knot_vector: ArrayView1<f64>,
 22135	    degree: usize,
 22136	) -> Result<Array2<f64>, BasisError> {
 22137	    validate_knots_for_degree(knot_vector, degree)?;
 22138	    validate_mspline_normalization_spans(knot_vector, degree)?;
 22139	    let num_basis = knot_vector.len() - degree - 1;
 22140	    let mut out = Array2::<f64>::zeros((data.len(), num_basis));
 22141	    let mut scratch = internal::BsplineScratch::new(degree);
 22142	    let support = degree + 1;
 22143	    let mut local = vec![0.0; support];
 22144	    let left = knot_vector[degree];
 22145	    let right = knot_vector[num_basis];
 22146	    let order = (degree + 1) as f64;
 22147	    let mut scales = vec![0.0; num_basis];
 22148	    for i in 0..num_basis {
 22149	        let span = knot_vector[i + degree + 1] - knot_vector[i];
 22150	        scales[i] = order / span;
 22151	    }
 22152	
 22153	    for (row_i, &x) in data.iter().enumerate() {
 22154	        if x < left || x > right {
 22155	            continue;
 22156	        }
 22157	        let start = internal::evaluate_splines_sparse_into(
 22158	            x,
 22159	            degree,
 22160	            knot_vector,
 22161	            &mut local,
 22162	            &mut scratch,
 22163	        );
 22164	        for (offset, &b) in local.iter().enumerate() {
 22165	            let j = start + offset;
 22166	            if j < num_basis {
 22167	                out[[row_i, j]] = b * scales[j];
 22168	            }
 22169	        }
 22170	    }
 22171	    Ok(out)
 22172	}
