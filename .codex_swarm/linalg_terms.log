   488	/// Compute A^T * v using faer's SIMD-optimized GEMV.
   489	/// For A of shape (n, p) and v of shape (n,), this computes the (p,) result.
   490	#[inline]
   491	pub fn fast_atv<S1: Data<Elem = f64>, S2: Data<Elem = f64>>(
   492	    a: &ArrayBase<S1, Ix2>,
   493	    v: &ArrayBase<S2, Ix1>,
   494	) -> Array1<f64> {
   495	    use faer::linalg::matmul::matmul;
   496	    use faer::{Accum, Mat};
   497	
   498	    if let Some(out) = crate::gpu::try_fast_atv(a, v) {
   499	        return out;
   500	    }
   501	
   502	    let (n, p) = a.dim();
   503	    debug_assert_eq!(n, v.len(), "A rows must match v length");
   504	
   505	    // For very small arrays, ndarray might be faster
   506	    if !should_use_faer_matmul(p, 1, n) {
   507	        return a.t().dot(v);
   508	    }
   509	
   510	    let mut result = Mat::<f64>::zeros(p, 1);
   511	
   512	    let aview = FaerArrayView::new(a);
   513	    let vview = FaerColView::new(v);
   514	    let a_ref = aview.as_ref();
   515	    let v_ref = vview.as_ref();
   516	
   517	    // dst = A^T * v (treating v as n×1 matrix)
   518	    let par = matmul_parallelism(p, 1, n);
   519	    matmul(
   520	        result.as_mut(),
   521	        Accum::Replace,
   522	        a_ref.transpose(),
   523	        v_ref,
   524	        1.0,
   525	        par,
   526	    );
   527	
   528	    let mut out = Array1::<f64>::zeros(p);
   529	    for i in 0..p {
   530	        out[i] = result[(i, 0)];
   531	    }
   532	    out
   533	}
