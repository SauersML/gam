  1558	
  1559	/// Lazy composed operator for reparameterized design: X_transformed = X_original · Qs.
  1560	///
  1561	/// Instead of materializing the dense n×p product X·Qs, this operator applies
  1562	/// the p×p orthogonal transform Qs on the coefficient side:
  1563	///
  1564	///   apply(v)           → X · (Qs · v)
  1565	///   apply_transpose(v) → Qs^T · (X^T · v)
  1566	///   diag_xtw_x(w)      → Qs^T · (X^T W X) · Qs
  1567	///
  1568	/// This preserves the sparsity of X and avoids an O(n·p) dense allocation.
  1569	pub struct ReparamOperator {
  1570	    x_original: DesignMatrix,
  1571	    qs: Arc<Array2<f64>>,
  1572	    n: usize,
  1573	    p: usize,
  1574	}
  1575	
  1576	impl ReparamOperator {
