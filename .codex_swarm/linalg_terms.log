 21979	                        bs_degree,
 21980	                        row,
 21981	                    )?,
 21982	                    _ => unreachable!(),
 21983	                }
 21984	            }
 21985	            db
 21986	        }
 21987	        _ => unreachable!(),
 21988	    };
 21989	    let num_ispline_cols = num_bspline_cols.saturating_sub(1);
 21990	    if num_ispline_cols == 0 {
 21991	        return Ok(Array2::zeros((data.len(), 0)));
 21992	    }
 21993	    // Right-cumulative sum: I-spline derivative column j = sum_{m=j+1..end} dB_m.
 21994	    // In our indexing: output column j (0-based) = sum of dB columns j+1..num_bspline_cols.
 21995	    let mut out = Array2::<f64>::zeros((data.len(), num_ispline_cols));
