   471	        Ok(Arc::new(dense))
   472	    }
   473	
   474	    fn from_sparse(sparse: SparseColMat<usize, f64>) -> Result<Self::Output, BasisError> {
   475	        let mut dense = Array2::<f64>::zeros((sparse.nrows(), sparse.ncols()));
   476	        let (symbolic, values) = sparse.parts();
   477	        let col_ptr = symbolic.col_ptr();
   478	        let row_idx = symbolic.row_idx();
