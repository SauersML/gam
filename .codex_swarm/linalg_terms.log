 21664	/// Scratch memory for B-spline evaluation to avoid allocations in tight loops.
 21665	pub struct SplineScratch {
 21666	    inner: internal::BsplineScratch,
 21667	    local: Vec<f64>,
 21668	    left_inner: internal::BsplineScratch,
 21669	    left_local: Vec<f64>,
 21670	    left_offsets: Vec<f64>,
 21671	}
 21672	
 21673	impl SplineScratch {
 21674	    pub fn new(degree: usize) -> Self {
 21675	        Self {
 21676	            inner: internal::BsplineScratch::new(degree),
 21677	            local: Vec::new(),
 21678	            left_inner: internal::BsplineScratch::new(degree),
 21679	            left_local: Vec::new(),
 21680	            left_offsets: Vec::new(),
 21681	        }
 21682	    }
 21683	}
 21684	
 21685	/// Evaluates B-spline basis functions at a single scalar point `x` into a provided buffer.
 21686	///
 21687	/// This is a non-allocating scalar basis evaluator.
 21688	pub fn evaluate_bspline_basis_scalar(
 21689	    x: f64,
 21690	    knot_vector: ArrayView1<f64>,
 21691	    degree: usize,
 21692	    out: &mut [f64],
 21693	    scratch: &mut SplineScratch,
 21694	) -> Result<(), BasisError> {
 21695	    validate_knots_for_degree(knot_vector, degree)?;
 21696	
 21697	    let num_basis = knot_vector.len() - degree - 1;
 21698	    if out.len() != num_basis {
 21699	        return Err(BasisError::InvalidKnotVector(format!(
 21700	            "Output buffer length {} does not match number of basis functions {}",
 21701	            out.len(),
 21702	            num_basis
 21703	        )));
 21704	    }
 21705	
 21706	    internal::evaluate_splines_at_point_into(x, degree, knot_vector, out, &mut scratch.inner);
 21707	
 21708	    Ok(())
 21709	}
 21710	
 21711	/// Evaluates M-spline basis functions at a scalar point `x` into a provided buffer.
 21712	///
 21713	/// Construction:
 21714	/// - evaluate B-splines of degree `degree`,
 21715	/// - scale each basis column by:
 21716	///   `M_i(x) = ((degree + 1) / (t_{i+degree+1} - t_i)) * B_i(x)`.
 21717	pub fn evaluate_mspline_scalar(
 21718	    x: f64,
 21719	    knot_vector: ArrayView1<f64>,
 21720	    degree: usize,
 21721	    out: &mut [f64],
 21722	    scratch: &mut SplineScratch,
 21723	) -> Result<(), BasisError> {
 21724	    validate_knots_for_degree(knot_vector, degree)?;
 21725	    validate_mspline_normalization_spans(knot_vector, degree)?;
 21726	    let num_basis = knot_vector.len() - degree - 1;
 21727	    if out.len() != num_basis {
 21728	        return Err(BasisError::DimensionMismatch(format!(
 21729	            "M-spline output buffer length {} does not match basis size {}",
 21730	            out.len(),
 21731	            num_basis
 21732	        )));
 21733	    }
 21734	
 21735	    let left = knot_vector[degree];
 21736	    let right = knot_vector[num_basis];
 21737	    if x < left || x > right {
 21738	        out.fill(0.0);
 21739	        return Ok(());
 21740	    }
 21741	
 21742	    // M-splines are locally supported: only `degree + 1` entries can be non-zero.
 21743	    // Fill zeros, then write only the contiguous active block.
 21744	    out.fill(0.0);
 21745	    if scratch.local.len() < degree + 1 {
 21746	        scratch.local.resize(degree + 1, 0.0);
 21747	    }
 21748	    let local = &mut scratch.local[..degree + 1];
 21749	    local.fill(0.0);
 21750	    let start =
 21751	        internal::evaluate_splines_sparse_into(x, degree, knot_vector, local, &mut scratch.inner);
 21752	    let order = (degree + 1) as f64;
 21753	    for (offset, &b) in local.iter().enumerate() {
 21754	        let i = start + offset;
 21755	        if i >= num_basis {
 21756	            continue;
 21757	        }
 21758	        let span = knot_vector[i + degree + 1] - knot_vector[i];
 21759	        out[i] = b * (order / span);
 21760	    }
 21761	    Ok(())
 21762	}
 21763	
 21764	/// Evaluates I-spline basis functions at a scalar point `x` into a provided buffer.
 21765	///
 21766	/// Construction:
 21767	/// - evaluate B-splines of degree `degree + 1`,
 21768	/// - take right cumulative sums:
 21769	///   `I_j(x) = sum_{m=j..end} B_m^{(degree+1)}(x)`.
 21770	///
 21771	/// For clamped knot vectors, this yields monotone basis functions over the knot domain.
 21772	pub fn evaluate_ispline_scalarwith_scratch(
 21773	    x: f64,
 21774	    knot_vector: ArrayView1<f64>,
 21775	    degree: usize,
 21776	    out: &mut [f64],
 21777	    scratch: &mut SplineScratch,
 21778	) -> Result<(), BasisError> {
 21779	    let bs_degree = degree
 21780	        .checked_add(1)
 21781	        .ok_or_else(|| BasisError::InvalidInput("I-spline degree overflow".to_string()))?;
 21782	    validate_knots_for_degree(knot_vector, bs_degree)?;
 21783	    let num_bspline_basis = knot_vector.len() - bs_degree - 1;
 21784	    let num_ispline_basis = num_bspline_basis.saturating_sub(1);
 21785	    if out.len() != num_ispline_basis {
 21786	        return Err(BasisError::DimensionMismatch(format!(
 21787	            "I-spline output buffer length {} does not match basis size {}",
 21788	            out.len(),
 21789	            num_ispline_basis
 21790	        )));
 21791	    }
 21792	
 21793	    // Domain for B_{., degree+1} is [t_{degree+1}, t_{num_basis}].
 21794	    let left = knot_vector[bs_degree];
 21795	    let right = knot_vector[num_bspline_basis];
 21796	    let support = bs_degree + 1;
 21797	    if x < left {
 21798	        out.fill(0.0);
 21799	        return Ok(());
 21800	    }
 21801	    if x >= right {
 21802	        if scratch.left_local.len() < support {
 21803	            scratch.left_local.resize(support, 0.0);
 21804	        }
 21805	        if scratch.left_offsets.len() < num_bspline_basis {
 21806	            scratch.left_offsets.resize(num_bspline_basis, 0.0);
 21807	        }
 21808	        scratch.left_offsets[..num_bspline_basis].fill(0.0);
 21809	        let left_local = &mut scratch.left_local[..support];
 21810	        left_local.fill(0.0);
 21811	        scratch.left_inner.ensure_degree(bs_degree);
 21812	        let left_start = internal::evaluate_splines_sparse_into(
 21813	            left,
 21814	            bs_degree,
 21815	            knot_vector,
 21816	            left_local,
 21817	            &mut scratch.left_inner,
 21818	        );
 21819	        let left_offsets = &mut scratch.left_offsets[..num_bspline_basis];
 21820	        let mut left_running = 0.0_f64;
 21821	        for offset in (0..support).rev() {
 21822	            let j = left_start + offset;
 21823	            if j >= num_bspline_basis {
 21824	                continue;
 21825	            }
 21826	            left_running += left_local[offset];
 21827	            left_offsets[j] = left_running;
 21828	        }
 21829	        for j in 1..num_bspline_basis {
 21830	            let value = 1.0 - left_offsets[j];
 21831	            out[j - 1] = if value.abs() <= 1e-15 { 0.0 } else { value };
 21832	        }
 21833	        return Ok(());
 21834	    }
 21835	
 21836	    // I-splines are right-cumulative sums of local B-spline values, then
 21837	    // shifted by their left-boundary value so every basis is anchored at 0
 21838	    // at the domain start.
 21839	    // For interior x, columns strictly left of the active block equal the
 21840	    // total active mass (partition of unity, numerically near 1).
 21841	    out.fill(0.0);
 21842	    if scratch.local.len() < support {
 21843	        scratch.local.resize(support, 0.0);
 21844	    }
 21845	    scratch.local[..support].fill(0.0);
 21846	    scratch.inner.ensure_degree(bs_degree);
 21847	    let local = &mut scratch.local[..support];
 21848	    let start = internal::evaluate_splines_sparse_into(
 21849	        x,
 21850	        bs_degree,
 21851	        knot_vector,
 21852	        local,
 21853	        &mut scratch.inner,
 21854	    );
 21855	
 21856	    let total = local.iter().copied().sum::<f64>();
 21857	    let lead_end = start.min(num_bspline_basis);
 21858	    if lead_end > 1 {
 21859	        out[..(lead_end - 1)].fill(total);
 21860	    }
 21861	
 21862	    let mut running = 0.0f64;
 21863	    for offset in (0..support).rev() {
 21864	        let j = start + offset;
 21865	        if j >= num_bspline_basis {
 21866	            continue;
 21867	        }
 21868	        running += local[offset];
 21869	        if j > 0 {
 21870	            out[j - 1] = running;
 21871	        }
 21872	    }
 21873	
 21874	    // Subtract left-boundary constants so I_j(left) = 0 exactly.
 21875	    if scratch.left_local.len() < support {
 21876	        scratch.left_local.resize(support, 0.0);
 21877	    }
 21878	    if scratch.left_offsets.len() < num_bspline_basis {
 21879	        scratch.left_offsets.resize(num_bspline_basis, 0.0);
 21880	    }
 21881	    scratch.left_offsets[..num_bspline_basis].fill(0.0);
 21882	    let left_local = &mut scratch.left_local[..support];
 21883	    left_local.fill(0.0);
 21884	    scratch.left_inner.ensure_degree(bs_degree);
 21885	    let left_start = internal::evaluate_splines_sparse_into(
 21886	        left,
 21887	        bs_degree,
 21888	        knot_vector,
 21889	        left_local,
 21890	        &mut scratch.left_inner,
 21891	    );
 21892	    let left_offsets = &mut scratch.left_offsets[..num_bspline_basis];
 21893	    let mut left_running = 0.0_f64;
 21894	    for offset in (0..support).rev() {
 21895	        let j = left_start + offset;
 21896	        if j >= num_bspline_basis {
 21897	            continue;
 21898	        }
 21899	        left_running += left_local[offset];
 21900	        left_offsets[j] = left_running;
 21901	    }
 21902	    for j in 1..num_bspline_basis {
 21903	        let out_idx = j - 1;
 21904	        out[out_idx] -= left_offsets[j];
 21905	        if out[out_idx].abs() <= 1e-15 {
 21906	            out[out_idx] = 0.0;
 21907	        }
 21908	    }
 21909	    Ok(())
 21910	}
 21911	
 21912	/// Compute the k-th derivative of an I-spline basis as a dense matrix.
 21913	///
 21914	/// The I-spline of degree `degree` uses internal B-splines of degree `degree+1`.
 21915	/// The k-th derivative of I-spline j is the right-cumulative sum of the k-th
 21916	/// derivatives of those B-splines, starting from column j+1 down to j.
 21917	///
 21918	/// This produces `num_bspline_basis - 1` columns (same as the I-spline value
 21919	/// basis), where `num_bspline_basis = len(knot_vector) - degree - 2`.
 21920	pub fn create_ispline_derivative_dense(
 21921	    data: ArrayView1<'_, f64>,
 21922	    knot_vector: &Array1<f64>,
 21923	    degree: usize,
 21924	    derivative_order: usize,
 21925	) -> Result<Array2<f64>, BasisError> {
 21926	    if derivative_order == 0 {
 21927	        // For order 0, return the I-spline value basis.
 21928	        let (basis_arc, _) = create_basis::<Dense>(
 21929	            data,
 21930	            KnotSource::Provided(knot_vector.view()),
 21931	            degree,
 21932	            BasisOptions::i_spline(),
 21933	        )?;
 21934	        return Ok(basis_arc.as_ref().clone());
 21935	    }
 21936	    let bs_degree = degree
 21937	        .checked_add(1)
 21938	        .ok_or_else(|| BasisError::InvalidInput("I-spline degree overflow".to_string()))?;
 21939	    if derivative_order > bs_degree {
 21940	        // Derivative order exceeds basis degree — result is identically zero.
 21941	        let num_bspline_basis = knot_vector.len().checked_sub(bs_degree + 1).unwrap_or(0);
 21942	        let num_ispline_basis = num_bspline_basis.saturating_sub(1);
 21943	        return Ok(Array2::zeros((data.len(), num_ispline_basis)));
 21944	    }
 21945	    let num_bspline_cols = knot_vector.len().saturating_sub(bs_degree + 1);
 21946	    let db = match derivative_order {
 21947	        1 | 2 => {
 21948	            let bspline_options = match derivative_order {
 21949	                1 => BasisOptions::first_derivative(),
 21950	                2 => BasisOptions::second_derivative(),
 21951	                _ => unreachable!(),
 21952	            };
 21953	            let (db_arc, _) = create_basis::<Dense>(
 21954	                data,
 21955	                KnotSource::Provided(knot_vector.view()),
 21956	                bs_degree,
 21957	                bspline_options,
 21958	            )?;
 21959	            db_arc.as_ref().clone()
 21960	        }
 21961	        3 | 4 => {
 21962	            let mut db = Array2::<f64>::zeros((data.len(), num_bspline_cols));
 21963	            for (row_idx, &x) in data.iter().enumerate() {
 21964	                let row = db.slice_mut(s![row_idx, ..]).into_slice().ok_or_else(|| {
 21965	                    BasisError::InvalidInput(
