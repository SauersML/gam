   579	fn sparse_csr_weighted_xtwx(
   580	    row_ptr: &[usize],
   581	    col_idx: &[usize],
   582	    vals: &[f64],
   583	    n: usize,
   584	    p: usize,
   585	    weights: ArrayView1<'_, f64>,
   586	) -> Array2<f64> {
   587	    let nnz = vals.len() as u64;
   588	    let avg = nnz.checked_div(n.max(1) as u64).unwrap_or(0);
   589	    let work = (n as u64).saturating_mul(avg.saturating_mul(avg));
   590	    if rayon::current_num_threads() <= 1 || work < SPARSE_ROW_PARALLEL_MIN_FLOPS {
   591	        return sparse_csr_weighted_xtwx_rows(row_ptr, col_idx, vals, p, weights, 0..n);
   592	    }
   593	
   594	    let n_threads = rayon::current_num_threads();
   595	    let target_chunks = (n_threads * 8).max(1);
   596	    let chunk_rows = n.div_ceil(target_chunks).max(1);
   597	    let starts: Vec<usize> = (0..n).step_by(chunk_rows).collect();
   598	    let partials: Vec<Array2<f64>> = starts
   599	        .into_par_iter()
   600	        .map(|start| {
   601	            sparse_csr_weighted_xtwx_rows(
   602	                row_ptr,
   603	                col_idx,
   604	                vals,
   605	                p,
   606	                weights,
   607	                start..(start + chunk_rows).min(n),
   608	            )
   609	        })
   610	        .collect();
   611	    let mut xtwx = Array2::<f64>::zeros((p, p));
   612	    for partial in &partials {
   613	        xtwx += partial;
   614	    }
   615	    xtwx
   616	}
   617	
   618	fn sparse_csr_weighted_xtwx_rows(
   619	    row_ptr: &[usize],
   620	    col_idx: &[usize],
   621	    vals: &[f64],
   622	    p: usize,
   623	    weights: ArrayView1<'_, f64>,
   624	    rows: Range<usize>,
   625	) -> Array2<f64> {
   626	    let mut xtwx = Array2::<f64>::zeros((p, p));
   627	    for i in rows {
   628	        let wi = weights[i].max(0.0);
   629	        if wi == 0.0 {
   630	            continue;
   631	        }
   632	        let start = row_ptr[i];
   633	        let end = row_ptr[i + 1];
   634	        for a_ptr in start..end {
   635	            let a = col_idx[a_ptr];
   636	            let wxa = wi * vals[a_ptr];
   637	            for b_ptr in a_ptr..end {
   638	                let b = col_idx[b_ptr];
   639	                let v = wxa * vals[b_ptr];
   640	                xtwx[[a, b]] += v;
   641	                if a != b {
   642	                    xtwx[[b, a]] += v;
   643	                }
   644	            }
   645	        }
   646	    }
   647	    xtwx
   648	}
