   130	        CenterStrategy::UniformGrid { points_per_dim } => {
   131	            format!("uniform grid with {points_per_dim} points per dimension")
   132	        }
   133	    }
   134	}
   135	
   136	fn rewrite_thin_plate_knots_error(
   137	    err: BasisError,
   138	    termname: &str,
   139	    feature_count: usize,
   140	    spec: &ThinPlateBasisSpec,
   141	) -> BasisError {
   142	    match err {
   143	        // Polynomial-nullspace shortfall reported directly by the kernel
   144	        // builder ("thin-plate spline requires at least N centers to span ...").
   145	        BasisError::InvalidInput(msg)
   146	            if msg.contains("thin-plate spline requires at least")
   147	                && (msg.contains("centers to span") || msg.contains("knots to span")) =>
   148	        {
   149	            let min_centers = crate::basis::thin_plate_polynomial_basis_dimension(feature_count);
   150	            let requested = describe_thin_plate_center_request(&spec.center_strategy);
   151	            BasisError::InvalidInput(format!(
   152	                "joint TPS term '{termname}' over {feature_count} covariates with {requested} is invalid; minimum centers is {min_centers}"
   153	            ))
   154	        }
   155	        // Insufficient-rows shortfall raised by `select_thin_plate_knots` when
   156	        // the requested center count exceeds the available row count. Rewrite
   157	        // it in term language so the diagnostic points at the smooth term and
   158	        // the polynomial-nullspace minimum the user needs to satisfy.
   159	        BasisError::InvalidInput(msg)
   160	            if msg.starts_with("requested ") && msg.contains(" knots but only ") =>
   161	        {
   162	            let min_centers = crate::basis::thin_plate_polynomial_basis_dimension(feature_count);
   163	            let requested = describe_thin_plate_center_request(&spec.center_strategy);
   164	            BasisError::InvalidInput(format!(
   165	                "joint TPS term '{termname}' over {feature_count} covariates with {requested} is invalid; minimum centers is {min_centers}"
   166	            ))
   167	        }
   168	        other => other,
   169	    }
   170	}
