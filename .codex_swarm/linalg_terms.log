   410	/// Trait for building basis matrices with different storage formats.
   411	/// This is an implementation detail for the unified `create_basis` function.
   412	pub trait BasisOutputFormat {
   413	    type Output;
   414	    const IS_SPARSE: bool;
   415	
   416	    fn build_basis(
   417	        data: ArrayView1<f64>,
   418	        degree: usize,
   419	        eval_kind: BasisEvalKind,
   420	        knotvec: Array1<f64>,
   421	    ) -> Result<(Self::Output, Array1<f64>), BasisError>;
   422	
   423	    fn from_dense(dense: Array2<f64>) -> Result<Self::Output, BasisError>;
   424	    fn from_sparse(sparse: SparseColMat<usize, f64>) -> Result<Self::Output, BasisError>;
   425	}
