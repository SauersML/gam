   649	// ---------------------------------------------------------------------------
   650	// Kronecker factor decomposition primitives
   651	// ---------------------------------------------------------------------------
   652	
   653	/// Per-factor decomposition result for Kronecker penalties.
   654	struct KroneckerFactorDecomp {
   655	    root: Array2<f64>,              // rank_j × q_j
   656	    positive_eigenvalues: Vec<f64>, // length = rank_j
   657	    rank: usize,
   658	    dim: usize,
   659	}
   660	
   661	/// Eigendecompose each Kronecker factor separately at O(Σ q_j³).
   662	/// Returns per-factor decompositions, or `None` if any factor is zero.
   663	fn decompose_kronecker_factors(
   664	    factors: &[Array2<f64>],
   665	    context: &str,
   666	) -> Result<Option<Vec<KroneckerFactorDecomp>>, EstimationError> {
   667	    let mut decomps = Vec::with_capacity(factors.len());
   668	    for (j, factor) in factors.iter().enumerate() {
   669	        let q_j = factor.nrows();
   670	        if q_j != factor.ncols() {
   671	            return Err(EstimationError::InvalidInput(format!(
   672	                "{context}: Kronecker factor {j} must be square, got {}x{}",
   673	                factor.nrows(),
   674	                factor.ncols()
   675	            )));
   676	        }
   677	        let is_identity = {
   678	            let mut is_id = true;
   679	            'outer: for r in 0..q_j {
   680	                for c in 0..q_j {
   681	                    let expected = if r == c { 1.0 } else { 0.0 };
   682	                    if (factor[[r, c]] - expected).abs() > 1e-12 {
   683	                        is_id = false;
   684	                        break 'outer;
   685	                    }
   686	                }
   687	            }
   688	            is_id
   689	        };
   690	        if is_identity {
   691	            decomps.push(KroneckerFactorDecomp {
   692	                root: Array2::eye(q_j),
   693	                positive_eigenvalues: vec![1.0; q_j],
   694	                rank: q_j,
   695	                dim: q_j,
   696	            });
   697	            continue;
   698	        }
   699	        let analysis = analyze_penalty_block(factor).map_err(|err| {
   700	            EstimationError::InvalidInput(format!(
   701	                "{context}: Kronecker factor {j} eigendecomp failed: {err}"
   702	            ))
   703	        })?;
   704	        if analysis.rank == 0 {
   705	            return Ok(None);
   706	        }
   707	        let mut root_j = Array2::zeros((analysis.rank, q_j));
   708	        let mut pos_eigs = Vec::with_capacity(analysis.rank);
   709	        let mut row_idx = 0;
   710	        for (i, &eigenval) in analysis.eigenvalues.iter().enumerate() {
   711	            if eigenval > analysis.tol {
   712	                let sqrt_ev = eigenval.sqrt();
   713	                let evec = analysis.eigenvectors.column(i);
   714	                for (c, &v) in evec.iter().enumerate() {
   715	                    root_j[[row_idx, c]] = sqrt_ev * v;
   716	                }
   717	                pos_eigs.push(eigenval);
   718	                row_idx += 1;
   719	            }
   720	        }
   721	        decomps.push(KroneckerFactorDecomp {
   722	            root: root_j,
   723	            positive_eigenvalues: pos_eigs,
   724	            rank: analysis.rank,
   725	            dim: q_j,
   726	        });
   727	    }
   728	    Ok(Some(decomps))
   729	}
   730	
   731	/// Build the block-local Kronecker root from pre-computed factor decompositions.
   732	fn assemble_kronecker_root_local(decomps: &[KroneckerFactorDecomp]) -> Array2<f64> {
   733	    let mut kron_root = decomps[0].root.clone();
   734	    for fr in &decomps[1..] {
   735	        let (r1, c1) = kron_root.dim();
   736	        let (r2, c2) = (fr.rank, fr.dim);
   737	        let mut new_root = Array2::zeros((r1 * r2, c1 * c2));
   738	        for i1 in 0..r1 {
   739	            for i2 in 0..r2 {
   740	                for j1 in 0..c1 {
   741	                    for j2 in 0..c2 {
   742	                        new_root[[i1 * r2 + i2, j1 * c2 + j2]] =
   743	                            kron_root[[i1, j1]] * fr.root[[i2, j2]];
   744	                    }
   745	                }
   746	            }
   747	        }
   748	        kron_root = new_root;
   749	    }
   750	    kron_root
   751	}
   752	
   753	/// Compute eigenvalues of the Kronecker product from per-factor eigenvalues.
   754	fn kronecker_eigenvalues(decomps: &[KroneckerFactorDecomp], block_dim: usize) -> (Vec<f64>, usize) {
   755	    let mut kron_eigs = decomps[0].positive_eigenvalues.clone();
   756	    for fd in &decomps[1..] {
   757	        let mut new_eigs = Vec::with_capacity(kron_eigs.len() * fd.positive_eigenvalues.len());
   758	        for &a in &kron_eigs {
   759	            for &b in &fd.positive_eigenvalues {
   760	                new_eigs.push(a * b);
   761	            }
   762	        }
   763	        kron_eigs = new_eigs;
   764	    }
   765	    let max_ev = kron_eigs.iter().copied().fold(0.0_f64, f64::max);
   766	    let tol = max_ev * 1e-10 * (block_dim as f64);
   767	    let positive: Vec<f64> = kron_eigs.into_iter().filter(|&ev| ev > tol).collect();
   768	    let nullity = block_dim - positive.len();
   769	    (positive, nullity)
   770	}
   771	
   772	// ---------------------------------------------------------------------------
   773	// CanonicalPenalty — block-local processed penalty for the solver
   774	// ---------------------------------------------------------------------------
   775	
   776	/// A canonicalized penalty with block-local root, ready for the solver.
   777	///
   778	/// Instead of storing a full `p x p` penalty matrix, this stores only the
   779	/// `rank x block_dim` root and the column range, enabling O(p_k^2) operations
   780	/// instead of O(p^2).
   781	#[derive(Clone)]
   782	pub struct CanonicalPenalty {
   783	    /// Square root matrix: S_k = root^T * root.
   784	    /// Shape: `rank x block_dim` for block-local, `rank x p` for dense.
   785	    pub root: Array2<f64>,
   786	    /// Column range in the global coefficient vector [start..end).
   787	    /// For dense penalties this is `0..p`.
   788	    pub col_range: std::ops::Range<usize>,
   789	    /// Full parameter dimension p.
   790	    pub total_dim: usize,
   791	    /// Structural nullity of the local penalty.
   792	    pub nullity: usize,
   793	    /// The symmetrized block-local penalty matrix (block_dim × block_dim).
   794	    /// Cached at construction time to avoid recomputing root^T * root
   795	    /// in hot paths (penalty assembly, trace products).
   796	    pub local: Array2<f64>,
   797	    /// Block-local prior mean used to center this penalty.
   798	    pub prior_mean: Array1<f64>,
   799	    /// Positive eigenvalues of the local penalty matrix (length = rank).
   800	    /// Cached at construction time for REML logdet block-factored paths.
   801	    pub positive_eigenvalues: Vec<f64>,
   802	    /// Optional operator-form handle bit-equivalent to `local`. Propagated
   803	    /// from `PenaltySpec::Block.op`. Downstream PIRLS and REML exact operator
   804	    /// algebra route through this for dense-Gram-free matvec when present.
   805	    pub op: Option<std::sync::Arc<dyn crate::terms::penalty_op::PenaltyOp>>,
   806	}
