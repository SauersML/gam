   708	pub fn solve_sparse_spdmulti_diagonal_sum<S>(
   709	    factor: &SparseExactFactor,
   710	    rhs: &ArrayBase<S, Ix2>,
   711	    row_start: usize,
   712	) -> Result<f64, EstimationError>
   713	where
   714	    S: Data<Elem = f64>,
   715	{
   716	    if row_start.saturating_add(rhs.ncols()) > rhs.nrows() {
   717	        return Err(EstimationError::InvalidInput(format!(
   718	            "sparse SPD selected diagonal out of bounds: row_start={}, rows={}, cols={}",
   719	            row_start,
   720	            rhs.nrows(),
   721	            rhs.ncols()
   722	        )));
   723	    }
   724	    let rhsview = FaerArrayView::new(rhs);
   725	    let out = factor.factor.solve(rhsview.as_ref());
   726	    let mut sum = 0.0;
   727	    for col in 0..rhs.ncols() {
   728	        let value = out[(row_start + col, col)];
   729	        if !value.is_finite() {
   730	            return Err(EstimationError::InvalidInput(
   731	                "sparse SPD selected diagonal solve produced non-finite values".to_string(),
   732	            ));
   733	        }
   734	        sum += value;
   735	    }
   736	    Ok(sum)
   737	}
