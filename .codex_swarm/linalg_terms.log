   991	fn mat_to_array(mat: MatRef<'_, f64>) -> Array2<f64> {
   992	    let nrows = mat.nrows();
   993	    let ncols = mat.ncols();
   994	    let mut out = Array2::<f64>::zeros((nrows, ncols));
   995	    if nrows == 0 || ncols == 0 {
   996	        return out;
   997	    }
   998	    // ndarray is row-major by default. Write row-by-row for best cache behavior
   999	    // on the output side.
  1000	    if let Some(out_slice) = out.as_slice_memory_order_mut() {
  1001	        // Row-major: out_slice[i * ncols + j] = mat[(i, j)]
  1002	        for i in 0..nrows {
  1003	            let row_start = i * ncols;
  1004	            for j in 0..ncols {
  1005	                out_slice[row_start + j] = mat[(i, j)];
  1006	            }
  1007	        }
  1008	    } else {
  1009	        for j in 0..ncols {
  1010	            for i in 0..nrows {
  1011	                out[[i, j]] = mat[(i, j)];
  1012	            }
  1013	        }
  1014	    }
  1015	    out
  1016	}
