   497	#[derive(Debug, Clone, Copy)]
   498	struct SubspaceLeakageMetrics {
   499	    max_abs_sq: f64,
   500	    max_rel_sq: f64,
   501	    worst_penalty: usize,
   502	    max_cross_gram_abs: f64,
   503	}
   504	
   505	fn assess_subspace_leakage(
   506	    qs: &Mat<f64>,
   507	    rs_transformed: &[Mat<f64>],
   508	    structural_rank: usize,
   509	    p: usize,
   510	) -> SubspaceLeakageMetrics {
   511	    let mut max_abs_sq = 0.0_f64;
   512	    let mut max_rel_sq = 0.0_f64;
   513	    let mut worst_penalty = 0usize;
   514	
   515	    for (k, rs) in rs_transformed.iter().enumerate() {
   516	        let rows = rs.nrows();
   517	        let cols = rs.ncols().min(p);
   518	        let null_start = structural_rank.min(cols);
   519	        let mut abs_sq = 0.0_f64;
   520	        let mut total_sq = 0.0_f64;
   521	        for i in 0..rows {
   522	            for j in 0..cols {
   523	                let v = rs[(i, j)];
   524	                let vv = v * v;
   525	                total_sq += vv;
   526	                if j >= null_start {
   527	                    abs_sq += vv;
   528	                }
   529	            }
   530	        }
   531	        let rel_sq = if total_sq > 0.0 {
   532	            abs_sq / total_sq
   533	        } else {
   534	            0.0
   535	        };
   536	        if rel_sq > max_rel_sq {
   537	            max_rel_sq = rel_sq;
   538	            worst_penalty = k;
   539	        }
   540	        max_abs_sq = max_abs_sq.max(abs_sq);
   541	    }
   542	
   543	    let mut max_cross_gram_abs = 0.0_f64;
   544	    let null_count = p.saturating_sub(structural_rank);
   545	    if structural_rank > 0 && null_count > 0 {
   546	        for i in 0..structural_rank {
   547	            for j in 0..null_count {
   548	                let qn_col = structural_rank + j;
   549	                let mut dot = 0.0_f64;
   550	                for r in 0..p {
   551	                    dot += qs[(r, i)] * qs[(r, qn_col)];
   552	                }
   553	                max_cross_gram_abs = max_cross_gram_abs.max(dot.abs());
   554	            }
   555	        }
   556	    }
   557	
   558	    SubspaceLeakageMetrics {
   559	        max_abs_sq,
   560	        max_rel_sq,
   561	        worst_penalty,
   562	        max_cross_gram_abs,
   563	    }
   564	}
