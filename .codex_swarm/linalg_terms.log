 10132	pub fn closed_form_anisotropic_pair_block(
 10133	    centers: ArrayView2<'_, f64>,
 10134	    q: usize,
 10135	    m: usize,
 10136	    s: usize,
 10137	    kappa: f64,
 10138	    aniso_log_scales: Option<&[f64]>,
 10139	) -> Array2<f64> {
 10140	    // Math team Letter A §9: G_q(η_raw, κ) ≠ G_q(η_centered, κ) in general;
 10141	    // the relation involves an exp((2d-4m-4s)μ) prefactor and a κ rescaling
 10142	    // that don't reduce to a uniform Jacobian. Use raw η directly so the
 10143	    // pair-block matches the closed-form Lebesgue penalty's natural raw-η
 10144	    // parameterization, and so its η-derivatives (computed elsewhere via
 10145	    // `pair_block_radial_with_j_second_derivatives` with raw η) are already
 10146	    // ∂G_q/∂η_raw without any chain-rule conversion.
 10147	    let k = centers.nrows();
 10148	    let d = centers.ncols();
 10149	    let zeros: Vec<f64>;
 10150	    let eta_raw: &[f64] = match aniso_log_scales {
 10151	        Some(eta) => eta,
 10152	        None => {
 10153	            zeros = vec![0.0_f64; d];
 10154	            &zeros
 10155	        }
 10156	    };
 10157	    let r_eps = if closed_form_penalty::analytic_self_pair_bundle(q, m, s, kappa, eta_raw).is_some()
 10158	    {
 10159	        0.0
 10160	    } else {
 10161	        pure_duchon_diagonal_epsilon(centers, eta_raw)
 10162	    };
 10163	    let powers = closed_form_penalty::AnisoMetricPowers::new(eta_raw);
 10164	
 10165	    // Parallelize by independent lower-triangular rows. This keeps one lag
 10166	    // scratch buffer per worker row, avoids the sqrt-based flat-index decode
 10167	    // in the hot loop, and still evaluates each symmetric pair only once.
 10168	    let n_pairs = k * (k + 1) / 2;
 10169	    let mut values = vec![0.0_f64; n_pairs];
 10170	    let values_ptr = SendPtr(values.as_mut_ptr());
 10171	    (0..k).into_par_iter().for_each(|i| {
 10172	        let row_ptr = values_ptr.add(lower_triangular_offset(i));
 10173	        let mut r_buf: SmallVec<[f64; 16]> = SmallVec::with_capacity(d);
 10174	        r_buf.resize(d, 0.0);
 10175	        for j in 0..=i {
 10176	            for axis in 0..d {
 10177	                r_buf[axis] = centers[[i, axis]] - centers[[j, axis]];
 10178	            }
 10179	            let value = closed_form_anisotropic_pair_value_with_powers(
 10180	                q, m, s, kappa, eta_raw, &powers, &r_buf, r_eps,
 10181	            );
 10182	            unsafe {
 10183	                *row_ptr.add(j) = value;
 10184	            }
 10185	        }
 10186	    });
 10187	
 10188	    symmetric_matrix_from_lower_values(k, &values)
 10189	}
 10190	
 10191	/// Pure-Duchon (κ=0) variant of [`closed_form_anisotropic_pair_block`].
 10192	///
 10193	/// Uses the analytic radial-derivative path
