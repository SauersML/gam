   338	pub(crate) fn boundary_hit_step_fraction(
   339	    slack: f64,
   340	    directional_slack_change: f64,
   341	    current_step_limit: f64,
   342	) -> Option<f64> {
   343	    if !slack.is_finite()
   344	        || !directional_slack_change.is_finite()
   345	        || !current_step_limit.is_finite()
   346	        || current_step_limit <= 0.0
   347	    {
   348	        return None;
   349	    }
   350	
   351	    let scale = slack
   352	        .abs()
   353	        .max(directional_slack_change.abs())
   354	        .max(current_step_limit.abs())
   355	        .max(1.0);
   356	    let directional_tol = (64.0 * f64::EPSILON * scale).max(1e-14);
   357	    if directional_slack_change >= -directional_tol {
   358	        return None;
   359	    }
   360	
   361	    let step = (slack / -directional_slack_change).max(0.0);
   362	    if step.is_finite() && step < current_step_limit {
   363	        return Some(step);
   364	    }
   365	    None
   366	}
