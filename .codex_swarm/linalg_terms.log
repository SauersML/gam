   551	#[inline]
   552	fn one_sided_derivative_eval_point(x: f64, knotview: ArrayView1<f64>, degree: usize) -> f64 {
   553	    let num_basis = knotview.len().saturating_sub(degree + 1);
   554	    if num_basis == 0 {
   555	        return x;
   556	    }
   557	    let left = knotview[degree];
   558	    let right = knotview[num_basis];
   559	    if !left.is_finite() || !right.is_finite() || left >= right {
   560	        return x;
   561	    }
   562	    if x <= left {
   563	        let next = left.next_up();
   564	        if next < right {
   565	            next
   566	        } else {
   567	            left + 0.5 * (right - left)
   568	        }
   569	    } else if x >= right {
   570	        let prev = right.next_down();
   571	        if prev > left {
   572	            prev
   573	        } else {
   574	            left + 0.5 * (right - left)
   575	        }
   576	    } else {
   577	        x
   578	    }
   579	}
