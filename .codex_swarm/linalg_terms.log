   932	                        }
   933	                        let wab_row = &mut wab_chunk[wab_off..wab_off + pb];
   934	                        let wbb_row = &mut wbb_chunk[wbb_off..wbb_off + pb];
   935	                        let xb_row = xb_slice.row(local);
   936	                        for (col, xij) in xb_row.iter().enumerate() {
   937	                            wab_row[col] = xij * wab_i;
   938	                            wbb_row[col] = xij * wbb_i;
   939	                        }
   940	                    }
   941	                }
   942	            }
   943	
   944	            let xa_view = FaerArrayView::new(&xa_slice);
   945	            let xb_view = FaerArrayView::new(&xb_slice);
   946	            let waa_xa_slice = waa_xa_buf.slice(s![0..rows, ..]);
   947	            let wab_xb_slice = wab_xb_buf.slice(s![0..rows, ..]);
   948	            let wbb_xb_slice = wbb_xb_buf.slice(s![0..rows, ..]);
   949	            let waa_xa_view = FaerArrayView::new(&waa_xa_slice);
   950	            let wab_xb_view = FaerArrayView::new(&wab_xb_slice);
   951	            let wbb_xb_view = FaerArrayView::new(&wbb_xb_slice);
   952	
   953	            // Block [0..pa, 0..pa]: X_a^T diag(w_aa) X_a
   954	            matmul(
   955	                out_mat.rb_mut().submatrix_mut(0, 0, pa, pa),
   956	                Accum::Add,
   957	                xa_view.as_ref().transpose(),
   958	                waa_xa_view.as_ref(),
   959	                1.0,
   960	                matmul_parallelism(pa, pa, rows),
   961	            );
   962	            // Block [0..pa, pa..total]: X_a^T diag(w_ab) X_b
   963	            matmul(
   964	                out_mat.rb_mut().submatrix_mut(0, pa, pa, pb),
   965	                Accum::Add,
   966	                xa_view.as_ref().transpose(),
   967	                wab_xb_view.as_ref(),
   968	                1.0,
   969	                matmul_parallelism(pa, pb, rows),
   970	            );
   971	            // Block [pa..total, pa..total]: X_b^T diag(w_bb) X_b
   972	            matmul(
   973	                out_mat.rb_mut().submatrix_mut(pa, pa, pb, pb),
   974	                Accum::Add,
   975	                xb_view.as_ref().transpose(),
   976	                wbb_xb_view.as_ref(),
   977	                1.0,
   978	                matmul_parallelism(pb, pb, rows),
   979	            );
