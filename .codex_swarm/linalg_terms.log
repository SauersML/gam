   949	use faer::dyn_stack::{MemBuffer, MemStack, StackReq};
   950	use faer::linalg::cholesky::llt::factor::LltRegularization;
   951	use faer::sparse::linalg::amd;
   952	use faer::sparse::linalg::cholesky::simplicial;
   953	
   954	/// A simplicial Cholesky factorization with raw access to L's CSC pattern and
   955	/// values, plus the AMD permutation.  Built using faer's low-level simplicial
   956	/// API so that L's sparse structure is directly available for Takahashi
   957	/// selected inversion.
   958	pub struct SimplicialFactor {
   959	    /// Column pointers of L (lower triangular, CSC), length n+1
   960	    l_col_ptr: Vec<usize>,
   961	    /// Row indices of L (lower triangular, CSC), length nnz(L)
   962	    l_row_idx: Vec<usize>,
   963	    /// Numeric values of L, length nnz(L)
   964	    l_values: Vec<f64>,
   965	    /// Inverse permutation returned by faer, used to map original coordinates
   966	    /// into the permuted simplicial factor basis.
   967	    perm_inv: Vec<usize>,
   968	    /// Dimension
   969	    n: usize,
   970	    /// log|H| = 2 * sum(log(L_ii))
   971	    pub logdet: f64,
   972	}
   973	
   974	/// Build a [`SimplicialFactor`] from a symmetric CSC matrix (upper, lower, or
   975	/// full storage – it is canonicalized to symmetric-upper internally).
   976	///
   977	/// The factorization uses AMD fill-reducing ordering and faer's simplicial
   978	/// LLᵀ numeric factorization.
   979	pub fn factorize_simplicial(
   980	    h: &SparseColMat<usize, f64>,
   981	) -> Result<SimplicialFactor, EstimationError> {
   982	    let h_upper = canonicalize_sparse_symmetric_upper(h, ZERO_TOL)?;
   983	    factorize_simplicial_canonical_upper(&h_upper)
   984	}
   985	
   986	fn factorize_simplicial_canonical_upper(
   987	    h_upper: &SparseColMat<usize, f64>,
   988	) -> Result<SimplicialFactor, EstimationError> {
   989	    let n = h_upper.ncols();
   990	    if n == 0 {
   991	        return Ok(SimplicialFactor {
   992	            l_col_ptr: vec![0],
   993	            l_row_idx: Vec::new(),
   994	            l_values: Vec::new(),
   995	            perm_inv: Vec::new(),
   996	            n: 0,
   997	            logdet: 0.0,
   998	        });
   999	    }
  1000	
  1001	    let a_nnz = h_upper.compute_nnz();
  1002	
  1003	    // 1. AMD ordering
  1004	    let mut perm_fwd = vec![0usize; n];
  1005	    let mut perm_inv = vec![0usize; n];
  1006	    {
  1007	        let mut mem = MemBuffer::new(amd::order_scratch::<usize>(n, a_nnz));
  1008	        amd::order(
  1009	            &mut perm_fwd,
  1010	            &mut perm_inv,
  1011	            h_upper.symbolic(),
  1012	            amd::Control::default(),
  1013	            MemStack::new(&mut mem),
  1014	        )
  1015	        .map_err(|_| EstimationError::ModelIsIllConditioned {
  1016	            condition_number: f64::INFINITY,
  1017	        })?;
  1018	    }
  1019	
  1020	    let perm = unsafe { faer::perm::PermRef::new_unchecked(&perm_fwd, &perm_inv, n) };
  1021	
  1022	    // 2. Permute to P A Pᵀ (upper-triangular, unsorted)
  1023	    let a_perm_upper = {
  1024	        let mut col_ptrs = vec![0usize; n + 1];
  1025	        let mut row_indices = vec![0usize; a_nnz];
  1026	        let mut values = vec![0.0f64; a_nnz];
  1027	        let mut mem = MemBuffer::new(faer::sparse::utils::permute_self_adjoint_scratch::<usize>(
  1028	            n,
  1029	        ));
  1030	        faer::sparse::utils::permute_self_adjoint_to_unsorted(
  1031	            &mut values,
  1032	            &mut col_ptrs,
  1033	            &mut row_indices,
  1034	            h_upper.as_ref(),
  1035	            perm,
  1036	            Side::Upper,
  1037	            Side::Upper,
  1038	            MemStack::new(&mut mem),
  1039	        );
  1040	        SparseColMat::<usize, f64>::new(
  1041	            unsafe { SymbolicSparseColMat::new_unchecked(n, n, col_ptrs, None, row_indices) },
  1042	            values,
  1043	        )
  1044	    };
  1045	
  1046	    // 3. Symbolic analysis
  1047	    let symbolic = {
  1048	        let mut mem = MemBuffer::new(StackReq::any_of(&[
  1049	            simplicial::prefactorize_symbolic_cholesky_scratch::<usize>(n, a_nnz),
  1050	            simplicial::factorize_simplicial_symbolic_cholesky_scratch::<usize>(n),
  1051	        ]));
  1052	        let stack = MemStack::new(&mut mem);
  1053	        let mut etree = vec![0isize; n];
  1054	        let mut col_counts = vec![0usize; n];
  1055	        simplicial::prefactorize_symbolic_cholesky(
  1056	            &mut etree,
  1057	            &mut col_counts,
  1058	            a_perm_upper.symbolic(),
  1059	            stack,
  1060	        );
  1061	        simplicial::factorize_simplicial_symbolic_cholesky(
  1062	            a_perm_upper.symbolic(),
  1063	            unsafe { simplicial::EliminationTreeRef::from_inner(&etree) },
  1064	            &col_counts,
  1065	            stack,
  1066	        )
  1067	        .map_err(|_| EstimationError::ModelIsIllConditioned {
  1068	            condition_number: f64::INFINITY,
  1069	        })?
  1070	    };
  1071	
  1072	    // 4. Numeric LLᵀ factorization
  1073	    let mut l_values = vec![0.0f64; symbolic.len_val()];
  1074	    {
  1075	        let mut mem = MemBuffer::new(simplicial::factorize_simplicial_numeric_llt_scratch::<
  1076	            usize,
  1077	            f64,
  1078	        >(n));
  1079	        simplicial::factorize_simplicial_numeric_llt::<usize, f64>(
  1080	            &mut l_values,
  1081	            a_perm_upper.as_ref(),
  1082	            LltRegularization::default(),
  1083	            &symbolic,
  1084	            MemStack::new(&mut mem),
  1085	        )
  1086	        .map_err(|_| EstimationError::HessianNotPositiveDefinite {
  1087	            min_eigenvalue: f64::NAN,
  1088	        })?;
  1089	    }
  1090	
  1091	    // 5. Extract col_ptr, row_idx from the symbolic structure
  1092	    let l_col_ptr: Vec<usize> = symbolic.col_ptr().to_vec();
  1093	    let l_row_idx: Vec<usize> = symbolic.row_idx().to_vec();
  1094	
  1095	    // 6. Compute logdet from L diagonal: L[j,j] = l_values[l_col_ptr[j]]
  1096	    let mut logdet = 0.0f64;
  1097	    for j in 0..n {
  1098	        let diag = l_values[l_col_ptr[j]];
  1099	        if diag <= 0.0 {
  1100	            return Err(EstimationError::HessianNotPositiveDefinite {
  1101	                min_eigenvalue: f64::NAN,
  1102	            });
  1103	        }
  1104	        logdet += diag.ln();
  1105	    }
  1106	    logdet *= 2.0;
  1107	
  1108	    Ok(SimplicialFactor {
  1109	        l_col_ptr,
  1110	        l_row_idx,
  1111	        l_values,
  1112	        perm_inv,
  1113	        n,
  1114	        logdet,
  1115	    })
  1116	}
