  1157	/// Creates a penalty matrix `S` for a B-spline basis from a difference matrix `D`.
  1158	/// The penalty is of the form `S = D' * D`, penalizing the squared `order`-th
  1159	/// differences of the spline coefficients. This is the core of P-splines.
  1160	///
  1161	/// This function supports both uniform knots (using ordinary differences) and
  1162	/// non-uniform knots (using divided differences), which is critical for
  1163	/// correctly penalizing curvature when knots are irregularly spaced (e.g. quantiles).
  1164	///
  1165	/// # Arguments
  1166	/// * `num_basis_functions`: The number of basis functions (i.e., columns in the basis matrix).
  1167	/// * `order`: The order of the difference penalty (e.g., 2 for second differences).
  1168	/// * `greville_abscissae`: Optional Greville abscissae for divided differences.
  1169	///   If `None`, assumes uniform knots and uses ordinary integer differences.
  1170	///   If `Some`, uses divided differences scaled by the inverse of the knot spans.
  1171	///
  1172	/// # Returns
  1173	/// A square `Array2<f64>` of shape `[num_basis, num_basis]` representing the penalty `S`.
  1174	pub fn create_difference_penalty_matrix(
  1175	    num_basis_functions: usize,
  1176	    order: usize,
  1177	    greville_abscissae: Option<ArrayView1<f64>>,
  1178	) -> Result<Array2<f64>, BasisError> {
  1179	    if order == 0 || order >= num_basis_functions {
  1180	        return Err(BasisError::InvalidPenaltyOrder {
  1181	            order,
  1182	            num_basis: num_basis_functions,
  1183	        });
  1184	    }
  1185	
  1186	    if let Some(g) = greville_abscissae {
  1187	        if g.len() != num_basis_functions {
  1188	            return Err(BasisError::DimensionMismatch(format!(
  1189	                "Greville abscissae length {} does not match num_basis_functions {}",
  1190	                g.len(),
  1191	                num_basis_functions
  1192	            )));
  1193	        }
  1194	    }
  1195	
  1196	    // Start with the identity matrix
  1197	    let mut d = Array2::<f64>::eye(num_basis_functions);
  1198	
  1199	    // Apply the differencing operation `order` times.
  1200	    // Each `diff` reduces the number of rows by 1.
  1201	    for o in 1..=order {
  1202	        // Calculate the difference between adjacent rows: D^{(o)} = Delta * D^{(o-1)}
  1203	        d = &d.slice(s![1.., ..]) - &d.slice(s![..-1, ..]);
  1204	
  1205	        // If using non-uniform knots, apply divided difference scaling:
  1206	        // D^{(o)}_i = D^{(o)}_i / (xi_{i+o} - xi_i)
  1207	        if let Some(g) = greville_abscissae {
  1208	            let nrows = d.nrows();
  1209	            for i in 0..nrows {
  1210	                let span = g[i + o] - g[i];
  1211	                if span.abs() <= 1e-12 {
  1212	                    return Err(BasisError::InvalidKnotVector(format!(
  1213	                        "singular divided-difference span at order {o}, row {i}: Greville abscissae g[{}]={:.6e} and g[{i}]={:.6e} collapse",
  1214	                        i + o,
  1215	                        g[i + o],
  1216	                        g[i]
  1217	                    )));
  1218	                }
  1219	                let mut row = d.row_mut(i);
  1220	                row /= span;
  1221	            }
  1222	        }
  1223	    }
  1224	
  1225	    // The penalty matrix S = D' * D
  1226	    let s = fast_ata(&d);
  1227	    Ok(s)
  1228	}
