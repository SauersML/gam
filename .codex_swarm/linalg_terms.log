   762	/// shape but takes an `apply` closure that writes its result into a caller
   763	/// buffer, enabling the inner-Newton PCG hot path to avoid per-iter
   764	/// `Array1::<f64>` allocations for the matvec output (biobank-scale critical).
   765	pub fn solve_spd_pcg_into<F>(
   766	    apply: F,
   767	    rhs: &Array1<f64>,
   768	    preconditioner_diag: &Array1<f64>,
   769	    rel_tol: f64,
