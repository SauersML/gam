  1472	    fn quadratic_form_diag(&self, middle: &Array2<f64>) -> Result<Array1<f64>, String> {
  1473	        match self {
  1474	            Self::Materialized(matrix) => {
  1475	                if middle.nrows() != matrix.ncols() || middle.ncols() != matrix.ncols() {
  1476	                    return Err(format!(
  1477	                        "quadratic_form_diag dimension mismatch: matrix is {}x{}, expected {}x{}",
  1478	                        middle.nrows(),
  1479	                        middle.ncols(),
  1480	                        matrix.ncols(),
  1481	                        matrix.ncols()
  1482	                    ));
  1483	                }
  1484	                let xc = fast_ab(matrix, middle);
  1485	                let n = matrix.nrows();
  1486	                let p = matrix.ncols();
  1487	                let mut out = Array1::<f64>::zeros(n);
  1488	                if matrix.is_standard_layout()
  1489	                    && xc.is_standard_layout()
  1490	                    && let (Some(m_all), Some(xc_all), Some(out_slice)) =
  1491	                        (matrix.as_slice(), xc.as_slice(), out.as_slice_mut())
  1492	                {
  1493	                    // Parallel per-row clamped quadratic-form diagonal with
  1494	                    // stride-1 reads from both row-major operands. Avoids the
  1495	                    // per-row `Array1::dot` call's overhead at biobank shapes
  1496	                    // (n ≈ 2e5, p ≈ 33).
  1497	                    use rayon::iter::{IndexedParallelIterator, ParallelIterator};
  1498	                    use rayon::slice::ParallelSliceMut;
  1499	                    out_slice
  1500	                        .par_chunks_mut(1)
  1501	                        .enumerate()
  1502	                        .for_each(|(i, slot)| {
  1503	                            let off = i * p;
  1504	                            let m_row = &m_all[off..off + p];
  1505	                            let xc_row = &xc_all[off..off + p];
  1506	                            let mut acc = 0.0_f64;
  1507	                            for j in 0..p {
  1508	                                acc += m_row[j] * xc_row[j];
  1509	                            }
  1510	                            slot[0] = acc.max(0.0);
  1511	                        });
  1512	                } else {
  1513	                    for i in 0..n {
  1514	                        out[i] = matrix.row(i).dot(&xc.row(i)).max(0.0);
  1515	                    }
  1516	                }
  1517	                Ok(out)
  1518	            }
  1519	            Self::Lazy(op) => op.quadratic_form_diag(middle),
  1520	        }
  1521	    }
