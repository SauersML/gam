   792	/// Compute the 2×2 block joint Hessian in a single streaming pass:
   793	///   [X_a^T diag(w_aa) X_a,   X_a^T diag(w_ab) X_b]
   794	///   [X_b^T diag(w_ab) X_a,   X_b^T diag(w_bb) X_b]
   795	///
   796	/// This reads X_a and X_b once per chunk instead of twice (saving 50% bandwidth).
   797	pub fn fast_joint_hessian_2x2<
   798	    S1: Data<Elem = f64>,
   799	    S2: Data<Elem = f64>,
   800	    S3: Data<Elem = f64>,
   801	    S4: Data<Elem = f64>,
   802	    S5: Data<Elem = f64>,
   803	>(
   804	    x_a: &ArrayBase<S1, Ix2>,
   805	    x_b: &ArrayBase<S2, Ix2>,
   806	    w_aa: &ArrayBase<S3, Ix1>,
   807	    w_ab: &ArrayBase<S4, Ix1>,
   808	    w_bb: &ArrayBase<S5, Ix1>,
   809	) -> Array2<f64> {
   810	    use faer::Accum;
   811	    use faer::linalg::matmul::matmul;
   812	    use ndarray::{ShapeBuilder, s};
   813	
   814	    let n = x_a.nrows();
   815	    let pa = x_a.ncols();
   816	    let pb = x_b.ncols();
   817	    let total = pa + pb;
   818	    debug_assert_eq!(n, x_b.nrows());
   819	    debug_assert_eq!(n, w_aa.len());
   820	    debug_assert_eq!(n, w_ab.len());
   821	    debug_assert_eq!(n, w_bb.len());
   822	
   823	    if n == 0 || total == 0 {
   824	        return Array2::<f64>::zeros((total, total));
   825	    }
   826	
   827	    // For small problems, fall back to separate computations
   828	    if !should_use_faer_matmul(pa.max(pb), pa.max(pb), n) {
   829	        let waa_xa = Array2::from_shape_fn((n, pa), |(i, j)| w_aa[i] * x_a[[i, j]]);
   830	        let wab_xb = Array2::from_shape_fn((n, pb), |(i, j)| w_ab[i] * x_b[[i, j]]);
   831	        let wbb_xb = Array2::from_shape_fn((n, pb), |(i, j)| w_bb[i] * x_b[[i, j]]);
   832	        let mut out = Array2::<f64>::zeros((total, total));
   833	        out.slice_mut(s![..pa, ..pa]).assign(&x_a.t().dot(&waa_xa));
   834	        out.slice_mut(s![..pa, pa..]).assign(&x_a.t().dot(&wab_xb));
   835	        out.slice_mut(s![pa.., pa..]).assign(&x_b.t().dot(&wbb_xb));
   836	        // Mirror upper to lower
   837	        for i in 0..total {
   838	            for j in 0..i {
   839	                out[[i, j]] = out[[j, i]];
   840	            }
   841	        }
   842	        return out;
   843	    }
   844	
   845	    const TARGET_BYTES: usize = 8 * 1024 * 1024;
   846	    const MIN_ROWS: usize = 512;
   847	    const MAX_ROWS: usize = 131_072;
   848	    // Need buffers for: waa_xa(chunk×pa) + wab_xb(chunk×pb) + wbb_xb(chunk×pb)
   849	    let cols_needed = pa + 2 * pb;
   850	    let chunk_rows = (TARGET_BYTES / (cols_needed.max(1) * 8))
   851	        .clamp(MIN_ROWS, MAX_ROWS)
   852	        .min(n);
   853	
   854	    let mut out = Array2::<f64>::zeros((total, total).f());
   855	    // Row-major weighted buffers so the per-row scale loops have stride-1
