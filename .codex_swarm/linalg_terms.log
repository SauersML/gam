   368	#[derive(Debug, Clone, Copy, PartialEq)]
   369	pub struct PcgSolveInfo {
   370	    pub iterations: usize,
   371	    pub converged: bool,
   372	    pub relative_residual_norm: f64,
   373	    pub initial_residual_norm: f64,
   374	    pub final_residual_norm: f64,
   375	    pub residual_reduction: f64,
   376	    pub condition_estimate: Option<f64>,
   377	}
   378	
   379	#[derive(Debug, Clone)]
   380	struct PcgDiagnostics {
   381	    residuals: Vec<f64>,
   382	    alpha: Vec<f64>,
   383	    beta: Vec<f64>,
   384	}
   385	
   386	impl PcgDiagnostics {
   387	    fn new(initial_residual_norm: f64) -> Self {
   388	        Self {
   389	            residuals: vec![initial_residual_norm],
   390	            alpha: Vec::new(),
   391	            beta: Vec::new(),
   392	        }
   393	    }
   394	
   395	    fn push_iteration(&mut self, alpha: f64, beta: Option<f64>, residual_norm: f64) {
   396	        self.alpha.push(alpha);
   397	        if let Some(beta) = beta {
   398	            self.beta.push(beta);
   399	        }
   400	        self.residuals.push(residual_norm);
   401	    }
   402	
   403	    fn condition_estimate(&self) -> Option<f64> {
   404	        // Build the CG Lanczos tridiagonal for the preconditioned operator.
   405	        // For SPD CG, T has diagonal 1/a_i + b_{i-1}/a_{i-1} and off-diagonal
   406	        // sqrt(b_i)/a_i. Its extremal eigenvalues are Ritz estimates.
   407	        let k = self.alpha.len();
   408	        if k == 0 || k > 256 {
   409	            return None;
   410	        }
   411	        let mut t = ndarray::Array2::<f64>::zeros((k, k));
   412	        for i in 0..k {
   413	            let alpha_i = self.alpha[i];
   414	            if !alpha_i.is_finite() || alpha_i <= 0.0 {
   415	                return None;
   416	            }
   417	            let mut diag = 1.0 / alpha_i;
   418	            if i > 0 {
   419	                let beta_prev = self.beta.get(i - 1).copied()?;
   420	                if !beta_prev.is_finite() || beta_prev < 0.0 {
   421	                    return None;
   422	                }
   423	                diag += beta_prev / self.alpha[i - 1];
   424	            }
   425	            t[[i, i]] = diag;
   426	            if i + 1 < k {
   427	                let beta_i = self.beta.get(i).copied().unwrap_or(0.0);
   428	                if !beta_i.is_finite() || beta_i < 0.0 {
   429	                    return None;
   430	                }
   431	                let off = beta_i.sqrt() / alpha_i;
   432	                t[[i, i + 1]] = off;
   433	                t[[i + 1, i]] = off;
   434	            }
   435	        }
   436	        let mut lower = f64::INFINITY;
   437	        let mut upper = 0.0_f64;
   438	        for i in 0..k {
   439	            let radius = if i > 0 { t[[i, i - 1]].abs() } else { 0.0 }
   440	                + if i + 1 < k { t[[i, i + 1]].abs() } else { 0.0 };
   441	            lower = lower.min(t[[i, i]] - radius);
   442	            upper = upper.max(t[[i, i]] + radius);
   443	        }
   444	        if lower.is_finite() && lower > 0.0 && upper.is_finite() && upper > 0.0 {
   445	            Some(upper / lower)
   446	        } else {
   447	            None
   448	        }
   449	    }
   450	
   451	    fn info(
   452	        &self,
   453	        iterations: usize,
   454	        converged: bool,
   455	        rhs_norm: f64,
   456	        final_residual_norm: f64,
   457	    ) -> PcgSolveInfo {
   458	        let initial = self.residuals.first().copied().unwrap_or(rhs_norm);
   459	        PcgSolveInfo {
   460	            iterations,
   461	            converged,
   462	            relative_residual_norm: final_residual_norm / rhs_norm.max(1.0),
   463	            initial_residual_norm: initial,
   464	            final_residual_norm,
   465	            residual_reduction: if initial > 0.0 {
   466	                final_residual_norm / initial
   467	            } else {
   468	                0.0
   469	            },
   470	            condition_estimate: self.condition_estimate(),
   471	        }
   472	    }
   473	}
