   435	        knotvec: Array1<f64>,
   436	    ) -> Result<(Self::Output, Array1<f64>), BasisError> {
   437	        let knotview = knotvec.view();
   438	
   439	        let num_basis_functions = knotview.len().saturating_sub(degree + 1);
   440	        let basis_matrix = if should_use_sparse_basis(num_basis_functions, degree, 1) {
   441	            let left = knotview[degree];
   442	            let right = knotview[num_basis_functions];
   443	            let data_clamped = data.mapv(|x| x.clamp(left, right));
   444	            let sparse = generate_basis_internal::<SparseStorage>(
   445	                data_clamped.view(),
   446	                knotview,
   447	                degree,
   448	                eval_kind,
   449	            )?;
   450	            let mut dense = Array2::<f64>::zeros((sparse.nrows(), sparse.ncols()));
   451	            let (symbolic, values) = sparse.parts();
   452	            let col_ptr = symbolic.col_ptr();
   453	            let row_idx = symbolic.row_idx();
   454	            for col in 0..sparse.ncols() {
   455	                let start = col_ptr[col];
   456	                let end = col_ptr[col + 1];
   457	                for idx in start..end {
   458	                    dense[[row_idx[idx], col]] += values[idx];
