   169	            self.q,
   170	            self.m,
   171	            self.s,
   172	            self.kappa,
   173	            &self.eta_raw,
   174	            &self.eta_metric_powers,
   175	            r0.as_slice(),
   176	            self.diagonal_epsilon,
   177	        )
   178	    }
   179	
   180	    /// Evaluate `(S w)` writing the result into `out`.
   181	    ///
   182	    /// With constraints composed, `S' = T^T diag(Z, I_poly)^T S_raw diag(Z, I_poly) T`.
   183	    /// We apply the chain right-to-left:
   184	    ///   1. `u = T w`            (dim → total_pre)
   185	    ///   2. `u_kernel = u[..kernel_cols]; u_poly = u[kernel_cols..]`
   186	    ///   3. `v = Z u_kernel`     (kernel_cols → K)
   187	    ///   4. `y = S_raw v`        (K → K), via on-the-fly pair-block evaluation
   188	    ///   5. `y_kernel = Z^T y`   (K → kernel_cols)
   189	    ///   6. compose with zero polynomial block, then `out = T^T [y_kernel; 0]`
   190	    pub fn matvec(&self, w: ArrayView1<'_, f64>, mut out: ArrayViewMut1<'_, f64>) {
   191	        assert_eq!(
   192	            w.len(),
   193	            self.dim(),
   194	            "ClosedFormPenaltyOperator::matvec: input dim mismatch"
   195	        );
   196	        assert_eq!(
   197	            out.len(),
   198	            self.dim(),
   199	            "ClosedFormPenaltyOperator::matvec: output dim mismatch"
   200	        );
