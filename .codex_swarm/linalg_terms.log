   618	fn validate_knots_for_degree(
   619	    knot_vector: ArrayView1<f64>,
   620	    degree: usize,
   621	) -> Result<(), BasisError> {
   622	    if degree < 1 {
   623	        return Err(BasisError::InvalidDegree(degree));
   624	    }
   625	
   626	    let required_knots = 2 * (degree + 1);
   627	    if knot_vector.len() < required_knots {
   628	        return Err(BasisError::InsufficientKnotsForDegree {
   629	            degree,
   630	            required: required_knots,
   631	            provided: knot_vector.len(),
   632	        });
   633	    }
   634	
   635	    if knot_vector.iter().any(|&k| !k.is_finite()) {
   636	        return Err(BasisError::InvalidKnotVector(
   637	            "knot vector contains non-finite (NaN or Infinity) values".to_string(),
   638	        ));
   639	    }
   640	
   641	    if knot_vector.len() >= 2 {
   642	        for i in 0..(knot_vector.len() - 1) {
   643	            if knot_vector[i] > knot_vector[i + 1] {
   644	                return Err(BasisError::InvalidKnotVector(
   645	                    "knot vector is not non-decreasing".to_string(),
   646	                ));
   647	            }
   648	        }
   649	    }
   650	
   651	    Ok(())
   652	}
   653	
   654	/// Rejects knot vectors whose effective basis functions have zero support
   655	/// (i.e. `t[i+degree+1] == t[i]` for any `i`). This is stricter than the
   656	/// structural `validate_knots_for_degree` and is only appropriate at the
   657	/// user-facing top-level of basis construction — the recursive derivative
   658	/// evaluators repeatedly call `validate_knots_for_degree` with a reduced
   659	/// `degree` on the *same* (clamped) knot vector, where the outermost lower-
   660	/// degree "basis function" always collapses to zero support by construction
   661	/// and is harmless because the derivative recursion guards the matching
   662	/// `1/(t_{i+k}-t_i)` denominator with an absolute-value check.
   663	fn validate_knot_spans_nondegenerate(
   664	    knot_vector: ArrayView1<f64>,
   665	    degree: usize,
   666	) -> Result<(), BasisError> {
   667	    if knot_vector.len() <= degree + 1 {
   668	        return Ok(());
   669	    }
   670	    let num_basis = knot_vector.len() - degree - 1;
   671	    for i in 0..num_basis {
   672	        let span = knot_vector[i + degree + 1] - knot_vector[i];
   673	        if span <= 1e-12 {
   674	            return Err(BasisError::InvalidKnotVector(format!(
   675	                "basis function {i} has zero support: t[i+degree+1]-t[i]={span:.3e} must be > 0"
   676	            )));
   677	        }
   678	    }
   679	    Ok(())
   680	}
