  1702	/// Compute an orthonormal basis for `null(a^T)` using column-pivoted QR on `a`.
  1703	///
  1704	/// This is intended for tall/skinny matrices where `a ∈ R^{m×n}` with `m >= n`.
  1705	/// If `A P^T = Q R`, then the trailing `m-rank(A)` columns of `Q` span
  1706	/// `null(A^T)`.
  1707	pub fn rrqr_nullspace_basis<S: Data<Elem = f64>>(
  1708	    a: &ArrayBase<S, Ix2>,
  1709	    rank_alpha: f64,
  1710	) -> Result<(Array2<f64>, usize), FaerLinalgError> {
  1711	    let faerview = FaerArrayView::new(a);
  1712	    let qr = faerview.as_ref().col_piv_qr();
  1713	    let r = qr.thin_R();
  1714	    let diag_len = r.nrows().min(r.ncols());
  1715	    let leading_diag = if diag_len > 0 { r[(0, 0)].abs() } else { 0.0 };
  1716	    let tol = rank_alpha
  1717	        * f64::EPSILON
  1718	        * (a.nrows().max(a.ncols()).max(1) as f64)
  1719	        * leading_diag.max(1.0);
  1720	    let rank = (0..diag_len).filter(|&i| r[(i, i)].abs() > tol).count();
  1721	    let z = if rank >= a.nrows() {
  1722	        Array2::<f64>::zeros((a.nrows(), 0))
  1723	    } else {
  1724	        let nullity = a.nrows() - rank;
  1725	        let mut selector = Mat::<f64>::zeros(a.nrows(), nullity);
  1726	        for j in 0..nullity {
  1727	            selector[(rank + j, j)] = 1.0;
  1728	        }
  1729	        let par = get_global_parallelism();
  1730	        faer::linalg::householder::apply_block_householder_sequence_on_the_left_in_place_with_conj(
  1731	            qr.Q_basis(),
  1732	            qr.Q_coeff(),
  1733	            Conj::No,
  1734	            selector.as_mut(),
  1735	            par,
  1736	            MemStack::new(&mut MemBuffer::new(
  1737	                faer::linalg::householder::apply_block_householder_sequence_on_the_left_in_place_scratch::<f64>(
  1738	                    a.nrows(),
  1739	                    qr.Q_coeff().nrows(),
  1740	                    nullity,
  1741	                ),
  1742	            )),
  1743	        );
  1744	        mat_to_array(selector.as_ref())
  1745	    };
  1746	    Ok((z, rank))
  1747	}
