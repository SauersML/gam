  1145	/// Returns true if the B-spline basis should be built in sparse form based on density.
  1146	pub fn should_use_sparse_basis(num_basis_cols: usize, degree: usize, dim: usize) -> bool {
  1147	    if num_basis_cols == 0 {
  1148	        return false;
  1149	    }
  1150	
  1151	    let support_perrow = (degree + 1).saturating_pow(dim as u32) as f64;
  1152	    let density = support_perrow / num_basis_cols as f64;
  1153	
  1154	    density < 0.20 && num_basis_cols > 32
  1155	}
