   393	    fn jacobi_preconditioner(&self) -> Result<Array1<f64>, String> {
   394	        let mut diag = self.operator.diag_gram(self.weights)?;
   395	        if let Some(pen) = self.penalty {
   396	            for i in 0..diag.len() {
   397	                diag[i] += pen[[i, i]];
   398	            }
   399	        }
   400	        if self.ridge > 0.0 {
   401	            for i in 0..diag.len() {
   402	                diag[i] += self.ridge;
   403	            }
   404	        }
   405	        Ok(diag)
   406	    }
   407	}
