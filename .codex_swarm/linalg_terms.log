   578	#[inline]
   579	pub fn fast_xt_diag_x<S1: Data<Elem = f64>, S2: Data<Elem = f64>>(
   580	    x: &ArrayBase<S1, Ix2>,
   581	    w: &ArrayBase<S2, Ix1>,
