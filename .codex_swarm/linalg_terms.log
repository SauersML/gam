   109	    fn accumulate_into(&self, mut dest: ArrayViewMut2<'_, f64>, weight: f64) {
   110	        if weight == 0.0 {
   111	            return;
   112	        }
   113	        match &self.representation {
   114	            PenaltyRepresentation::Dense(block) => {
   115	                dest.scaled_add(weight, block);
   116	            }
   117	            PenaltyRepresentation::Banded { bands, offsets } => {
   118	                let positive_offsets: HashSet<usize> = offsets
   119	                    .iter()
   120	                    .filter_map(|&off| (off >= 0).then_some(off as usize))
   121	                    .collect();
   122	                for (band, &offset) in bands.iter().zip(offsets.iter()) {
   123	                    let off = offset.unsigned_abs() as usize;
   124	                    if offset < 0 && positive_offsets.contains(&off) {
   125	                        continue;
   126	                    }
   127	                    for (idx, &value) in band.iter().enumerate() {
   128	                        let (i, j) = if offset >= 0 {
   129	                            (idx, idx + off)
   130	                        } else {
   131	                            (idx + off, idx)
   132	                        };
   133	                        let Some(entry_ij) = dest.get_mut((i, j)) else {
   134	                            continue;
   135	                        };
   136	                        *entry_ij += weight * value;
   137	                        if i != j
   138	                            && let Some(entry_ji) = dest.get_mut((j, i))
   139	                        {
   140	                            *entry_ji += weight * value;
   141	                        }
   142	                    }
   143	                }
   144	            }
   145	            PenaltyRepresentation::Kronecker { left, right } => {
   146	                let (lrows, l_cols) = left.dim();
   147	                let (rrows, r_cols) = right.dim();
   148	                for i in 0..lrows {
   149	                    for j in 0..l_cols {
   150	                        let scale = left[(i, j)] * weight;
   151	                        if scale == 0.0 {
   152	                            continue;
   153	                        }
   154	                        let mut block = dest.slice_mut(s![
   155	                            i * rrows..(i + 1) * rrows,
   156	                            j * r_cols..(j + 1) * r_cols
   157	                        ]);
   158	                        block.scaled_add(scale, right);
   159	                    }
   160	                }
   161	            }
   162	        }
   163	    }
