   569	pub fn solve_sparse_spd<S>(
   570	    factor: &SparseExactFactor,
   571	    rhs: &ArrayBase<S, Ix1>,
   572	) -> Result<Array1<f64>, EstimationError>
   573	where
   574	    S: Data<Elem = f64>,
   575	{
   576	    if rhs.len() != factor.n {
   577	        return Err(EstimationError::InvalidInput(format!(
   578	            "sparse SPD solve dimension mismatch: rhs has {}, factor has {}",
   579	            rhs.len(),
   580	            factor.n
   581	        )));
   582	    }
   583	    let rhsview = FaerColView::new(rhs);
   584	    let out = factor.factor.solve(rhsview.as_ref());
   585	    let mut result = Array1::<f64>::zeros(rhs.len());
   586	    for i in 0..rhs.len() {
   587	        let value = out[(i, 0)];
   588	        if !value.is_finite() {
   589	            return Err(EstimationError::InvalidInput(
   590	                "sparse SPD solve produced non-finite values".to_string(),
   591	            ));
   592	        }
   593	        result[i] = value;
   594	    }
   595	    Ok(result)
   596	}
   597	
   598	/// In-place variant of [`solve_sparse_spd`]. Writes the solution directly into
   599	/// `out`, avoiding the intermediate `Array1` allocation on the hot PIRLS path.
   600	/// `out` must already be sized to match `factor.n` (typically the reused
   601	/// Newton-direction buffer).
   602	pub fn solve_sparse_spd_into<S>(
   603	    factor: &SparseExactFactor,
   604	    rhs: &ArrayBase<S, Ix1>,
   605	    out: &mut Array1<f64>,
   606	) -> Result<(), EstimationError>
   607	where
   608	    S: Data<Elem = f64>,
   609	{
   610	    if rhs.len() != factor.n {
   611	        return Err(EstimationError::InvalidInput(format!(
   612	            "sparse SPD solve dimension mismatch: rhs has {}, factor has {}",
   613	            rhs.len(),
   614	            factor.n
   615	        )));
   616	    }
   617	    if out.len() != factor.n {
   618	        return Err(EstimationError::InvalidInput(format!(
   619	            "sparse SPD solve output dimension mismatch: out has {}, factor has {}",
   620	            out.len(),
   621	            factor.n
   622	        )));
   623	    }
   624	    let rhsview = FaerColView::new(rhs);
   625	    let solved = factor.factor.solve(rhsview.as_ref());
   626	    for i in 0..factor.n {
   627	        let value = solved[(i, 0)];
   628	        if !value.is_finite() {
   629	            return Err(EstimationError::InvalidInput(
   630	                "sparse SPD solve produced non-finite values".to_string(),
   631	            ));
   632	        }
   633	        out[i] = value;
   634	    }
   635	    Ok(())
   636	}
