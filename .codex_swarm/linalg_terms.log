   772	where
   773	    F: Fn(&Array1<f64>, &mut Array1<f64>),
   774	{
   775	    solve_spd_pcg_with_info_into(apply, rhs, preconditioner_diag, rel_tol, max_iter)
   776	        .map(|(solution, _)| solution)
   777	}
