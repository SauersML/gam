  1979	fn cardinal_bspline_value(x: f64, degree: usize) -> f64 {
  1980	    if degree == 0 {
  1981	        return if (0.0..1.0).contains(&x) { 1.0 } else { 0.0 };
  1982	    }
  1983	    if x <= 0.0 || x >= (degree + 1) as f64 {
  1984	        return 0.0;
  1985	    }
  1986	    let mut acc = 0.0;
  1987	    for i in 0..=(degree + 1) {
  1988	        let sign = if i % 2 == 0 { 1.0 } else { -1.0 };
  1989	        acc += sign * binomial_f64(degree + 1, i) * positive_part_pow(x - i as f64, degree);
  1990	    }
  1991	    (acc / factorial_f64(degree)).max(0.0)
  1992	}
