   138	        let p = matrix.nrows();
   139	        if matrix.ncols() != p || rhs.len() != p {
   140	            return None;
   141	        }
   142	
   143	        for retry in 0..MAX_SOLVE_RETRIES {
   144	            let ridge = if baseridge > 0.0 {
   145	                baseridge * 10f64.powi(retry as i32)
   146	            } else {
   147	                0.0
   148	            };
   149	            let h = addridge(matrix, ridge);
   150	            let factor = match self.factorize(&h) {
   151	                Ok(f) => f,
   152	                Err(_) => continue,
   153	            };
   154	            let mut out = rhs.clone();
   155	            let mut out_mat = crate::faer_ndarray::array1_to_col_matmut(&mut out);
   156	            factor.solve_in_place(out_mat.as_mut());
   157	            if out.iter().all(|v| v.is_finite()) {
   158	                return Some(out);
   159	            }
   160	        }
   161	        None
   162	    }
   163	
   164	    fn factorize_with_ridge_plan(
   165	        &self,
   166	        matrix: &Array2<f64>,
   167	        planner: &mut RidgePlanner,
   168	    ) -> Option<(crate::faer_ndarray::FaerSymmetricFactor, f64, Array2<f64>)> {
   169	        loop {
   170	            let ridge = planner.ridge();
   171	            let h_eff = addridge(matrix, ridge);
   172	            if let Ok(factor) = self.factorize(&h_eff) {
   173	                return Some((factor, ridge, h_eff));
   174	            }
   175	            if planner.attempts() >= MAX_FACTORIZATION_ATTEMPTS {
   176	                log::warn!(
   177	                    "Failed to factorize {} after ridge {:.3e}",
   178	                    self.label,
   179	                    ridge
   180	                );
   181	                return None;
   182	            }
   183	            planner.bumpwith_matrix(matrix);
   184	        }
   185	    }
   186	}
