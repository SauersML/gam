  7920	fn matern_kernel_radial_triplet(
  7921	    r: f64,
  7922	    length_scale: f64,
  7923	    nu: MaternNu,
  7924	) -> Result<(f64, f64, f64), BasisError> {
  7925	    let phi = matern_kernel_from_distance(r, length_scale, nu)?;
  7926	    let q = match nu {
  7927	        MaternNu::Half => 1.0 / length_scale,
  7928	        MaternNu::ThreeHalves => 3.0_f64.sqrt() / length_scale,
  7929	        MaternNu::FiveHalves => 5.0_f64.sqrt() / length_scale,
  7930	        MaternNu::SevenHalves => 7.0_f64.sqrt() / length_scale,
  7931	        MaternNu::NineHalves => 9.0_f64.sqrt() / length_scale,
  7932	    };
  7933	    let a = q * r;
  7934	    let (p, p1, p2) = matern_poly_terms(nu, a);
  7935	    let exp_a = (-a).exp();
  7936	    let phi_r = q * (p1 - p) * exp_a;
  7937	    let phi_rr = q * q * (p2 - 2.0 * p1 + p) * exp_a;
  7938	    if !phi.is_finite() || !phi_r.is_finite() || !phi_rr.is_finite() {
  7939	        return Err(BasisError::InvalidInput(format!(
  7940	            "non-finite Matérn radial derivatives at r={r}, length_scale={length_scale}, nu={nu:?}"
  7941	        )));
  7942	    }
  7943	    Ok((phi, phi_r, phi_rr))
  7944	}
