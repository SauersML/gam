   200	/// Concrete carrier of a penalty within the candidate / canonical-block
   201	/// pipeline. The `Dense` variant carries an owned `Array2<f64>` and is the
   202	/// default; the `Operator` variant carries an `Arc<dyn PenaltyOp>` so the
   203	/// operator may be reused across consumers (eigendecomposition, PCG matvec,
   204	/// log-det). Construction sites that build penalties from closed-form factory
   205	/// routines (`operator_penalty_candidates_closed_form{,_pure}`) may emit
   206	/// `Operator` form when the size threshold warrants it; below threshold the
   207	/// dense form is preserved.
   208	#[derive(Clone)]
   209	pub enum PenaltyForm {
   210	    Dense(Array2<f64>),
   211	    Operator(Arc<dyn PenaltyOp>),
   212	}
   213	
   214	impl PenaltyForm {
   215	    pub fn dim(&self) -> usize {
   216	        match self {
   217	            PenaltyForm::Dense(m) => {
   218	                debug_assert_eq!(m.nrows(), m.ncols());
   219	                m.nrows()
   220	            }
   221	            PenaltyForm::Operator(op) => op.dim(),
   222	        }
   223	    }
