   829	impl CanonicalPenalty {
   830	    /// Construct a dense (full-width) canonical penalty from a `rank x p` root.
   831	    /// Used to wrap reparam-transformed roots for consumers that expect
   832	    /// `&[CanonicalPenalty]`.
   833	    pub fn from_dense_root(root: Array2<f64>, p: usize) -> Self {
   834	        Self::from_dense_root_with_mean(root, p, Array1::zeros(p))
   835	    }
   836	
   837	    pub fn from_dense_root_with_mean(root: Array2<f64>, p: usize, prior_mean: Array1<f64>) -> Self {
   838	        debug_assert_eq!(prior_mean.len(), p);
   839	        let local = root.t().dot(&root);
   840	        let positive_eigenvalues = Vec::new(); // not needed for TK paths
   841	        Self {
   842	            root,
   843	            col_range: 0..p,
   844	            total_dim: p,
   845	            nullity: 0,
   846	            local,
   847	            prior_mean,
   848	            positive_eigenvalues,
   849	            op: None,
   850	        }
   851	    }
   852	
   853	    /// Embed the block-local root into a full-width `rank × total_dim` matrix.
   854	    /// For dense penalties (col_range = 0..p), returns the root unchanged.
   855	    pub fn full_width_root(&self) -> Array2<f64> {
   856	        if self.col_range.start == 0 && self.col_range.end == self.total_dim {
   857	            return self.root.clone();
   858	        }
   859	        let rank = self.root.nrows();
   860	        let mut full = Array2::<f64>::zeros((rank, self.total_dim));
   861	        full.slice_mut(ndarray::s![.., self.col_range.clone()])
   862	            .assign(&self.root);
   863	        full
   864	    }
   865	
   866	    /// Numerical rank of this penalty.
   867	    pub fn rank(&self) -> usize {
   868	        self.root.nrows()
   869	    }
   870	
   871	    /// Block dimension (number of columns this penalty covers).
   872	    pub fn block_dim(&self) -> usize {
   873	        self.col_range.len()
   874	    }
   875	
   876	    /// Whether this penalty is block-local (col_range != 0..total_dim).
   877	    pub fn is_block_local(&self) -> bool {
   878	        self.col_range.start != 0 || self.col_range.end != self.total_dim
   879	    }
   880	
   881	    /// Return a reference to the cached local penalty matrix.
   882	    /// Shape: `block_dim x block_dim`.
   883	    pub fn local_ref(&self) -> &Array2<f64> {
   884	        &self.local
   885	    }
   886	
   887	    /// Return an owned copy of the local penalty matrix.
   888	    /// Prefer `local_ref()` when a reference suffices.
   889	    pub fn local_penalty(&self) -> Array2<f64> {
   890	        self.local.clone()
   891	    }
   892	
   893	    /// Accumulate lambda * S_k into a pre-allocated `p x p` target matrix.
   894	    /// Only touches the block [col_range × col_range].
   895	    pub fn accumulate_weighted(&self, target: &mut Array2<f64>, lambda: f64) {
   896	        if lambda == 0.0 || self.rank() == 0 {
   897	            return;
   898	        }
   899	        let r = &self.col_range;
   900	        target
   901	            .slice_mut(s![r.start..r.end, r.start..r.end])
   902	            .scaled_add(lambda, &self.local);
   903	    }
   904	
   905	    /// Compute `scale * tr(M · S_k)` where M is a `p × p` dense matrix.
   906	    /// Only reads `M[start..end, start..end]` — O(block_dim²) not O(p²).
   907	    pub fn trace_product(&self, m: &Array2<f64>, scale: f64) -> f64 {
   908	        if self.rank() == 0 || scale == 0.0 {
   909	            return 0.0;
   910	        }
   911	        let r = &self.col_range;
   912	        let m_block = m.slice(s![r.start..r.end, r.start..r.end]);
   913	        let rm = self.root.dot(&m_block);
   914	        scale
   915	            * rm.iter()
   916	                .zip(self.root.iter())
   917	                .map(|(&a, &b)| a * b)
   918	                .sum::<f64>()
   919	    }
   920	
   921	    /// Compute `scale * v^T S_k v` (quadratic form).
   922	    /// Only reads `v[start..end]` — O(rank × block_dim) not O(rank × p).
   923	    pub fn quadratic(&self, v: &Array1<f64>, scale: f64) -> f64 {
   924	        if self.rank() == 0 || scale == 0.0 {
   925	            return 0.0;
   926	        }
   927	        let v_block = v.slice(s![self.col_range.start..self.col_range.end]);
   928	        let rv = self.root.dot(&v_block);
   929	        scale * rv.dot(&rv)
   930	    }
   931	
   932	    /// Compute `scale * S_k * prior_mean` embedded into the global basis.
   933	    pub fn prior_linear_shift(&self, scale: f64) -> Array1<f64> {
   934	        let mut out = Array1::<f64>::zeros(self.total_dim);
   935	        if self.rank() == 0 || scale == 0.0 || self.prior_mean.iter().all(|&v| v == 0.0) {
   936	            return out;
   937	        }
   938	        let block = self.local.dot(&self.prior_mean) * scale;
   939	        out.slice_mut(s![self.col_range.start..self.col_range.end])
   940	            .assign(&block);
   941	        out
   942	    }
   943	
   944	    /// Compute `scale * prior_mean' S_k prior_mean`.
   945	    pub fn prior_constant_shift(&self, scale: f64) -> f64 {
   946	        if self.rank() == 0 || scale == 0.0 || self.prior_mean.iter().all(|&v| v == 0.0) {
   947	            return 0.0;
   948	        }
   949	        scale * self.prior_mean.dot(&self.local.dot(&self.prior_mean))
   950	    }
   951	
   952	    /// Embed this block's prior mean into the global coefficient basis.
   953	    pub fn full_width_prior_mean(&self) -> Array1<f64> {
   954	        if self.col_range.start == 0 && self.col_range.end == self.total_dim {
   955	            return self.prior_mean.clone();
   956	        }
   957	        let mut out = Array1::<f64>::zeros(self.total_dim);
   958	        out.slice_mut(s![self.col_range.start..self.col_range.end])
   959	            .assign(&self.prior_mean);
   960	        out
   961	    }
   962	
   963	    /// Convert to a PenaltyCoordinate for the unified REML evaluator.
   964	    pub fn to_penalty_coordinate(
   965	        &self,
   966	    ) -> crate::solver::estimate::reml::unified::PenaltyCoordinate {
   967	        use crate::solver::estimate::reml::unified::PenaltyCoordinate;
   968	        if self.is_block_local() {
   969	            PenaltyCoordinate::from_block_root_with_mean(
   970	                self.root.clone(),
   971	                self.col_range.start,
   972	                self.col_range.end,
   973	                self.total_dim,
   974	                self.prior_mean.clone(),
   975	            )
   976	        } else {
   977	            PenaltyCoordinate::from_dense_root_with_mean(self.root.clone(), self.prior_mean.clone())
   978	        }
   979	    }
   980	}

