  1681	fn periodic_spline_interval_index(sites: ArrayView1<'_, f64>, x: f64) -> usize {
  1682	    let n = sites.len();
  1683	    match sites
  1684	        .as_slice()
  1685	        .expect("periodic spline sites are contiguous")
  1686	        .binary_search_by(|v| v.partial_cmp(&x).unwrap_or(std::cmp::Ordering::Less))
  1687	    {
  1688	        Ok(idx) => idx.min(n - 1),
  1689	        Err(0) => n - 1,
  1690	        Err(idx) => idx - 1,
  1691	    }
  1692	}
  1693	
  1694	fn solve_periodic_cubic_second_derivatives(
  1695	    values: ArrayView2<'_, f64>,
  1696	    h: &[f64],
  1697	) -> Result<Array2<f64>, BasisError> {
  1698	    let n = values.nrows();
  1699	    let d = values.ncols();
  1700	    if h.len() != n {
  1701	        return Err(BasisError::DimensionMismatch(
  1702	            "periodic spacing count must match value rows".to_string(),
  1703	        ));
  1704	    }
  1705	    let mut diag = vec![0.0; n];
  1706	    let mut rhs = Array2::<f64>::zeros((n, d));
  1707	    for i in 0..n {
  1708	        let prev = if i == 0 { n - 1 } else { i - 1 };
  1709	        let next = if i + 1 == n { 0 } else { i + 1 };
  1710	        diag[i] = 2.0 * (h[prev] + h[i]);
  1711	        for col in 0..d {
  1712	            let slope_next = (values[[next, col]] - values[[i, col]]) / h[i];
  1713	            let slope_prev = (values[[i, col]] - values[[prev, col]]) / h[prev];
  1714	            rhs[[i, col]] = 6.0 * (slope_next - slope_prev);
  1715	        }
  1716	    }
  1717	    solve_cyclic_tridiagonal_multi_rhs(&h[..n - 1], &diag, &h[..n - 1], h[n - 1], rhs)
  1718	}
  1719	
  1720	fn solve_cyclic_tridiagonal_multi_rhs(
  1721	    lower: &[f64],
  1722	    diag: &[f64],
  1723	    upper: &[f64],
  1724	    corner: f64,
  1725	    rhs: Array2<f64>,
  1726	) -> Result<Array2<f64>, BasisError> {
  1727	    let n = diag.len();
  1728	    if lower.len() + 1 != n || upper.len() + 1 != n || rhs.nrows() != n {
  1729	        return Err(BasisError::DimensionMismatch(
  1730	            "cyclic tridiagonal solve shape mismatch".to_string(),
  1731	        ));
  1732	    }
  1733	    if n < 3 {
  1734	        return Err(BasisError::InvalidInput(
  1735	            "periodic cubic spline system requires at least three sites".to_string(),
  1736	        ));
  1737	    }
  1738	
  1739	    let nrhs = rhs.ncols();
  1740	    let mut augmented = Array2::<f64>::zeros((n, nrhs + 2));
  1741	    augmented.slice_mut(s![.., 0..nrhs]).assign(&rhs);
  1742	    augmented[[0, nrhs]] = corner;
  1743	    augmented[[n - 1, nrhs + 1]] = corner;
  1744	
  1745	    let solved = solve_tridiagonal_multi_rhs(lower, diag, upper, augmented)?;
  1746	    let y = solved.slice(s![.., 0..nrhs]);
  1747	    let w0_col = nrhs;
  1748	    let w1_col = nrhs + 1;
  1749	
  1750	    let a00 = 1.0 + solved[[n - 1, w0_col]];
  1751	    let a01 = solved[[n - 1, w1_col]];
  1752	    let a10 = solved[[0, w0_col]];
  1753	    let a11 = 1.0 + solved[[0, w1_col]];
  1754	    let det = a00 * a11 - a01 * a10;
  1755	    if det.abs() <= 1e-14 || !det.is_finite() {
  1756	        return Err(BasisError::InvalidInput(
  1757	            "periodic cubic spline system is singular".to_string(),
  1758	        ));
  1759	    }
  1760	
  1761	    let mut out = Array2::<f64>::zeros((n, nrhs));
  1762	    for col in 0..nrhs {
  1763	        let z0 = y[[n - 1, col]];
  1764	        let z1 = y[[0, col]];
  1765	        let correction0 = (a11 * z0 - a01 * z1) / det;
  1766	        let correction1 = (-a10 * z0 + a00 * z1) / det;
  1767	        for row in 0..n {
  1768	            out[[row, col]] = y[[row, col]]
  1769	                - solved[[row, w0_col]] * correction0
  1770	                - solved[[row, w1_col]] * correction1;
  1771	        }
  1772	    }
  1773	    if out.iter().all(|v| v.is_finite()) {
  1774	        Ok(out)
  1775	    } else {
  1776	        Err(BasisError::InvalidInput(
  1777	            "periodic cubic spline solve produced non-finite values".to_string(),
  1778	        ))
  1779	    }
  1780	}
  1781	
  1782	fn solve_tridiagonal_multi_rhs(
  1783	    lower: &[f64],
  1784	    diag: &[f64],
  1785	    upper: &[f64],
  1786	    mut rhs: Array2<f64>,
  1787	) -> Result<Array2<f64>, BasisError> {
  1788	    let n = diag.len();
  1789	    if lower.len() + 1 != n || upper.len() + 1 != n || rhs.nrows() != n {
  1790	        return Err(BasisError::DimensionMismatch(
  1791	            "tridiagonal solve shape mismatch".to_string(),
  1792	        ));
  1793	    }
  1794	    let nrhs = rhs.ncols();
  1795	    let mut pivots = vec![0.0; n];
  1796	    let mut upper_factor = vec![0.0; n - 1];
  1797	
  1798	    pivots[0] = diag[0];
  1799	    if pivots[0].abs() <= 1e-14 || !pivots[0].is_finite() {
  1800	        return Err(BasisError::InvalidInput(
  1801	            "periodic cubic spline system is singular".to_string(),
  1802	        ));
  1803	    }
  1804	    upper_factor[0] = upper[0] / pivots[0];
  1805	    for col in 0..nrhs {
  1806	        rhs[[0, col]] /= pivots[0];
  1807	    }
  1808	
  1809	    for i in 1..n {
  1810	        pivots[i] = diag[i] - lower[i - 1] * upper_factor[i - 1];
  1811	        if pivots[i].abs() <= 1e-14 || !pivots[i].is_finite() {
  1812	            return Err(BasisError::InvalidInput(
  1813	                "periodic cubic spline system is singular".to_string(),
  1814	            ));
  1815	        }
  1816	        if i + 1 < n {
  1817	            upper_factor[i] = upper[i] / pivots[i];
  1818	        }
  1819	        for col in 0..nrhs {
  1820	            rhs[[i, col]] = (rhs[[i, col]] - lower[i - 1] * rhs[[i - 1, col]]) / pivots[i];
  1821	        }
  1822	    }
  1823	
  1824	    for i_rev in 0..(n - 1) {
  1825	        let i = n - 2 - i_rev;
  1826	        for col in 0..nrhs {
  1827	            rhs[[i, col]] -= upper_factor[i] * rhs[[i + 1, col]];
  1828	        }
  1829	    }
  1830	    Ok(rhs)
  1831	}
