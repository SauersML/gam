 22041	    knot_vector: ArrayView1<f64>,
 22042	    degree: usize,
 22043	    out: &mut [f64],
 22044	) -> Result<(), BasisError> {
 22045	    if degree < 1 {
 22046	        return Err(BasisError::InvalidDegree(degree));
 22047	    }
 22048	    let num_basis_lower = knot_vector.len().saturating_sub(degree);
 22049	    let mut lower_basis = vec![0.0; num_basis_lower];
 22050	    let mut lower_scratch = internal::BsplineScratch::new(degree.saturating_sub(1));
