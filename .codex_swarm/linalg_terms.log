 13987	/// so the series argument is back in `[0, 1/2)`.
 13988	#[inline]
 13989	fn dilog_unit(z: f64) -> f64 {
 13990	    if !z.is_finite() {
 13991	        return f64::NAN;
 13992	    }
 13993	    let z = z.clamp(0.0, 1.0);
 13994	    if z == 0.0 {
 13995	        return 0.0;
 13996	    }
 13997	    if z >= 1.0 {
 13998	        return std::f64::consts::PI * std::f64::consts::PI / 6.0;
 13999	    }
 14000	    if z <= 0.5 {
