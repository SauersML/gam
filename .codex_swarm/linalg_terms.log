   688	                    let value = vals[ptr];
   689	                    x_slice[[local, col]] += value;
   690	                    wx_slice[[local, col]] += wi * value;
   691	                }
   692	            }
   693	        }
   694	        let x_slice = x_chunk.slice(s![0..rows, ..]);
   695	        let wx_slice = wx_chunk.slice(s![0..rows, ..]);
   696	        let x_view = FaerArrayView::new(&x_slice);
   697	        let wx_view = FaerArrayView::new(&wx_slice);
   698	        matmul(
   699	            out_view.as_mut(),
   700	            Accum::Add,
   701	            x_view.as_ref().transpose(),
   702	            wx_view.as_ref(),
   703	            1.0,
   704	            par,
   705	        );
   706	    }
   707	}
   708	
   709	fn sparse_csr_diag_gram(
   710	    row_ptr: &[usize],
   711	    col_idx: &[usize],
   712	    vals: &[f64],
   713	    n: usize,
   714	    p: usize,
   715	    weights: ArrayView1<'_, f64>,
   716	) -> Array1<f64> {
   717	    let work = vals.len() as u64;
   718	    if rayon::current_num_threads() <= 1 || work < SPARSE_ROW_PARALLEL_MIN_FLOPS {
   719	        return sparse_csr_diag_gram_rows(row_ptr, col_idx, vals, p, weights, 0..n);
   720	    }
   721	    let n_threads = rayon::current_num_threads();
   722	    let chunk_rows = n.div_ceil(n_threads * 8).max(1);
   723	    let starts: Vec<usize> = (0..n).step_by(chunk_rows).collect();
   724	    let partials: Vec<Array1<f64>> = starts
   725	        .into_par_iter()
   726	        .map(|start| {
   727	            sparse_csr_diag_gram_rows(
   728	                row_ptr,
   729	                col_idx,
   730	                vals,
   731	                p,
   732	                weights,
   733	                start..(start + chunk_rows).min(n),
   734	            )
   735	        })
   736	        .collect();
   737	    let mut diag = Array1::<f64>::zeros(p);
   738	    for partial in &partials {
   739	        diag += partial;
   740	    }
   741	    diag
   742	}
   743	
   744	fn sparse_csr_diag_gram_rows(
   745	    row_ptr: &[usize],
   746	    col_idx: &[usize],
   747	    vals: &[f64],
   748	    p: usize,
   749	    weights: ArrayView1<'_, f64>,
   750	    rows: Range<usize>,
   751	) -> Array1<f64> {
   752	    let mut diag = Array1::<f64>::zeros(p);
   753	    for i in rows {
   754	        let wi = weights[i].max(0.0);
   755	        if wi == 0.0 {
   756	            continue;
   757	        }
   758	        for idx in row_ptr[i]..row_ptr[i + 1] {
   759	            let j = col_idx[idx];
   760	            let xij = vals[idx];
   761	            diag[j] += wi * xij * xij;
   762	        }
   763	    }
   764	    diag
   765	}
