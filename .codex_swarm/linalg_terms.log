   235	pub(crate) fn add_relative_diag_ridge(matrix: &mut Array2<f64>, scale: f64, floor: f64) -> f64 {
   236	    let ridge = scale
   237	        * matrix
   238	            .diag()
   239	            .iter()
   240	            .map(|&value| value.abs())
   241	            .fold(0.0, f64::max)
   242	            .max(floor);
