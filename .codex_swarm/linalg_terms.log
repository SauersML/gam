 21214	/// Compute the constraint transform Z using Greville abscissae (geometric constraints).
 21215	///
 21216	/// This creates a transform that removes constant and linear trends from spline
 21217	/// coefficients based purely on knot geometry, without reference to observed data.
 21218	/// This makes Z constant w.r.t. model parameters β, ensuring dZ/dβ = 0 exactly,
 21219	/// which enables exact analytic gradients.
 21220	///
 21221	/// # Mathematical Background
 21222	/// For B-splines, a linear function f(x) = a + bx has coefficients c_j = a + b·G_j
 21223	/// where G_j are the Greville abscissae. Therefore, constraining the coefficient
 21224	/// vector θ to satisfy:
 21225	///   - Σ θ_j = 0  (orthogonal to constants)
 21226	///   - Σ θ_j·G_j = 0  (orthogonal to linear in Greville coordinates)
 21227	/// removes the ability to represent any linear function.
 21228	///
 21229	/// # Arguments
 21230	/// * `knot_vector` - Full knot vector
 21231	/// * `degree` - B-spline degree
 21232	/// * `penalty_order` - Order of difference penalty (typically 2)
 21233	///
 21234	/// # Returns
 21235	/// Tuple of (transform Z, projected_penalty Z'SZ) where:
 21236	/// - Z: k × (k-2) matrix mapping raw coefficients to constrained space
 21237	/// - S_constrained: (k-2) × (k-2) projected second-difference penalty
 21238	pub fn compute_geometric_constraint_transform(
 21239	    knot_vector: &Array1<f64>,
 21240	    degree: usize,
 21241	    penalty_order: usize,
 21242	) -> Result<(Array2<f64>, Array2<f64>), BasisError> {
 21243	    // 1. Compute Greville abscissae
 21244	    let g = compute_greville_abscissae(knot_vector, degree)?;
 21245	    let k = g.len();
 21246	
 21247	    if k < 3 {
 21248	        return Err(BasisError::InsufficientColumnsForConstraint { found: k });
 21249	    }
 21250	
 21251	    // 2. Build constraint matrix C_geom (2 × k)
 21252	    // Row 0: all ones (intercept constraint)
 21253	    // Row 1: Greville abscissae (linear constraint)
 21254	    let mut c_geom = Array2::<f64>::zeros((2, k));
 21255	    for j in 0..k {
 21256	        c_geom[[0, j]] = 1.0;
 21257	        c_geom[[1, j]] = g[j];
 21258	    }
 21259	
 21260	    // 3. Standardize linear row for numerical conditioning
 21261	    let g_mean = g.mean().unwrap_or(0.0);
