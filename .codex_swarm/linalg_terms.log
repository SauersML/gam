   313	/// Enforce exact symmetry on a square matrix by averaging off-diagonal pairs.
   314	pub(crate) fn enforce_symmetry(matrix: &mut Array2<f64>) {
   315	    let n = matrix.nrows();
   316	    debug_assert_eq!(n, matrix.ncols());
   317	    for i in 0..n {
   318	        for j in i + 1..n {
   319	            let avg = 0.5 * (matrix[[i, j]] + matrix[[j, i]]);
   320	            matrix[[i, j]] = avg;
   321	            matrix[[j, i]] = avg;
   322	        }
   323	    }
   324	}
