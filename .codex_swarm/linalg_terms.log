  1299	/// Hard cap on the dimension `p` allowed to fall back to a dense p × p
  1300	/// eigendecomposition of the overlapping balanced penalty.
  1301	///
  1302	/// Beyond this cap the overlapping-penalty path errors out instead of
  1303	/// allocating an O(p²) workspace whose eigendecomposition would dominate the
  1304	/// solve. ResourcePolicy threading is the long-term home for this cap (the
  1305	/// resource_serialize agent is widening ResourcePolicy coverage); until that
  1306	/// lands, both overlapping branches share this single constant so they can't
  1307	/// drift apart.
  1308	pub(crate) const OVERLAPPING_PENALTY_DENSE_FALLBACK_MAX_P: usize = 4096;
  1309	
  1310	/// Creates a balanced penalty root from canonical penalties.
  1311	///
  1312	/// When all penalties have non-overlapping col_ranges, the balanced sum is
  1313	/// block-diagonal and eigendecomposition is done per-block at O(Σ p_k³)
  1314	/// instead of the global O(p³). Falls back to the global path when penalties
  1315	/// overlap.
  1316	pub fn create_balanced_penalty_root_from_canonical(
  1317	    penalties: &[CanonicalPenalty],
  1318	    p: usize,
  1319	) -> Result<Array2<f64>, EstimationError> {
  1320	    if penalties.is_empty() {
  1321	        return Ok(Array2::zeros((0, p)));
  1322	    }
  1323	
  1324	    // Group penalties by col_range.
  1325	    let mut block_groups: BTreeMap<(usize, usize), Vec<&CanonicalPenalty>> = BTreeMap::new();
  1326	    for cp in penalties {
  1327	        if cp.rank() == 0 {
  1328	            continue;
  1329	        }
  1330	        let key = (cp.col_range.start, cp.col_range.end);
  1331	        block_groups.entry(key).or_default().push(cp);
  1332	    }
  1333	
  1334	    if block_groups.is_empty() {
  1335	        return Ok(Array2::zeros((0, p)));
  1336	    }
  1337	
  1338	    // Check for overlapping ranges.
  1339	    let ranges: Vec<(usize, usize)> = block_groups.keys().copied().collect();
  1340	    let mut overlapping = false;
  1341	    for i in 1..ranges.len() {
  1342	        if ranges[i].0 < ranges[i - 1].1 {
  1343	            overlapping = true;
  1344	            break;
  1345	        }
  1346	    }
  1347	
  1348	    if overlapping {
  1349	        if p > OVERLAPPING_PENALTY_DENSE_FALLBACK_MAX_P {
  1350	            return Err(EstimationError::LayoutError(format!(
  1351	                "overlapping penalty root would require dense {}x{} eigendecomposition; \
  1352	                 large-model dense fallback is disabled. Keep penalties structured or \
  1353	                 extend the overlapping-penalty solver path",
  1354	                p, p
  1355	            )));
  1356	        }
  1357	        // Fallback: accumulate into p × p and eigendecompose globally.
  1358	        let mut s_balanced = Array2::zeros((p, p));
  1359	        for cp in penalties {
  1360	            if cp.rank() == 0 {
  1361	                continue;
  1362	            }
  1363	            let local = cp.local_ref();
  1364	            let frob_norm = local.iter().map(|&x| x * x).sum::<f64>().sqrt();
  1365	            if frob_norm > 1e-12 {
  1366	                let r = &cp.col_range;
  1367	                s_balanced
  1368	                    .slice_mut(s![r.start..r.end, r.start..r.end])
  1369	                    .scaled_add(1.0 / frob_norm, local);
  1370	            }
  1371	        }
  1372	        let (eigenvalues, eigenvectors) =
  1373	            robust_eigh(&s_balanced, Side::Lower, "balanced penalty matrix")?;
  1374	        let max_eig = eigenvalues.iter().fold(0.0f64, |max, &val| max.max(val));
  1375	        let tolerance = if max_eig > 0.0 {
  1376	            max_eig * 1e-12
  1377	        } else {
  1378	            1e-12
  1379	        };
  1380	        let penalty_rank = eigenvalues.iter().filter(|&&ev| ev > tolerance).count();
  1381	        if penalty_rank == 0 {
  1382	            return Ok(Array2::zeros((0, p)));
  1383	        }
  1384	        let mut eb = Array2::zeros((p, penalty_rank));
  1385	        let mut col_idx = 0;
  1386	        for (i, &eigenval) in eigenvalues.iter().enumerate() {
  1387	            if eigenval > tolerance {
  1388	                let sqrt_ev = eigenval.sqrt();
  1389	                let evec = eigenvectors.column(i);
  1390	                eb.column_mut(col_idx).assign(&(&evec * sqrt_ev));
  1391	                col_idx += 1;
  1392	            }
  1393	        }
  1394	        return Ok(eb.t().to_owned());
  1395	    }
  1396	
  1397	    // Non-overlapping: eigendecompose per block at O(Σ p_k³).
  1398	    struct BlockRoot {
  1399	        col_range: Range<usize>,
  1400	        root: Array2<f64>, // rank_b × block_dim
  1401	    }
  1402	    // Materialize the BTreeMap order first. Rayon preserves Vec collection
  1403	    // order for indexed parallel iterators, so assembly below remains stable by
  1404	    // ascending column range while independent block eigendecompositions run in
  1405	    // parallel.
  1406	    let ordered_blocks: Vec<((usize, usize), Vec<&CanonicalPenalty>)> =
  1407	        block_groups.into_iter().collect();
  1408	    let block_roots: Vec<BlockRoot> = ordered_blocks
  1409	        .into_par_iter()
  1410	        .map(
  1411	            |((start, end), cps)| -> Result<Option<BlockRoot>, EstimationError> {
  1412	                let block_dim = end - start;
  1413	                let mut s_balanced_local = Array2::zeros((block_dim, block_dim));
  1414	
  1415	                for cp in cps {
  1416	                    let local = cp.local_ref();
  1417	                    let frob_norm = local.iter().map(|&x| x * x).sum::<f64>().sqrt();
  1418	                    if frob_norm > 1e-12 {
  1419	                        s_balanced_local.scaled_add(1.0 / frob_norm, local);
  1420	                    }
  1421	                }
  1422	
  1423	                let (eigenvalues, eigenvectors) =
  1424	                    robust_eigh(&s_balanced_local, Side::Lower, "balanced penalty block")?;
  1425	                let max_eig = eigenvalues.iter().fold(0.0f64, |max, &val| max.max(val));
  1426	                let tolerance = if max_eig > 0.0 {
  1427	                    max_eig * 1e-12
  1428	                } else {
  1429	                    1e-12
  1430	                };
  1431	                let block_rank = eigenvalues.iter().filter(|&&ev| ev > tolerance).count();
  1432	
  1433	                if block_rank == 0 {
  1434	                    return Ok(None);
  1435	                }
  1436	
  1437	                let mut root = Array2::zeros((block_rank, block_dim));
  1438	                let mut row_idx = 0;
  1439	                for (i, &eigenval) in eigenvalues.iter().enumerate() {
  1440	                    if eigenval > tolerance {
  1441	                        let sqrt_ev = eigenval.sqrt();
  1442	                        let evec = eigenvectors.column(i);
  1443	                        root.row_mut(row_idx).assign(&(&evec * sqrt_ev));
  1444	                        row_idx += 1;
  1445	                    }
  1446	                }
  1447	
  1448	                Ok(Some(BlockRoot {
  1449	                    col_range: start..end,
  1450	                    root,
  1451	                }))
  1452	            },
  1453	        )
  1454	        .collect::<Result<Vec<_>, _>>()?
  1455	        .into_iter()
  1456	        .flatten()
  1457	        .collect();
  1458	    let total_rank: usize = block_roots.iter().map(|br| br.root.nrows()).sum();
  1459	
  1460	    if total_rank == 0 {
  1461	        return Ok(Array2::zeros((0, p)));
  1462	    }
  1463	
  1464	    // Assemble global balanced root: total_rank × p
  1465	    let mut eb = Array2::zeros((total_rank, p));
  1466	    let mut row_offset = 0;
  1467	    for br in &block_roots {
  1468	        let rank_b = br.root.nrows();
  1469	        eb.slice_mut(s![
  1470	            row_offset..(row_offset + rank_b),
  1471	            br.col_range.start..br.col_range.end
  1472	        ])
  1473	        .assign(&br.root);
  1474	        row_offset += rank_b;
  1475	    }
  1476	
  1477	    Ok(eb)
  1478	}
