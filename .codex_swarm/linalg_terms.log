   779	#[derive(Clone)]
   780	pub(crate) struct RidgePlanner {
   781	    cond_estimate: Option<f64>,
   782	    ridge: f64,
   783	    attempts: usize,
   784	    scale: f64,
   785	}
   786	
   787	impl RidgePlanner {
   788	    pub(crate) fn new(matrix: &Array2<f64>) -> Self {
   789	        let scale = max_abs_diag(matrix);
   790	        let min_step = scale * 1e-10;
   791	        // Most Hessians factorize on the first attempt. Avoid an eager exact
   792	        // condition-number decomposition here and only pay for spectral
   793	        // diagnostics after an actual factorization failure.
   794	        //
   795	        // RidgePlanner is *strictly* a numerical-perturbation device: the
   796	        // perturbation is applied so a Cholesky factorization succeeds for
   797	        // an inverse / linear solve, and the matrix the caller hands back
   798	        // to the rest of the system is the unperturbed one.
   799	        Self {
   800	            cond_estimate: None,
   801	            ridge: min_step,
   802	            attempts: 0,
   803	            scale,
   804	        }
   805	    }
   806	
   807	    pub(crate) fn ridge(&self) -> f64 {
   808	        self.ridge
   809	    }
   810	
   811	    #[inline]
   812	    fn estimate_conditionwithridge(&self, matrix: &Array2<f64>, ridge: f64) -> Option<f64> {
   813	        let regularized = if ridge > 0.0 {
   814	            addridge(matrix, ridge)
   815	        } else {
   816	            matrix.clone()
   817	        };
   818	        calculate_condition_number(&regularized)
   819	            .ok()
   820	            .filter(|c| c.is_finite() && *c > 0.0)
   821	    }
   822	
   823	    pub(crate) fn bumpwith_matrix(&mut self, matrix: &Array2<f64>) {
   824	        self.attempts += 1;
   825	        let min_step = self.scale * 1e-10;
   826	        let base = self.ridge.max(min_step);
   827	
   828	        // Primary rule: inertia-target. Estimate λ_min(H) on the unperturbed
   829	        // matrix; pick δ so that λ_min(H + δ I) ≥ τ for an SPD floor τ tied
   830	        // to the matrix scale. This is a defensible "make it positive
   831	        // definite by exactly the amount needed" rule, in contrast with
   832	        // condition-number sqrt heuristics that happen to land in the same
   833	        // ballpark only by coincidence.
   834	        let spd_floor = self.scale * 1e-8;
   835	        let mut next_ridge = if let Some((lam_min, _lam_max)) = symmetric_extremes(matrix) {
   836	            // δ = max(min_step, τ - λ_min). Multiply by a small safety
   837	            // factor (1.5×) on the deficit so a single eigensolver round-off
   838	            // does not leave us a hair below τ on the first retry.
   839	            let deficit = (spd_floor - lam_min).max(0.0);
   840	            let proposal = (1.5 * deficit).max(base * 1.5).max(min_step);
   841	            // Cap escalation per attempt so we don't shoot past what's
   842	            // needed when λ_min is wildly negative; the surrounding loop
   843	            // will re-bump up to MAX_FACTORIZATION_ATTEMPTS times.
   844	            proposal.min(base * 10.0)
   845	        } else {
   846	            f64::NAN
   847	        };
   848	
   849	        // Fallback rule: condition-number heuristic. Used only when the
   850	        // eigensolver itself failed (rare, usually means a non-finite
   851	        // matrix or extreme scaling).
   852	        if !next_ridge.is_finite() {
   853	            let cond_now = self.estimate_conditionwithridge(matrix, base);
   854	            self.cond_estimate = cond_now;
   855	            next_ridge = if let Some(cond) = cond_now {
   856	                let ratio = cond / HESSIAN_CONDITION_TARGET;
   857	                let mut multiplier = if ratio > 1.0 {
   858	                    ratio.sqrt().clamp(1.5, 10.0)
   859	                } else {
   860	                    (2.0 + self.attempts as f64).clamp(3.0, 10.0)
   861	                };
   862	                let mut proposal = base * multiplier;
   863	                if let Some(cond_next) = self.estimate_conditionwithridge(matrix, proposal)
   864	                    && cond_next > cond * 0.9
   865	                    && ratio > 1.0
   866	                {
   867	                    multiplier = (multiplier * 1.8).clamp(2.0, 10.0);
   868	                    proposal = base * multiplier;
   869	                }
   870	                proposal.max(min_step)
   871	            } else if self.ridge <= 0.0 {
   872	                min_step
   873	            } else {
   874	                (base * 10.0).max(min_step)
   875	            };
   876	        }
   877	
   878	        if !next_ridge.is_finite() || next_ridge <= 0.0 {
   879	            next_ridge = self.scale;
   880	        }
   881	
   882	        self.ridge = next_ridge;
   883	    }
   884	
   885	    pub(crate) fn attempts(&self) -> usize {
   886	        self.attempts
   887	    }
   888	}
