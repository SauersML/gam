  1207	impl TakahashiInverse {
  1208	    /// Binary search for entry (row, col) in lower-triangular CSC.
  1209	    /// Returns the value-array index if the entry exists.
  1210	    fn find_entry(col_ptr: &[usize], row_idx: &[usize], row: usize, col: usize) -> Option<usize> {
