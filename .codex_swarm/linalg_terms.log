   266	#[cfg(debug_assertions)]
   267	fn symmetrize_faer_matrix_in_place(matrix: &mut Mat<f64>) {
   268	    let n = matrix.nrows().min(matrix.ncols());
   269	    for i in 0..n {
   270	        for j in 0..i {
   271	            let avg = 0.5 * (matrix[(i, j)] + matrix[(j, i)]);
   272	            matrix[(i, j)] = avg;
   273	            matrix[(j, i)] = avg;
   274	        }
   275	    }
   276	}
