   104	            }
   105	            FaerSymmetricFactor::Lblt(..) => {
   106	                // lblt doesn't easily expose diagonal determinant. Fallback to sparse or other representations if needed, but typically Lblt is indefinite!
   107	                // Actually faer doesn't easily expose lblt logdet since it has 2x2 blocks.
   108	                // For our ML systems, if we dropped to LBLT, the matrix was indefinite and logdet is ill-defined (or complex).
   109	                f64::NAN
   110	            }
   111	        }
   112	    }
