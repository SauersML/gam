   581	impl BasisOutputFormat for Sparse {
   582	    type Output = SparseColMat<usize, f64>;
   583	    const IS_SPARSE: bool = true;
   584	
   585	    fn build_basis(
   586	        data: ArrayView1<f64>,
   587	        degree: usize,
   588	        eval_kind: BasisEvalKind,
   589	        knotvec: Array1<f64>,
   590	    ) -> Result<(Self::Output, Array1<f64>), BasisError> {
   591	        let knotview = knotvec.view();
   592	        let sparse =
   593	            generate_basis_internal::<SparseStorage>(data.view(), knotview, degree, eval_kind)?;
   594	        Ok((sparse, knotvec))
   595	    }
   596	
   597	    fn from_dense(dense: Array2<f64>) -> Result<Self::Output, BasisError> {
   598	        let (nrows, ncols) = dense.dim();
   599	        let mut triplets: Vec<Triplet<usize, usize, f64>> = Vec::new();
   600	        triplets.reserve(nrows.saturating_mul(ncols / 8));
   601	        for i in 0..nrows {
   602	            for j in 0..ncols {
   603	                let v = dense[[i, j]];
   604	                if v.abs() > 0.0 {
   605	                    triplets.push(Triplet::new(i, j, v));
   606	                }
   607	            }
   608	        }
   609	        SparseColMat::try_new_from_triplets(nrows, ncols, &triplets)
   610	            .map_err(|e| BasisError::SparseCreation(format!("{e:?}")))
   611	    }
   612	
   613	    fn from_sparse(sparse: SparseColMat<usize, f64>) -> Result<Self::Output, BasisError> {
   614	        Ok(sparse)
   615	    }
   616	}
