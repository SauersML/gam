    21	/// Matrix-free closed-form anisotropic Duchon penalty operator.
    22	///
    23	/// Stores the parameters of the closed-form pair-block (`q, m, s, κ, η`, knot
    24	/// centers, and optional constraint factors). The hot `matvec` path stays
    25	/// matrix-free; `cached_dense` is populated only by `dense_form()`.
    26	pub struct ClosedFormPenaltyOperator {
    27	    /// Derivative order (0 = mass, 1 = tension, 2 = stiffness).
    28	    q: usize,
    29	    /// Outer kernel order parameter.
    30	    m: usize,
    31	    /// Inner Matérn order parameter.
    32	    s: usize,
    33	    /// Inverse length scale (κ ≥ 0).
    34	    kappa: f64,
    35	    /// Knot centers in the un-anisotropized coordinate, shape (K, d).
    36	    centers: Array2<f64>,
    37	    /// Per-axis raw anisotropy log-scales (length d). The pair-block builder
    38	    /// consumes these directly and applies the `J = exp(Σ η_k)` Jacobian
    39	    /// internally.
    40	    eta_raw: Vec<f64>,
    41	    /// Cached powers of `B = diag(exp(-2η))` for the analytic pair kernel.
    42	    eta_metric_powers: closed_form_penalty::AnisoMetricPowers,
    43	    /// Optional kernel-nullspace transform Z (K × kernel_cols).
    44	    kernel_nullspace: Option<Array2<f64>>,
    45	    /// Number of polynomial-block columns padded after the kernel block.
    46	    polynomial_block_cols: usize,
    47	    /// Optional outer spatial identifiability transform T (total_pre × total).
    48	    outer_identifiability: Option<Array2<f64>>,
    49	    /// Diagonal epsilon convention for regimes without an exact analytic
    50	    /// self-pair. In the convergent closed-form regimes this is zero and is
    51	    /// never read by pair evaluation.
    52	    diagonal_epsilon: f64,
    53	    /// Lazily-populated dense form. Populated only by `dense_form`; the
    54	    /// matvec/diag/trace/log-det paths stay matrix-free.
    55	    ///
    56	    /// `RayonSafeOnce` (not `OnceLock`) because `build_dense` runs faer
    57	    /// GEMMs (`fast_ab`, `fast_atb`) which dispatch nested rayon work — a
    58	    /// plain `OnceLock` here would deadlock if `dense_form` is first hit
    59	    /// concurrently from inside an outer par_iter. See
    60	    /// `feedback_oncelock_rayon_deadlock`.
    61	    cached_dense: crate::resource::RayonSafeOnce<Array2<f64>>,
    62	}
    63	
    64	// Cloning the operator resets its cache so the new instance rebuilds on first
    65	// use. This matches the legacy `derive(Clone)` behavior (which also produced a
    66	// fresh dense build per matvec — the cache is strictly an addition).
    67	impl Clone for ClosedFormPenaltyOperator {
    68	    fn clone(&self) -> Self {
