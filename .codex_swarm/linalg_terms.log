   260	/// Unified B-spline basis generation with configurable storage, knot source, and options.
   261	///
   262	/// This function consolidates various basis generation functions into a single entry point.
   263	/// Use type parameters to select output format:
   264	/// - `create_basis::<Dense>(...)` for dense `Array2<f64>` output
   265	/// - `create_basis::<Sparse>(...)` for sparse `SparseColMat` output
   266	///
   267	/// # Arguments
   268	/// * `data` - Data points to evaluate basis at
   269	/// * `knot_source` - Either pre-computed knots or parameters for uniform generation
   270	/// * `degree` - B-spline degree (e.g., 3 for cubic)
   271	/// * `options` - Derivative order and other options
   272	///
   273	/// # Returns
   274	/// Tuple of (basis matrix, knot vector used)
   275	pub fn create_basis<O: BasisOutputFormat>(
   276	    data: ArrayView1<f64>,
   277	    knot_source: KnotSource<'_>,
   278	    degree: usize,
   279	    options: BasisOptions,
   280	) -> Result<(O::Output, Array1<f64>), BasisError> {
   281	    if degree < 1 {
   282	        return Err(BasisError::InvalidDegree(degree));
   283	    }
   284	
   285	    if options.basis_family != BasisFamily::BSpline && options.derivative_order != 0 {
   286	        return Err(BasisError::InvalidInput(
   287	            "derivatives are only supported for BasisFamily::BSpline".to_string(),
   288	        ));
   289	    }
   290	
   291	    let eval_kind = match options.derivative_order {
   292	        0 => BasisEvalKind::Basis,
   293	        1 => BasisEvalKind::FirstDerivative,
   294	        2 => BasisEvalKind::SecondDerivative,
   295	        n => {
   296	            return Err(BasisError::InvalidInput(format!(
   297	                "unsupported derivative order {n}; only 0, 1, 2 are supported"
   298	            )));
   299	        }
   300	    };
   301	
   302	    let knot_degree = match options.basis_family {
   303	        BasisFamily::BSpline | BasisFamily::MSpline => degree,
   304	        BasisFamily::ISpline => degree
   305	            .checked_add(1)
   306	            .ok_or_else(|| BasisError::InvalidInput("I-spline degree overflow".to_string()))?,
   307	    };
   308	
   309	    let knotvec: Array1<f64> = match knot_source {
   310	        KnotSource::Provided(view) => view.to_owned(),
   311	        KnotSource::Generate {
   312	            data_range,
   313	            num_internal_knots,
   314	        } => {
   315	            if data_range.0 > data_range.1 {
   316	                return Err(BasisError::InvalidRange(data_range.0, data_range.1));
   317	            }
   318	            if data_range.0 == data_range.1 {
   319	                return Err(BasisError::DegenerateRange(num_internal_knots));
   320	            }
   321	            internal::generate_full_knot_vector(data_range, num_internal_knots, knot_degree)?
   322	        }
   323	    };
   324	    validate_knots_for_degree(knotvec.view(), knot_degree)?;
   325	    validate_knot_spans_nondegenerate(knotvec.view(), knot_degree)?;
   326	
   327	    match options.basis_family {
   328	        BasisFamily::BSpline => O::build_basis(data, degree, eval_kind, knotvec),
   329	        BasisFamily::MSpline => {
   330	            if O::IS_SPARSE {
   331	                let sparse = create_mspline_sparse(data, knotvec.view(), degree)?;
   332	                Ok((O::from_sparse(sparse)?, knotvec))
   333	            } else {
   334	                let dense = create_mspline_dense(data, knotvec.view(), degree)?;
   335	                Ok((O::from_dense(dense)?, knotvec))
   336	            }
   337	        }
   338	        BasisFamily::ISpline => {
   339	            if O::IS_SPARSE {
   340	                return Err(BasisError::InvalidInput(
   341	                    "BasisFamily::ISpline does not support sparse output; use Dense".to_string(),
   342	                ));
   343	            }
   344	            let dense = create_ispline_dense(data, knotvec.view(), degree)?;
   345	            Ok((O::from_dense(dense)?, knotvec))
   346	        }
   347	    }
   348	}
