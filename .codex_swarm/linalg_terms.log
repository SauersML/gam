 19966	fn monomial_basis_block(points: ArrayView2<'_, f64>, max_total_degree: usize) -> Array2<f64> {
 19967	    let n = points.nrows();
 19968	    let exponents = monomial_exponents(points.ncols(), max_total_degree);
 19969	    let mut block = Array2::<f64>::zeros((n, exponents.len()));
 19970	    for (col, exponents) in exponents.iter().enumerate() {
 19971	        for row in 0..n {
 19972	            let mut value = 1.0;
 19973	            for axis in 0..points.ncols() {
 19974	                let exponent = exponents[axis];
 19975	                if exponent != 0 {
 19976	                    value *= points[[row, axis]].powi(exponent as i32);
 19977	                }
 19978	            }
 19979	            block[[row, col]] = value;
 19980	        }
 19981	    }
 19982	    block
 19983	}
