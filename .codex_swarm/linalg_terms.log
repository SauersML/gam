   770	            left / denom_left
   771	        } else {
   772	            0.0
   773	        };
   774	        let right_term = if denom_right.abs() > 1e-12 {
   775	            right / denom_right
   776	        } else {
   777	            0.0
   778	        };
   779	        values[offset] = (degree as f64) * (left_term - right_term);
   780	    }
