   587	/// Compute A^T * diag(W) * A with an explicit faer parallelism policy for
   588	/// callers that parallelize multiple independent Hessian blocks externally.
   589	#[inline]
   590	pub fn fast_xt_diag_x_with_parallelism<S1: Data<Elem = f64>, S2: Data<Elem = f64>>(
   591	    x: &ArrayBase<S1, Ix2>,
   592	    w: &ArrayBase<S2, Ix1>,
   593	    par: Par,
   594	) -> Array2<f64> {
   595	    use faer::Accum;
   596	    use faer::linalg::matmul::triangular::{BlockStructure, matmul as tri_matmul};
   597	    use ndarray::{ShapeBuilder, s};
   598	
   599	    let (n, p) = x.dim();
   600	    debug_assert_eq!(n, w.len(), "X rows must match W length");
