   267	/// SPD-only spectrum condition number: λ_max / λ_min on the principal
   268	/// (positive-eigenvalue) spectrum.
   269	///
   270	/// **Invariant:** caller must have already established the matrix is
   271	/// positive definite. For indefinite matrices λ_min may be negative or
   272	/// zero and the ratio max/min becomes meaningless (it can be negative or
   273	/// infinite even when the matrix is well-scaled). When the spectrum sign is
   274	/// unknown, inspect inertia directly via [`symmetric_extremes`].
   275	pub(crate) fn symmetric_spectrum_condition_number(matrix: &Array2<f64>) -> f64 {
   276	    matrix
   277	        .eigh(Side::Lower)
   278	        .ok()
   279	        .map(|(evals, _)| {
   280	            let min = evals
   281	                .iter()
   282	                .fold(f64::INFINITY, |acc, &value| acc.min(value));
   283	            let max = evals
   284	                .iter()
   285	                .fold(f64::NEG_INFINITY, |acc, &value| acc.max(value));
   286	            max / min.max(1e-12)
   287	        })
   288	        .unwrap_or(f64::NAN)
   289	}
   290	
   291	/// Estimate min/max eigenvalues of a symmetric matrix via a short
   292	/// `eigh` call. Used by the inertia-aware stabilization rule below.
   293	/// Returns `None` if the eigensolver fails.
   294	pub(crate) fn symmetric_extremes(matrix: &Array2<f64>) -> Option<(f64, f64)> {
   295	    let (evals, _) = matrix.eigh(Side::Lower).ok()?;
   296	    let mut min = f64::INFINITY;
   297	    let mut max = f64::NEG_INFINITY;
   298	    for &v in evals.iter() {
   299	        if v < min {
   300	            min = v;
   301	        }
   302	        if v > max {
   303	            max = v;
   304	        }
   305	    }
   306	    if min.is_finite() && max.is_finite() {
   307	        Some((min, max))
   308	    } else {
   309	        None
   310	    }
   311	}
