   115	                pure_duchon_diagonal_epsilon(centers, &eta_raw)
   116	            };
   117	        Self {
   118	            q,
   119	            m,
   120	            s,
   121	            kappa,
   122	            centers: centers.to_owned(),
   123	            eta_metric_powers: closed_form_penalty::AnisoMetricPowers::new(&eta_raw),
   124	            eta_raw,
   125	            kernel_nullspace: kernel_nullspace.cloned(),
   126	            polynomial_block_cols,
   127	            outer_identifiability: outer_identifiability.cloned(),
   128	            diagonal_epsilon,
   129	            cached_dense: crate::resource::RayonSafeOnce::new(),
   130	        }
   131	    }
   132	
   133	    /// Return the cached dense form, building it on first call.
   134	    fn ensure_dense(&self) -> &Array2<f64> {
   135	        self.cached_dense.get_or_init(|| self.build_dense())
   136	    }
   137	
   138	    /// Number of raw kernel rows (K).
   139	    pub fn raw_dim(&self) -> usize {
   140	        self.centers.nrows()
   141	    }
   142	
   143	    /// Number of columns *after* applying constraint composition: the
   144	    /// dimension that callers see when invoking matvec/dense_form.
   145	    pub fn dim(&self) -> usize {
   146	        let kernel_cols = self
   147	            .kernel_nullspace
   148	            .as_ref()
   149	            .map(|z| z.ncols())
   150	            .unwrap_or_else(|| self.centers.nrows());
   151	        let total_pre = kernel_cols + self.polynomial_block_cols;
   152	        match &self.outer_identifiability {
   153	            Some(t) => t.ncols(),
   154	            None => total_pre,
   155	        }
   156	    }
   157	
   158	    #[inline]
   159	    fn is_raw_layout(&self) -> bool {
   160	        self.kernel_nullspace.is_none()
