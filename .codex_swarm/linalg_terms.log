  7999	            let r_eff = r.max(1e-12);
  8000	            let ratio = phi_r / r_eff;
  8001	            (phi, phi_r, phi_rr, ratio)
  8002	        }
  8003	        MaternNu::ThreeHalves => {
  8004	            let s = 3.0_f64.sqrt() / length_scale;
  8005	            let a = s * r;
  8006	            let e = (-a).exp();
  8007	            let phi = (1.0 + a) * e;
  8008	            let phi_r = -s * e * a;
  8009	            let phi_rr = s * s * e * (a - 1.0);
  8010	            let ratio = -s * s * e;
  8011	            (phi, phi_r, phi_rr, ratio)
  8012	        }
  8013	        MaternNu::FiveHalves => {
  8014	            let s = 5.0_f64.sqrt() / length_scale;
  8015	            let a = s * r;
  8016	            let e = (-a).exp();
  8017	            let phi = (1.0 + a + (a * a) / 3.0) * e;
  8018	            let phi_r = -(s / 3.0) * e * a * (a + 1.0);
  8019	            let phi_rr = (s * s / 3.0) * e * (a * a - a - 1.0);
  8020	            let ratio = -(s * s / 3.0) * e * (a + 1.0);
  8021	            (phi, phi_r, phi_rr, ratio)
  8022	        }
  8023	        MaternNu::SevenHalves => {
  8024	            let s = 7.0_f64.sqrt() / length_scale;
  8025	            let a = s * r;
  8026	            let e = (-a).exp();
  8027	            let phi = (1.0 + a + (2.0 / 5.0) * a * a + (1.0 / 15.0) * a * a * a) * e;
  8028	            let phi_r = -(s / 15.0) * e * a * (a * a + 3.0 * a + 3.0);
  8029	            let phi_rr = (s * s / 15.0) * e * (a * a * a - 3.0 * a - 3.0);
  8030	            let ratio = -(s * s / 15.0) * e * (a * a + 3.0 * a + 3.0);
  8031	            (phi, phi_r, phi_rr, ratio)
  8032	        }
  8033	        MaternNu::NineHalves => {
  8034	            let s = 9.0_f64.sqrt() / length_scale;
  8035	            let a = s * r;
  8036	            let e = (-a).exp();
  8037	            let phi = (1.0
  8038	                + a
  8039	                + (3.0 / 7.0) * a * a
  8040	                + (2.0 / 21.0) * a * a * a
  8041	                + (1.0 / 105.0) * a * a * a * a)
