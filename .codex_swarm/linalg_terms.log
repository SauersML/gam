   249	pub(crate) fn boundary_hit_indices(
   250	    values: ArrayView1<'_, f64>,
   251	    bound: f64,
   252	    tolerance: f64,
   253	) -> (Vec<usize>, Vec<usize>) {
   254	    let at_lower = values
   255	        .iter()
   256	        .enumerate()
   257	        .filter_map(|(idx, &value)| (value <= -bound + tolerance).then_some(idx))
   258	        .collect();
   259	    let at_upper = values
   260	        .iter()
   261	        .enumerate()
   262	        .filter_map(|(idx, &value)| (value >= bound - tolerance).then_some(idx))
   263	        .collect();
   264	    (at_lower, at_upper)
   265	}
