 14227	        SphereWahbaKernel::Sobolev => {
 14228	            wahba_sphere_kernel_sobolev_closed_form(cos_gamma, penalty_order)
 14229	        }
 14230	        SphereWahbaKernel::Pseudo => wahba_sphere_kernel_pseudo_from_cos(cos_gamma, penalty_order),
 14231	    };
 14232	    if !value.is_finite() {
 14233	        return Err(BasisError::InvalidInput(
 14234	            "spherical spline kernel produced a non-finite value".to_string(),
 14235	        ));
 14236	    }
 14237	    Ok(value)
 14238	}
