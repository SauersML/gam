   490	fn apply_dense_bspline_extrapolation(
   491	    data: ArrayView1<f64>,
   492	    knotview: ArrayView1<f64>,
   493	    degree: usize,
   494	    eval_kind: BasisEvalKind,
   495	    basis_matrix: &mut Array2<f64>,
   496	) -> Result<(), BasisError> {
   497	    let num_basis_functions = basis_matrix.ncols();
   498	    if num_basis_functions == 0 {
   499	        return Ok(());
   500	    }
   501	
   502	    let left = knotview[degree];
   503	    let right = knotview[num_basis_functions];
   504	
   505	    if matches!(eval_kind, BasisEvalKind::FirstDerivative) {
   506	        let num_basis_lower = knotview.len().saturating_sub(degree);
   507	        let mut lower_basis = vec![0.0; num_basis_lower];
   508	        let mut lower_scratch = internal::BsplineScratch::new(degree.saturating_sub(1));
   509	        for (i, &x) in data.iter().enumerate() {
   510	            if x >= left && x <= right {
   511	                continue;
   512	            }
   513	            let x_c = x.clamp(left, right);
   514	            let mut row = basis_matrix.row_mut(i);
   515	            let row_slice = row
   516	                .as_slice_mut()
   517	                .expect("basis matrix rows should be contiguous");
   518	            evaluate_bspline_derivative_scalar_into(
   519	                x_c,
   520	                knotview,
   521	                degree,
   522	                row_slice,
   523	                &mut lower_basis,
   524	                &mut lower_scratch,
   525	            )?;
   526	        }
   527	    }
   528	
   529	    if matches!(eval_kind, BasisEvalKind::SecondDerivative) {
   530	        for (i, &x) in data.iter().enumerate() {
   531	            if x < left || x > right {
   532	                basis_matrix.row_mut(i).fill(0.0);
   533	            }
   534	        }
   535	    }
   536	
   537	    if matches!(eval_kind, BasisEvalKind::Basis) {
   538	        let z_clamped = data.mapv(|x| x.clamp(left, right));
   539	        apply_linear_extension_from_first_derivative(
   540	            data,
   541	            z_clamped.view(),
   542	            knotview,
   543	            degree,
   544	            basis_matrix,
   545	        )?;
   546	    }
   547	
   548	    Ok(())
   549	}
