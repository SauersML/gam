   921	fn evaluate_bsplinerow_entries<F>(
   922	    x: f64,
   923	    degree: usize,
   924	    knotview: ArrayView1<f64>,
   925	    eval_kind: BasisEvalKind,
   926	    num_basis_functions: usize,
   927	    scratch: &mut BasisEvalScratch,
   928	    values: &mut [f64],
   929	    mut write_entry: F,
   930	) where
   931	    F: FnMut(usize, f64),
   932	{
   933	    let start_col =
   934	        evaluate_splines_sparsewith_kind(x, degree, knotview, eval_kind, values, scratch);
   935	    for (offset, &v) in values.iter().enumerate() {
   936	        if v == 0.0 {
   937	            continue;
   938	        }
   939	        let col_j = start_col + offset;
   940	        if col_j < num_basis_functions {
   941	            write_entry(col_j, v);
   942	        }
   943	    }
   944	}
