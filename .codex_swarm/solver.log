   475	pub fn gaussian_reml_closed_form_batch<'a>(
   476	    problems: &[GaussianRemlScalarBatchProblem<'a>],
   477	    penalty: ArrayView2<'a, f64>,
   478	    nullspace_dim: Option<usize>,
   479	) -> Result<Vec<GaussianRemlResult>, EstimationError> {
   480	    let fits: Vec<Result<GaussianRemlResult, EstimationError>> = problems
   481	        .par_iter()
   482	        .map(|problem| {
   483	            gaussian_reml_closed_form_with_nullspace_dim(
   484	                problem.x.view(),
   485	                problem.y.view(),
   486	                penalty.view(),
   487	                nullspace_dim,
   488	                problem.weights.as_ref().map(|weights| weights.view()),
