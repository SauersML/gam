  1170	pub fn inverse_link_jet_for_family(
  1171	    family: LikelihoodFamily,
  1172	    eta: f64,
  1173	    mixture_link_state: Option<&MixtureLinkState>,
  1174	    sas_link_state: Option<&SasLinkState>,
  1175	) -> Result<InverseLinkJet, EstimationError> {
  1176	    match family {
  1177	        LikelihoodFamily::GaussianIdentity => inverse_link_jet_for_link_function(
  1178	            LinkFunction::Identity,
  1179	            eta,
  1180	            mixture_link_state,
  1181	            sas_link_state,
  1182	        ),
  1183	        LikelihoodFamily::BinomialLogit => inverse_link_jet_for_link_function(
  1184	            LinkFunction::Logit,
  1185	            eta,
  1186	            mixture_link_state,
  1187	            sas_link_state,
  1188	        ),
  1189	        LikelihoodFamily::BinomialProbit => inverse_link_jet_for_link_function(
  1190	            LinkFunction::Probit,
  1191	            eta,
  1192	            mixture_link_state,
  1193	            sas_link_state,
  1194	        ),
  1195	        LikelihoodFamily::BinomialCLogLog => inverse_link_jet_for_link_function(
  1196	            LinkFunction::CLogLog,
  1197	            eta,
  1198	            mixture_link_state,
  1199	            sas_link_state,
  1200	        ),
  1201	        LikelihoodFamily::BinomialLatentCLogLog => Err(EstimationError::InvalidInput(
  1202	            "BinomialLatentCLogLog inverse-link requires explicit latent cloglog state".to_string(),
  1203	        )),
  1204	        LikelihoodFamily::BinomialSas => inverse_link_jet_for_link_function(
  1205	            LinkFunction::Sas,
  1206	            eta,
  1207	            mixture_link_state,
  1208	            sas_link_state,
  1209	        )
  1210	        .map_err(|_| {
  1211	            EstimationError::InvalidInput(
  1212	                "BinomialSas inverse-link requires SAS link state".to_string(),
  1213	            )
  1214	        }),
  1215	        LikelihoodFamily::BinomialBetaLogistic => inverse_link_jet_for_link_function(
  1216	            LinkFunction::BetaLogistic,
  1217	            eta,
  1218	            mixture_link_state,
  1219	            sas_link_state,
  1220	        )
  1221	        .map_err(|_| {
  1222	            EstimationError::InvalidInput(
  1223	                "BinomialBetaLogistic inverse-link requires Beta-Logistic link state".to_string(),
  1224	            )
  1225	        }),
  1226	        LikelihoodFamily::BinomialMixture => {
  1227	            let state = mixture_link_state.ok_or_else(|| {
  1228	                EstimationError::InvalidInput(
  1229	                    "BinomialMixture inverse-link requires mixture link state".to_string(),
  1230	                )
  1231	            })?;
  1232	            inverse_link_jet_for_link_function(
  1233	                LinkFunction::Logit,
  1234	                eta,
  1235	                Some(state),
  1236	                sas_link_state,
  1237	            )
  1238	        }
  1239	        LikelihoodFamily::PoissonLog | LikelihoodFamily::GammaLog => {
  1240	            inverse_link_jet_for_link_function(
  1241	                LinkFunction::Log,
  1242	                eta,
  1243	                mixture_link_state,
  1244	                sas_link_state,
  1245	            )
  1246	        }
  1247	        LikelihoodFamily::RoystonParmar => Ok(royston_parmar_inverse_link_jet(eta)),
  1248	    }
  1249	}
