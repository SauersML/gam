   984	fn beta_logistic_inverse_link_mu_d1(eta: f64, delta: f64, epsilon: f64) -> (f64, f64) {
   985	    let (u, du) = logistic_uwith_derivatives(eta);
   986	    let a = (delta - epsilon).exp();
   987	    let b = (delta + epsilon).exp();
   988	    let mu = beta_reg(a, b, u);
   989	    if du == 0.0 {
   990	        return (mu, 0.0);
   991	    }
   992	    let log_d1 = a * u.ln() + b * (1.0 - u).ln() - ln_beta(a, b);
   993	    (mu, log_d1.exp())
   994	}
