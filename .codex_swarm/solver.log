   314	        // moderately-large dim (so 2 m_s + m_h matvecs beats `dim`
   315	        // dense HVPs).
   316	        if op.is_implicit() && self.dim() >= 128 {
   317	            let mut config = StochasticTraceConfig::default();
   318	            let sketch = (self.dim() / 32).clamp(4, 16);
   319	            config.hutchpp_sketch_dim = Some(sketch);
   320	            config.n_probes_max = (sketch * 4).max(32);
   321	            config.n_probes_min = sketch.max(8);
   322	            return hutchpp_estimate_trace_hinv_operator(self, op, &config);
   323	        }
