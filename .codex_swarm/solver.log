  1137	fn validate_gaussian_reml_forward_fit(
  1138	    x: ArrayView2<'_, f64>,
  1139	    y: ArrayView2<'_, f64>,
  1140	    penalty: ArrayView2<'_, f64>,
  1141	    weights: Option<ArrayView1<'_, f64>>,
  1142	    fit: &GaussianRemlMultiResult,
  1143	) -> Result<(), EstimationError> {
  1144	    // Fingerprint the canonicalized penalty: caches are keyed on the
  1145	    // symmetric average, and the caller may hand us a raw input (e.g. a
  1146	    // single-entry-perturbed matrix produced by ``torch.autograd.gradcheck``).
  1147	    let penalty_owned = canonicalize_penalty(penalty);
  1148	    let penalty = penalty_owned.view();
  1149	    let n = x.nrows();
  1150	    let p = x.ncols();
  1151	    let d = y.ncols();
  1152	    validate_gaussian_reml_design(x, penalty, weights)?;
  1153	    validate_gaussian_reml_eigen_cache(&fit.cache, p)?;
  1154	    if y.nrows() != n
  1155	        || fit.coefficients.dim() != (p, d)
  1156	        || fit.fitted.dim() != (n, d)
  1157	        || fit.sigma2.len() != d
  1158	    {
  1159	        return Err(EstimationError::InvalidInput(format!(
  1160	            "Gaussian REML backward forward-state shape mismatch: expected coefficients=({p},{d}), fitted=({n},{d}), sigma2={d}"
  1161	        )));
  1162	    }
  1163	    if !(fit.lambda.is_finite()
  1164	        && fit.lambda > 0.0
  1165	        && fit.rho.is_finite()
  1166	        && fit.reml_score.is_finite()
  1167	        && fit.reml_hess_rho.is_finite()
  1168	        && fit.edf.is_finite())
  1169	        || fit.coefficients.iter().any(|value| !value.is_finite())
  1170	        || fit.fitted.iter().any(|value| !value.is_finite())
  1171	        || fit.sigma2.iter().any(|value| !value.is_finite())
  1172	    {
  1173	        return Err(EstimationError::InvalidInput(
  1174	            "Gaussian REML backward forward state must be finite".to_string(),
  1175	        ));
  1176	    }
  1177	    let penalty_fingerprint = matrix_fingerprint(penalty);
  1178	    if fit.cache.penalty_fingerprint != penalty_fingerprint {
  1179	        return Err(EstimationError::InvalidInput(
  1180	            "Gaussian REML backward forward-state penalty mismatch".to_string(),
  1181	        ));
  1182	    }
  1183	    let weight = gaussian_reml_weights(n, weights)?;
  1184	    let xtwx = dense_xt_diag_x(x, weight.view());
  1185	    if fit.cache.xtwx_fingerprint != matrix_fingerprint(xtwx.view()) {
  1186	        return Err(EstimationError::InvalidInput(
  1187	            "Gaussian REML backward forward-state X'WX mismatch".to_string(),
  1188	        ));
  1189	    }
  1190	    Ok(())
  1191	}
  1192	
  1193	fn gaussian_reml_inverse_hessian_from_cache(
  1194	    cache: &GaussianRemlEigenCache,
  1195	    lambda: f64,
  1196	) -> Result<Array2<f64>, EstimationError> {
  1197	    if !(lambda.is_finite() && lambda > 0.0) {
  1198	        return Err(EstimationError::InvalidInput(format!(
  1199	            "Gaussian REML lambda must be finite and positive; got {lambda}"
  1200	        )));
  1201	    }
  1202	    let p = cache.penalty_eigenvalues.len();
  1203	    let mut scaled_basis = cache.coefficient_basis.clone();
  1204	    for eig in 0..p {
  1205	        let scale = 1.0 / (1.0 + lambda * cache.penalty_eigenvalues[eig]);
  1206	        for row in 0..p {
  1207	            scaled_basis[[row, eig]] *= scale;
  1208	        }
  1209	    }
  1210	    let inverse = dense_ab(scaled_basis.view(), cache.coefficient_basis.t());
  1211	    if inverse.iter().any(|value| !value.is_finite()) {
  1212	        return Err(EstimationError::ModelIsIllConditioned {
  1213	            condition_number: f64::INFINITY,
  1214	        });
  1215	    }
  1216	    Ok(inverse)
  1217	}
  1218	
  1219	fn add_ridge_profile_vjp(
  1220	    scale: f64,
  1221	    x: ArrayView2<'_, f64>,
  1222	    y: ArrayView2<'_, f64>,
  1223	    penalty: ArrayView2<'_, f64>,
  1224	    weights: &Array1<f64>,
  1225	    lambda: f64,
  1226	    inverse_hessian: &Array2<f64>,
  1227	    beta: &Array2<f64>,
  1228	    upstream_beta: ArrayView2<'_, f64>,
  1229	    grad_x: &mut Array2<f64>,
  1230	    grad_y: &mut Array2<f64>,
  1231	    grad_penalty: &mut Array2<f64>,
  1232	    grad_weights: &mut Array1<f64>,
  1233	) -> f64 {
  1234	    let m = dense_ab(inverse_hessian.view(), upstream_beta);
  1235	    let c = dense_ab(m.view(), beta.t());
  1236	    let c_sym = &c + &c.t();
  1237	    let ymt = dense_ab(y, m.t());
  1238	    let xcs = dense_ab(x, c_sym.view());
  1239	    for i in 0..x.nrows() {
  1240	        let wi = weights[i] * scale;
  1241	        for k in 0..x.ncols() {
  1242	            grad_x[[i, k]] += wi * (ymt[[i, k]] - xcs[[i, k]]);
  1243	        }
  1244	    }
  1245	
  1246	    let xm = dense_ab(x, m.view());
  1247	    for i in 0..x.nrows() {
  1248	        let wi = weights[i] * scale;
  1249	        for j in 0..y.ncols() {
  1250	            grad_y[[i, j]] += wi * xm[[i, j]];
  1251	        }
  1252	    }
  1253	
  1254	    let xc = dense_ab(x, c.view());
  1255	    for i in 0..x.nrows() {
  1256	        let mut from_b = 0.0;
  1257	        for j in 0..y.ncols() {
  1258	            from_b += y[[i, j]] * xm[[i, j]];
  1259	        }
  1260	        let mut from_a = 0.0;
  1261	        for k in 0..x.ncols() {
  1262	            from_a += x[[i, k]] * xc[[i, k]];
  1263	        }
  1264	        grad_weights[i] += scale * (from_b - from_a);
  1265	    }
  1266	
  1267	    let penalty_beta = dense_ab(penalty, beta.view());
  1268	    for row in 0..penalty.nrows() {
  1269	        for col in 0..penalty.ncols() {
  1270	            let mut value = 0.0;
  1271	            for output in 0..beta.ncols() {
  1272	                value += m[[row, output]] * beta[[col, output]];
  1273	            }
  1274	            grad_penalty[[row, col]] -= scale * lambda * value;
  1275	        }
  1276	    }
  1277	    -scale
  1278	        * m.iter()
  1279	            .zip(penalty_beta.iter())
  1280	            .map(|(left, right)| left * right)
  1281	            .sum::<f64>()
  1282	}
