  2845	    for i in rows {
  2846	        let w_i = weights[i].max(0.0);
  2847	        if w_i == 0.0 {
  2848	            continue;
  2849	        }
  2850	        let cols = x_t.row_idx_of_col_raw(i);
  2851	        let vals = x_t.val_of_col(i);
  2852	        let nnz_i = cols.len();
  2853	        for jj in 0..nnz_i {
  2854	            let j = cols[jj].unbound();
  2855	            let wvj = w_i * vals[jj];
  2856	            let row = &mut acc_data[j * p..j * p + p];
  2857	            for kk in jj..nnz_i {
  2858	                let k = cols[kk].unbound();
  2859	                row[k] += wvj * vals[kk];
  2860	            }
  2861	        }
  2862	    }
  2863	}
  2864	
  2865	fn compute_jeffreys_pirls_diagnostics_sparse(
  2866	    x_design_csr: &SparseRowMat<usize, f64>,
  2867	    eta: ArrayView1<f64>,
  2868	    observation_weights: ArrayView1<f64>,
  2869	) -> Result<(Array1<f64>, f64), EstimationError> {
  2870	    let n = x_design_csr.nrows();
  2871	    let p = x_design_csr.ncols();
  2872	    let mut x_dense = Array2::<f64>::zeros((n, p));
  2873	    let xview = x_design_csr.as_ref();
  2874	    for i in 0..n {
  2875	        let vals = xview.val_of_row(i);
  2876	        let cols = xview.col_idx_of_row_raw(i);
  2877	        if cols.len() != vals.len() {
  2878	            return Err(EstimationError::InvalidInput(
  2879	                "sparse row structure mismatch: column/value lengths differ".to_string(),
  2880	            ));
  2881	        }
  2882	        for (idx, &col) in cols.iter().enumerate() {
  2883	            x_dense[[i, col.unbound()]] = vals[idx];
  2884	        }
  2885	    }
  2886	    compute_jeffreys_pirls_diagnostics(x_dense.view(), eta, observation_weights)
  2887	}
  2888	
  2889	fn compute_jeffreys_pirls_diagnostics(
  2890	    x_design: ArrayView2<f64>,
  2891	    eta: ArrayView1<f64>,
  2892	    observation_weights: ArrayView1<f64>,
  2893	) -> Result<(Array1<f64>, f64), EstimationError> {
  2894	    // PIRLS must use the same identifiable-subspace Jeffreys functional as the
  2895	    // outer REML code:
  2896	    //   Φ(β) = 0.5 log|Xᵀ W(η) X|_+.
  2897	    // The operator below is the single source of truth for both the Jeffreys
  2898	    // scalar value and the PIRLS hat-diagonal correction derived from it.
  2899	    let op = FirthDenseOperator::build_with_observation_weights(
  2900	        &x_design.to_owned(),
  2901	        &eta.to_owned(),
  2902	        observation_weights,
  2903	    )?;
  2904	    Ok((op.pirls_hat_diag(), op.jeffreys_logdet()))
  2905	}
  2906	
  2907	fn ensure_positive_definitewithridge(
  2908	    hess: &mut Array2<f64>,
  2909	    label: &str,
  2910	) -> Result<f64, EstimationError> {
  2911	    let ridge = if FIXED_STABILIZATION_RIDGE > 0.0 {
  2912	        FIXED_STABILIZATION_RIDGE
  2913	    } else {
  2914	        0.0
  2915	    };
  2916	
  2917	    if hess.cholesky(Side::Lower).is_ok() {
  2918	        return Ok(0.0);
  2919	    }
  2920	
  2921	    if ridge > 0.0 {
  2922	        for i in 0..hess.nrows() {
  2923	            hess[[i, i]] += ridge;
  2924	        }
  2925	
  2926	        if hess.cholesky(Side::Lower).is_ok() {
  2927	            log::debug!("{} stabilized with fixed ridge {:.1e}.", label, ridge);
  2928	            return Ok(ridge);
  2929	        }
  2930	    }
  2931	
  2932	    if let Ok((evals, _)) = hess.eigh(Side::Lower) {
  2933	        let min_eig = evals.iter().fold(f64::INFINITY, |a, &b| a.min(b));
  2934	        return Err(EstimationError::HessianNotPositiveDefinite {
  2935	            min_eigenvalue: min_eig,
  2936	        });
  2937	    }
  2938	    Err(EstimationError::HessianNotPositiveDefinite {
  2939	        min_eigenvalue: f64::NEG_INFINITY,
  2940	    })
  2941	}
  2942	
  2943	fn solve_newton_direction_dense(
  2944	    hessian: &Array2<f64>,
  2945	    gradient: &Array1<f64>,
  2946	    direction_out: &mut Array1<f64>,
  2947	) -> Result<(), EstimationError> {
  2948	    let dense_solve_start = std::time::Instant::now();
  2949	    let p = hessian.nrows();
  2950	    if direction_out.len() != gradient.len() {
  2951	        *direction_out = Array1::zeros(gradient.len());
  2952	    }
  2953	
  2954	    // GPU fast path: fused Cholesky factor + solve in a single host↔device
  2955	    // round-trip. CPU execution remains in charge when the GPU is unavailable,
  2956	    // the matrix is too small to amortize the round-trip, or the device
  2957	    // factorization reports a non-PD pivot.
  2958	    let mut hess_buf = hessian.clone();
  2959	    let mut rhs_mat = gradient.to_owned().insert_axis(ndarray::Axis(1));
  2960	    let gpu_route = crate::gpu::describe_chol_solve_route(p, rhs_mat.ncols());
  2961	    let gpu_attempt_expected = crate::gpu::will_attempt_chol_solve(p);
  2962	    if crate::gpu::try_chol_solve_inplace(&mut hess_buf, &mut rhs_mat).is_some() {
  2963	        let mut solved = rhs_mat.remove_axis(ndarray::Axis(1));
  2964	        if array1_is_finite(&solved) {
  2965	            solved.mapv_inplace(|v| -v);
  2966	            direction_out.assign(&solved);
  2967	            log::info!(
  2968	                "[STAGE] PIRLS dense newton solve backend=GPU p={} flops~{} elapsed={:.3}s route=\"{}\"",
  2969	                p,
  2970	                (p as u64).saturating_mul((p as u64).saturating_mul(p as u64)) / 3,
  2971	                dense_solve_start.elapsed().as_secs_f64(),
  2972	                gpu_route,
  2973	            );
  2974	            return Ok(());
  2975	        }
  2976	    }
  2977	    let cpu_route = if gpu_attempt_expected {
  2978	        format!(
  2979	            "GPU route was eligible but cuSOLVER did not return a finite solution; \
  2980	             falling back to CPU stable solver; initial_route=\"{gpu_route}\""
  2981	        )
  2982	    } else {
  2983	        gpu_route
  2984	    };
  2985	
  2986	    let factor = StableSolver::new("pirls newton direction")
  2987	        .factorize(hessian)
  2988	        .map_err(EstimationError::LinearSystemSolveFailed)?;
  2989	    direction_out.assign(gradient);
  2990	    let mut rhsview = array1_to_col_matmut(direction_out);
  2991	    factor.solve_in_place(rhsview.as_mut());
  2992	    direction_out.mapv_inplace(|v| -v);
  2993	    if array1_is_finite(direction_out) {
  2994	        log::info!(
  2995	            "[STAGE] PIRLS dense newton solve backend=CPU p={} flops~{} elapsed={:.3}s route=\"{}\"",
  2996	            p,
  2997	            (p as u64).saturating_mul((p as u64).saturating_mul(p as u64)) / 3,
  2998	            dense_solve_start.elapsed().as_secs_f64(),
  2999	            cpu_route,
  3000	        );
  3001	        return Ok(());
  3002	    }
  3003	    Err(EstimationError::LinearSystemSolveFailed(
  3004	        FaerLinalgError::FactorizationFailed,
  3005	    ))
  3006	}
  3007	
  3008	/// Solve the Newton direction implicitly via PCG against an operator-form
  3009	/// Hessian. Bypasses materialization of the `p × p` Hessian when at least one
  3010	/// penalty is operator-form and `p` is large enough that the implicit-matvec
  3011	/// cost amortizes against avoiding a dense Cholesky.
  3012	///
  3013	/// `apply_xtwx`: closure computing `(X^T W X) v`.
  3014	/// `xtwx_diag`: diagonal of `X^T W X`, used in the Jacobi preconditioner.
  3015	/// `dense_penalties`: pairs `(λ_k, S_k)` for penalties whose dense matrix is
  3016	/// the only available representation; their contribution to `H v` is computed
  3017	/// as `λ_k · S_k.dot(v)` and their diagonal contribution to the preconditioner
  3018	/// is `λ_k · diag(S_k)`.
  3019	/// `op_penalties`: pairs `(λ_k, op)` for penalties carrying a `PenaltyOp`
  3020	/// handle; their contribution to `H v` is `λ_k · op.matvec(v)` and their
  3021	/// diagonal is `λ_k · op.diag()`.
  3022	/// `ridge`: nonnegative ridge added to the Hessian diagonal for stabilization.
  3023	///
  3024	/// On success the negated solution `−H⁻¹ g` is written into `direction_out`,
  3025	/// matching the sign convention of `solve_newton_direction_dense`.
  3026	pub fn solve_newton_direction_implicit<F>(
  3027	    apply_xtwx: F,
  3028	    xtwx_diag: ArrayView1<'_, f64>,
  3029	    dense_penalties: &[(f64, &Array2<f64>)],
  3030	    op_penalties: &[(f64, &dyn crate::terms::penalty_op::PenaltyOp)],
  3031	    gradient: &Array1<f64>,
  3032	    direction_out: &mut Array1<f64>,
  3033	    ridge: f64,
  3034	    rel_tol: f64,
  3035	    max_iter: usize,
  3036	) -> Result<(), EstimationError>
  3037	where
  3038	    F: Fn(&Array1<f64>) -> Array1<f64>,
  3039	{
  3040	    let p = gradient.len();
  3041	    if xtwx_diag.len() != p {
  3042	        return Err(EstimationError::InvalidInput(format!(
  3043	            "solve_newton_direction_implicit: xtwx_diag length {} != gradient length {}",
  3044	            xtwx_diag.len(),
  3045	            p
  3046	        )));
  3047	    }
  3048	    for (_, s) in dense_penalties.iter() {
  3049	        if s.nrows() != p || s.ncols() != p {
  3050	            return Err(EstimationError::InvalidInput(format!(
  3051	                "solve_newton_direction_implicit: dense penalty dim {}×{} != p={}",
  3052	                s.nrows(),
  3053	                s.ncols(),
  3054	                p
  3055	            )));
  3056	        }
  3057	    }
  3058	    for (_, op) in op_penalties.iter() {
  3059	        if op.dim() != p {
  3060	            return Err(EstimationError::InvalidInput(format!(
  3061	                "solve_newton_direction_implicit: op penalty dim {} != p={}",
  3062	                op.dim(),
  3063	                p
  3064	            )));
  3065	        }
  3066	    }
  3067	    if direction_out.len() != p {
  3068	        *direction_out = Array1::zeros(p);
  3069	    }
  3070	
  3071	    let pcg_start = std::time::Instant::now();
  3072	
  3073	    let mut precond_diag = xtwx_diag.to_owned();
  3074	    if ridge > 0.0 {
  3075	        precond_diag.mapv_inplace(|d| d + ridge);
  3076	    }
  3077	    for (lambda, s) in dense_penalties.iter() {
  3078	        if *lambda == 0.0 {
  3079	            continue;
  3080	        }
  3081	        for i in 0..p {
  3082	            precond_diag[i] += *lambda * s[[i, i]];
  3083	        }
  3084	    }
  3085	    for (lambda, op) in op_penalties.iter() {
  3086	        if *lambda == 0.0 {
  3087	            continue;
  3088	        }
  3089	        let d = op.diag();
  3090	        for i in 0..p {
  3091	            precond_diag[i] += *lambda * d[i];
  3092	        }
  3093	    }
  3094	
  3095	    // SAFETY: `apply_xtwx`, `dense_penalties`, and `op_penalties` are passed
  3096	    // by reference into the closure. The PCG closure runs synchronously within
  3097	    // this function, so the borrows live for the duration of the call.
  3098	    let apply_h = |v: &Array1<f64>| -> Array1<f64> {
  3099	        let mut hv = apply_xtwx(v);
  3100	        if ridge > 0.0 {
  3101	            hv.zip_mut_with(v, |h, &x| *h += ridge * x);
  3102	        }
  3103	        for (lambda, s) in dense_penalties.iter() {
  3104	            if *lambda == 0.0 {
  3105	                continue;
  3106	            }
  3107	            let sv = s.dot(v);
  3108	            hv.scaled_add(*lambda, &sv);
  3109	        }
  3110	        for (lambda, op) in op_penalties.iter() {
  3111	            if *lambda == 0.0 {
  3112	                continue;
  3113	            }
  3114	            let mut sv = Array1::<f64>::zeros(p);
  3115	            op.matvec(v.view(), sv.view_mut());
  3116	            hv.scaled_add(*lambda, &sv);
  3117	        }
  3118	        hv
  3119	    };
  3120	
  3121	    let solution =
  3122	        crate::linalg::utils::solve_spd_pcg(apply_h, gradient, &precond_diag, rel_tol, max_iter)
  3123	            .ok_or(EstimationError::LinearSystemSolveFailed(
  3124	                FaerLinalgError::FactorizationFailed,
  3125	            ))?;
  3126	
  3127	    direction_out.assign(&solution);
  3128	    direction_out.mapv_inplace(|v| -v);
  3129	    if !array1_is_finite(direction_out) {
  3130	        return Err(EstimationError::LinearSystemSolveFailed(
  3131	            FaerLinalgError::FactorizationFailed,
  3132	        ));
  3133	    }
  3134	    log::info!(
  3135	        "[STAGE] PIRLS implicit (PCG) newton solve p={} dense_pens={} op_pens={} elapsed={:.3}s",
  3136	        p,
  3137	        dense_penalties.len(),
  3138	        op_penalties.len(),
  3139	        pcg_start.elapsed().as_secs_f64(),
  3140	    );
  3141	    Ok(())
  3142	}
  3143	
  3144	fn project_coefficients_to_lower_bounds(beta: &mut Array1<f64>, lower_bounds: &Array1<f64>) {
  3145	    for i in 0..beta.len() {
  3146	        let lb = lower_bounds[i];
  3147	        if lb.is_finite() && beta[i] < lb {
  3148	            beta[i] = lb;
  3149	        }
  3150	    }
  3151	}
  3152	
  3153	/// Compute the projected gradient norm for bound-constrained optimization.
  3154	///
  3155	/// At a constrained optimum, gradient components for variables at their lower
  3156	/// bound that point into the infeasible direction (gradient > 0 for minimization)
  3157	/// are KKT multipliers, not convergence defects.  Zeroing them gives the
  3158	/// standard "projected gradient" used to test stationarity.
  3159	fn projected_gradient_norm(
  3160	    gradient: &Array1<f64>,
  3161	    beta: &Array1<f64>,
  3162	    lower_bounds: Option<&Array1<f64>>,
  3163	) -> f64 {
  3164	    let Some(lb) = lower_bounds else {
  3165	        return gradient.dot(gradient).sqrt();
  3166	    };
  3167	    let mut sum_sq = 0.0;
  3168	    for i in 0..gradient.len() {
  3169	        let g = gradient[i];
  3170	        if lb[i].is_finite() && g > 0.0 {
  3171	            // Use a relative+absolute tolerance so near-bound coefficients
  3172	            // (e.g. I-spline time coefficients at 1e-6) are recognized as
  3173	            // active.  At a KKT point the gradient into the infeasible region
  3174	            // is a multiplier, not a convergence defect.
  3175	            let slack = beta[i] - lb[i];
  3176	            let scale = beta[i].abs().max(lb[i].abs()).max(1.0);
  3177	            let tol = 1e-6 * scale + 1e-10;
  3178	            if slack < tol {
  3179	                continue;
  3180	            }
  3181	        }
  3182	        sum_sq += g * g;
  3183	    }
  3184	    sum_sq.sqrt()
  3185	}
  3186	
  3187	/// "Soft" P-IRLS acceptance reasons — fits that did not certify strict KKT
  3188	/// stationarity but that the post-loop rescue would still classify as
  3189	/// `StalledAtValidMinimum`. Evaluating them per-iter (gated by a streak)
  3190	/// lets the loop exit at the iteration that first meets the criterion
  3191	/// instead of grinding to `MaxIterations` only to be rescued with the
  3192	/// same conditions.
  3193	#[derive(Clone, Copy, Debug, PartialEq, Eq)]
  3194	enum PirlsSoftAccept {
  3195	    /// Projected gradient inside the 10× near-stationary band AND the
  3196	    /// progress signal has plateaued at `tol · objective_scale` (or, in
  3197	    /// the LM-rejection context, at the much tighter `1e-12 · |Φ|` model
  3198	    /// noise floor — see [`SoftAcceptProgress`]). The standard
  3199	    /// "good-enough plateau" rescue, and the only branch that fires
  3200	    /// when no LM step was accepted.
  3201	    NearStationaryPlateau,
  3202	    /// `max|η|` is pinned against [`PIRLS_ETA_ABS_CAP`] AND the deviance
  3203	    /// has plateaued. Same saturated-boundary class as separated binomial
  3204	    /// fits: extra Newton work only re-tries the clipped boundary. Only
  3205	    /// meaningful when a step was actually taken — the LM-rejection
  3206	    /// context skips this branch.
  3207	    BoundarySaturation,
  3208	    /// Projected gradient is small *relative to the objective magnitude*
  3209	    /// (not just the dimension scale) AND the deviance has plateaued
  3210	    /// strictly (×0.1 floor) AND is non-decreasing. This is the
  3211	    /// per-observation rescue for biobank-scale GLMs where ‖g‖ scales
  3212	    /// with √n and the absolute KKT test becomes systematically too
  3213	    /// tight even when the fit is functionally converged. Like
  3214	    /// [`PirlsSoftAccept::BoundarySaturation`], this is only meaningful
  3215	    /// when a step was actually taken.
  3216	    RelativeBandPlateau,
  3217	}
  3218	
  3219	/// Source of the "is the fit still moving?" signal handed to
  3220	/// [`pirls_soft_acceptance`]. There are two contexts in which we need to
  3221	/// decide whether a fit should be accepted as a soft minimum:
  3222	///
  3223	/// - [`SoftAcceptProgress::Realized`] — a step was accepted (per-iter
  3224	///   path) or the loop has run out of iterations (post-loop rescue). We
  3225	///   know the realized change in penalized deviance and can compare it
  3226	///   directly against the standard `tol · objective_scale` plateau band.
  3227	///   All three [`PirlsSoftAccept`] branches are eligible.
  3228	///
  3229	/// - [`SoftAcceptProgress::Predicted`] — no LM candidate step survived
  3230	///   screening, so there is no realized Δdev to test. Instead, the
  3231	///   model's *predicted* reduction from the unaccepted step (`predicted
  3232	///   = -(g·d + ½ d·H·d)`) is compared against the much tighter model
  3233	///   noise floor `1e-12 · max(|Φ|, 1)`. This preserves the historical
  3234	///   LM-rejection acceptance criterion exactly: only the
  3235	///   near-stationary-plateau branch is eligible (saturated-η and
  3236	///   relative-band tests both rely on a realized deviance change and
  3237	///   would widen acceptance if applied with `predicted=0`).
  3238	#[derive(Clone, Copy, Debug)]
  3239	enum SoftAcceptProgress {
  3240	    /// Realized change in penalized deviance from the most recent
  3241	    /// accepted step (per-iter) or final accepted step (post-loop).
  3242	    Realized { dev_change: f64 },
  3243	    /// Predicted reduction `-(g·d + ½ d·H·d)` from the unaccepted LM
  3244	    /// candidate step, paired with the current penalized objective so
  3245	    /// the helper can scale the model noise floor consistently with the
  3246	    /// LM-rejection branch's historical `1e-12 · max(|Φ|, 1)` cutoff.
  3247	    Predicted {
  3248	        predicted_reduction: f64,
  3249	        current_penalized: f64,
  3250	    },
  3251	}
  3252	
  3253	/// Evaluate every "soft" acceptance criterion that the post-loop rescue
  3254	/// applies to a fit which has hit `MaxIterations`. Returns the first
  3255	/// matching reason, or `None` if no criterion fires.
  3256	///
  3257	/// Three call sites share this helper:
  3258	///
  3259	/// 1. **Per-iter** (after an accepted step) — gated on a 2-iter plateau
  3260	///    streak so a single noisy step that briefly satisfies the band
  3261	///    can't trigger an early exit. All three branches are eligible.
  3262	/// 2. **Post-loop rescue** (MaxIterations hit) — accepts immediately;
  3263	///    all three branches are eligible.
  3264	/// 3. **LM-rejection** (no candidate step survived screening) — accepts
  3265	///    immediately, but only the [`PirlsSoftAccept::NearStationaryPlateau`]
  3266	///    branch is eligible, with the tighter model noise floor that the
  3267	///    historical LM-rejection check used. Saturated-η and relative-band
  3268	///    tests need a realized Δdev and are skipped.
  3269	///
  3270	/// Sharing the helper guarantees the three acceptance contexts stay in
  3271	/// lockstep — anything accepted post-loop is also a candidate for
  3272	/// early-exit, and the LM-rejection branch accepts exactly the same set
  3273	/// of states it accepted before unification.
  3274	#[inline]
  3275	fn pirls_soft_acceptance(
  3276	    state: &WorkingState,
  3277	    projected_grad: f64,
  3278	    progress: SoftAcceptProgress,
  3279	    max_abs_eta: f64,
  3280	    progress_tol: f64,
  3281	    kkt_tol: f64,
  3282	) -> Option<PirlsSoftAccept> {
  3283	    let objective_scale = state.deviance.abs().max(state.penalty_term.abs()).max(1.0);
  3284	    // Progress tests stay on the fixed PIRLS tolerance; only KKT stationarity uses kkt_tol.
  3285	    let scaled_dev_tol = progress_tol * objective_scale;
  3286	
  3287	    // Near-stationary plateau is eligible in every context. The only
  3288	    // thing that varies is which "is the fit still moving?" signal we
  3289	    // compare against which floor.
  3290	    let near_stationary_plateau = match progress {
  3291	        SoftAcceptProgress::Realized { dev_change } => {
  3292	            state.near_stationary_kkt(projected_grad, kkt_tol) && dev_change.abs() < scaled_dev_tol
  3293	        }
  3294	        SoftAcceptProgress::Predicted {
  3295	            predicted_reduction,
  3296	            current_penalized,
  3297	        } => {
  3298	            // Historical LM-rejection floor: model-predicted reduction
  3299	            // below `1e-12 · max(|Φ|, 1)` is indistinguishable from
  3300	            // numerical noise on the quadratic model. Keep this exact
  3301	            // formula — it is strictly tighter than `tol · scaled_dev_tol`
  3302	            // for the standard tol=1e-6, so the unified helper does not
  3303	            // widen the LM-rejection acceptance set.
  3304	            let reduction_noise_floor = current_penalized.abs().max(1.0) * 1e-12;
  3305	            state.near_stationary_kkt(projected_grad, kkt_tol)
  3306	                && predicted_reduction.abs() <= reduction_noise_floor
  3307	        }
  3308	    };
  3309	    if near_stationary_plateau {
  3310	        return Some(PirlsSoftAccept::NearStationaryPlateau);
  3311	    }
  3312	
  3313	    // The remaining branches both require a realized Δdev to be
  3314	    // meaningful: η-cap saturation tests "did the step move and yet η
  3315	    // stayed pinned at the cap?", and the relative-band plateau tests a
  3316	    // signed, magnitude-bounded Δdev. Substituting `predicted=0` would
  3317	    // trivially satisfy both with zero diagnostic value and would widen
  3318	    // the LM-rejection acceptance set, so they are gated on a Realized
