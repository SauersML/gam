   496	pub fn gaussian_reml_multi_closed_form_batch<'a>(
   497	    problems: &[GaussianRemlMultiBatchProblem<'a>],
   498	    penalty: ArrayView2<'a, f64>,
   499	    nullspace_dim: Option<usize>,
   500	) -> Result<Vec<GaussianRemlMultiResult>, EstimationError> {
   501	    if problems.is_empty() {
   502	        return Ok(Vec::new());
   503	    }
   504	    // Phase A: par_iter compute X'WX per problem (the only per-fit step that
   505	    // depends on `n_b`; remaining work is `O(p)` and can amortize through
   506	    // `_with_cache`).
   507	    let xtwx_per_problem: Vec<Array2<f64>> = problems
   508	        .par_iter()
   509	        .map(|problem| {
   510	            let weight = match problem.weights.as_ref() {
   511	                Some(w) => w.to_owned(),
   512	                None => Array1::ones(problem.x.nrows()),
   513	            };
   514	            dense_xt_diag_x(problem.x.view(), weight.view())
   515	        })
   516	        .collect();
   517	    // Phase B: one batched cuSOLVER Cholesky (when policy approves uniform p
   518	    // and K aggregate FLOPs), per-fit Cholesky fallback otherwise.
   519	    let caches =
   520	        build_gaussian_reml_eigen_cache_batched(xtwx_per_problem, penalty.view(), nullspace_dim);
   521	    // Phase C: par_iter finish each fit with its prebuilt cache, falling
   522	    // back to a fresh build when the cache build failed for that element.
   523	    let fits: Vec<Result<GaussianRemlMultiResult, EstimationError>> = problems
   524	        .par_iter()
   525	        .zip(caches.into_par_iter())
   526	        .map(|(problem, cache_result)| {
   527	            let init_lambda = problem.init_rho.map(f64::exp);
   528	            let cache = cache_result.ok();
   529	            gaussian_reml_multi_closed_form_from_parts(
   530	                problem.x.view(),
   531	                problem.y.view(),
   532	                penalty.view(),
   533	                nullspace_dim,
   534	                problem.weights.as_ref().map(|weights| weights.view()),
   535	                init_lambda,
   536	                cache.as_ref(),
   537	            )
   538	        })
   539	        .collect();
   540	    fits.into_iter().collect()
   541	}
