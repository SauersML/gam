    83	fn infer_penalty_rank(penalty: &crate::construction::CanonicalPenalty) -> Result<usize, String> {
    84	    let block_dim = penalty.block_dim();
    85	    if penalty.positive_eigenvalues.len() + penalty.nullity == block_dim {
    86	        return Ok(penalty.positive_eigenvalues.len());
    87	    }
    88	    if block_dim == 0 {
    89	        return Ok(0);
    90	    }
