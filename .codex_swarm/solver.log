  4414	    fn is_lm_retriable_candidate_error(err: &EstimationError) -> bool {
  4415	        match err {
  4416	            EstimationError::LinearSystemSolveFailed(_)
  4417	            | EstimationError::HessianNotPositiveDefinite { .. } => true,
  4418	            EstimationError::InvalidInput(message) => {
  4419	                let message = message.to_ascii_lowercase();
  4420	                message.contains("nan")
  4421	                    || message.contains("non-finite")
  4422	                    || message.contains("infinite")
  4423	                    || message.contains("overflow")
  4424	                    || message.contains("exceeds f64 range")
  4425	            }
  4426	            // A candidate step that drives the linear predictor into a region
  4427	            // where the model's likelihood is structurally infeasible (e.g.
  4428	            // survival monotonicity violated, cumulative hazard decreasing) is
  4429	            // the natural LM-halving trigger: the proposed step is too
  4430	            // aggressive and the gain-ratio guard never gets to see it.
  4431	            // Retrying with a larger damping factor collapses towards a
  4432	            // feasible region rather than hard-failing at the first infeasible
  4433	            // candidate.
  4434	            EstimationError::ParameterConstraintViolation(_) => true,
  4435	            _ => false,
  4436	        }
  4437	    }
