  1779	        None => Ok(Array1::ones(n)),
  1780	    }
  1781	}
  1782	
  1783	fn gaussian_reml_eigen_cache_from_xtwx(
  1784	    xtwx: Array2<f64>,
  1785	    penalty: ArrayView2<'_, f64>,
  1786	    nullspace_dim: Option<usize>,
  1787	) -> Result<GaussianRemlEigenCache, EstimationError> {
  1788	    let xtwx_fingerprint = matrix_fingerprint(xtwx.view());
  1789	    let lower = gaussian_reml_cholesky_lower(xtwx)?;
  1790	    gaussian_reml_eigen_cache_from_lower(lower, penalty, nullspace_dim, xtwx_fingerprint)
  1791	}
  1792	
  1793	/// Cache-build entry point for callers that have already computed `L =
  1794	/// chol(X'WX, lower)`. Used by the batched K-way fit path so a single
  1795	/// `cusolverDnDpotrfBatched` call factors all K matrices, then each cache
  1796	/// finishes per-fit without re-doing the Cholesky.
  1797	fn gaussian_reml_eigen_cache_from_lower(
  1798	    lower: Array2<f64>,
  1799	    penalty: ArrayView2<'_, f64>,
  1800	    nullspace_dim: Option<usize>,
  1801	    xtwx_fingerprint: u64,
  1802	) -> Result<GaussianRemlEigenCache, EstimationError> {
  1803	    gaussian_reml_eigen_cache_from_lower_with_transform(
  1804	        lower,
  1805	        penalty,
  1806	        nullspace_dim,
  1807	        xtwx_fingerprint,
  1808	        None,
  1809	    )
  1810	}
  1811	
  1812	/// Cache-build variant that accepts a pre-computed whitened penalty
  1813	/// `L⁻¹·S·L⁻ᵀ`. The batched cache build supplies it via broadcast/strided
  1814	/// batched cuBLAS gemms when the policy approves; per-fit callers pass
  1815	/// `None` and the helper falls back to `invert_lower_triangular` + two
  1816	/// `dense_ab` calls (which themselves route to `try_fast_*` per the
  1817	/// host/GPU dispatch policy).
  1818	fn gaussian_reml_eigen_cache_from_lower_with_transform(
  1819	    lower: Array2<f64>,
  1820	    penalty: ArrayView2<'_, f64>,
  1821	    nullspace_dim: Option<usize>,
  1822	    xtwx_fingerprint: u64,
  1823	    precomputed_transform: Option<Array2<f64>>,
  1824	) -> Result<GaussianRemlEigenCache, EstimationError> {
  1825	    let p = lower.nrows();
  1826	    if lower.ncols() != p {
  1827	        return Err(EstimationError::InvalidInput(
  1828	            "Gaussian REML Cholesky factor must be square".to_string(),
  1829	        ));
  1830	    }
  1831	    let penalty_fingerprint = matrix_fingerprint(penalty);
  1832	    let logdet_xtwx = 2.0 * lower.diag().iter().map(|v| v.ln()).sum::<f64>();
  1833	    let transformed_penalty = match precomputed_transform {
  1834	        Some(transformed) => transformed,
  1835	        None => {
  1836	            let l_inv = invert_lower_triangular(&lower)?;
  1837	            let penalty_in_metric = dense_ab(l_inv.view(), penalty);
  1838	            dense_ab(penalty_in_metric.view(), l_inv.t())
  1839	        }
  1840	    };
  1841	    let (mut penalty_eigenvalues, eigenvectors) =
  1842	        transformed_penalty.eigh(Side::Lower).map_err(|_| {
  1843	            EstimationError::ModelIsIllConditioned {
  1844	                condition_number: f64::INFINITY,
  1845	            }
  1846	        })?;
  1847	    // Rank tolerance must be RELATIVE to the largest eigenvalue — never
  1848	    // floored at an absolute value. The old `.max(1.0)` clamped the
  1849	    // tolerance up whenever max|eig| < 1, classifying genuine modes as
  1850	    // null for small-scale penalties (e.g. Wahba pseudo-spline `m=4`
  1851	    // with `K(p,p) ≈ 3e-4`). That broke REML's invariance under
  1852	    // `S → c·S` — the optimum λ rescales but the score landscape
  1853	    // diverges from the true marginal likelihood, and the smooth
  1854	    // contribution collapsed to ~0 on smooth truths.
  1855	    // Fully scale-invariant form: `safety · max|eig| · eps`.
  1856	    let max_abs_eig = penalty_eigenvalues
  1857	        .iter()
  1858	        .fold(0.0_f64, |acc, &value| acc.max(value.abs()));
  1859	    let eig_tol = max_abs_eig * EIGEN_REL_TOL;
  1860	    for value in &mut penalty_eigenvalues {
  1861	        if *value < 0.0 && value.abs() <= eig_tol {
  1862	            *value = 0.0;
  1863	        }
  1864	        if *value < 0.0 {
  1865	            return Err(EstimationError::InvalidInput(format!(
  1866	                "Gaussian REML penalty is not positive semidefinite; eigenvalue={value:.3e}"
  1867	            )));
  1868	        }
  1869	    }
  1870	    let penalty_rank = penalty_eigenvalues
  1871	        .iter()
  1872	        .filter(|&&value| value > eig_tol)
  1873	        .count();
  1874	    let nullity = p - penalty_rank;
  1875	    if let Some(expected_nullity) = nullspace_dim {
  1876	        if expected_nullity != nullity {
  1877	            return Err(EstimationError::InvalidInput(format!(
  1878	                "Gaussian REML penalty nullspace mismatch: expected {expected_nullity}, inferred {nullity}"
  1879	            )));
  1880	        }
  1881	    }
  1882	    let logdet_penalty_positive = gaussian_penalty_positive_logdet(penalty, penalty_rank)?;
  1883	    let coefficient_basis = solve_upper_triangular_matrix(&lower.t().to_owned(), &eigenvectors)?;
  1884	
  1885	    Ok(GaussianRemlEigenCache {
  1886	        penalty_eigenvalues,
  1887	        eigenvectors,
  1888	        coefficient_basis,
  1889	        xtwx_fingerprint,
  1890	        penalty_fingerprint,
  1891	        logdet_xtwx,
  1892	        logdet_penalty_positive,
  1893	        penalty_rank,
  1894	        nullity,
  1895	    })
  1896	}
  1897	
  1898	fn gaussian_reml_cholesky_lower(xtwx: Array2<f64>) -> Result<Array2<f64>, EstimationError> {
  1899	    if crate::gpu::GpuRuntime::global()
  1900	        .policy()
  1901	        .route_chol_solve(xtwx.nrows())
  1902	    {
  1903	        let mut gpu_xtwx = xtwx.clone();
  1904	        if crate::gpu::try_cholesky_lower_inplace(&mut gpu_xtwx).is_some()
  1905	            && gpu_xtwx.iter().all(|value| value.is_finite())
  1906	            && gpu_xtwx.diag().iter().all(|value| *value > 0.0)
  1907	        {
  1908	            return Ok(gpu_xtwx);
  1909	        }
  1910	    }
  1911	    // Attempt Cholesky directly; on failure, retry with a tiny diagonal jitter
  1912	    // proportional to the matrix trace. X'WX is symmetric positive semidefinite
  1913	    // by construction, but FP noise (e.g. in a basis whose kernel block is only
  1914	    // FP-orthogonal to its explicit polynomial nullspace columns, as the
  1915	    // periodic Duchon basis is) can push the smallest eigenvalue slightly
  1916	    // negative on adversarial inputs, intermittently failing Cholesky. A
  1917	    // jitter of 1e-12 * trace/p shifts every eigenvalue up by an amount well
  1918	    // below the natural scale of the well-conditioned eigenvalues but well
  1919	    // above f64 FP noise, eliminating the spurious-failure regime.
  1920	    if let Ok(chol) = xtwx.cholesky(Side::Lower) {
  1921	        return Ok(chol.lower_triangular());
  1922	    }
  1923	    let p = xtwx.nrows();
  1924	    let trace: f64 = (0..p).map(|i| xtwx[[i, i]]).sum();
  1925	    if !trace.is_finite() || trace <= 0.0 {
  1926	        return Err(EstimationError::ModelIsIllConditioned {
  1927	            condition_number: f64::INFINITY,
  1928	        });
  1929	    }
  1930	    let mut jitter = 1e-12 * trace / (p as f64);
  1931	    for _ in 0..6 {
  1932	        let mut jittered = xtwx.clone();
  1933	        for i in 0..p {
  1934	            jittered[[i, i]] += jitter;
  1935	        }
  1936	        if let Ok(chol) = jittered.cholesky(Side::Lower) {
  1937	            return Ok(chol.lower_triangular());
  1938	        }
  1939	        jitter *= 10.0;
  1940	    }
  1941	    Err(EstimationError::ModelIsIllConditioned {
  1942	        condition_number: f64::INFINITY,
  1943	    })
  1944	}
  1945	
  1946	fn gaussian_penalty_positive_logdet(
  1947	    penalty: ArrayView2<'_, f64>,
  1948	    penalty_rank: usize,
  1949	) -> Result<f64, EstimationError> {
  1950	    if penalty_rank == 0 {
  1951	        return Ok(0.0);
  1952	    }
  1953	    let (pen_eigs, _) = penalty.to_owned().eigh(Side::Lower).map_err(|_| {
  1954	        EstimationError::ModelIsIllConditioned {
  1955	            condition_number: f64::INFINITY,
  1956	        }
  1957	    })?;
  1958	    // Scale-invariant relative tolerance — see the cousin site for the
  1959	    // rationale. Same `.max(1.0)` floor used to live here and corrupted
  1960	    // the positive-eigenvalue count for small-scale penalties.
  1961	    let pen_scale = pen_eigs
  1962	        .iter()
  1963	        .fold(0.0_f64, |acc, &value| acc.max(value.abs()));
  1964	    let pen_tol = pen_scale * EIGEN_REL_TOL;
  1965	    let mut positive_eigs: Vec<f64> = pen_eigs
  1966	        .iter()
  1967	        .copied()
  1968	        .filter(|&value| value > pen_tol)
  1969	        .collect();
  1970	    if positive_eigs.len() != penalty_rank {
  1971	        positive_eigs = pen_eigs
  1972	            .iter()
  1973	            .copied()
  1974	            .filter(|&value| value > 0.0)
  1975	            .collect();
  1976	        positive_eigs.sort_by(|a, b| b.total_cmp(a));
  1977	        if positive_eigs.len() < penalty_rank {
  1978	            return Err(EstimationError::ModelIsIllConditioned {
  1979	                condition_number: f64::INFINITY,
  1980	            });
  1981	        }
  1982	        positive_eigs.truncate(penalty_rank);
  1983	    }
  1984	    Ok(positive_eigs.iter().map(|value| value.ln()).sum())
  1985	}
  1986	
  1987	fn validate_gaussian_reml_eigen_cache(
  1988	    cache: &GaussianRemlEigenCache,
  1989	    p: usize,
  1990	) -> Result<(), EstimationError> {
  1991	    if cache.penalty_eigenvalues.len() != p
  1992	        || cache.eigenvectors.dim() != (p, p)
  1993	        || cache.coefficient_basis.dim() != (p, p)
  1994	    {
  1995	        return Err(EstimationError::InvalidInput(format!(
  1996	            "Gaussian REML eigen cache dimension mismatch: expected {p} coefficients"
  1997	        )));
  1998	    }
  1999	    if cache.penalty_rank > p || cache.nullity > p || cache.penalty_rank + cache.nullity != p {
  2000	        return Err(EstimationError::InvalidInput(format!(
  2001	            "Gaussian REML eigen cache rank/nullity mismatch: rank={}, nullity={}, p={p}",
  2002	            cache.penalty_rank, cache.nullity
  2003	        )));
  2004	    }
  2005	    if !(cache.logdet_xtwx.is_finite() && cache.logdet_penalty_positive.is_finite()) {
  2006	        return Err(EstimationError::InvalidInput(
  2007	            "Gaussian REML eigen cache log-determinants must be finite".to_string(),
  2008	        ));
  2009	    }
  2010	    if cache
  2011	        .penalty_eigenvalues
  2012	        .iter()
  2013	        .any(|value| !value.is_finite() || *value < 0.0)
  2014	        || cache.eigenvectors.iter().any(|value| !value.is_finite())
  2015	        || cache
  2016	            .coefficient_basis
  2017	            .iter()
  2018	            .any(|value| !value.is_finite())
  2019	    {
  2020	        return Err(EstimationError::InvalidInput(
  2021	            "Gaussian REML eigen cache entries must be finite with non-negative eigenvalues"
  2022	                .to_string(),
  2023	        ));
  2024	    }
  2025	    Ok(())
  2026	}
  2027	
  2028	fn prepare_gaussian_reml(
  2029	    x: ArrayView2<'_, f64>,
  2030	    y: ArrayView2<'_, f64>,
  2031	    penalty: ArrayView2<'_, f64>,
  2032	    nullspace_dim: Option<usize>,
  2033	    weights: Option<ArrayView1<'_, f64>>,
  2034	    eigen_cache: Option<&GaussianRemlEigenCache>,
  2035	) -> Result<GaussianRemlPrepared, EstimationError> {
  2036	    // Enforce the symmetric-S contract once at the central forward chokepoint;
  2037	    // every closed-form forward path funnels through here.
  2038	    let penalty_owned = canonicalize_penalty(penalty);
  2039	    let penalty = penalty_owned.view();
  2040	    let n = x.nrows();
  2041	    let p = x.ncols();
  2042	    let d = y.ncols();
  2043	    validate_gaussian_reml_design(x, penalty, weights)?;
  2044	    if y.nrows() != n {
  2045	        return Err(EstimationError::InvalidInput(format!(
  2046	            "Gaussian REML row mismatch: X has {n} rows but Y has {}",
  2047	            y.nrows()
  2048	        )));
  2049	    }
  2050	    if y.iter().any(|v| !v.is_finite()) {
  2051	        return Err(EstimationError::InvalidInput(
  2052	            "Gaussian REML inputs must be finite".to_string(),
  2053	        ));
  2054	    }
  2055	    let weight = gaussian_reml_weights(n, weights)?;
  2056	
  2057	    let xtwy = dense_xt_diag_y(x, weight.view(), y);
  2058	    let ywy = Array1::from_iter((0..d).map(|j| {
  2059	        let mut value = 0.0;
  2060	        for row in 0..n {
  2061	            value += weight[row] * y[[row, j]] * y[[row, j]];
  2062	        }
  2063	        value
  2064	    }));
  2065	    let xtwx = dense_xt_diag_x(x, weight.view());
  2066	
  2067	    if let Some(cache) = eigen_cache {
  2068	        validate_gaussian_reml_eigen_cache(cache, p)?;
  2069	        let xtwx_fingerprint = matrix_fingerprint(xtwx.view());
  2070	        if cache.xtwx_fingerprint != xtwx_fingerprint {
  2071	            return Err(EstimationError::InvalidInput(
  2072	                "Gaussian REML eigen cache X'WX mismatch".to_string(),
  2073	            ));
  2074	        }
  2075	        let penalty_fingerprint = matrix_fingerprint(penalty);
  2076	        if cache.penalty_fingerprint != penalty_fingerprint {
  2077	            return Err(EstimationError::InvalidInput(
  2078	                "Gaussian REML eigen cache penalty mismatch".to_string(),
  2079	            ));
  2080	        }
  2081	        if let Some(expected_nullity) = nullspace_dim {
  2082	            if expected_nullity != cache.nullity {
  2083	                return Err(EstimationError::InvalidInput(format!(
  2084	                    "Gaussian REML eigen cache nullspace mismatch: expected {expected_nullity}, got {}",
  2085	                    cache.nullity
  2086	                )));
  2087	            }
  2088	        }
  2089	        if n <= cache.nullity {
  2090	            return Err(EstimationError::InvalidInput(format!(
  2091	                "Gaussian REML requires n > nullspace dimension; got n={n}, nullity={}",
  2092	                cache.nullity
  2093	            )));
  2094	        }
  2095	        let projected_rhs = dense_atb(cache.coefficient_basis.view(), xtwy.view());
  2096	        let projected_rhs_squared = projected_rhs.mapv(|value| value * value);
  2097	        return Ok(GaussianRemlPrepared {
  2098	            cache: cache.clone(),
  2099	            ywy,
  2100	            projected_rhs_squared,
  2101	            projected_rhs,
  2102	            n_observations: n,
  2103	            n_outputs: d,
  2104	        });
  2105	    }
  2106	
  2107	    let cache = gaussian_reml_eigen_cache_from_xtwx(xtwx, penalty, nullspace_dim)?;
  2108	    if n <= cache.nullity {
  2109	        return Err(EstimationError::InvalidInput(format!(
  2110	            "Gaussian REML requires n > nullspace dimension; got n={n}, nullity={}",
  2111	            cache.nullity
  2112	        )));
  2113	    }
  2114	    let projected_rhs = dense_atb(cache.coefficient_basis.view(), xtwy.view());
  2115	    let projected_rhs_squared = projected_rhs.mapv(|value| value * value);
  2116	
  2117	    Ok(GaussianRemlPrepared {
  2118	        cache,
  2119	        ywy,
  2120	        projected_rhs_squared,
  2121	        projected_rhs,
  2122	        n_observations: n,
  2123	        n_outputs: d,
  2124	    })
  2125	}
  2126	
  2127	impl GaussianRemlPrepared {
  2128	    fn nu(&self) -> f64 {
  2129	        self.n_observations as f64 - self.cache.nullity as f64
  2130	    }
  2131	
  2132	    fn evaluate(&self, rho: f64) -> ObjectiveEval {
  2133	        evaluate_reml_parts(
  2134	            &self.cache,
  2135	            self.ywy.view(),
  2136	            self.projected_rhs_squared.view(),
  2137	            self.n_observations,
  2138	            self.n_outputs,
  2139	            rho,
  2140	        )
  2141	    }
  2142	
  2143	    fn coefficients(&self, lambda: f64) -> Array2<f64> {
  2144	        let mut scaled = self.projected_rhs.clone();
  2145	        for i in 0..self.cache.penalty_eigenvalues.len() {
  2146	            let scale = 1.0 / (1.0 + lambda * self.cache.penalty_eigenvalues[i]);
  2147	            for value in scaled.row_mut(i) {
  2148	                *value *= scale;
  2149	            }
  2150	        }
  2151	        dense_ab(self.cache.coefficient_basis.view(), scaled.view())
  2152	    }
  2153	
  2154	    fn sigma2(&self, lambda: f64) -> Array1<f64> {
  2155	        let nu = self.nu();
  2156	        Array1::from_iter((0..self.n_outputs).map(|j| {
  2157	            let mut fitted_quadratic = 0.0;
  2158	            for i in 0..self.cache.penalty_eigenvalues.len() {
  2159	                let denom = 1.0 + lambda * self.cache.penalty_eigenvalues[i];
  2160	                fitted_quadratic += self.projected_rhs_squared[[i, j]] / denom;
  2161	            }
  2162	            ((self.ywy[j] - fitted_quadratic).max(MIN_DEVIANCE)) / nu
  2163	        }))
  2164	    }
  2165	}
  2166	
  2167	fn optimize_rho(
  2168	    prepared: &GaussianRemlPrepared,
  2169	    init_rho: Option<f64>,
  2170	) -> Result<f64, EstimationError> {
  2171	    if prepared.cache.penalty_rank == 0 {
  2172	        return Ok(init_rho.unwrap_or(0.0).clamp(RHO_LOWER, RHO_UPPER));
  2173	    }
  2174	
  2175	    const GRID_INTERVALS: usize = 96;
  2176	    let mut stationary = Vec::<f64>::new();
  2177	    let mut prev_rho = RHO_LOWER;
  2178	    let mut prev_eval = prepared.evaluate(prev_rho);
  2179	    for i in 1..=GRID_INTERVALS {
  2180	        let rho = RHO_LOWER + (RHO_UPPER - RHO_LOWER) * (i as f64) / (GRID_INTERVALS as f64);
  2181	        let eval = prepared.evaluate(rho);
  2182	        if prev_eval.grad <= 0.0 && eval.grad >= 0.0 {
  2183	            push_candidate(
  2184	                &mut stationary,
  2185	                refine_stationary_rho(prepared, prev_rho, rho, 0.5 * (prev_rho + rho)),
  2186	            );
  2187	        }
  2188	        prev_rho = rho;
  2189	        prev_eval = eval;
  2190	    }
  2191	
  2192	    let mut candidates = stationary;
  2193	    push_candidate(&mut candidates, RHO_LOWER);
  2194	    push_candidate(&mut candidates, RHO_UPPER);
  2195	    if let Some(rho0) = init_rho {
  2196	        push_candidate(&mut candidates, rho0);
  2197	    }
  2198	
  2199	    // Evaluate each candidate exactly once. `min_by` over a comparator that
  2200	    // re-evaluates would do O(n log n) extra `prepared.evaluate` calls during
  2201	    // the sort.
  2202	    candidates
  2203	        .into_iter()
  2204	        .map(|rho| (rho, prepared.evaluate(rho).cost))
  2205	        .min_by(|(_, a), (_, b)| a.total_cmp(b))
  2206	        .map(|(rho, _)| rho)
  2207	        .ok_or_else(|| {
  2208	            EstimationError::InvalidInput(
  2209	                "Gaussian REML optimizer produced no candidates".to_string(),
  2210	            )
  2211	        })
  2212	}
  2213	
  2214	fn fill_weighted_rhs_no_alloc(
  2215	    x: ArrayView2<'_, f64>,
  2216	    y: ArrayView2<'_, f64>,
  2217	    weights: Option<ArrayView1<'_, f64>>,
  2218	    workspace: &mut GaussianRemlNoAllocWorkspace,
  2219	) -> Result<(), EstimationError> {
  2220	    let d = y.ncols();
  2221	
  2222	    // XᵀWY and YᵀWY via faer BLAS. Both `fast_xt_diag_y` and `fast_atb`
  2223	    // dispatch to faer's SIMD-optimized GEMM (with chunked weight scaling
  2224	    // when weights are present), replacing the previous scalar triple loop
  2225	    // over (n, p, d). For YᵀWY we only need the diagonal entries, but d is
  2226	    // small (typically 1–10) so computing the full d×d Gram is negligible.
  2227	    let (xtwy, ywy_full) = match weights {
  2228	        Some(w) => (fast_xt_diag_y(&x, &w, &y), fast_xt_diag_y(&y, &w, &y)),
  2229	        None => (fast_atb(&x, &y), fast_atb(&y, &y)),
  2230	    };
  2231	    workspace.xtwy.assign(&xtwy);
  2232	    for output in 0..d {
  2233	        workspace.ywy[output] = ywy_full[[output, output]];
  2234	    }
  2235	
  2236	    if workspace
  2237	        .xtwy
  2238	        .iter()
  2239	        .chain(workspace.ywy.iter())
  2240	        .any(|value| !value.is_finite())
  2241	    {
  2242	        return Err(EstimationError::InvalidInput(
  2243	            "Gaussian REML weighted cross-products must be finite".to_string(),
  2244	        ));
  2245	    }
  2246	    Ok(())
  2247	}
  2248	
  2249	fn project_rhs_no_alloc(
  2250	    cache: &GaussianRemlEigenCache,
  2251	    workspace: &mut GaussianRemlNoAllocWorkspace,
  2252	) {
  2253	    // projected_rhs = coefficient_basisᵀ · xtwy, computed via faer BLAS
  2254	    // (was previously a scalar triple loop over (p, d, p)).
  2255	    let projected = fast_atb(&cache.coefficient_basis, &workspace.xtwy);
  2256	    workspace.projected_rhs.assign(&projected);
  2257	    let p = cache.penalty_eigenvalues.len();
  2258	    let d = workspace.ywy.len();
  2259	    for eig in 0..p {
  2260	        for output in 0..d {
  2261	            let value = workspace.projected_rhs[[eig, output]];
  2262	            workspace.projected_rhs_squared[[eig, output]] = value * value;
  2263	        }
  2264	    }
  2265	}
  2266	
  2267	fn evaluate_reml_parts(
  2268	    cache: &GaussianRemlEigenCache,
  2269	    ywy: ArrayView1<'_, f64>,
  2270	    projected_rhs_squared: ArrayView2<'_, f64>,
  2271	    n_observations: usize,
  2272	    n_outputs: usize,
  2273	    rho: f64,
  2274	) -> ObjectiveEval {
  2275	    let lambda = rho.exp();
  2276	    let nu = n_observations as f64 - cache.nullity as f64;
  2277	    let d = n_outputs as f64;
  2278	    let mut logdet_h = cache.logdet_xtwx;
  2279	    let mut trace_h = 0.0;
  2280	    let mut trace_h_deriv = 0.0;
  2281	    let mut edf = 0.0;
  2282	    for &delta in &cache.penalty_eigenvalues {
  2283	        let t = lambda * delta;
  2284	        logdet_h += (1.0 + t).ln();
  2285	        if delta > 0.0 {
  2286	            trace_h += t / (1.0 + t);
  2287	            trace_h_deriv += t / ((1.0 + t) * (1.0 + t));
  2288	        }
  2289	        edf += 1.0 / (1.0 + t);
  2290	    }
  2291	    let logdet_s = cache.logdet_penalty_positive + (cache.penalty_rank as f64) * rho;
  2292	
  2293	    let mut cost = 0.5 * d * (logdet_h - logdet_s);
  2294	    let mut grad = 0.5 * d * (trace_h - cache.penalty_rank as f64);
  2295	    let mut hess = 0.5 * d * trace_h_deriv;
  2296	    for output in 0..n_outputs {
  2297	        let mut fitted_quadratic = 0.0;
  2298	        let mut dp_grad = 0.0;
  2299	        let mut dp_hess = 0.0;
  2300	        for eig in 0..cache.penalty_eigenvalues.len() {
  2301	            let c2 = projected_rhs_squared[[eig, output]];
  2302	            let t = lambda * cache.penalty_eigenvalues[eig];
  2303	            let denom = 1.0 + t;
  2304	            fitted_quadratic += c2 / denom;
  2305	            dp_grad += c2 * t / (denom * denom);
  2306	            dp_hess += c2 * t * (1.0 - t) / (denom * denom * denom);
  2307	        }
  2308	        let dp = (ywy[output] - fitted_quadratic).max(MIN_DEVIANCE);
  2309	        cost += 0.5 * nu * (1.0 + (2.0 * std::f64::consts::PI * dp / nu).ln());
  2310	        grad += 0.5 * nu * dp_grad / dp;
  2311	        hess += 0.5 * nu * (dp_hess / dp - (dp_grad * dp_grad) / (dp * dp));
  2312	    }
  2313	    ObjectiveEval {
  2314	        cost,
  2315	        grad,
  2316	        hess,
  2317	        edf,
  2318	    }
  2319	}
