   203	/// A penalty specification for the public estimate API.
   204	///
   205	/// `Block` stores only the active sub-block and its column range, avoiding
   206	/// the O(p^2) cost of embedding into a full penalty matrix.
   207	/// `Dense` stores a full `p x p` penalty matrix for callers that already
   208	/// have one.
   209	#[derive(Clone)]
   210	pub enum PenaltySpec {
   211	    /// Block-local penalty: `local` is `block_dim x block_dim`,
   212	    /// applied to columns `col_range` of the coefficient vector.
   213	    Block {
   214	        local: Array2<f64>,
   215	        col_range: Range<usize>,
   216	        prior_mean: CoefficientPriorMean,
   217	        /// Optional structural hint for fast-path spectral decomposition.
   218	        structure_hint: Option<crate::terms::smooth::PenaltyStructureHint>,
   219	        /// Optional operator-form handle bit-equivalent to `local`.
   220	        op: Option<std::sync::Arc<dyn crate::terms::penalty_op::PenaltyOp>>,
   221	    },
   222	    /// Full dense penalty matrix (`p x p`).
   223	    Dense(Array2<f64>),
   224	    /// Full dense penalty matrix with a programmatic prior mean in the same
   225	    /// global coefficient basis.
   226	    DenseWithMean {
   227	        matrix: Array2<f64>,
   228	        prior_mean: CoefficientPriorMean,
   229	    },
   230	}
   231	
   232	impl std::fmt::Debug for PenaltySpec {
   233	    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
   234	        match self {
   235	            PenaltySpec::Block {
   236	                local,
   237	                col_range,
   238	                prior_mean,
   239	                structure_hint,
   240	                op,
   241	            } => f
   242	                .debug_struct("Block")
   243	                .field(
   244	                    "local",
   245	                    &format_args!("{}×{}", local.nrows(), local.ncols()),
   246	                )
   247	                .field("col_range", col_range)
   248	                .field("prior_mean", prior_mean)
   249	                .field("structure_hint", structure_hint)
   250	                .field("op", &op.as_ref().map(|o| o.dim()))
   251	                .finish(),
   252	            PenaltySpec::Dense(m) => f
   253	                .debug_tuple("Dense")
   254	                .field(&format_args!("{}×{}", m.nrows(), m.ncols()))
   255	                .finish(),
   256	            PenaltySpec::DenseWithMean { matrix, prior_mean } => f
   257	                .debug_struct("DenseWithMean")
   258	                .field(
   259	                    "matrix",
   260	                    &format_args!("{}×{}", matrix.nrows(), matrix.ncols()),
   261	                )
   262	                .field("prior_mean", prior_mean)
   263	                .finish(),
   264	        }
   265	    }
   266	}
