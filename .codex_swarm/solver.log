   763	/// Representative curvature scale for a Hessian operator.
   764	///
   765	/// Returns the geometric mean of the active Hessian eigenvalues,
   766	/// `exp(log|H|_+ / rank(H))`. This has the same physical units as a Hessian
   767	/// diagonal entry but is basis-invariant, cheap after the operator has computed
   768	/// its log-determinant, and well-defined for both dense spectral and
   769	/// matrix-free operator paths.
   770	pub fn hessian_operator_geometric_scale(op: &dyn HessianOperator) -> Option<f64> {
   771	    let rank = op.active_rank();
   772	    if rank == 0 {
   773	        return None;
   774	    }
   775	    let logdet = op.logdet();
   776	    if !logdet.is_finite() {
   777	        return None;
   778	    }
   779	    let scale = (logdet / rank as f64).exp();
   780	    if scale.is_finite() && scale > 0.0 {
   781	        Some(scale)
   782	    } else {
   783	        None
   784	    }
   785	}
