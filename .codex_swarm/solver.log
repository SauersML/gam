    99	fn solve_newton_direction_dense(
   100	    hessian: &Array2<f64>,
   101	    gradient: &Array1<f64>,
   102	    direction_out: &mut Array1<f64>,
   103	) -> Result<(), EstimationError> {
   104	    if direction_out.len() != gradient.len() {
   105	        *direction_out = Array1::zeros(gradient.len());
   106	    }
   107	
   108	    let factor = StableSolver::new("active-set newton direction")
   109	        .factorize(hessian)
   110	        .map_err(EstimationError::LinearSystemSolveFailed)?;
   111	    direction_out.assign(gradient);
   112	    let mut rhsview = array1_to_col_matmut(direction_out);
   113	    factor.solve_in_place(rhsview.as_mut());
   114	    direction_out.mapv_inplace(|v| -v);
   115	    if array1_is_finite(direction_out) {
   116	        return Ok(());
   117	    }
   118	    Err(EstimationError::LinearSystemSolveFailed(
   119	        FaerLinalgError::FactorizationFailed,
   120	    ))
   121	}
