    64	/// KKT diagnostics for inequality-constrained Newton subproblems.
    65	///
    66	/// Constraints are represented as `A * beta >= b` in the same coefficient
    67	/// coordinate system as the returned `beta`.
    68	///
    69	/// **Invariants** (held by all producers; not enforced at consumer boundary):
    70	/// - `n_active <= n_constraints` (a row cannot be active twice).
    71	/// - All four residual components (`primal_feasibility`, `dual_feasibility`,
    72	///   `complementarity`, `stationarity`) are `>= 0.0` and finite.
    73	/// - `active_tolerance >= 0.0` and finite.
    74	#[derive(Clone, Debug, Serialize, Deserialize)]
    75	pub struct ConstraintKktDiagnostics {
    76	    /// Number of inequality rows.
    77	    pub n_constraints: usize,
    78	    /// Number of rows considered active (`slack <= active_tolerance`).
    79	    pub n_active: usize,
    80	    /// Maximum primal feasibility violation: `max_i max(0, b_i - a_i^T beta)`.
    81	    pub primal_feasibility: f64,
    82	    /// Maximum dual feasibility violation: `max_i max(0, -lambda_i)`.
    83	    pub dual_feasibility: f64,
    84	    /// Maximum complementarity residual: `max_i |lambda_i * slack_i|`.
    85	    pub complementarity: f64,
    86	    /// Stationarity residual: `||grad - A^T lambda||_inf`.
    87	    pub stationarity: f64,
    88	    /// Tolerance used to classify active constraints from slacks.
    89	    pub active_tolerance: f64,
    90	}
