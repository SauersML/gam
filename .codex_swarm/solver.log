  2754	impl SparseSpGemmState {
  2755	    /// Compute XᵀWX into the symbolic-pattern array `xtwxvalues` via faer's
  2756	    /// sparse-sparse matmul: XᵀWX = (√W·X)ᵀ · (√W·X).
  2757	    fn compute(
  2758	        &mut self,
  2759	        x: &SparseColMat<usize, f64>,
  2760	        x_t: SparseColMatRef<'_, usize, f64>,
  2761	        weights: &Array1<f64>,
  2762	        p: usize,
  2763	        xtwx_symbolic: SymbolicSparseColMatRef<'_, usize>,
  2764	        xtwxvalues: &mut [f64],
  2765	    ) {
  2766	        let n = x_t.ncols();
  2767	        debug_assert_eq!(weights.len(), n);
  2768	        debug_assert_eq!(self.sqrt_weights.len(), n);
  2769	
  2770	        // Cache √max(0, w) once per row so the inner loops can multiply
  2771	        // without repeated sqrt calls. Single owning slice avoids ndarray
  2772	        // bounds checks in the hot loops below.
  2773	        let sqrt_w = self.sqrt_weights.as_mut_slice();
  2774	        for (dst, &w) in sqrt_w.iter_mut().zip(weights.iter()) {
  2775	            *dst = w.max(0.0).sqrt();
  2776	        }
  2777	        let sqrt_w: &[f64] = sqrt_w;
  2778	
  2779	        let x_ref = x.as_ref();
  2780	        // Right factor: √W · X, stored in X's CSC sparsity pattern.
  2781	        for col in 0..p {
  2782	            let rows = x_ref.row_idx_of_col_raw(col);
  2783	            let xvals = x_ref.val_of_col(col);
  2784	            let range = x_ref.col_range(col);
  2785	            let dst = &mut self.wxvalues[range];
  2786	            for ((d, &s), row) in dst.iter_mut().zip(xvals.iter()).zip(rows.iter()) {
  2787	                *d = s * sqrt_w[row.unbound()];
  2788	            }
  2789	        }
  2790	        // Left factor: (√W · X)ᵀ in X^T's CSC sparsity pattern. X^T's columns
  2791	        // correspond to rows of X, so each column scales by √w_row — read
  2792	        // straight from the cached slice with no per-column sqrt.
  2793	        for col in 0..n {
  2794	            let w = sqrt_w[col];
  2795	            let xvals = x_t.val_of_col(col);
  2796	            let range = x_t.col_range(col);
  2797	            let dst = &mut self.wx_tvalues[range];
  2798	            for (d, &s) in dst.iter_mut().zip(xvals.iter()) {
  2799	                *d = s * w;
  2800	            }
  2801	        }
  2802	
  2803	        let wx_ref = SparseColMatRef::new(x.symbolic(), &self.wxvalues[..]);
  2804	        let wx_t_ref = SparseColMatRef::new(x_t.symbolic(), &self.wx_tvalues[..]);
  2805	        let mut stack = MemStack::new(&mut self.scratch);
  2806	        let xtwxmut = SparseColMatMut::new(xtwx_symbolic, xtwxvalues);
  2807	        sparse_sparse_matmul_numeric(
  2808	            xtwxmut,
  2809	            Accum::Replace,
  2810	            wx_t_ref,
  2811	            wx_ref,
  2812	            1.0,
  2813	            &self.info,
  2814	            self.par,
  2815	            &mut stack,
  2816	        );
  2817	    }
  2818	}
  2819	
  2820	/// Accumulate the upper triangle of Σᵢ wᵢ · xᵢ xᵢᵀ over `rows` into `acc`.
  2821	///
  2822	/// `x_t` is Xᵀ in CSC: column i lists the nonzero columns of row i of X.
  2823	/// Faer's CSC convention stores these in ascending order, so iterating
  2824	/// `jj < kk` over per-row index pairs gives `j ≤ k` and only ever writes
  2825	/// to `acc[[j, k]]` with `j ≤ k` (the upper triangle, including the
  2826	/// diagonal at `jj == kk`).
  2827	///
  2828	/// Inner-loop layout: `acc` is row-major p×p, so row j lives in the
  2829	/// contiguous slice `acc_data[j·p .. (j+1)·p]`. We reborrow that slice once
  2830	/// per outer-product step — cheaper than ndarray's `row_mut(j).as_slice_mut()`
  2831	/// because it skips the per-call stride-validation and contiguity check.
  2832	#[inline]
  2833	fn accumulate_outer_upper(
  2834	    acc: &mut Array2<f64>,
  2835	    x_t: SparseColMatRef<'_, usize, f64>,
  2836	    weights: &Array1<f64>,
  2837	    rows: std::ops::Range<usize>,
  2838	) {
  2839	    debug_assert_eq!(acc.nrows(), acc.ncols());
  2840	    let p = acc.ncols();
