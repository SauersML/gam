  1284	fn add_reml_score_vjp(
  1285	    scale: f64,
  1286	    x: ArrayView2<'_, f64>,
  1287	    weights: &Array1<f64>,
  1288	    inverse_hessian: &Array2<f64>,
  1289	    beta: &Array2<f64>,
  1290	    residual: &Array2<f64>,
  1291	    sigma2: &Array1<f64>,
  1292	    nu: f64,
  1293	    lambda: f64,
  1294	    cache: &GaussianRemlEigenCache,
  1295	    grad_x: &mut Array2<f64>,
  1296	    grad_y: &mut Array2<f64>,
  1297	    grad_penalty: &mut Array2<f64>,
  1298	    grad_weights: &mut Array1<f64>,
  1299	) {
  1300	    let d = beta.ncols() as f64;
  1301	    let xp = dense_ab(x, inverse_hessian.view());
  1302	    let penalty_pinv = gaussian_reml_penalty_pseudoinverse_from_cache(cache);
  1303	    for row in 0..grad_penalty.nrows() {
  1304	        for col in 0..grad_penalty.ncols() {
  1305	            grad_penalty[[row, col]] +=
  1306	                scale * 0.5 * d * (lambda * inverse_hessian[[col, row]] - penalty_pinv[[col, row]]);
  1307	        }
  1308	    }
  1309	    for i in 0..x.nrows() {
  1310	        let wi = weights[i] * scale * d;
  1311	        for k in 0..x.ncols() {
  1312	            grad_x[[i, k]] += wi * xp[[i, k]];
  1313	        }
  1314	        let mut leverage = 0.0;
  1315	        for k in 0..x.ncols() {
  1316	            leverage += x[[i, k]] * xp[[i, k]];
  1317	        }
  1318	        grad_weights[i] += scale * 0.5 * d * leverage;
  1319	    }
  1320	
  1321	    for j in 0..beta.ncols() {
  1322	        let dp = (sigma2[j] * nu).max(MIN_DEVIANCE);
  1323	        let coef = scale * 0.5 * nu / dp;
  1324	        add_deviance_profile_vjp(
  1325	            coef,
  1326	            j,
  1327	            x,
  1328	            weights,
  1329	            beta,
  1330	            residual,
  1331	            grad_x,
  1332	            grad_y,
  1333	            grad_weights,
  1334	        );
  1335	        add_rank_one_penalty_vjp(coef * lambda, beta.column(j), grad_penalty);
  1336	    }
  1337	}
  1338	
  1339	/// VJP contribution from an upstream gradient on `edf`.
  1340	///
  1341	/// With `M = X^T W X + λ S`, `edf = trace(M^{-1} · X^T W X) = p - λ trace(M^{-1} S)`.
  1342	/// Holding `λ` fixed, the direct partials are
  1343	///   ∂edf/∂A = λ M^{-1} S M^{-1}      (A = X^T W X, symmetric)
  1344	///   ∂edf/∂S = −λ M^{-1} A M^{-1} = −λ M^{-1} + λ² M^{-1} S M^{-1}
  1345	///   ∂edf/∂λ = −trace(M^{-1} S) + λ trace((M^{-1} S)²)
  1346	/// The λ-component is returned as the lambda_adjoint contribution and routed
  1347	/// through the implicit-function chain by the caller (same path as
  1348	/// `upstream_lambda` and `upstream_reml_score`).
  1349	fn add_edf_vjp(
  1350	    scale: f64,
  1351	    x: ArrayView2<'_, f64>,
  1352	    penalty: ArrayView2<'_, f64>,
  1353	    weights: &Array1<f64>,
  1354	    lambda: f64,
  1355	    inverse_hessian: &Array2<f64>,
  1356	    grad_x: &mut Array2<f64>,
  1357	    grad_penalty: &mut Array2<f64>,
  1358	    grad_weights: &mut Array1<f64>,
  1359	) -> f64 {
  1360	    // m_inv_s = M^{-1} S, then g_a = λ M^{-1} S M^{-1} = ∂edf/∂A.
  1361	    let m_inv_s = dense_ab(inverse_hessian.view(), penalty);
  1362	    let mut g_a = dense_ab(m_inv_s.view(), inverse_hessian.view());
  1363	    g_a.mapv_inplace(|v| v * lambda);
  1364	
  1365	    // Chain ∂edf/∂A through A = X^T W X.
  1366	    //   grad_X += scale · 2 · (W X) · G_A
  1367	    //   grad_w_i += scale · (X G_A X^T)_{ii}
  1368	    let xg = dense_ab(x, g_a.view());
  1369	    for i in 0..x.nrows() {
  1370	        let row_scale = 2.0 * scale * weights[i];
  1371	        for k in 0..x.ncols() {
  1372	            grad_x[[i, k]] += row_scale * xg[[i, k]];
  1373	        }
  1374	        let mut quad = 0.0;
  1375	        for k in 0..x.ncols() {
  1376	            quad += x[[i, k]] * xg[[i, k]];
  1377	        }
  1378	        grad_weights[i] += scale * quad;
  1379	    }
  1380	
  1381	    // ∂edf/∂S = -λ M^{-1} + λ² M^{-1} S M^{-1} = -λ M^{-1} + λ · g_a
  1382	    // (since g_a = λ M^{-1} S M^{-1}, so λ · g_a = λ² M^{-1} S M^{-1}).
  1383	    for row in 0..grad_penalty.nrows() {
  1384	        for col in 0..grad_penalty.ncols() {
  1385	            grad_penalty[[row, col]] +=
  1386	                scale * (-lambda * inverse_hessian[[row, col]] + lambda * g_a[[row, col]]);
  1387	        }
  1388	    }
  1389	
  1390	    // ∂edf/∂λ (with A, S fixed) = -tr(M^{-1} S) + λ tr((M^{-1} S)²).
  1391	    let p_dim = m_inv_s.nrows();
  1392	    let mut tr_m_inv_s = 0.0;
  1393	    for i in 0..p_dim {
  1394	        tr_m_inv_s += m_inv_s[[i, i]];
  1395	    }
  1396	    let mut tr_squared = 0.0;
  1397	    for i in 0..p_dim {
  1398	        for j in 0..p_dim {
  1399	            tr_squared += m_inv_s[[i, j]] * m_inv_s[[j, i]];
  1400	        }
  1401	    }
  1402	    scale * (-tr_m_inv_s + lambda * tr_squared)
  1403	}
  1404	
  1405	fn add_reml_rho_gradient_vjp(
  1406	    scale: f64,
  1407	    x: ArrayView2<'_, f64>,
  1408	    y: ArrayView2<'_, f64>,
  1409	    penalty: ArrayView2<'_, f64>,
  1410	    weights: &Array1<f64>,
  1411	    lambda: f64,
  1412	    inverse_hessian: &Array2<f64>,
  1413	    beta: &Array2<f64>,
  1414	    residual: &Array2<f64>,
  1415	    sigma2: &Array1<f64>,
  1416	    nu: f64,
  1417	    grad_x: &mut Array2<f64>,
  1418	    grad_y: &mut Array2<f64>,
  1419	    grad_penalty: &mut Array2<f64>,
  1420	    grad_weights: &mut Array1<f64>,
  1421	) {
  1422	    let d = beta.ncols() as f64;
  1423	    let k_matrix = penalty.to_owned() * lambda;
  1424	    let inverse_k = dense_ab(inverse_hessian.view(), k_matrix.view());
  1425	    let trace_kernel = dense_ab(inverse_k.view(), inverse_hessian.view());
  1426	    for row in 0..grad_penalty.nrows() {
  1427	        for col in 0..grad_penalty.ncols() {
  1428	            grad_penalty[[row, col]] +=
  1429	                scale * 0.5 * d * lambda * (inverse_hessian[[col, row]] - trace_kernel[[col, row]]);
  1430	        }
  1431	    }
  1432	    let xt = dense_ab(x, trace_kernel.view());
  1433	    for i in 0..x.nrows() {
  1434	        let wi = -scale * d * weights[i];
  1435	        for k in 0..x.ncols() {
  1436	            grad_x[[i, k]] += wi * xt[[i, k]];
  1437	        }
  1438	        let mut quad = 0.0;
  1439	        for k in 0..x.ncols() {
  1440	            quad += x[[i, k]] * xt[[i, k]];
  1441	        }
  1442	        grad_weights[i] -= scale * 0.5 * d * quad;
  1443	    }
  1444	
  1445	    let k_beta = dense_ab(k_matrix.view(), beta.view());
  1446	    let mut upstream_beta = Array2::<f64>::zeros(beta.dim());
  1447	    for j in 0..beta.ncols() {
  1448	        let dp = (sigma2[j] * nu).max(MIN_DEVIANCE);
  1449	        let q = beta.column(j).dot(&k_beta.column(j));
  1450	        let q_coef = scale * nu / dp;
  1451	        for row in 0..beta.nrows() {
  1452	            upstream_beta[[row, j]] = q_coef * k_beta[[row, j]];
  1453	        }
  1454	        let dp_coef = -scale * 0.5 * nu * q / (dp * dp);
  1455	        add_rank_one_penalty_vjp(
  1456	            (0.5 * q_coef + dp_coef) * lambda,
  1457	            beta.column(j),
  1458	            grad_penalty,
  1459	        );
  1460	        add_deviance_profile_vjp(
  1461	            dp_coef,
  1462	            j,
  1463	            x,
  1464	            weights,
  1465	            beta,
  1466	            residual,
  1467	            grad_x,
  1468	            grad_y,
  1469	            grad_weights,
  1470	        );
  1471	    }
  1472	    let _ = add_ridge_profile_vjp(
  1473	        1.0,
  1474	        x,
  1475	        y,
  1476	        penalty,
  1477	        weights,
  1478	        lambda,
  1479	        inverse_hessian,
  1480	        beta,
  1481	        upstream_beta.view(),
  1482	        grad_x,
  1483	        grad_y,
  1484	        grad_penalty,
  1485	        grad_weights,
  1486	    );
  1487	}
  1488	
  1489	fn add_rank_one_penalty_vjp(
  1490	    scale: f64,
  1491	    beta_col: ArrayView1<'_, f64>,
  1492	    grad_penalty: &mut Array2<f64>,
  1493	) {
  1494	    for row in 0..beta_col.len() {
  1495	        for col in 0..beta_col.len() {
  1496	            grad_penalty[[row, col]] += scale * beta_col[row] * beta_col[col];
  1497	        }
  1498	    }
  1499	}
