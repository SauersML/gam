    75	#[inline]
    76	fn gamma_shape_score(shape: f64, target: f64) -> f64 {
    77	    shape.ln() - digamma(shape) - target
    78	}
    79	
    80	fn estimate_gamma_shape_from_eta(
    81	    y: ArrayView1<'_, f64>,
    82	    eta: &Array1<f64>,
    83	    priorweights: ArrayView1<'_, f64>,
    84	) -> f64 {
    85	    const EPS: f64 = 1e-12;
    86	
    87	    use rayon::iter::{IntoParallelIterator, ParallelIterator};
    88	    let (weighted_target, total_weight) = (0..eta.len())
    89	        .into_par_iter()
    90	        .map(|i| {
    91	            let wi = priorweights[i].max(0.0);
    92	            if wi == 0.0 {
    93	                return (0.0_f64, 0.0_f64);
    94	            }
    95	            let yi = y[i].max(EPS);
    96	            let mui = eta[i].clamp(-700.0, 700.0).exp().max(EPS);
    97	            let ratio = yi / mui;
    98	            (wi * (ratio - ratio.ln() - 1.0), wi)
    99	        })
   100	        .reduce(
   101	            || (0.0_f64, 0.0_f64),
   102	            |(t1, w1), (t2, w2)| (t1 + t2, w1 + w2),
   103	        );
   104	
   105	    if total_weight <= 0.0 {
   106	        return 1.0;
   107	    }
   108	
   109	    let target = (weighted_target / total_weight).max(0.0);
   110	    if target <= GAMMA_SHAPE_TARGET_TOL {
   111	        return GAMMA_SHAPE_MAX;
   112	    }
   113	
   114	    let discriminant = (target - 3.0) * (target - 3.0) + 24.0 * target;
   115	    let approx = ((3.0 - target) + discriminant.sqrt()) / (12.0 * target);
   116	    let mut lo = GAMMA_SHAPE_MIN;
   117	    let mut hi = approx.max(1.0);
   118	
   119	    while hi < GAMMA_SHAPE_MAX && gamma_shape_score(hi, target) > 0.0 {
   120	        hi = (hi * 2.0).min(GAMMA_SHAPE_MAX);
   121	    }
   122	    if gamma_shape_score(hi, target) > 0.0 {
   123	        return GAMMA_SHAPE_MAX;
   124	    }
   125	
   126	    for _ in 0..80 {
   127	        let mid = 0.5 * (lo + hi);
   128	        if gamma_shape_score(mid, target) > 0.0 {
   129	            lo = mid;
   130	        } else {
   131	            hi = mid;
   132	        }
   133	        if (hi - lo) <= GAMMA_SHAPE_TARGET_TOL * hi.max(1.0) {
   134	            break;
   135	        }
   136	    }
   137	
   138	    0.5 * (lo + hi)
   139	}
