   564	/// Result of a cheap LM-candidate screen: penalized objective + arithmetic
   565	/// finiteness, without the gradient/Hessian needed for an accepted step.
   566	#[derive(Debug, Clone)]
   567	pub struct CandidateScreen {
   568	    pub penalized_objective: f64,
   569	    pub deviance: f64,
   570	    pub penalty_term: f64,
   571	    pub arithmetic_finite: bool,
   572	}
   573	
   574	/// Outcome of `WorkingModel::screen_candidate`: either a cheap screen result
   575	/// (LM loop must upgrade with `update_with_curvature` on acceptance) or the
   576	/// full state when screening was not applicable.
   577	pub enum CandidateEvaluation {
   578	    Screen(CandidateScreen),
   579	    Full(WorkingState),
   580	}
   581	
   582	impl CandidateEvaluation {
   583	    #[inline]
   584	    fn penalized_objective(&self, firth_bias_reduction: bool) -> f64 {
   585	        match self {
   586	            Self::Screen(s) => s.penalized_objective,
   587	            Self::Full(state) => {
   588	                let mut value = state.deviance + state.penalty_term;
   589	                if firth_bias_reduction && let Some(j) = state.jeffreys_logdet() {
   590	                    value -= 2.0 * j;
   591	                }
   592	                value
   593	            }
   594	        }
   595	    }
   596	
   597	    #[inline]
   598	    fn arithmetic_finite(&self) -> bool {
   599	        match self {
   600	            Self::Screen(s) => s.arithmetic_finite,
   601	            Self::Full(state) => state.gradient.iter().all(|g| g.is_finite()),
   602	        }
   603	    }
   604	
   605	    #[inline]
   606	    fn into_full(self) -> Option<WorkingState> {
   607	        match self {
   608	            Self::Full(state) => Some(state),
   609	            Self::Screen(_) => None,
   610	        }
   611	    }
   612	}
