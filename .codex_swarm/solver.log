   113	//  Typed errors for the unified REML/LAML evaluator.
   114	//
   115	//  The evaluator and its helpers historically returned `Result<_, String>`.
   116	//  Internally we now build typed errors at the leaves and convert at the
   117	//  boundary via `From<RemlError> for String`, which is byte-equivalent to
   118	//  the previous `format!(...)` strings so external callers continue to see
   119	//  the same diagnostic text.
   120	// ═══════════════════════════════════════════════════════════════════════════
   121	
   122	/// Typed failure categories raised by the unified REML/LAML evaluator and
   123	/// its outer-Hessian / penalty-root helpers.
   124	///
   125	/// Each variant carries a pre-formatted `reason` string so that the
   126	/// `Display` impl is byte-equivalent to the original `format!(...)` text the
   127	/// module emitted before the typed-error migration. External signatures
   128	/// remain `Result<_, String>`; the boundary conversion goes through
   129	/// `From<RemlError> for String`.
   130	#[derive(Debug, Clone)]
   131	pub enum RemlError {
   132	    /// A length / shape disagreement between two views that should match
   133	    /// (penalty coords vs Hessian dim, residual length vs operator dim,
   134	    /// precomputed-correction count vs total, etc.).
   135	    DimensionMismatch { reason: String },
   136	    /// A scalar / vector / matrix entry that must be finite came back NaN
   137	    /// or ±∞ (cost, gradient entry, Hessian entry, cross-trace entry).
   138	    NonFiniteValue { reason: String },
   139	    /// A correction path was invoked against an operator kernel that does
   140	    /// not support it (scalar-only correction on a non-scalar kernel,
   141	    /// callback correction on a non-callback kernel).
   142	    InvalidKernelMode { reason: String },
   143	    /// A caller violated the evaluator contract. These are not numerical
   144	    /// failures; they mean an upstream solver presented an inner state with
   145	    /// insufficient certificates for the requested derivative surface.
   146	    ContractViolation { reason: String },
   147	}
   148	
   149	impl std::fmt::Display for RemlError {
   150	    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
   151	        match self {
   152	            RemlError::DimensionMismatch { reason }
   153	            | RemlError::NonFiniteValue { reason }
   154	            | RemlError::InvalidKernelMode { reason }
   155	            | RemlError::ContractViolation { reason } => f.write_str(reason),
   156	        }
   157	    }
   158	}
   159	
   160	impl std::error::Error for RemlError {}
   161	
   162	impl From<RemlError> for String {
   163	    fn from(err: RemlError) -> String {
   164	        err.to_string()
   165	    }
   166	}
