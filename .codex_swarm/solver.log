   862	    /// Scale-invariant relative gradient residual.
   863	    ///
   864	    /// Returns ||g||_2 / (1 + ||score||_2 + ||S*beta||_2 + ridge*||beta||_2).
   865	    /// `g_norm` is the projected/constrained stationarity residual in the
   866	    /// current PIRLS basis; the denominator is the natural magnitude of the
   867	    /// penalized gradient and is invariant under uniform rescaling of the
   868	    /// objective.
   869	    #[inline]
   870	    pub fn relative_gradient_norm(&self, g_norm: f64) -> f64 {
   871	        g_norm / (1.0 + self.gradient_natural_scale)
   872	    }
   873	
   874	    /// Dimension-based scale `√n · max(1, √p)` for the structural KKT bound.
   875	    ///
   876	    /// Under standardized columns, the score `Xᵀ(μ − y)` has components of
   877	    /// order O(√n), so the absolute test ‖g‖ < τ becomes systematically too
   878	    /// tight at large n. Multiplying τ by this scale restores the advertised
   879	    /// per-observation meaning.
   880	    #[inline]
   881	    fn kkt_dimension_scale(&self) -> f64 {
   882	        let n = self.eta.len().max(1) as f64;
   883	        let p = (self.gradient.len() as f64).max(1.0);
   884	        n.sqrt() * p.sqrt()
   885	    }
   886	
   887	    /// Strict KKT acceptance: `g_norm` certifies stationarity under EITHER
   888	    /// scale-invariant criterion (dimension-based or data-driven natural-scale).
   889	    ///
   890	    /// Both certificates are invariant under uniform rescaling of the objective
   891	    /// `F → c·F` (in the limit where the natural scale dominates the additive
   892	    /// `1` floor). Acceptance under either is sufficient because:
   893	    ///   - the natural-scale bound is tighter when the data are well-scaled
   894	    ///     (it tracks actual gradient component magnitudes);
   895	    ///   - the dimension bound is tighter when the design matrix has unusual
   896	    ///     scaling (so the natural scale is dominated by a single component).
   897	    #[inline]
   898	    pub fn certifies_kkt(&self, g_norm: f64, tol: f64) -> bool {
   899	        g_norm < tol * self.kkt_dimension_scale() || self.relative_gradient_norm(g_norm) < tol
   900	    }
   901	
   902	    /// Near-stationary band (10× the strict KKT tolerance) under EITHER
   903	    /// scale-invariant criterion. Used as a "good-enough" plateau check
   904	    /// that classifies a fit as `StalledAtValidMinimum` rather than as a
   905	    /// hard non-convergence. The band is `10 · tol` without a
   906	    /// floor — a caller asking for `tol = 1e-12` gets a 1e-11 band, not
   907	    /// the 1e-5 the old `tol.max(1e-6) * 10` formula silently widened it
   908	    /// to. The 1e-6 floor was masking real convergence regressions
   909	    /// (e.g. `constant_prior_mean_centers_penalty`'s LM-ridge induced
   910	    /// 2.5e-8 bias visible only when the user asked for sub-1e-6
   911	    /// precision).
   912	    #[inline]
   913	    pub fn near_stationary_kkt(&self, g_norm: f64, tol: f64) -> bool {
   914	        let near_tol = tol * 10.0;
   915	        g_norm <= near_tol * self.kkt_dimension_scale()
   916	            || self.relative_gradient_norm(g_norm) <= near_tol
   917	    }
   918	}
