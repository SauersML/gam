   973	    let q = e.hypot(1.0);
   974	    let inv_q = 1.0 / q;
   975	    let r1 = delta * inv_q;
   976	    let u1 = g1 * r1;
   977	    let z1 = c * u1;
   978	    // `mu = Phi(z)` and `d1 = phi(z) * z1`, the same closed forms used by the
   979	    // full jet via `chain_inverse_link_jet(probit_jet(z), z1, _, _)`.
   980	    let base = probit_jet(z);
   981	    (base.mu, canonicalzero(base.d1 * z1))
   982	}
