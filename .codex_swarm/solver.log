  1053	fn inverse_link_pdf_derivative_for_inverse_link(
  1054	    link: &InverseLink,
  1055	    eta: f64,
  1056	    order: PdfDerivativeOrder,
  1057	) -> Result<f64, EstimationError> {
  1058	    match link {
  1059	        InverseLink::Standard(LinkFunction::Identity) => Ok(0.0),
  1060	        InverseLink::Standard(LinkFunction::Log) => Ok(eta.clamp(-700.0, 700.0).exp()),
  1061	        InverseLink::Standard(LinkFunction::Probit) => Ok(order.probit(eta)),
  1062	        InverseLink::Standard(LinkFunction::Logit) => {
  1063	            Ok(order.component(LinkComponent::Logit, eta))
  1064	        }
  1065	        InverseLink::Standard(LinkFunction::CLogLog) => {
  1066	            Ok(order.component(LinkComponent::CLogLog, eta))
  1067	        }
  1068	        InverseLink::LatentCLogLog(state) => order.latent_cloglog(eta, state.latent_sd),
  1069	        InverseLink::Standard(LinkFunction::Sas) => Ok(order.sas(eta, 0.0, 0.0)),
  1070	        InverseLink::Sas(state) => Ok(order.sas(eta, state.epsilon, state.log_delta)),
  1071	        InverseLink::Standard(LinkFunction::BetaLogistic) => Ok(order.beta_logistic(eta, 0.0, 0.0)),
  1072	        InverseLink::BetaLogistic(state) => {
  1073	            Ok(order.beta_logistic(eta, state.log_delta, state.epsilon))
  1074	        }
  1075	        InverseLink::Mixture(state) => Ok(state
  1076	            .components
  1077	            .iter()
  1078	            .zip(state.pi.iter())
  1079	            .map(|(&component, &weight)| weight * order.component(component, eta))
  1080	            .sum()),
  1081	    }
  1082	}
