   690	        &self,
   691	        h_i: &dyn HyperOperator,
   692	        h_j: &dyn HyperOperator,
   693	    ) -> f64 {
   694	        self.trace_logdet_hessian_cross(&h_i.to_dense(), &h_j.to_dense())
   695	    }
