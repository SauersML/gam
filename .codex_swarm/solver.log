   191	    /// Gamma(shape, rate) conjugate hyperprior on the precision lambda = exp(rho).
   192	    ///
   193	    /// The REML/LAML objective is minimized, so this contributes
   194	    /// `rate * exp(rho) - (shape - 1) * rho` up to an additive constant. For a
   195	    /// block with effective dimension n_p and centered quadratic
   196	    /// `(beta - mu)'S_p(beta - mu)`, the conditional posterior is
   197	    /// `Gamma(shape + n_p/2, rate + quadratic/2)` and the closed-form MAP
   198	    /// precision is `(shape + n_p/2 - 1) / (rate + quadratic/2)`.
   199	    /// `Gamma(1, 0)` is the explicit flat/default case and reproduces the
   200	    /// current MacKay/Tipping fixed point.
   201	    GammaPrecision {
   202	        shape: f64,
   203	        rate: f64,
   204	    },
   205	    /// Coordinate-specific priors for models whose smoothing parameters do
   206	    /// not share one prior family, such as nested coefficient groups.
   207	    Independent(Vec<RhoPrior>),
   208	}
