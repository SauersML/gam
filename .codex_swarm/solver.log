     9	#[derive(Clone, Debug)]
    10	pub struct LinearInequalityConstraints {
    11	    pub a: Array2<f64>,
    12	    pub b: Array1<f64>,
    13	}
    14	
    15	impl LinearInequalityConstraints {
    16	    /// Construct with the equal-row-count invariant enforced. The dimensions
    17	    /// `a.nrows() == b.len()` are required by every downstream KKT / active-set
    18	    /// routine; routing every construction site through this constructor
    19	    /// eliminates a class of "rows out of sync" bugs at the type boundary.
    20	    #[inline]
    21	    pub fn new(a: Array2<f64>, b: Array1<f64>) -> Result<Self, String> {
    22	        if a.nrows() != b.len() {
    23	            return Err(format!(
    24	                "LinearInequalityConstraints: row count mismatch (A has {} rows, b has length {})",
    25	                a.nrows(),
    26	                b.len(),
    27	            ));
    28	        }
    29	        Ok(Self { a, b })
    30	    }
    31	
    32	    /// Internal helper for sites that have *just* produced `(a, b)` with the
    33	    /// invariant guaranteed (e.g. via a row-by-row push loop). Skips the
    34	    /// runtime length check; callers that aren't in that position must use
    35	    /// [`Self::new`] instead.
    36	    #[inline]
    37	    pub(crate) fn from_paired(a: Array2<f64>, b: Array1<f64>) -> Self {
    38	        debug_assert_eq!(a.nrows(), b.len(), "paired constraint shape invariant");
    39	        Self { a, b }
    40	    }
    41	
    42	    /// Build the per-coordinate `β_i ≥ lower_bounds[i]` inequality system.
    43	    /// Non-finite entries are treated as "no bound" and skipped; returns
    44	    /// `None` when every entry is non-finite so callers can short-circuit
    45	    /// the no-constraint case without allocating the empty A/b pair.
    46	    pub fn from_per_coordinate_lower_bounds(lower_bounds: &Array1<f64>) -> Option<Self> {
    47	        let active_rows: Vec<usize> = (0..lower_bounds.len())
    48	            .filter(|&i| lower_bounds[i].is_finite())
    49	            .collect();
    50	        if active_rows.is_empty() {
    51	            return None;
    52	        }
    53	        let p = lower_bounds.len();
    54	        let mut a = Array2::<f64>::zeros((active_rows.len(), p));
    55	        let mut b = Array1::<f64>::zeros(active_rows.len());
    56	        for (r, &idx) in active_rows.iter().enumerate() {
    57	            a[[r, idx]] = 1.0;
    58	            b[r] = lower_bounds[idx];
    59	        }
    60	        Some(Self::from_paired(a, b))
    61	    }
    62	}
