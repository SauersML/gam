  1081	fn rho_derivatives_to_lambda(lambda: f64, grad_rho: f64, hess_rho: f64) -> (f64, f64) {
  1082	    (grad_rho / lambda, (hess_rho - grad_rho) / (lambda * lambda))
  1083	}
