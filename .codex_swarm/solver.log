   773	    }
   774	    let weight = gaussian_reml_weights(n, weights)?;
   775	    let inverse_hessian = match gaussian_reml_inverse_hessian_from_cache(&fit.cache, lambda) {
   776	        Ok(inv) => inv,
   777	        Err(EstimationError::ModelIsIllConditioned { condition_number }) => {
   778	            warn_ill_conditioned_backward_once(p, d, condition_number);
   779	            return Ok(zero_backward_result(n, p, d));
   780	        }
   781	        Err(err) => return Err(err),
   782	    };
   783	    gaussian_reml_multi_closed_form_backward_from_fit_with_inverse_hessian_impl(
   784	        x,
   785	        y,
   786	        penalty,
