   268	impl PenaltySpec {
   269	    /// The column range this penalty covers.
   270	    /// For `Dense`, this is `0..p` where `p = m.ncols()`.
   271	    pub fn col_range(&self, p: usize) -> Range<usize> {
   272	        match self {
   273	            PenaltySpec::Block { col_range, .. } => col_range.clone(),
   274	            PenaltySpec::Dense(m) => {
   275	                debug_assert_eq!(m.ncols(), p);
   276	                0..p
   277	            }
   278	            PenaltySpec::DenseWithMean { matrix, .. } => {
   279	                debug_assert_eq!(matrix.ncols(), p);
   280	                0..p
   281	            }
   282	        }
   283	    }
   284	
   285	    /// Op-form handle when present (only for `Block`; `Dense` always returns `None`).
   286	    pub fn op(&self) -> Option<&std::sync::Arc<dyn crate::terms::penalty_op::PenaltyOp>> {
   287	        match self {
   288	            PenaltySpec::Block { op, .. } => op.as_ref(),
   289	            PenaltySpec::Dense(_) | PenaltySpec::DenseWithMean { .. } => None,
   290	        }
   291	    }
   292	
   293	    /// Convert from a `BlockwisePenalty`, preserving the structure hint and op.
   294	    pub fn from_blockwise(bp: crate::terms::smooth::BlockwisePenalty) -> Self {
   295	        PenaltySpec::Block {
   296	            local: bp.local,
   297	            col_range: bp.col_range,
   298	            prior_mean: bp.prior_mean,
   299	            structure_hint: bp.structure_hint,
   300	            op: bp.op,
   301	        }
   302	    }
   303	
   304	    pub fn from_blockwise_ref(bp: &crate::terms::smooth::BlockwisePenalty) -> Self {
   305	        PenaltySpec::Block {
   306	            local: bp.local.clone(),
   307	            col_range: bp.col_range.clone(),
   308	            prior_mean: bp.prior_mean.clone(),
   309	            structure_hint: bp.structure_hint.clone(),
   310	            op: bp.op.clone(),
   311	        }
   312	    }
   313	
   314	    /// Materialize the full `p x p` dense penalty matrix.
   315	    /// For `Dense`, this is a clone.  For `Block`, this embeds `local` into a
   316	    /// zero matrix at the given `col_range`.
   317	    pub fn to_dense(&self) -> Array2<f64> {
   318	        match self {
   319	            PenaltySpec::Dense(m) => m.clone(),
   320	            PenaltySpec::DenseWithMean { matrix, .. } => matrix.clone(),
   321	            PenaltySpec::Block {
   322	                local, col_range, ..
   323	            } => {
   324	                let p = col_range.end.max(local.nrows());
   325	                // Caller should supply p externally when the total dim is larger;
   326	                // this is the best we can do without it.
   327	                let mut out = Array2::zeros((p, p));
   328	                out.slice_mut(s![col_range.clone(), col_range.clone()])
   329	                    .assign(local);
   330	                out
   331	            }
   332	        }
   333	    }
   334	
   335	    /// Materialize the full `p_total x p_total` dense penalty matrix.
   336	    /// For `Dense`, this is a clone (asserts that it matches `p_total`).
   337	    /// For `Block`, this embeds `local` into a `p_total x p_total` zero matrix.
   338	    pub fn to_global(&self, p_total: usize) -> Array2<f64> {
   339	        match self {
   340	            PenaltySpec::Dense(m) => {
   341	                debug_assert_eq!(m.nrows(), p_total);
   342	                m.clone()
   343	            }
   344	            PenaltySpec::DenseWithMean { matrix, .. } => {
   345	                debug_assert_eq!(matrix.nrows(), p_total);
   346	                matrix.clone()
   347	            }
   348	            PenaltySpec::Block {
   349	                local, col_range, ..
   350	            } => {
   351	                let mut out = Array2::zeros((p_total, p_total));
   352	                out.slice_mut(s![col_range.clone(), col_range.clone()])
   353	                    .assign(local);
   354	                out
   355	            }
   356	        }
   357	    }
   358	}
