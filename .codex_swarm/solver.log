  1084	pub fn inverse_link_pdfthird_derivative_for_inverse_link(
  1085	    link: &InverseLink,
  1086	    eta: f64,
  1087	) -> Result<f64, EstimationError> {
  1088	    // This dispatch returns the fourth eta-derivative of the inverse-link CDF,
  1089	    // equivalently the third derivative of the inverse-link density
  1090	    //
  1091	    //   f(eta) = d/deta mu(eta).
  1092	    //
  1093	    // It is used downstream as the `f'''` input in
  1094	    //
  1095	    //   d³/deta³ log f = f'''/f - 3 f'f''/f² + 2(f')³/f³.
  1096	    //
  1097	    // Mixture links preserve linearity:
  1098	    //
  1099	    //   mu = sum_j pi_j mu_j
  1100	    //   => f''' = sum_j pi_j f_j'''
  1101	    //
  1102	    // because the mixture weights `pi_j` are constant with respect to `eta`.
  1103	    inverse_link_pdf_derivative_for_inverse_link(link, eta, PdfDerivativeOrder::Third)
  1104	}
