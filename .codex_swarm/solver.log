  1269	/// Computes mixture jet and exact partial derivatives wrt free softmax logits.
  1270	///
  1271	/// Uses identities:
  1272	///   d mu     / d rho_j = pi_j (mu_j     - mu)
  1273	///   d mu'    / d rho_j = pi_j (mu_j'    - mu')
  1274	///   d mu''   / d rho_j = pi_j (mu_j''   - mu'')
  1275	///   d mu'''  / d rho_j = pi_j (mu_j'''  - mu''')
  1276	pub fn mixture_inverse_link_jetwith_rho_partials(
  1277	    state: &MixtureLinkState,
  1278	    eta: f64,
  1279	) -> MixtureJetWithRhoPartials {
  1280	    let k = state.components.len().min(state.pi.len());
  1281	    let m = k.saturating_sub(1);
  1282	    let mut djet_drho = vec![
  1283	        InverseLinkJet {
  1284	            mu: 0.0,
  1285	            d1: 0.0,
  1286	            d2: 0.0,
  1287	            d3: 0.0,
  1288	        };
  1289	        m
  1290	    ];
  1291	    let jet = mixture_inverse_link_jetwith_rho_partials_into(state, eta, &mut djet_drho);
  1292	    MixtureJetWithRhoPartials { jet, djet_drho }
  1293	}
  1294	
  1295	/// Computes mixture jet and writes exact rho partial jets into `out` (length >= K-1).
  1296	/// This avoids heap allocation in hot loops.
  1297	pub fn mixture_inverse_link_jetwith_rho_partials_into(
  1298	    state: &MixtureLinkState,
  1299	    eta: f64,
  1300	    out: &mut [InverseLinkJet],
  1301	) -> InverseLinkJet {
  1302	    let k = state.components.len().min(state.pi.len());
  1303	    let m = k.saturating_sub(1);
  1304	    assert!(
  1305	        out.len() >= m,
  1306	        "rho-partial output buffer too small: got {}, need {}",
  1307	        out.len(),
  1308	        m
  1309	    );
  1310	    let mut mixed = InverseLinkJet {
  1311	        mu: 0.0,
  1312	        d1: 0.0,
  1313	        d2: 0.0,
  1314	        d3: 0.0,
  1315	    };
  1316	    for i in 0..k {
  1317	        let jet_i = component_inverse_link_jet(state.components[i], eta);
  1318	        let w = state.pi[i];
  1319	        mixed.mu += w * jet_i.mu;
  1320	        mixed.d1 += w * jet_i.d1;
  1321	        mixed.d2 += w * jet_i.d2;
  1322	        mixed.d3 += w * jet_i.d3;
  1323	        // Cache the first K-1 component jets directly in the output buffer so
  1324	        // we don't recompute them in the partial loop.
  1325	        if i < m {
  1326	            out[i] = jet_i;
  1327	        }
  1328	    }
  1329	    for j in 0..m {
  1330	        let pi_j = state.pi[j];
  1331	        let cj = out[j];
  1332	        out[j] = InverseLinkJet {
  1333	            mu: pi_j * (cj.mu - mixed.mu),
  1334	            d1: pi_j * (cj.d1 - mixed.d1),
  1335	            d2: pi_j * (cj.d2 - mixed.d2),
  1336	            d3: pi_j * (cj.d3 - mixed.d3),
  1337	        };
  1338	    }
  1339	    mixed
  1340	}
