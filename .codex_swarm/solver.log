  1140	#[inline]
  1141	fn royston_parmar_inverse_link_jet(eta: f64) -> InverseLinkJet {
  1142	    // ApproxKind: NumericalApproximation — exp(exp(eta)) overflows f64 for
  1143	    // eta > ~3.7; the |eta| > 30 saturation tail returns survival ≈ 0 with
  1144	    // d_k = 0, matching the analytic limit to within IEEE-754 underflow.
  1145	    const SURVIVAL_ETA_CLAMP: f64 = 30.0;
  1146	
  1147	    let z = eta.clamp(-SURVIVAL_ETA_CLAMP, SURVIVAL_ETA_CLAMP);
  1148	    let hazard = z.exp();
  1149	    let survival = (-hazard).exp();
  1150	    if eta < -SURVIVAL_ETA_CLAMP || eta > SURVIVAL_ETA_CLAMP {
  1151	        return InverseLinkJet {
  1152	            mu: survival,
  1153	            d1: 0.0,
  1154	            d2: 0.0,
  1155	            d3: 0.0,
  1156	        };
  1157	    }
  1158	
  1159	    let d1 = -hazard * survival;
  1160	    let d2 = hazard * (hazard - 1.0) * survival;
  1161	    let d3 = (-hazard * hazard * hazard + 3.0 * hazard * hazard - hazard) * survival;
  1162	    InverseLinkJet {
  1163	        mu: survival,
  1164	        d1,
  1165	        d2,
  1166	        d3,
  1167	    }
  1168	}
