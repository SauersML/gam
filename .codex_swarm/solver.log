  1769	                PirlsCoordinateFrame::TransformedQs
  1770	            }
  1771	        };
  1772	        GamModelFinalState {
  1773	            likelihood: self.likelihood,
  1774	            coordinate_frame,
  1775	            finalmu: lastmu,
  1776	            finalweights: lasthessian_weights,
  1777	            scoreweights: lastweights,
  1778	            finalz: lastz,
  1779	            final_c: lasthessian_c,
  1780	            final_d: lasthessian_d,
  1781	            final_dmu_deta: last_dmu_deta,
  1782	            final_d2mu_deta2: last_d2mu_deta2,
