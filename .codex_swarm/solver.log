  1106	/// Fifth derivative of the inverse-link CDF (= fourth derivative of the PDF).
  1107	///
  1108	/// Extends `inverse_link_pdfthird_derivative_for_inverse_link` by one order.
  1109	/// Used for the outer REML Hessian Q[v_k, v_l] term in survival models,
  1110	/// specifically the `m1 * u_{abcd}` Arbogast contribution.
  1111	pub fn inverse_link_pdffourth_derivative_for_inverse_link(
  1112	    link: &InverseLink,
  1113	    eta: f64,
  1114	) -> Result<f64, EstimationError> {
  1115	    inverse_link_pdf_derivative_for_inverse_link(link, eta, PdfDerivativeOrder::Fourth)
  1116	}
