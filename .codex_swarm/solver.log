    63	/// Check whether penalty ranges decompose into independent exact blocks.
    64	///
    65	/// Multiple smoothing components may share the same block (for example tensor
    66	/// product marginals); those can still be factorized block-local.  Only partial
    67	/// overlaps force the dense assembled fallback.
    68	fn are_penalties_block_factored(penalties: &[crate::construction::CanonicalPenalty]) -> bool {
    69	    for (i, a) in penalties.iter().enumerate() {
    70	        for b in &penalties[i + 1..] {
    71	            let overlaps =
    72	                a.col_range.start < b.col_range.end && b.col_range.start < a.col_range.end;
    73	            let same_range =
    74	                a.col_range.start == b.col_range.start && a.col_range.end == b.col_range.end;
    75	            if overlaps && !same_range {
    76	                return false;
    77	            }
    78	        }
    79	    }
    80	    true
    81	}
