  9672	#[derive(Clone)]
  9673	pub enum DirectionalWorkingCurvature {
  9674	    /// Directional derivative of the PIRLS curvature when the working
  9675	    /// curvature is diagonal in observation space:
  9676	    ///   W_τ = diag(w_τ).
  9677	    Diagonal(Array1<f64>),
  9678	}
  9679	
  9680	pub fn directionalworking_curvature_from_c_array(
  9681	    c_array: &Array1<f64>,
  9682	    hessian_weights: &Array1<f64>,
  9683	    eta_direction: &Array1<f64>,
  9684	) -> DirectionalWorkingCurvature {
  9685	    let mut w_direction = c_array * eta_direction;
  9686	    for i in 0..w_direction.len() {
  9687	        if hessian_weights[i] <= 0.0 || !w_direction[i].is_finite() {
  9688	            w_direction[i] = 0.0;
  9689	        }
  9690	    }
  9691	    DirectionalWorkingCurvature::Diagonal(w_direction)
  9692	}
