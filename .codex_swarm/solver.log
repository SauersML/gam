   141	#[inline]
   142	fn gamma_loglikelihood_with_shape(
   143	    y: ArrayView1<'_, f64>,
   144	    mu: &Array1<f64>,
   145	    priorweights: ArrayView1<'_, f64>,
   146	    shape: f64,
   147	) -> f64 {
   148	    const EPS: f64 = 1e-12;
   149	    use rayon::iter::{IntoParallelIterator, ParallelIterator};
   150	    let shape_c = shape.clamp(GAMMA_SHAPE_MIN, GAMMA_SHAPE_MAX);
   151	    let shape_ln = shape_c.ln();
   152	    let ln_gamma_shape = ln_gamma(shape_c);
   153	    (0..y.len())
   154	        .into_par_iter()
   155	        .map(|i| {
   156	            let yi_c = y[i].max(EPS);
   157	            let mui_c = mu[i].max(EPS);
   158	            priorweights[i]
   159	                * (shape_c * shape_ln - ln_gamma_shape - shape_c * mui_c.ln()
   160	                    + (shape_c - 1.0) * yi_c.ln()
   161	                    - shape_c * yi_c / mui_c)
   162	        })
   163	        .sum()
   164	}
