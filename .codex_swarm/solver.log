   123	fn solve_symmetric_system(
   124	    matrix: &Array2<f64>,
   125	    rhs: &Array1<f64>,
   126	    out: &mut Array1<f64>,
   127	) -> Result<(), EstimationError> {
   128	    if out.len() != rhs.len() {
   129	        *out = Array1::zeros(rhs.len());
   130	    }
   131	    out.assign(rhs);
   132	    let factor = StableSolver::new("active-set symmetric system")
   133	        .factorize(matrix)
   134	        .map_err(|_| {
   135	            EstimationError::InvalidInput("symmetric system factorization failed".to_string())
   136	        })?;
   137	    out.assign(rhs);
   138	    let mut rhsview = array1_to_col_matmut(out);
   139	    factor.solve_in_place(rhsview.as_mut());
   140	    if array1_is_finite(out) {
   141	        return Ok(());
   142	    }
   143	    Err(EstimationError::InvalidInput(
   144	        "symmetric system solve produced non-finite values".to_string(),
   145	    ))
   146	}
   147	
   148	fn solve_dense_system_via_pseudoinverse(
   149	    matrix: &Array2<f64>,
   150	    rhs: &Array1<f64>,
   151	    out: &mut Array1<f64>,
   152	) -> Result<(), EstimationError> {
   153	    if matrix.nrows() != matrix.ncols() || rhs.len() != matrix.nrows() {
   154	        return Err(EstimationError::InvalidInput(
   155	            "dense pseudoinverse solve dimension mismatch".to_string(),
   156	        ));
   157	    }
   158	
   159	    let (u_opt, singular, vt_opt) = matrix.svd(true, true).map_err(|_| {
   160	        EstimationError::InvalidInput("dense pseudoinverse solve SVD failed".to_string())
   161	    })?;
   162	    let (Some(u), Some(vt)) = (u_opt, vt_opt) else {
   163	        return Err(EstimationError::InvalidInput(
   164	            "dense pseudoinverse solve missing singular vectors".to_string(),
   165	        ));
   166	    };
   167	
   168	    let max_singular = singular.iter().fold(0.0_f64, |acc, &v| acc.max(v.abs()));
   169	    let tol = 100.0
   170	        * f64::EPSILON
   171	        * (matrix.nrows().max(matrix.ncols()).max(1) as f64)
   172	        * max_singular.max(1.0);
   173	    let mut coeff = u.t().dot(rhs);
   174	    for (idx, value) in coeff.iter_mut().enumerate() {
   175	        let sigma = singular[idx];
   176	        if sigma.abs() > tol {
   177	            *value /= sigma;
   178	        } else {
   179	            *value = 0.0;
   180	        }
   181	    }
   182	    let solution = vt.t().dot(&coeff);
   183	    if !array1_is_finite(&solution) {
   184	        return Err(EstimationError::InvalidInput(
   185	            "dense pseudoinverse solve produced non-finite values".to_string(),
   186	        ));
   187	    }
   188	    if out.len() != solution.len() {
   189	        *out = Array1::zeros(solution.len());
   190	    }
   191	    out.assign(&solution);
   192	    Ok(())
   193	}
