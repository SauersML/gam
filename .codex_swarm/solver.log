   581	pub fn gaussian_reml_free_b_score(
   582	    x: ArrayView2<'_, f64>,
   583	    y: ArrayView2<'_, f64>,
   584	    coefficients: ArrayView2<'_, f64>,
   585	    log_lambda: f64,
   586	    penalty: ArrayView2<'_, f64>,
   587	    weights: Option<ArrayView1<'_, f64>>,
   588	) -> Result<GaussianRemlFreeBScore, EstimationError> {
   589	    if !log_lambda.is_finite() {
   590	        return Err(EstimationError::InvalidInput(format!(
   591	            "Gaussian REML log_lambda must be finite; got {log_lambda}"
   592	        )));
   593	    }
   594	    let lambda = log_lambda.exp();
   595	    let penalty_owned = canonicalize_penalty(penalty);
   596	    let penalty = penalty_owned.view();
   597	    let n = x.nrows();
   598	    let p = x.ncols();
   599	    let d = y.ncols();
   600	    validate_gaussian_reml_design(x, penalty, weights)?;
   601	    if y.nrows() != n {
   602	        return Err(EstimationError::InvalidInput(format!(
   603	            "Gaussian REML row mismatch: X has {n} rows but Y has {}",
   604	            y.nrows()
   605	        )));
   606	    }
   607	    if coefficients.dim() != (p, d) {
   608	        return Err(EstimationError::InvalidInput(format!(
   609	            "Gaussian REML coefficient shape mismatch: expected {p}x{d}, got {}x{}",
   610	            coefficients.nrows(),
   611	            coefficients.ncols()
   612	        )));
   613	    }
   614	    if y.iter().chain(coefficients.iter()).any(|v| !v.is_finite()) {
   615	        return Err(EstimationError::InvalidInput(
   616	            "Gaussian REML inputs must be finite".to_string(),
   617	        ));
   618	    }
   619	
   620	    let weight = gaussian_reml_weights(n, weights)?;
   621	    let cache =
   622	        build_gaussian_reml_eigen_cache_with_nullspace_dim(x, penalty, None, Some(weight.view()))?;
   623	    if n <= cache.nullity {
   624	        return Err(EstimationError::InvalidInput(format!(
   625	            "Gaussian REML requires n > nullspace dimension; got n={n}, nullity={}",
   626	            cache.nullity
   627	        )));
   628	    }
   629	    let nu = n as f64 - cache.nullity as f64;
   630	    let fitted = dense_ab(x, coefficients);
   631	    let residual = y.to_owned() - &fitted;
   632	    let xtw_residual = dense_xt_diag_y(x, weight.view(), residual.view());
   633	    let s_beta = dense_ab(penalty, coefficients);
   634	
   635	    let mut logdet_h = cache.logdet_xtwx;
   636	    let mut trace_h = 0.0;
   637	    let mut edf = 0.0;
   638	    for &delta in &cache.penalty_eigenvalues {
   639	        let t = lambda * delta;
   640	        logdet_h += (1.0 + t).ln();
   641	        if delta > 0.0 {
   642	            trace_h += t / (1.0 + t);
   643	        }
   644	        edf += 1.0 / (1.0 + t);
   645	    }
   646	    let logdet_s = cache.logdet_penalty_positive + (cache.penalty_rank as f64) * log_lambda;
   647	    let mut reml_score = 0.5 * (d as f64) * (logdet_h - logdet_s);
   648	    let mut grad_log_lambda = 0.5 * (d as f64) * (trace_h - cache.penalty_rank as f64);
   649	    let mut grad_coefficients = Array2::<f64>::zeros((p, d));
   650	    let inverse_hessian = {
   651	        let xtwx = dense_xt_diag_x(x, weight.view());
   652	        let mut hessian = xtwx;
   653	        hessian += &(penalty.to_owned() * lambda);
   654	        hessian
   655	            .cholesky(Side::Lower)
   656	            .map_err(EstimationError::LinearSystemSolveFailed)?
   657	            .solve_mat(&Array2::<f64>::eye(p))
   658	    };
   659	    let penalty_pinv = gaussian_reml_penalty_pseudoinverse_from_cache(&cache);
   660	    let mut grad_penalty = Array2::<f64>::zeros((p, p));
   661	    for row in 0..p {
   662	        for col in 0..p {
   663	            grad_penalty[[row, col]] += 0.5
   664	                * (d as f64)
   665	                * (lambda * inverse_hessian[[col, row]] - penalty_pinv[[col, row]]);
   666	        }
   667	    }
   668	    let mut sigma2 = Array1::<f64>::zeros(d);
   669	
   670	    for output in 0..d {
   671	        let mut weighted_rss = 0.0;
   672	        for row in 0..n {
   673	            let r = residual[[row, output]];
   674	            weighted_rss += weight[row] * r * r;
   675	        }
   676	        let beta_col = coefficients.column(output);
   677	        let s_beta_col = s_beta.column(output);
   678	        let penalty_quadratic = beta_col.dot(&s_beta_col);
   679	        let dp = (weighted_rss + lambda * penalty_quadratic).max(MIN_DEVIANCE);
   680	        sigma2[output] = dp / nu;
   681	        reml_score += 0.5 * nu * (1.0 + (2.0 * std::f64::consts::PI * dp / nu).ln());
   682	        grad_log_lambda += 0.5 * nu * lambda * penalty_quadratic / dp;
   683	        let scale = nu / dp;
   684	        for coeff in 0..p {
   685	            grad_coefficients[[coeff, output]] =
   686	                scale * (-xtw_residual[[coeff, output]] + lambda * s_beta[[coeff, output]]);
   687	        }
   688	        add_rank_one_penalty_vjp(0.5 * scale * lambda, beta_col, &mut grad_penalty);
   689	    }
   690	    for i in 0..p {
   691	        for j in (i + 1)..p {
   692	            let avg = 0.5 * (grad_penalty[[i, j]] + grad_penalty[[j, i]]);
   693	            grad_penalty[[i, j]] = avg;
   694	            grad_penalty[[j, i]] = avg;
   695	        }
   696	    }
   697	
   698	    Ok(GaussianRemlFreeBScore {
   699	        reml_score,
   700	        grad_coefficients,
   701	        grad_penalty,
   702	        grad_log_lambda,
   703	        fitted,
   704	        sigma2,
   705	        edf,
   706	    })
   707	}
