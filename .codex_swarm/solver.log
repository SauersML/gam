   282	pub(crate) struct SparsePenalizedSystemStats {
   283	    pub(crate) nnz_xtwx_symbolic: usize,
   284	    pub(crate) nnz_s_lambda_upper: usize,
   285	    pub(crate) nnz_h_upper: usize,
   286	    pub(crate) density_upper: f64,
