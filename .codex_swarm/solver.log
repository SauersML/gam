  9092	fn fixed_glm_dispersion(likelihood: GlmLikelihoodSpec) -> f64 {
  9093	    likelihood.fixed_phi().unwrap_or(1.0)
  9094	}
  9095	
  9096	#[inline]
  9097	pub fn weight_family_for_glm_likelihood(likelihood: GlmLikelihoodSpec) -> WeightFamily {
  9098	    match likelihood.family {
  9099	        GlmLikelihoodFamily::GaussianIdentity => WeightFamily::Gaussian,
  9100	        GlmLikelihoodFamily::PoissonLog => WeightFamily::Poisson,
  9101	        GlmLikelihoodFamily::GammaLog => WeightFamily::Gamma,
  9102	        GlmLikelihoodFamily::BinomialLogit
  9103	        | GlmLikelihoodFamily::BinomialProbit
  9104	        | GlmLikelihoodFamily::BinomialCLogLog
  9105	        | GlmLikelihoodFamily::BinomialSas
  9106	        | GlmLikelihoodFamily::BinomialBetaLogistic
  9107	        | GlmLikelihoodFamily::BinomialMixture => WeightFamily::Binomial,
  9108	    }
  9109	}
  9110	
  9111	#[inline]
  9112	fn weight_link_for_inverse_link(inverse_link: &InverseLink) -> WeightLink {
  9113	    match inverse_link {
  9114	        InverseLink::Standard(LinkFunction::Identity) => WeightLink::Identity,
  9115	        InverseLink::Standard(LinkFunction::Log) => WeightLink::Log,
  9116	        InverseLink::Standard(LinkFunction::Logit) => WeightLink::Logit,
  9117	        InverseLink::Standard(LinkFunction::Probit)
  9118	        | InverseLink::Standard(LinkFunction::CLogLog)
  9119	        | InverseLink::Standard(LinkFunction::Sas)
  9120	        | InverseLink::Standard(LinkFunction::BetaLogistic)
  9121	        | InverseLink::LatentCLogLog(_)
  9122	        | InverseLink::Sas(_)
  9123	        | InverseLink::BetaLogistic(_)
  9124	        | InverseLink::Mixture(_) => WeightLink::Other,
  9125	    }
  9126	}
  9127	
  9128	#[inline]
  9129	fn supports_observed_hessian_curvature_for_likelihood(
  9130	    likelihood: GlmLikelihoodSpec,
  9131	    _: &InverseLink,
  9132	) -> bool {
  9133	    matches!(
  9134	        likelihood.family,
  9135	        GlmLikelihoodFamily::GammaLog
  9136	            | GlmLikelihoodFamily::BinomialProbit
  9137	            | GlmLikelihoodFamily::BinomialCLogLog
  9138	            | GlmLikelihoodFamily::BinomialSas
  9139	            | GlmLikelihoodFamily::BinomialBetaLogistic
  9140	            | GlmLikelihoodFamily::BinomialMixture
  9141	    )
  9142	}
  9143	
  9144	#[inline]
  9145	fn eta_for_observed_hessian_jet(inverse_link: &InverseLink, eta: f64) -> f64 {
  9146	    match inverse_link {
  9147	        // Why: canonical links keep V(mu) representable across the full f64 eta range; only guard against inf.
  9148	        InverseLink::Standard(LinkFunction::Logit | LinkFunction::Log) => eta.clamp(-700.0, 700.0),
  9149	        InverseLink::Standard(LinkFunction::Identity) => eta,
  9150	        // Why: probit mu=Phi(eta) saturates to 1.0 in f64 by |eta|~8.3; +/-6 keeps V=mu(1-mu) ~ 1e-9 representable.
  9151	        InverseLink::Standard(LinkFunction::Probit) => eta.clamp(-6.0, 6.0),
  9152	        // Why: cloglog has mu~exp(eta) for eta<<0 (underflows below ~-23) and 1-mu~exp(-exp(eta)) collapses by eta=3.
  9153	        InverseLink::Standard(LinkFunction::CLogLog) | InverseLink::LatentCLogLog(_) => {
  9154	            eta.clamp(-23.0, 3.0)
  9155	        }
  9156	        // Why: SAS / beta-logistic / mixture compose logistic-like sigmoids that saturate by |eta|~20 (logistic(20)~1-2e-9).
  9157	        InverseLink::Standard(LinkFunction::Sas | LinkFunction::BetaLogistic)
  9158	        | InverseLink::Sas(_)
  9159	        | InverseLink::BetaLogistic(_)
  9160	        | InverseLink::Mixture(_) => eta.clamp(-20.0, 20.0),
  9161	    }
  9162	}
  9163	
  9164	/// Returns true at rows where PIRLS clamped η (so the observed-info weights
  9165	/// were computed at the clamped value, making `∂W/∂η` zero w.r.t. the
  9166	/// **unclamped** η).  Outer REML/LAML derivative formulas must mask `c_obs`
  9167	/// and `d_obs` to zero on these rows or the analytic ∂H/∂ψ disagrees with
  9168	/// the H whose log-det we differentiate.
  9169	#[inline]
  9170	pub fn eta_clamp_active(inverse_link: &InverseLink, eta: f64) -> bool {
  9171	    let clamped = eta_for_observed_hessian_jet(inverse_link, eta);
  9172	    clamped != eta
  9173	}
  9174	
  9175	/// Build solver-conditioned weights from the exact hessian weights.
  9176	///
  9177	/// The returned array applies a solver-only floor per observation so the
  9178	/// Newton linear system X'W X + S stays numerically usable. This floor is
  9179	/// purely a linear-algebra concern: the exact statistical weights stored in
  9180	/// `lasthessian_weights` / `finalweights` are not affected.
  9181	fn solver_hessian_weights_into(
  9182	    hessian_weights: &Array1<f64>,
  9183	    fisher_weights: &Array1<f64>,
  9184	    out: &mut Array1<f64>,
  9185	) {
  9186	    if out.len() != hessian_weights.len() {
  9187	        *out = Array1::<f64>::zeros(hessian_weights.len());
  9188	    }
  9189	    ndarray::Zip::from(out)
  9190	        .and(hessian_weights)
  9191	        .and(fisher_weights)
  9192	        .par_for_each(|o, &w, &fw| {
  9193	            let floor = solver_hessian_weight_floor(fw);
  9194	            *o = if w.is_finite() && w > floor { w } else { floor };
  9195	        });
  9196	}
  9197	
  9198	/// Compute vectorised observed-information curvature arrays (w_obs, c_obs, d_obs)
  9199	/// for the Hessian surface at the mode.
  9200	///
  9201	/// This function is the primary entry point for obtaining the observed weights
  9202	/// that flow into the outer REML/LAML Hessian H_obs = X' W_obs X + S. The
  9203	/// observed corrections include residual-dependent terms that vanish for
  9204	/// canonical links but are nonzero for probit, cloglog, SAS, mixture, Gamma-log,
  9205	/// and other flexible links.
  9206	///
  9207	/// The output arrays are:
  9208	/// - `hessian_weights`: W_obs per observation (exact; solver floor applied separately).
  9209	/// - `hessian_c`: c_obs = dW_obs/deta per observation (for outer gradient C[v]).
  9210	/// - `hessian_d`: d_obs = d^2W_obs/deta^2 per observation (for outer Hessian Q[v_k,v_l]).
  9211	///
  9212	/// See `observed_weight_noncanonical` for the per-observation formulas and
  9213	/// response.md Section 3 for the mathematical justification of why observed
  9214	/// (not Fisher) information is required.
  9215	fn compute_observed_hessian_curvature_arrays_into(
  9216	    likelihood: GlmLikelihoodSpec,
  9217	    inverse_link: &InverseLink,
  9218	    eta: &Array1<f64>,
  9219	    y: ArrayView1<'_, f64>,
  9220	    fisher_weights: &Array1<f64>,
  9221	    priorweights: ArrayView1<'_, f64>,
  9222	    hessian_weights: &mut Array1<f64>,
  9223	    hessian_c: &mut Array1<f64>,
  9224	    hessian_d: &mut Array1<f64>,
  9225	) -> Result<(), EstimationError> {
  9226	    assert!(supports_observed_hessian_curvature_for_likelihood(
  9227	        likelihood,
  9228	        inverse_link
  9229	    ));
  9230	    let n = eta.len();
  9231	    if hessian_weights.len() != n {
  9232	        *hessian_weights = Array1::<f64>::zeros(n);
  9233	    }
  9234	    if hessian_c.len() != n {
  9235	        *hessian_c = Array1::<f64>::zeros(n);
  9236	    }
  9237	    if hessian_d.len() != n {
  9238	        *hessian_d = Array1::<f64>::zeros(n);
  9239	    }
  9240	
  9241	    let weight_family = weight_family_for_glm_likelihood(likelihood);
  9242	    let weight_link = weight_link_for_inverse_link(inverse_link);
  9243	    let phi = fixed_glm_dispersion(likelihood);
  9244	
  9245	    // Parallel per-row weight assembly. At biobank scale (n = 320k) this loop
  9246	    // dominates non-canonical paths because each row independently evaluates
  9247	    // inverse-link jets and residual-dependent observed curvature. Write
  9248	    // directly into reusable output slices rather than collecting row tuples,
  9249	    // which removes an O(n) temporary allocation on every PIRLS update.
  9250	    hessian_weights
  9251	        .as_slice_mut()
  9252	        .expect("hessian weights must be contiguous")
  9253	        .par_iter_mut()
  9254	        .zip(
  9255	            hessian_c
  9256	                .as_slice_mut()
  9257	                .expect("hessian c must be contiguous")
  9258	                .par_iter_mut(),
  9259	        )
  9260	        .zip(
  9261	            hessian_d
  9262	                .as_slice_mut()
  9263	                .expect("hessian d must be contiguous")
  9264	                .par_iter_mut(),
  9265	        )
  9266	        .enumerate()
  9267	        .try_for_each(|(i, ((w_out, c_out), d_out))| -> Result<(), EstimationError> {
  9268	            let eta_used = eta_for_observed_hessian_jet(inverse_link, eta[i]);
  9269	            // Why: closed-form observed_weight_noncanonical requires (mu, d1..d3, h4) at one consistent eta;
  9270	            // mixing PIRLS-state jets at unclamped eta with h4 at eta_used produced 0/0 in phi_v* divisions,
  9271	            // surfacing as: "observed Hessian curvature is not positive finite at row N: observed=NaN, fisher=0".
  9272	            let jet =
  9273	                crate::mixture_link::inverse_link_jet_for_inverse_link(inverse_link, eta_used)?;
  9274	            let h4 = crate::mixture_link::inverse_link_pdfthird_derivative_for_inverse_link(
  9275	                inverse_link, eta_used,
  9276	            )?;
  9277	            let (w_obs, c_obs, d_obs) = observed_weight_dispatch(
  9278	                weight_family,
  9279	                weight_link,
  9280	                eta_used,
  9281	                y[i],
  9282	                jet.mu,
  9283	                phi,
  9284	                priorweights[i].max(0.0),
  9285	                jet,
  9286	                h4,
  9287	            );
  9288	            let fisher_weight = fisher_weights[i].max(0.0);
  9289	            if !(w_obs.is_finite() && w_obs > 0.0) {
  9290	                return Err(EstimationError::InvalidInput(format!(
  9291	                    "observed Hessian curvature is not positive finite at row {i}: observed={w_obs}, fisher={fisher_weight}"
  9292	                )));
  9293	            }
  9294	            if !c_obs.is_finite() || !d_obs.is_finite() {
  9295	                return Err(EstimationError::InvalidInput(format!(
  9296	                    "observed Hessian curvature derivatives are non-finite at row {i}: c={c_obs}, d={d_obs}"
  9297	                )));
  9298	            }
  9299	            *w_out = w_obs;
  9300	            *c_out = c_obs;
  9301	            *d_out = d_obs;
  9302	            Ok(())
  9303	        })
  9304	}
  9305	
  9306	fn compute_observed_hessian_curvature_arrays(
  9307	    likelihood: GlmLikelihoodSpec,
  9308	    inverse_link: &InverseLink,
  9309	    eta: &Array1<f64>,
  9310	    y: ArrayView1<'_, f64>,
  9311	    fisher_weights: &Array1<f64>,
  9312	    priorweights: ArrayView1<'_, f64>,
  9313	) -> Result<(Array1<f64>, Array1<f64>, Array1<f64>), EstimationError> {
  9314	    let n = eta.len();
  9315	    let mut hessian_weights = Array1::<f64>::zeros(n);
  9316	    let mut hessian_c = Array1::<f64>::zeros(n);
  9317	    let mut hessian_d = Array1::<f64>::zeros(n);
  9318	    compute_observed_hessian_curvature_arrays_into(
  9319	        likelihood,
  9320	        inverse_link,
  9321	        eta,
  9322	        y,
  9323	        fisher_weights,
  9324	        priorweights,
  9325	        &mut hessian_weights,
  9326	        &mut hessian_c,
  9327	        &mut hessian_d,
  9328	    )?;
  9329	    Ok((hessian_weights, hessian_c, hessian_d))
  9330	}
  9331	
  9332	/// Per-observation observed-information weights and their first two
  9333	/// eta-derivatives for a general exponential-dispersion family with a
  9334	/// noncanonical link.
  9335	///
  9336	/// The observed weight differs from the Fisher (expected) weight by a
  9337	/// residual-dependent correction (see response.md Section 3):
  9338	///
  9339	///   W_obs = W_Fisher - (y - mu) * B
  9340	///   B = (h'' V - h'^2 V') / (phi V^2)
  9341	///
  9342	///   c_obs = c_Fisher + h' * B - (y - mu) * B_eta
  9343	///   d_obs = d_Fisher + h'' * B + 2*h' * B_eta - (y - mu) * B_etaeta
  9344	///
  9345	/// For canonical links (for example logit-Binomial and log-Poisson), B = 0
  9346	/// so observed = Fisher and no correction is needed.
  9347	///
  9348	/// These observed quantities are required for:
  9349	/// 1. The outer REML/LAML Hessian H_obs = X' W_obs X + S (log|H| term).
  9350	/// 2. The outer gradient's C[v] correction (uses c_obs).
  9351	/// 3. The outer Hessian's Q[v_k, v_l] correction (uses d_obs).
  9352	///
  9353	/// Using Fisher weights in the outer REML would yield a PQL-type surrogate
  9354	/// rather than the exact Laplace approximation.
  9355	///
  9356	/// # Arguments
  9357	/// * `y`   -- response value
  9358	/// * `mu`  -- fitted mean h(eta)
  9359	/// * `h1`...`h4` -- inverse-link derivatives h'(eta) ... h''''(eta)
  9360	/// * `vj`  -- variance-function jet (V, V', V'', V''') evaluated at mu
  9361	/// * `phi` -- dispersion parameter (1.0 for Bernoulli/Poisson)
  9362	/// * `pw`  -- prior weight for this observation
  9363	///
  9364	/// # Returns
  9365	/// `(w_obs, c_obs, d_obs)` -- the observed weight and its first two
  9366	/// eta-derivatives, all pre-multiplied by `pw`.
  9367	#[inline]
  9368	pub fn observed_weight_noncanonical(
  9369	    y: f64,
  9370	    mu: f64,
  9371	    h1: f64,
  9372	    h2: f64,
  9373	    h3: f64,
  9374	    h4: f64,
  9375	    vj: VarianceJet,
  9376	    phi: f64,
  9377	    pw: f64,
  9378	) -> (f64, f64, f64) {
  9379	    let VarianceJet {
  9380	        v,
  9381	        v1,
  9382	        v2,
  9383	        v3,
  9384	        v4: _,
  9385	    } = vj;
  9386	    let phi_v = phi * v;
  9387	    let phi_v2 = phi * v * v;
  9388	    let phi_v3 = phi * v * v * v;
  9389	
  9390	    // ---- Fisher weight and derivatives ----
  9391	    let h1_sq = h1 * h1;
  9392	    let w_f = h1_sq / phi_v;
  9393	
  9394	    // c_F = (2 h₁ h₂ V − h₁³ V₁) / (φ V²)
  9395	    let n0 = h1_sq; // numerator of w_F
  9396	    let n1 = 2.0 * h1 * h2; // ∂(h₁²)/∂η
  9397	    let n2 = 2.0 * (h2 * h2 + h1 * h3); // ∂²(h₁²)/∂η²
  9398	    let vd1 = h1 * v1; // ∂V/∂η = V'·h'
  9399	    let vd2 = h2 * v1 + h1_sq * v2; // ∂²V/∂η²
  9400	
  9401	    let c_f = (n1 * v - n0 * vd1) / phi_v2;
  9402	
  9403	    // d_F = ∂c_F/∂η via quotient rule on c_F = (n1·v − n0·vd1) / (φ·v²)
  9404	    // numerator of c_F and its η-derivative (cross terms cancel):
  9405	    let numer_cf = n1 * v - n0 * vd1;
  9406	    let dnumer_cf = n2 * v - n0 * vd2;
  9407	    let d_f = (dnumer_cf * v - 2.0 * numer_cf * vd1) / (phi_v3);
  9408	
  9409	    // ---- Observed correction term B and its η-derivatives ----
  9410	    // B = (h₂ V − h₁² V₁) / (φ V²)
  9411	    let b_num = h2 * v - h1_sq * v1;
  9412	    let b = b_num / phi_v2;
  9413	
  9414	    // B_η = (h₃ V² − 3 h₁ h₂ V V₁ − h₁³ V V₂ + 2 h₁³ V₁²) / (φ V³)
  9415	    let b_eta_num =
  9416	        h3 * v * v - 3.0 * h1 * h2 * v * v1 - h1_sq * h1 * v * v2 + 2.0 * h1_sq * h1 * v1 * v1;
  9417	    let b_eta = b_eta_num / phi_v3;
  9418	
  9419	    // B_ηη = ∂B_η/∂η.
  9420	    //
  9421	    // We differentiate b_eta_num / (φ V³) using the quotient rule.
  9422	    //
  9423	    // Numerator derivative of b_eta_num w.r.t. η, using chain rule ∂/∂η = h₁·∂/∂μ
  9424	    // for the V-dependent parts:
  9425	    //
  9426	    //   ∂/∂η [h₃ V²]               = h₄ V² + 2 h₃ V h₁ V₁
  9427	    //   ∂/∂η [3 h₁ h₂ V V₁]        = 3(h₂² + h₁ h₃)V V₁ + 3 h₁ h₂(h₁ V₁² + V h₁ V₂)
  9428	    //   ∂/∂η [h₁³ V V₂]            = 3 h₁² h₂ V V₂ + h₁³(h₁ V₁ V₂ + V h₁ V₃)
  9429	    //   ∂/∂η [2 h₁³ V₁²]           = 6 h₁² h₂ V₁² + 4 h₁³ V₁ h₁ V₂
  9430	    //                                = 6 h₁² h₂ V₁² + 4 h1_sq * h1_sq * v1 * v2
  9431	    //
  9432	    // Denominator derivative: ∂/∂η [φ V³] = 3 φ V² h₁ V₁.
  9433	
  9434	    let h1_cu = h1_sq * h1;
  9435	    let h1_qu = h1_sq * h1_sq;
  9436	
  9437	    let db_eta_num = h4 * v * v + 2.0 * h3 * v * h1 * v1
  9438	        - 3.0 * (h2 * h2 + h1 * h3) * v * v1
  9439	        - 3.0 * h1 * h2 * (h1 * v1 * v1 + v * h1 * v2)
  9440	        - 3.0 * h1_sq * h2 * v * v2
  9441	        - h1_cu * (h1 * v1 * v2 + v * h1 * v3)
  9442	        + 6.0 * h1_sq * h2 * v1 * v1
  9443	        + 4.0 * h1_qu * v1 * v2;
  9444	
  9445	    let phi_v4 = phi_v3 * v;
  9446	    let b_etaeta = (db_eta_num * v - 3.0 * b_eta_num * h1 * v1) / phi_v4;
  9447	
  9448	    // ---- Assemble observed quantities ----
  9449	    let resid = y - mu;
  9450	
  9451	    let w_obs = w_f - resid * b;
  9452	    let c_obs = c_f + h1 * b - resid * b_eta;
  9453	    let d_obs = d_f + h2 * b + 2.0 * h1 * b_eta - resid * b_etaeta;
  9454	
  9455	    (pw * w_obs, pw * c_obs, pw * d_obs)
  9456	}
  9457	
  9458	/// Per-observation third η-derivative of the observed-information weight,
  9459	/// `e_obs := ∂³W_obs/∂η³`, for a general exponential-dispersion family with
  9460	/// any (canonical or non-canonical) link.
  9461	///
  9462	/// Closed-form derivation:
  9463	///   Define `T(η) := h₁(η)/(φ V(μ(η)))`. Then
  9464	///   * Fisher weight `W_F = h₁ · T`
  9465	///   * Observed correction `B = T'`, so `B_η = T''`, `B_ηη = T'''`,
  9466	///     `B_ηηη = T''''`
  9467	///   * `W_obs = W_F − (y−μ) · T'`
  9468	///
  9469	/// Differentiating three times:
  9470	///   `∂³W_obs/∂η³ = W_F''' + h₃·T' + 3 h₂·T'' + 3 h₁·T''' − (y−μ)·T''''`
  9471	///
  9472	/// `T` is computed via Leibniz on `T·Q = h₁` with `Q = φV`; `W_F` via
  9473	/// Leibniz on `W_F·1 = h₁·T` (product rule).
  9474	///
  9475	/// All inverse-link derivatives `h₁..h₅` and variance-function derivatives
  9476	/// `V..V₄` are required as inputs. Caller supplies them.
  9477	///
  9478	/// Returns `pw * e_obs` (pre-multiplied by the prior weight) so the result
  9479	/// scales identically to `(w_obs, c_obs, d_obs)` from
  9480	/// `observed_weight_noncanonical`.
  9481	#[inline]
  9482	pub fn e_obs_from_jets(
  9483	    y: f64,
  9484	    mu: f64,
  9485	    h1: f64,
  9486	    h2: f64,
  9487	    h3: f64,
  9488	    h4: f64,
  9489	    h5: f64,
  9490	    vj: VarianceJet,
  9491	    phi: f64,
  9492	    pw: f64,
  9493	) -> f64 {
  9494	    let VarianceJet { v, v1, v2, v3, v4 } = vj;
  9495	    let q = phi * v;
  9496	
  9497	    // Q = φV and its η-derivatives.
  9498	    //   Q'    = φ V₁ h₁
  9499	    //   Q''   = φ (V₁ h₂ + V₂ h₁²)
  9500	    //   Q'''  = φ (V₁ h₃ + 3 V₂ h₁ h₂ + V₃ h₁³)
  9501	    //   Q'''' = φ (V₁ h₄ + 4 V₂ h₁ h₃ + 3 V₂ h₂² + 6 V₃ h₁² h₂ + V₄ h₁⁴)
  9502	    let h1_sq = h1 * h1;
  9503	    let h1_cu = h1_sq * h1;
  9504	    let h1_qu = h1_sq * h1_sq;
  9505	
  9506	    let q1 = phi * v1 * h1;
  9507	    let q2 = phi * (v1 * h2 + v2 * h1_sq);
  9508	    let q3 = phi * (v1 * h3 + 3.0 * v2 * h1 * h2 + v3 * h1_cu);
  9509	    let q4 = phi
  9510	        * (v1 * h4 + 4.0 * v2 * h1 * h3 + 3.0 * v2 * h2 * h2 + 6.0 * v3 * h1_sq * h2 + v4 * h1_qu);
  9511	
  9512	    // T = h₁/Q and T', T'', T''', T'''' via Leibniz on T·Q = h₁.
  9513	    //   T'    = (h₂  − T·Q')/Q
  9514	    //   T''   = (h₃  − 2 T'·Q' − T·Q'')/Q
  9515	    //   T'''  = (h₄  − 3 T''·Q' − 3 T'·Q'' − T·Q''')/Q
  9516	    //   T'''' = (h₅  − 4 T'''·Q' − 6 T''·Q'' − 4 T'·Q''' − T·Q'''')/Q
  9517	    let t0 = h1 / q;
  9518	    let t1 = (h2 - t0 * q1) / q;
  9519	    let t2 = (h3 - 2.0 * t1 * q1 - t0 * q2) / q;
  9520	    let t3 = (h4 - 3.0 * t2 * q1 - 3.0 * t1 * q2 - t0 * q3) / q;
  9521	    let t4 = (h5 - 4.0 * t3 * q1 - 6.0 * t2 * q2 - 4.0 * t1 * q3 - t0 * q4) / q;
  9522	
  9523	    // Fisher weight derivatives via product rule on W_F = h₁·T.
  9524	    //   W_F^(0) = h₁ T
  9525	    //   W_F^(1) = h₁ T₁ + h₂ T
  9526	    //   W_F^(2) = h₁ T₂ + 2 h₂ T₁ + h₃ T
  9527	    //   W_F^(3) = h₁ T₃ + 3 h₂ T₂ + 3 h₃ T₁ + h₄ T
  9528	    let w_f3 = h1 * t3 + 3.0 * h2 * t2 + 3.0 * h3 * t1 + h4 * t0;
  9529	
  9530	    // Observed third derivative: differentiate W_obs = W_F − (y−μ)·T₁ thrice.
  9531	    // (resid)' = −h₁, so iterating product rule yields
  9532	    //   ∂³((y−μ)·T₁)/∂η³ = −h₃·T₁ − 3 h₂·T₂ − 3 h₁·T₃ + (y−μ)·T₄
  9533	    let resid = y - mu;
  9534	    let e_obs = w_f3 + h3 * t1 + 3.0 * h2 * t2 + 3.0 * h1 * t3 - resid * t4;
  9535	
  9536	    pw * e_obs
  9537	}
  9538	
  9539	// Direct (closed-form) observed-information weights for specific family-link
  9540	// combinations.  These avoid the overhead of the generic noncanonical formula
  9541	// when the algebra simplifies.
  9542	
  9543	/// Gaussian family with log link: y ~ N(μ, φ), μ = exp(η).
  9544	///
  9545	/// Returns `(w_obs, c_obs, d_obs)` pre-multiplied by the prior weight `pw`.
  9546	///
  9547	/// ```text
  9548	/// w_obs = ω μ(2μ − y) / φ
  9549	/// c_obs = ω μ(4μ − y) / φ
  9550	/// d_obs = ω μ(8μ − y) / φ
  9551	/// ```
  9552	#[inline]
  9553	pub fn observed_weight_gaussian_log(y: f64, mu: f64, phi: f64, pw: f64) -> (f64, f64, f64) {
  9554	    let inv_phi = pw / phi;
  9555	    let w = inv_phi * mu * (2.0 * mu - y);
  9556	    let c = inv_phi * mu * (4.0 * mu - y);
  9557	    let d = inv_phi * mu * (8.0 * mu - y);
  9558	    (w, c, d)
  9559	}
  9560	
  9561	/// Gaussian family with inverse link: y ~ N(μ, φ), μ = 1/η.
  9562	///
  9563	/// Returns `(w_obs, c_obs, d_obs)` pre-multiplied by the prior weight `pw`.
  9564	///
  9565	/// ```text
  9566	/// w_obs = ω (3 − 2ηy) / (φ η⁴)
  9567	/// c_obs = 6ω (ηy − 2) / (φ η⁵)
  9568	/// d_obs = 12ω (5 − 2ηy) / (φ η⁶)
  9569	/// ```
  9570	#[inline]
  9571	pub fn observed_weight_gaussian_inverse(y: f64, eta: f64, phi: f64, pw: f64) -> (f64, f64, f64) {
  9572	    let eta2 = eta * eta;
  9573	    let eta4 = eta2 * eta2;
  9574	    let eta5 = eta4 * eta;
  9575	    let eta6 = eta4 * eta2;
  9576	    let ey = eta * y;
  9577	    let inv_phi = pw / phi;
  9578	    let w = inv_phi * (3.0 - 2.0 * ey) / eta4;
  9579	    let c = inv_phi * 6.0 * (ey - 2.0) / eta5;
  9580	    let d = inv_phi * 12.0 * (5.0 - 2.0 * ey) / eta6;
  9581	    (w, c, d)
  9582	}
  9583	
  9584	#[inline]
  9585	fn observed_weight_binomial_logit_from_jet(
  9586	    n_trials: f64,
  9587	    jet: MixtureInverseLinkJet,
  9588	    pw: f64,
  9589	) -> (f64, f64, f64) {
  9590	    let scale = pw * n_trials;
  9591	    (scale * jet.d1, scale * jet.d2, scale * jet.d3)
  9592	}
  9593	
  9594	/// Family tag for the observed-information weight dispatch.
  9595	///
  9596	/// This is a simplified family tag that identifies the variance function,
  9597	/// independent of the link function. It is used by [`observed_weight_dispatch`]
  9598	/// to select closed-form weight specializations.
  9599	#[derive(Debug, Clone, Copy, PartialEq, Eq)]
  9600	pub enum WeightFamily {
  9601	    Gaussian,
  9602	    Binomial,
  9603	    Poisson,
  9604	    Gamma,
  9605	}
  9606	
  9607	/// Link tag for the observed-information weight dispatch.
  9608	///
  9609	/// Identifies the link function for selecting closed-form weight
  9610	/// specializations in [`observed_weight_dispatch`].
  9611	#[derive(Debug, Clone, Copy, PartialEq, Eq)]
  9612	pub enum WeightLink {
  9613	    Identity,
  9614	    Log,
  9615	    Logit,
  9616	    Inverse,
  9617	    /// Any other link — falls back to the generic noncanonical formula.
  9618	    Other,
  9619	}
  9620	
  9621	#[inline]
  9622	pub fn variance_jet_for_weight_family(family: WeightFamily, mu: f64) -> VarianceJet {
  9623	    match family {
  9624	        WeightFamily::Gaussian => VarianceJet::gaussian(),
  9625	        WeightFamily::Binomial => VarianceJet::binomial_n(mu),
  9626	        WeightFamily::Poisson => VarianceJet::poisson(mu),
  9627	        WeightFamily::Gamma => VarianceJet::gamma(mu),
  9628	    }
  9629	}
  9630	
  9631	/// Dispatch to closed-form observed-information weights for known family-link
  9632	/// combinations, falling back to the generic noncanonical formula.
  9633	///
  9634	/// Returns `(w_obs, c_obs, d_obs)` pre-multiplied by the prior weight.
  9635	///
  9636	/// For the `Binomial + Logit` case, `n_trials` is passed as `phi` (dispersion
  9637	/// slot is unused for binomial) and the prior weight controls the
  9638	/// observation-level scaling. For all other cases, `phi` is the dispersion
  9639	/// parameter.
  9640	///
  9641	/// `jet` and `h4` are the inverse-link derivatives used by the generic
  9642	/// noncanonical fallback path. They may be zero for the specialized paths.
  9643	pub fn observed_weight_dispatch(
  9644	    family: WeightFamily,
  9645	    link: WeightLink,
  9646	    eta: f64,
  9647	    y: f64,
  9648	    mu: f64,
  9649	    phi: f64,
  9650	    prior_weight: f64,
  9651	    jet: MixtureInverseLinkJet,
  9652	    h4: f64,
  9653	) -> (f64, f64, f64) {
  9654	    match (family, link) {
  9655	        (WeightFamily::Gaussian, WeightLink::Log) => {
  9656	            observed_weight_gaussian_log(y, mu, phi, prior_weight)
  9657	        }
  9658	        (WeightFamily::Gaussian, WeightLink::Inverse) => {
  9659	            observed_weight_gaussian_inverse(y, eta, phi, prior_weight)
  9660	        }
  9661	        (WeightFamily::Binomial, WeightLink::Logit) => {
  9662	            observed_weight_binomial_logit_from_jet(1.0, jet, prior_weight)
  9663	        }
  9664	        _ => {
  9665	            // Generic noncanonical path via the full variance-function jet.
  9666	            let vj = variance_jet_for_weight_family(family, mu);
  9667	            observed_weight_noncanonical(y, mu, jet.d1, jet.d2, jet.d3, h4, vj, phi, prior_weight)
  9668	        }
  9669	    }
  9670	}
