  1194	    /// Ensure the sparse penalty cache is populated and consistent with `x` and `s_lambda`.
  1195	    fn ensure_sparse_penalty_cache(
  1196	        &mut self,
  1197	        x: &SparseColMat<usize, f64>,
  1198	        s_lambda: &Array2<f64>,
  1199	    ) -> Result<(), EstimationError> {
  1200	        let penalty_pattern = SparsePenaltyPattern::from_dense_upper(s_lambda, 1e-12);
  1201	        let rebuild = match self.sparse_penalized_system_cache.as_ref() {
  1202	            Some(cache) => !cache.matches(x, &penalty_pattern),
  1203	            None => true,
  1204	        };
  1205	        if rebuild {
  1206	            self.sparse_penalized_system_cache =
  1207	                Some(SparsePenalizedSystemCache::new(x, penalty_pattern)?);
  1208	        }
  1209	        Ok(())
  1210	    }
