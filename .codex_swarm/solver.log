   511	pub fn validate_mixturespec(spec: &MixtureLinkSpec) -> Result<(), String> {
   512	    if spec.components.is_empty() {
   513	        return Err("mixture link requires at least 1 component".to_string());
   514	    }
   515	    if spec.initial_rho.len() + 1 != spec.components.len() {
   516	        return Err(format!(
   517	            "mixture link rho length mismatch: expected {}, got {}",
   518	            spec.components.len() - 1,
   519	            spec.initial_rho.len()
   520	        ));
   521	    }
   522	    for i in 0..spec.components.len() {
   523	        for j in (i + 1)..spec.components.len() {
   524	            if spec.components[i] == spec.components[j] {
   525	                return Err("mixture link components must be unique".to_string());
   526	            }
   527	        }
   528	    }
   529	    Ok(())
   530	}
