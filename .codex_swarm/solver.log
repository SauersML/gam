   122	impl CoefficientPriorMean {
   123	    pub fn scalar(value: f64) -> Self {
   124	        Self::Scalar(value)
   125	    }
   126	
   127	    pub fn constant(values: Array1<f64>) -> Self {
   128	        Self::Constant(values)
   129	    }
   130	
   131	    pub fn functional(
   132	        metadata: Array1<f64>,
   133	        evaluator: Arc<dyn Fn(&Array1<f64>) -> Array1<f64> + Send + Sync>,
   134	    ) -> Self {
   135	        Self::Functional {
   136	            metadata,
   137	            evaluator,
   138	        }
   139	    }
   140	
   141	    pub fn kernel_basis(
   142	        covariates: Array1<f64>,
   143	        amplitude: f64,
   144	        kernel: Arc<dyn Fn(&Array1<f64>) -> Array1<f64> + Send + Sync>,
   145	    ) -> Self {
   146	        Self::KernelBasis {
   147	            covariates,
   148	            amplitude,
   149	            kernel,
   150	        }
   151	    }
   152	
   153	    pub(crate) fn evaluate(
   154	        &self,
   155	        block_dim: usize,
   156	        context: &str,
   157	    ) -> Result<Array1<f64>, EstimationError> {
   158	        let values = match self {
   159	            Self::Zero => Array1::zeros(block_dim),
   160	            Self::Scalar(value) => {
   161	                if !value.is_finite() {
   162	                    return Err(EstimationError::InvalidInput(format!(
   163	                        "{context}: coefficient prior mean scalar must be finite, got {value}"
   164	                    )));
   165	                }
   166	                Array1::from_elem(block_dim, *value)
   167	            }
   168	            Self::Constant(values) => values.clone(),
   169	            Self::Functional {
   170	                metadata,
   171	                evaluator,
   172	            } => evaluator(metadata),
   173	            Self::KernelBasis {
   174	                covariates,
   175	                amplitude,
   176	                kernel,
   177	            } => {
   178	                if !amplitude.is_finite() {
   179	                    return Err(EstimationError::InvalidInput(format!(
   180	                        "{context}: coefficient prior mean amplitude must be finite, got {amplitude}"
   181	                    )));
   182	                }
   183	                let mut values = kernel(covariates);
   184	                values *= *amplitude;
   185	                values
   186	            }
   187	        };
   188	        if values.len() != block_dim {
   189	            return Err(EstimationError::InvalidInput(format!(
   190	                "{context}: coefficient prior mean length must be {block_dim}, got {}",
   191	                values.len()
   192	            )));
   193	        }
   194	        if values.iter().any(|&value| !value.is_finite()) {
   195	            return Err(EstimationError::InvalidInput(format!(
   196	                "{context}: coefficient prior mean contains non-finite values"
   197	            )));
   198	        }
   199	        Ok(values)
   200	    }
   201	}
