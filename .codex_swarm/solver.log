    70	/// Programmatic prior mean for a coefficient penalty block.
    71	///
    72	/// The mean is evaluated once during penalty canonicalization and then enters
    73	/// the solver as the centering vector in `(beta - mean)' S (beta - mean)`.
    74	#[derive(Clone, Default)]
    75	pub enum CoefficientPriorMean {
    76	    #[default]
    77	    Zero,
    78	    Scalar(f64),
    79	    Constant(Array1<f64>),
    80	    Functional {
    81	        metadata: Array1<f64>,
    82	        evaluator: Arc<dyn Fn(&Array1<f64>) -> Array1<f64> + Send + Sync>,
    83	    },
    84	    /// Covariate-functional mean `mu(a) = amplitude * K(a)` for a coefficient block.
    85	    ///
    86	    /// Formula-level coefficient groups pass their row/covariate metadata as
    87	    /// `covariates`; the user-supplied kernel returns the block-sized basis
    88	    /// vector `K(a)` and the scalar amplitude supplies `alpha`.
    89	    KernelBasis {
    90	        covariates: Array1<f64>,
    91	        amplitude: f64,
    92	        kernel: Arc<dyn Fn(&Array1<f64>) -> Array1<f64> + Send + Sync>,
    93	    },
    94	}
    95	
    96	impl std::fmt::Debug for CoefficientPriorMean {
    97	    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
    98	        match self {
    99	            Self::Zero => f.write_str("Zero"),
   100	            Self::Scalar(value) => f.debug_tuple("Scalar").field(value).finish(),
   101	            Self::Constant(values) => f
   102	                .debug_tuple("Constant")
   103	                .field(&format_args!("len={}", values.len()))
   104	                .finish(),
   105	            Self::Functional { metadata, .. } => f
   106	                .debug_struct("Functional")
   107	                .field("metadata_len", &metadata.len())
   108	                .finish_non_exhaustive(),
   109	            Self::KernelBasis {
   110	                covariates,
   111	                amplitude,
   112	                ..
   113	            } => f
   114	                .debug_struct("KernelBasis")
   115	                .field("covariate_len", &covariates.len())
   116	                .field("amplitude", amplitude)
   117	                .finish_non_exhaustive(),
   118	        }
   119	    }
   120	}
