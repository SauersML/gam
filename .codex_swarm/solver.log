   511	                let mut acc = 0.0;
   512	                for j in 0..p {
   513	                    acc += rows[[i, j]] * z_chunk[[j, i]];
   514	                }
   515	                h[start + i] = acc;
   516	            }
   517	            start = end;
   518	        }
   519	        h
   520	    }

