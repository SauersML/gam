  1787	
  1788	    /// Compute X_transformed * β into a pre-allocated buffer, avoiding
  1789	    /// per-iteration allocation in the dense case.
  1790	    fn transformed_matvec_into(&self, beta: &Coefficients, out: &mut Array1<f64>) {
  1791	        self.transformed_matvec_array_into(beta.as_ref(), out);
  1792	    }
  1793	
  1794	    /// View-based sibling of `transformed_matvec_into` that operates on a raw
  1795	    /// `&Array1<f64>` to avoid wrapping (and cloning into) `Coefficients` on
  1796	    /// hot LM-screen paths.
  1797	    fn transformed_matvec_array_into(&self, beta: &Array1<f64>, out: &mut Array1<f64>) {
  1798	        match &self.coordinate_design {
  1799	            WorkingCoordinateDesign::TransformedExplicit { x_transformed, .. } => {
  1800	                if let Some(dense) = x_transformed.as_dense() {
  1801	                    fast_av_into(dense, beta, out);
  1802	                    return;
  1803	                }
  1804	                out.assign(&x_transformed.matrixvectormultiply(beta));
  1805	            }
  1806	            WorkingCoordinateDesign::TransformedImplicit { transform } => {
  1807	                // Composed: X · (Qs · beta).  Qs·beta is p-dim (cheap),
  1808	                // then write X·(Qs·beta) directly into out when X is dense.
  1809	                let beta_orig = transform.apply(beta);
  1810	                if let Some(dense) = self.x_original.as_dense() {
  1811	                    fast_av_into(dense, &beta_orig, out);
  1812	                } else {
  1813	                    out.assign(&self.x_original.apply(&beta_orig));
  1814	                }
  1815	            }
  1816	            WorkingCoordinateDesign::OriginalSparseNative => {
  1817	                out.assign(&self.x_original.matrixvectormultiply(beta));
  1818	            }
  1819	        }
  1820	    }
  1821	
  1822	    fn transformed_transpose_matvec(&self, vec: &Array1<f64>) -> Array1<f64> {
  1823	        match &self.coordinate_design {
  1824	            WorkingCoordinateDesign::OriginalSparseNative => {
  1825	                self.x_original.transpose_vector_multiply(vec)
  1826	            }
  1827	            WorkingCoordinateDesign::TransformedExplicit { x_transformed, .. } => {
  1828	                x_transformed.transpose_vector_multiply(vec)
  1829	            }
  1830	            WorkingCoordinateDesign::TransformedImplicit { transform } => {
  1831	                let xtv = self.x_original.transpose_vector_multiply(vec);
  1832	                transform.apply_transpose(&xtv)
  1833	            }
  1834	        }
  1835	    }
  1836	
  1837	    /// Compute X^T W X via the workspace BLAS-accelerated streaming path.
  1838	    /// Falls back to the scalar loop for sparse matrices.
  1839	    fn compute_xtwx_blas(
  1840	        workspace: &mut PirlsWorkspace,
  1841	        design: &DesignMatrix,
  1842	        weights: &Array1<f64>,
  1843	    ) -> Result<Array2<f64>, EstimationError> {
  1844	        match design {
  1845	            // Only the materialized arm can use the streaming-BLAS dense path.
  1846	            // Lazy operator-backed dense designs (TPS/Matern at biobank scale)
  1847	            // cannot be densified; fall through to the operator XᵀWX path.
  1848	            DesignMatrix::Dense(x) if x.is_materialized_dense() => {
  1849	                let p = x.ncols();
  1850	                let x_dense = x.to_dense_arc();
  1851	                // GPU fast path: cuBLAS routes `Xᵀ diag(w) X` as a single
  1852	                // device GEMM after row-scaling. The signed weights are
  1853	                // preserved because the device kernel forms `Xᵀ (W X)`
  1854	                // without any sqrt clipping. The resident variant keeps X
  1855	                // on the device across PIRLS iterations — on biobank shapes
  1856	                // (n≈3e5) that saves ~84 MiB of H2D traffic per Newton step.
  1857	                if let Some(out) = crate::gpu::try_fast_xt_diag_x_arc(&x_dense, weights) {
  1858	                    return Ok(out);
  1859	                }
  1860	                if let Some(out) = crate::gpu::try_fast_xt_diag_x(x_dense.as_ref(), weights) {
  1861	                    return Ok(out);
  1862	                }
  1863	                // Reuse workspace hessian buffer to avoid per-iteration allocation.
  1864	                if workspace.hessian_buf.nrows() != p || workspace.hessian_buf.ncols() != p {
  1865	                    workspace.hessian_buf = Array2::zeros((p, p).f());
  1866	                } else {
  1867	                    workspace.hessian_buf.fill(0.0);
  1868	                }
  1869	                PirlsWorkspace::add_dense_xtwx_streaming_signed(
  1870	                    weights,
  1871	                    &mut workspace.weighted_x_chunk,
  1872	                    x_dense.as_ref(),
  1873	                    &mut workspace.hessian_buf,
  1874	                    get_global_parallelism(),
  1875	                );
  1876	                // Move the buffer out instead of cloning — saves O(p²) memcpy.
  1877	                // Next call will reallocate (same cost as the existing zero-fill).
  1878	                Ok(std::mem::take(&mut workspace.hessian_buf))
  1879	            }
  1880	            _ => crate::matrix::xt_diag_x_symmetric(design, weights)
  1881	                .map(|h| h.to_dense())
  1882	                .map_err(EstimationError::InvalidInput),
  1883	        }
  1884	    }
  1885	
  1886	    fn penalized_hessian(&mut self, weights: &Array1<f64>) -> Result<Array2<f64>, EstimationError> {
  1887	        match &self.coordinate_design {
  1888	            WorkingCoordinateDesign::TransformedExplicit { x_transformed, .. } => {
  1889	                let mut h = Self::compute_xtwx_blas(&mut self.workspace, x_transformed, weights)?;
  1890	                self.penalty.add_to_hessian(&mut h);
  1891	                Ok(h)
  1892	            }
  1893	            WorkingCoordinateDesign::TransformedImplicit { transform } => {
  1894	                let xtwx = Self::compute_xtwx_blas(&mut self.workspace, &self.x_original, weights)?;
  1895	                let mut h = transform.conjugate_matrix(&xtwx);
  1896	                self.penalty.add_to_hessian(&mut h);
  1897	                Ok(h)
  1898	            }
  1899	            WorkingCoordinateDesign::OriginalSparseNative => {
  1900	                let mut h =
  1901	                    Self::compute_xtwx_blas(&mut self.workspace, &self.x_original, weights)?;
  1902	                self.penalty.add_to_hessian(&mut h);
  1903	                Ok(h)
  1904	            }
  1905	        }
  1906	    }
  1907	
  1908	    fn supports_observed_hessian_curvature(&self) -> bool {
  1909	        supports_observed_hessian_curvature_for_likelihood(self.likelihood, &self.link_kind)
  1910	    }
  1911	
  1912	    /// Compute the Hessian-side weight arrays (w, c, d) for the requested curvature kind.
  1913	    ///
  1914	    /// When `requested == Observed` and the link supports it, returns the
  1915	    /// **observed-information** weights including the residual-dependent correction:
  1916	    ///   W_obs = W_Fisher - (y - mu) * B,  B = (h'' V - h'^2 V') / (phi V^2)
  1917	    ///   c_obs = c_Fisher + h'*B - (y-mu)*B_eta
  1918	    ///   d_obs = d_Fisher + h''*B + 2*h'*B_eta - (y-mu)*B_etaeta
  1919	    ///
  1920	    /// For canonical links (for example logit-Binomial and log-Poisson), B = 0
  1921	    /// so observed = Fisher. Gamma-log is non-canonical and therefore needs its
  1922	    /// own observed-information correction.
  1923	    ///
  1924	    /// These arrays serve dual purpose:
  1925	    /// 1. **Inner iteration**: They define the Newton system H*delta = -g.
  1926	    ///    Fisher scoring (using W_Fisher) is also valid here since any convergent
  1927	    ///    algorithm finds the same mode.
  1928	    /// 2. **Outer REML**: They define the Laplace Hessian H_obs = X'W_obs X + S.
  1929	    ///    The outer log|H| and trace terms MUST use observed information for the
  1930	    ///    exact Laplace approximation. See response.md Section 3.
  1931	    fn update_hessian_curvature_arrays(
  1932	        &mut self,
  1933	        requested: HessianCurvatureKind,
  1934	    ) -> Result<HessianCurvatureKind, EstimationError> {
  1935	        if requested == HessianCurvatureKind::Fisher || !self.supports_observed_hessian_curvature()
  1936	        {
  1937	            self.lasthessian_weights.assign(&self.lastweights);
  1938	            self.lasthessian_c.assign(&self.last_c);
  1939	            self.lasthessian_d.assign(&self.last_d);
  1940	            return Ok(HessianCurvatureKind::Fisher);
  1941	        }
  1942	
  1943	        compute_observed_hessian_curvature_arrays_into(
  1944	            self.likelihood,
  1945	            &self.link_kind,
  1946	            &self.workspace.eta_buf,
  1947	            self.y,
  1948	            &self.lastweights,
  1949	            self.priorweights,
  1950	            &mut self.lasthessian_weights,
  1951	            &mut self.lasthessian_c,
  1952	            &mut self.lasthessian_d,
  1953	        )?;
  1954	        Ok(HessianCurvatureKind::Observed)
  1955	    }
  1956	
  1957	    fn sparse_penalized_hessian(
  1958	        &mut self,
  1959	        weights: &Array1<f64>,
  1960	        ridge: f64,
  1961	    ) -> Result<SparseColMat<usize, f64>, EstimationError> {
  1962	        let x_sparse = self.x_original.as_sparse().ok_or_else(|| {
  1963	            EstimationError::InvalidInput(
  1964	                "sparse-native PIRLS requires a sparse original design".to_string(),
  1965	            )
  1966	        })?;
  1967	        let PirlsPenalty::Dense { s_transformed, .. } = &self.penalty else {
  1968	            return Err(EstimationError::InvalidInput(
  1969	                "sparse-native PIRLS requires a dense transformed penalty matrix".to_string(),
  1970	            ));
  1971	        };
  1972	        self.workspace.assemble_sparse_penalized_hessian(
  1973	            x_sparse,
  1974	            weights,
  1975	            s_transformed,
  1976	            ridge,
  1977	            None,
  1978	        )
  1979	    }
  1980	
  1981	    /// LM-screen helper: evaluates a candidate β by reusing the previous
  1982	    /// `current_eta` plus a single design-matrix matvec `X·δ`, then runs the
  1983	    /// inverse-link only far enough to recover μ, w, z and the deviance.
  1984	    /// No Hessian assembly, no derivative buffers, no Jeffreys logdet.
  1985	    ///
  1986	    /// The LM loop calls `update_with_curvature` to upgrade the screen to a
  1987	    /// full `WorkingState` only when the screen is accepted. Rejected LM
  1988	    /// candidates therefore skip the O(np²) curvature build entirely.
  1989	    fn screen_candidate_from_direction(
  1990	        &mut self,
  1991	        beta: &Coefficients,
  1992	        direction: &Array1<f64>,
  1993	        current_eta: &LinearPredictor,
  1994	    ) -> Result<CandidateScreen, EstimationError> {
  1995	        let n = self.offset.len();
  1996	        if self.workspace.eta_buf.len() != n {
  1997	            self.workspace.eta_buf = Array1::zeros(n);
  1998	        }
  1999	        if self.workspace.delta_eta.len() != n {
  2000	            self.workspace.delta_eta = Array1::zeros(n);
  2001	        }
  2002	
  2003	        // Compute δη = X·direction once into the workspace, then assemble
  2004	        // η_cand = η_current + δη in parallel.
  2005	        let mut delta_eta = std::mem::take(&mut self.workspace.delta_eta);
  2006	        // Avoid wrapping/cloning `direction` into a `Coefficients` newtype just
  2007	        // to satisfy the &Coefficients overload — the view-based sibling
  2008	        // performs the identical matvec without the per-LM-attempt clone.
  2009	        self.transformed_matvec_array_into(direction, &mut delta_eta);
  2010	        Zip::from(&mut self.workspace.eta_buf)
  2011	            .and(current_eta.as_ref())
  2012	            .and(&delta_eta)
  2013	            .par_for_each(|eta, &base, &d| *eta = base + d);
  2014	        self.workspace.delta_eta = delta_eta;
  2015	
  2016	        if self.likelihood.scale.gamma_shape_is_estimated() {
  2017	            let shape =
  2018	                estimate_gamma_shape_from_eta(self.y, &self.workspace.eta_buf, self.priorweights);
  2019	            self.likelihood = self.likelihood.with_gamma_shape(shape);
  2020	        }
  2021	
  2022	        let integrated = self.covariate_se.as_ref().map(|se| IntegratedWorkingInput {
  2023	            quadctx: &self.quadctx,
  2024	            se: se.view(),
  2025	            mixture_link_state: self.link_kind.mixture_state(),
  2026	            sas_link_state: self.link_kind.sas_state(),
  2027	        });
  2028	        match &self.link_kind {
  2029	            InverseLink::Mixture(_)
  2030	            | InverseLink::LatentCLogLog(_)
  2031	            | InverseLink::Sas(_)
  2032	            | InverseLink::BetaLogistic(_) => {
  2033	                if let Some(integ) = integrated {
  2034	                    update_glmvectors_integrated_for_link(
  2035	                        integ.quadctx,
  2036	                        self.y,
  2037	                        &self.workspace.eta_buf,
  2038	                        integ.se,
  2039	                        &self.link_kind,
  2040	                        self.priorweights,
  2041	                        &mut self.lastmu,
  2042	                        &mut self.lastweights,
  2043	                        &mut self.lastz,
  2044	                        None,
  2045	                    )?;
  2046	                } else {
  2047	                    update_glmvectors(
  2048	                        self.y,
  2049	                        &self.workspace.eta_buf,
  2050	                        &self.link_kind,
  2051	                        self.priorweights,
  2052	                        &mut self.lastmu,
  2053	                        &mut self.lastweights,
  2054	                        &mut self.lastz,
  2055	                        None,
  2056	                    )?;
  2057	                }
  2058	            }
  2059	            InverseLink::Standard(_) => {
  2060	                self.likelihood.irls_update(
  2061	                    self.y,
  2062	                    &self.workspace.eta_buf,
  2063	                    self.priorweights,
  2064	                    &mut self.lastmu,
  2065	                    &mut self.lastweights,
  2066	                    &mut self.lastz,
  2067	                    integrated,
  2068	                    None,
  2069	                )?;
  2070	            }
  2071	        }
  2072	
  2073	        let deviance = self
  2074	            .likelihood
  2075	            .loglik_deviance(self.y, &self.lastmu, self.priorweights)?;
  2076	        let penalty_term = self.penalty.shifted_quadratic(beta.as_ref());
  2077	        let penalized_objective = deviance + penalty_term;
  2078	        let arithmetic_finite = penalized_objective.is_finite()
  2079	            && self.workspace.eta_buf.iter().all(|v| v.is_finite())
  2080	            && self.lastmu.iter().all(|v| v.is_finite())
  2081	            && self.lastweights.iter().all(|v| v.is_finite());
  2082	        Ok(CandidateScreen {
  2083	            penalized_objective,
  2084	            deviance,
  2085	            penalty_term,
  2086	            arithmetic_finite,
  2087	        })
  2088	    }
  2089	}
