   543	fn gaussian_reml_multi_closed_form_from_parts(
   544	    x: ArrayView2<'_, f64>,
   545	    y: ArrayView2<'_, f64>,
   546	    penalty: ArrayView2<'_, f64>,
   547	    nullspace_dim: Option<usize>,
   548	    weights: Option<ArrayView1<'_, f64>>,
   549	    init_lambda: Option<f64>,
   550	    eigen_cache: Option<&GaussianRemlEigenCache>,
   551	) -> Result<GaussianRemlMultiResult, EstimationError> {
   552	    let prepared = prepare_gaussian_reml(x, y, penalty, nullspace_dim, weights, eigen_cache)?;
   553	    let init_rho = init_lambda
   554	        .map(validate_initial_lambda)
   555	        .transpose()?
   556	        .map(f64::ln);
   557	    let rho = optimize_rho(&prepared, init_rho)?;
   558	    let eval = prepared.evaluate(rho);
   559	    let lambda = rho.exp();
   560	    let coefficients = prepared.coefficients(lambda);
   561	    let fitted = dense_ab(x, coefficients.view());
   562	    let sigma2 = prepared.sigma2(lambda);
   563	    let (reml_grad_lambda, reml_hess_lambda) =
   564	        rho_derivatives_to_lambda(lambda, eval.grad, eval.hess);
   565	    Ok(GaussianRemlMultiResult {
   566	        lambda,
   567	        rho,
   568	        coefficients,
   569	        fitted,
   570	        reml_score: eval.cost,
   571	        reml_grad_lambda,
   572	        reml_hess_lambda,
   573	        reml_grad_rho: eval.grad,
   574	        reml_hess_rho: eval.hess,
   575	        edf: eval.edf,
   576	        sigma2,
   577	        cache: prepared.cache,
   578	    })
   579	}
