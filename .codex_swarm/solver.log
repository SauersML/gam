  4212	
  4213	/// Madsen-Nielsen-Tingleff smooth Marquardt trust-region update (eq 3.17 in
  4214	/// "Methods for non-linear least squares problems", IMM Tech Univ Denmark,
  4215	/// 2nd ed 2004) for the LM accept branch. Replaces the older binary
  4216	/// `if rho > 0.25 { /10 } else { keep }` rule.
  4217	///
  4218	/// The accepted-step damping update is
  4219	///   λ_next = λ_loop · max(1/3, 1 − (2ρ − 1)³)
  4220	/// where ρ = actual_reduction / predicted_reduction is the gain ratio.
  4221	/// The cubic expression interpolates smoothly across the gain-ratio scale:
  4222	///
  4223	/// | ρ      | factor | rationale                                        |
  4224	/// |--------|-------:|--------------------------------------------------|
  4225	/// | 1.0    | 1/3    | good Newton match — mild shrink (was ÷10 before, |
  4226	/// |        |        | which over-shot to 1e-9 and forced the next      |
  4227	/// |        |        | iter to discover the over-trust by rejection)    |
  4228	/// | 0.75   | 0.875  | slight shrink                                    |
  4229	/// | 0.5    | 1.0    | no change — the model is "fine"                  |
  4230	/// | 0.25   | 1.125  | slight EXPAND on marginal accepts (new behavior; |
  4231	/// |        |        | the binary rule held lambda flat here, then the  |
  4232	/// |        |        | next iter often needed extra halvings)           |
  4233	/// | →0⁺    | →2.0   | capped at 2.0 so a just-barely-accepted step     |
  4234	/// |        |        | bumps λ toward gradient-descent at most ×2       |
  4235	///
  4236	/// Cap at 2.0 (vs unbounded `1 − (2ρ − 1)³` which diverges as ρ→−∞) is
  4237	/// safety: this branch only fires for accepted (ρ > 0) steps, but the
  4238	/// post-accept ρ can be as small as `noise_floor / predicted_reduction`,
  4239	/// where the cubic blow-up isn't physical.
  4240	#[inline]
  4241	fn madsen_lm_accept_factor(rho: f64) -> f64 {
  4242	    let two_rho_minus_one = 2.0 * rho - 1.0;
  4243	    let cube = two_rho_minus_one * two_rho_minus_one * two_rho_minus_one;
  4244	    (1.0 - cube).clamp(1.0 / 3.0, 2.0)
  4245	}
  4246	
  4247	pub fn runworking_model_pirls<M, F>(
  4248	    model: &mut M,
  4249	    mut beta: Coefficients,
  4250	    options: &WorkingModelPirlsOptions,
  4251	    mut iteration_callback: F,
  4252	) -> Result<WorkingModelPirlsResult, EstimationError>
  4253	where
  4254	    M: WorkingModel + ?Sized,
  4255	    F: FnMut(&WorkingModelIterationInfo),
  4256	{
  4257	    const LM_MAX_LAMBDA: f64 = 1e12;
  4258	    const CONSTRAINED_OBJECTIVE_PLATEAU_STREAK: usize = 20;
  4259	
  4260	    // ── Anderson acceleration of depth 1 (AA(1)) for the Fisher fixed-point ──
  4261	    // PIRLS normally uses observed-information Newton (already super-linear, no
  4262	    // help available from AA). When `force_fisher_for_rest` engages, the inner
  4263	    // iteration becomes the linearly-convergent Fisher contraction — exactly
  4264	    // the regime where AA(1) provably improves the rate. State is local to
  4265	    // this PIRLS call; costs nothing while `force_fisher_for_rest` stays
  4266	    // false because the mixing branch is never entered.
  4267	    const AA1_DAMPING_FLOOR: f64 = 1e-12;
  4268	    const AA1_DISABLE_REJECT_THRESHOLD: usize = 3;
  4269	
  4270	    struct AndersonOneState {
  4271	        prev_beta: Option<Array1<f64>>,
  4272	        prev_residual: Option<Array1<f64>>,
  4273	        r_k: Array1<f64>,
  4274	        dr: Array1<f64>,
  4275	        dx: Array1<f64>,
  4276	        beta_accel: Array1<f64>,
  4277	        consecutive_accepts: usize,
  4278	        consecutive_rejects: usize,
  4279	        disabled: bool,
  4280	        engaged_logged: bool,
  4281	    }
  4282	
  4283	    impl AndersonOneState {
  4284	        fn new() -> Self {
  4285	            Self {
  4286	                prev_beta: None,
  4287	                prev_residual: None,
  4288	                r_k: Array1::zeros(0),
  4289	                dr: Array1::zeros(0),
  4290	                dx: Array1::zeros(0),
  4291	                beta_accel: Array1::zeros(0),
  4292	                consecutive_accepts: 0,
  4293	                consecutive_rejects: 0,
  4294	                disabled: false,
  4295	                engaged_logged: false,
  4296	            }
  4297	        }
  4298	
  4299	        fn ensure_len(buf: &mut Array1<f64>, len: usize) {
  4300	            if buf.len() != len {
  4301	                *buf = Array1::zeros(len);
  4302	            }
  4303	        }
  4304	
  4305	        /// Try to produce an accelerated candidate from the plain Fisher
  4306	        /// fixed-point step `beta_new = beta_old + direction`. The fixed-point
  4307	        /// residual at this iteration is `r_k = beta_new - beta_old`.
  4308	        ///
  4309	        /// Returns `Some(beta_accel)` when a finite acceleration is available,
  4310	        /// `None` when AA should be skipped (no history yet, disabled, or
  4311	        /// numerical floor hit).
  4312	        fn aa1_mix(
  4313	            &mut self,
  4314	            beta_old: &Array1<f64>,
  4315	            beta_new: &Array1<f64>,
  4316	        ) -> Option<&Array1<f64>> {
  4317	            if self.disabled {
  4318	                return None;
  4319	            }
  4320	            let prev_beta = self.prev_beta.as_ref()?;
  4321	            let prev_residual = self.prev_residual.as_ref()?;
  4322	            if prev_beta.len() != beta_old.len() || prev_residual.len() != beta_old.len() {
  4323	                return None;
  4324	            }
  4325	            let len = beta_old.len();
  4326	            Self::ensure_len(&mut self.r_k, len);
  4327	            Self::ensure_len(&mut self.dr, len);
  4328	            Self::ensure_len(&mut self.dx, len);
  4329	            Self::ensure_len(&mut self.beta_accel, len);
  4330	            // r_k = beta_new - beta_old
  4331	            Zip::from(&mut self.r_k)
  4332	                .and(beta_new)
  4333	                .and(beta_old)
  4334	                .for_each(|r, &new, &old| *r = new - old);
  4335	            // dr = r_k - prev_residual
  4336	            Zip::from(&mut self.dr)
  4337	                .and(&self.r_k)
  4338	                .and(prev_residual)
  4339	                .for_each(|dr, &r, &prev| *dr = r - prev);
  4340	            // dx = beta_old - prev_beta
  4341	            Zip::from(&mut self.dx)
  4342	                .and(beta_old)
  4343	                .and(prev_beta)
  4344	                .for_each(|dx, &old, &prev| *dx = old - prev);
  4345	            let den = self.dr.dot(&self.dr);
  4346	            if !den.is_finite() || den < AA1_DAMPING_FLOOR {
  4347	                return None;
  4348	            }
  4349	            let alpha = (self.dr.dot(&self.r_k) / den).clamp(-1.0, 1.0);
  4350	            // beta_accel = beta_new - alpha * (dx + dr)
  4351	            for i in 0..len {
  4352	                self.beta_accel[i] = beta_new[i] - alpha * (self.dx[i] + self.dr[i]);
  4353	            }
  4354	            if !array1_is_finite(&self.beta_accel) {
  4355	                return None;
  4356	            }
  4357	            // The caller copies this borrow into its candidate buffer before the next AA mutation.
