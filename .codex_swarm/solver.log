   532	pub fn softmax_last_fixedzero(rho: &Array1<f64>) -> Array1<f64> {
   533	    let k = rho.len() + 1;
   534	    let mut logits = Vec::with_capacity(k);
   535	    let mut maxv = 0.0_f64;
   536	    for &v in rho {
   537	        maxv = maxv.max(v);
   538	        logits.push(v);
   539	    }
   540	    maxv = maxv.max(0.0);
   541	    logits.push(0.0);
   542	
   543	    let mut sum = 0.0_f64;
   544	    let mut exps = vec![0.0_f64; k];
   545	    for i in 0..k {
   546	        let e = (logits[i] - maxv).exp();
   547	        exps[i] = e;
   548	        sum += e;
   549	    }
   550	    if !sum.is_finite() || sum <= 0.0 {
   551	        return Array1::from_elem(k, 1.0 / k as f64);
   552	    }
   553	    let inv = 1.0 / sum;
   554	    Array1::from_iter(exps.into_iter().map(|v| v * inv))
   555	}
   556	
   557	/// Returns softmax weights and Jacobian wrt free logits (last logit fixed at zero).
   558	/// Jacobian shape is (K, K-1): d pi_k / d rho_j.
   559	pub fn softmaxwith_jacobian_last_fixedzero(
   560	    rho: &Array1<f64>,
   561	) -> (Array1<f64>, ndarray::Array2<f64>) {
   562	    let pi = softmax_last_fixedzero(rho);
   563	    let k = pi.len();
   564	    let m = k.saturating_sub(1);
   565	    let mut jac = ndarray::Array2::<f64>::zeros((k, m));
   566	    for j in 0..m {
   567	        let pi_j = pi[j];
   568	        for kk in 0..k {
   569	            let delta = if kk == j { 1.0 } else { 0.0 };
   570	            jac[[kk, j]] = pi[kk] * (delta - pi_j);
   571	        }
   572	    }
   573	    (pi, jac)
   574	}
