   448	#[inline]
   449	fn tanh_bound(value: f64, bound: f64) -> f64 {
   450	    let b = bound.max(f64::EPSILON);
   451	    b * (value / b).tanh()
   452	}
   453	
   454	#[inline]
   455	fn tanh_bound_d1(value: f64, bound: f64) -> f64 {
   456	    let b = bound.max(f64::EPSILON);
   457	    let t = (value / b).tanh();
   458	    1.0 - t * t
   459	}
   460	
   461	#[inline]
   462	fn tanh_bound_d2(value: f64, bound: f64) -> f64 {
   463	    let b = bound.max(f64::EPSILON);
   464	    let t = (value / b).tanh();
   465	    let s = 1.0 - t * t;
   466	    -2.0 * t * s / b
   467	}
   468	
   469	#[inline]
   470	fn tanh_bound_d3(value: f64, bound: f64) -> f64 {
   471	    let b = bound.max(f64::EPSILON);
   472	    let t = (value / b).tanh();
   473	    let s = 1.0 - t * t;
   474	    -2.0 * s * (1.0 - 3.0 * t * t) / (b * b)
   475	}
   476	
   477	#[inline]
   478	fn tanh_bound_d4(value: f64, bound: f64) -> f64 {
   479	    let b = bound.max(f64::EPSILON);
   480	    let t = (value / b).tanh();
   481	    let s = 1.0 - t * t;
   482	    8.0 * t * s * (2.0 - 3.0 * t * t) / (b * b * b)
   483	}
   484	
   485	#[inline]
   486	fn tanh_bound_d5(value: f64, bound: f64) -> f64 {
   487	    // 5th derivative of B * tanh(x/B):
   488	    //   g5 = 8 * s * (2 - 15*t^2 + 15*t^4) / B^4
   489	    // where t = tanh(x/B) and s = 1 - t^2.
   490	    let b = bound.max(f64::EPSILON);
   491	    let t = (value / b).tanh();
   492	    let s = 1.0 - t * t;
   493	    let t2 = t * t;
   494	    let b4 = b * b * b * b;
   495	    8.0 * s * (2.0 - 15.0 * t2 + 15.0 * t2 * t2) / b4
   496	}
   497	
   498	#[inline]
   499	fn sas_effective_log_delta(raw_log_delta: f64) -> (f64, f64) {
   500	    let ld_eff = tanh_bound(raw_log_delta, SAS_LOG_DELTA_BOUND);
   501	    let dld_eff_draw = tanh_bound_d1(raw_log_delta, SAS_LOG_DELTA_BOUND);
   502	    (ld_eff, dld_eff_draw)
   503	}
   504	
   505	#[inline]
   506	fn sas_delta_from_raw_log_delta(raw_log_delta: f64) -> f64 {
   507	    let (ld_eff, _) = sas_effective_log_delta(raw_log_delta);
   508	    ld_eff.exp()
   509	}
