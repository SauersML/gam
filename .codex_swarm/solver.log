   266	pub(crate) fn feasible_point_for_linear_constraints(
   267	    constraints: &LinearInequalityConstraints,
   268	    p: usize,
   269	) -> Option<Array1<f64>> {
   270	    if constraints.a.ncols() != p
   271	        || constraints.a.nrows() == 0
   272	        || constraints.b.len() != constraints.a.nrows()
   273	    {
   274	        return None;
   275	    }
   276	    if constraints.b.iter().all(|v| v.abs() <= 1e-14) {
   277	        return Some(Array1::zeros(p));
   278	    }
   279	
   280	    let gram = constraints.a.dot(&constraints.a.t());
   281	    let (u_opt, singular, vt_opt) = gram.svd(true, true).ok()?;
   282	    let (Some(u), Some(vt)) = (u_opt, vt_opt) else {
   283	        return None;
   284	    };
   285	    let max_singular = singular.iter().fold(0.0_f64, |acc, &v| acc.max(v.abs()));
   286	    let tol = 100.0 * f64::EPSILON * constraints.a.nrows().max(1) as f64 * max_singular.max(1.0);
   287	    let mut coeff = u.t().dot(&constraints.b);
   288	    for (idx, value) in coeff.iter_mut().enumerate() {
   289	        let sigma = singular[idx];
   290	        if sigma.abs() > tol {
   291	            *value /= sigma;
   292	        } else {
   293	            *value = 0.0;
   294	        }
   295	    }
   296	    let dual = vt.t().dot(&coeff);
   297	    let beta = constraints.a.t().dot(&dual);
   298	    if beta.len() != p || beta.iter().any(|v| !v.is_finite()) {
   299	        return None;
   300	    }
   301	    let slack = constraints.a.dot(&beta) - &constraints.b;
   302	    if slack.iter().all(|v| *v >= -1e-8) {
   303	        Some(beta)
   304	    } else {
   305	        None
   306	    }
   307	}
   308	
   309	fn max_linear_constraint_violation(
   310	    beta: &Array1<f64>,
   311	    constraints: &LinearInequalityConstraints,
   312	) -> (f64, usize) {
   313	    let mut worst = 0.0_f64;
   314	    let mut worst_row = 0usize;
   315	    for i in 0..constraints.a.nrows() {
   316	        let slack = constraints.a.row(i).dot(beta) - constraints.b[i];
   317	        let viol = (-slack).max(0.0);
   318	        if viol > worst {
   319	            worst = viol;
   320	            worst_row = i;
   321	        }
   322	    }
   323	    (worst, worst_row)
   324	}
