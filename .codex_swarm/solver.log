    64	const GAMMA_SHAPE_MIN: f64 = 1e-8;
    65	const GAMMA_SHAPE_MAX: f64 = 1e12;
    66	const GAMMA_SHAPE_TARGET_TOL: f64 = 1e-12;
    67	
    68	/// Saturation threshold for `|η|` diagnostics at inner P-IRLS iterates.
    69	///
    70	/// This value no longer rejects otherwise finite step candidates. Stable
    71	/// likelihood code owns tail arithmetic; this threshold only helps the rescue
