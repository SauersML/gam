   524	    row_order.sort_by_key(|&idx| groups_out[idx].first().copied().unwrap_or(usize::MAX));
   525	    if row_order.iter().enumerate().any(|(idx, &orig)| idx != orig) {
   526	        let mut a_sorted = Array2::<f64>::zeros((rank, p));
   527	        let mut b_sorted = Array1::<f64>::zeros(rank);
   528	        let mut groups_sorted = Vec::with_capacity(rank);
   529	        for (out_idx, orig_idx) in row_order.into_iter().enumerate() {
   530	            a_sorted.row_mut(out_idx).assign(&a_out.row(orig_idx));
   531	            b_sorted[out_idx] = b_out[orig_idx];
   532	            groups_sorted.push(groups_out[orig_idx].clone());
   533	        }
   534	        a_out = a_sorted;
   535	        b_out = b_sorted;
   536	        groups_out = groups_sorted;
   537	    }
   538	
   539	    if rank < k {
   540	        log::debug!(
   541	            "rank-reduced active constraints from {} to {} rows (rank deficiency {})",
   542	            k,
   543	            rank,
   544	            k - rank
   545	        );
   546	    }
   547	
   548	    (a_out, b_out, groups_out)
   549	}
   550	
   551	pub(crate) fn working_set_kkt_diagnostics_from_multipliers(
   552	    x: &Array1<f64>,
   553	    gradient: &Array1<f64>,
   554	    working_constraints: &LinearInequalityConstraints,
   555	    lambda_active_true: &Array1<f64>,
   556	    n_total_constraints: usize,
   557	) -> Result<ConstraintKktDiagnostics, EstimationError> {
   558	    let p = working_constraints.a.ncols();
   559	    if x.len() != p || gradient.len() != p {
   560	        return Err(EstimationError::InvalidInput(
   561	            "working-set KKT diagnostic dimension mismatch".to_string(),
   562	        ));
   563	    }
   564	    if lambda_active_true.len() != working_constraints.a.nrows() {
   565	        return Err(EstimationError::InvalidInput(format!(
   566	            "working-set KKT multiplier length mismatch: got {}, expected {}",
   567	            lambda_active_true.len(),
   568	            working_constraints.a.nrows()
   569	        )));
   570	    }
   571	    let m = working_constraints.a.nrows();
   572	    let mut slack = Array1::<f64>::zeros(m);
   573	    let mut primal_feasibility: f64 = 0.0;
   574	    for i in 0..m {
   575	        let s_i = working_constraints.a.row(i).dot(x) - working_constraints.b[i];
   576	        slack[i] = s_i;
   577	        primal_feasibility = primal_feasibility.max((-s_i).max(0.0));
   578	    }
   579	
   580	    let lambda = lambda_active_true.to_owned();
   581	
   582	    let mut dual_feasibility: f64 = 0.0;
   583	    let mut complementarity: f64 = 0.0;
   584	    for i in 0..m {
   585	        dual_feasibility = dual_feasibility.max((-lambda[i]).max(0.0));
   586	        complementarity = complementarity.max((lambda[i] * slack[i]).abs());
   587	    }
   588	    let stationarity = {
   589	        let mut resid = gradient.to_owned();
   590	        resid -= &working_constraints.a.t().dot(&lambda);
   591	        resid.iter().fold(0.0_f64, |acc, &v| acc.max(v.abs()))
   592	    };
   593	
   594	    Ok(ConstraintKktDiagnostics {
   595	        n_constraints: n_total_constraints,
   596	        n_active: m,
   597	        primal_feasibility,
   598	        dual_feasibility,
   599	        complementarity,
   600	        stationarity,
   601	        active_tolerance: 1e-8,
   602	    })
   603	}
   604	
   605	fn canonicalize_active_constraint_ids(
   606	    x: &Array1<f64>,
   607	    constraints: &LinearInequalityConstraints,
   608	    active: &[usize],
   609	) -> Result<Vec<usize>, EstimationError> {
   610	    if active.is_empty() {
   611	        return Ok(Vec::new());
   612	    }
   613	    let compressed_working = compress_active_working_set(x, constraints, active)?;
   614	    let mut canonical = Vec::with_capacity(compressed_working.groups.len());
   615	    for group in &compressed_working.groups {
   616	        if let Some(&active_pos) = group.first() {
   617	            canonical.push(active[active_pos]);
   618	        }
   619	    }
   620	    Ok(canonical)
   621	}
   622	
   623	fn fallback_projected_gradient_direction(
   624	    x: &Array1<f64>,
   625	    d_total: &Array1<f64>,
   626	    gradient: &Array1<f64>,
   627	    working_constraints: &LinearInequalityConstraints,
   628	    constraints: &LinearInequalityConstraints,
   629	) -> Result<Option<(Array1<f64>, Vec<usize>)>, EstimationError> {
   630	    let p = gradient.len();
   631	    if x.len() != p || d_total.len() != p || constraints.a.ncols() != p {
   632	        return Err(EstimationError::InvalidInput(
   633	            "projected-gradient fallback dimension mismatch".to_string(),
   634	        ));
   635	    }
   636	
   637	    let tangent_direction = if working_constraints.a.nrows() == 0 {
   638	        -gradient
   639	    } else {
   640	        let identity = Array2::<f64>::eye(p);
   641	        let residual = &working_constraints.b - &working_constraints.a.dot(x);
   642	        let (direction, _) =
   643	            solve_kkt_direction(&identity, gradient, &working_constraints.a, Some(&residual))?;
   644	        direction
   645	    };
   646	
   647	    if !array1_is_finite(&tangent_direction) {
   648	        return Ok(None);
   649	    }
   650	
   651	    let step_inf = tangent_direction
   652	        .iter()
   653	        .fold(0.0_f64, |acc, &value| acc.max(value.abs()));
   654	    if step_inf <= 1e-12 {
   655	        let active = canonicalize_active_constraint_ids(x, constraints, &[])?;
   656	        return Ok(Some((d_total.clone(), active)));
   657	    }
   658	
   659	    let directional_derivative = gradient.dot(&tangent_direction);
   660	    if !directional_derivative.is_finite() || directional_derivative >= 0.0 {
   661	        return Ok(None);
   662	    }
   663	
   664	    let mut alpha = 1.0_f64;
   665	    for i in 0..constraints.a.nrows() {
   666	        let ai = constraints.a.row(i);
   667	        let slack = ai.dot(x) - constraints.b[i];
   668	        let ai_d = ai.dot(&tangent_direction);
   669	        if let Some(candidate) = boundary_hit_step_fraction(slack, ai_d, alpha) {
   670	            alpha = candidate;
   671	        }
   672	    }
   673	    if !alpha.is_finite() || alpha <= 0.0 {
   674	        return Ok(None);
   675	    }
   676	
   677	    let fallback_step = tangent_direction * alpha;
   678	    let new_x = x + &fallback_step;
   679	    let (worst, _) = max_linear_constraint_violation(&new_x, constraints);
   680	    if worst > 1e-8 {
   681	        return Ok(None);
   682	    }
   683	    let active = (0..constraints.a.nrows())
   684	        .filter(|&i| constraints.a.row(i).dot(&new_x) - constraints.b[i] <= 1e-10)
   685	        .collect::<Vec<_>>();
   686	    let active = canonicalize_active_constraint_ids(&new_x, constraints, &active)?;
   687	    Ok(Some((d_total + &fallback_step, active)))
   688	}
   689	
   690	fn log_active_set_transition(
   691	    event: &str,
   692	    iteration: usize,
   693	    active_len: usize,
   694	    constraint: Option<usize>,
   695	) {
   696	    log::debug!(
   697	        "[active-set/QP] iter={} event={} active={} constraint={}",
   698	        iteration,
   699	        event,
   700	        active_len,
   701	        constraint
   702	            .map(|idx| idx.to_string())
   703	            .unwrap_or_else(|| "NA".to_string()),
   704	    );
   705	}
   706	
   707	fn solve_newton_direction_with_linear_constraints_impl(
   708	    hessian: &Array2<f64>,
   709	    gradient: &Array1<f64>,
   710	    beta: &Array1<f64>,
   711	    constraints: &LinearInequalityConstraints,
   712	    direction_out: &mut Array1<f64>,
   713	    active_hint: Option<&mut Vec<usize>>,
   714	    max_iterations: usize,
   715	) -> Result<(), EstimationError> {
   716	    let p = gradient.len();
   717	    if direction_out.len() != p {
   718	        *direction_out = Array1::zeros(p);
   719	    }
   720	    let m = constraints.a.nrows();
   721	    if constraints.a.ncols() != p || constraints.b.len() != m || beta.len() != p {
   722	        return Err(EstimationError::InvalidInput(format!(
   723	            "linear constraint shape mismatch: A={}x{}, b={}, p={}",
   724	            constraints.a.nrows(),
   725	            constraints.a.ncols(),
   726	            constraints.b.len(),
   727	            p
   728	        )));
   729	    }
   730	
   731	    let tol_active = 1e-10;
   732	    let tol_step = 1e-12;
   733	    let tol_dual = 1e-10;
   734	    let mut x = beta.to_owned();
   735	    let mut d_total = Array1::<f64>::zeros(p);
   736	    let mut g_cur = gradient.to_owned();
   737	
   738	    let has_active_hint = active_hint
   739	        .as_ref()
   740	        .map(|hint| !hint.is_empty())
   741	        .unwrap_or(false);
   742	    if !has_active_hint && solve_newton_direction_dense(hessian, gradient, direction_out).is_ok() {
   743	        let candidate = beta + &*direction_out;
   744	        let mut feasible = true;
   745	        for i in 0..m {
   746	            let slack = constraints.a.row(i).dot(&candidate) - constraints.b[i];
   747	            if slack < -1e-10 {
   748	                feasible = false;
   749	                break;
   750	            }
   751	        }
   752	        if feasible {
   753	            return Ok(());
   754	        }
   755	    }
   756	
   757	    let mut active: Vec<usize> = Vec::new();
   758	    let mut is_active = vec![false; m];
   759	    if let Some(hint) = active_hint.as_ref() {
   760	        for &idx in hint.iter() {
   761	            if idx < m && !is_active[idx] {
   762	                active.push(idx);
   763	                is_active[idx] = true;
   764	                log_active_set_transition("warm-add", 0, active.len(), Some(idx));
   765	            }
   766	        }
   767	    }
   768	    for i in 0..m {
   769	        let slack = constraints.a.row(i).dot(&x) - constraints.b[i];
   770	        if slack <= tol_active && !is_active[i] {
   771	            active.push(i);
   772	            is_active[i] = true;
   773	            log_active_set_transition("initial-boundary-add", 0, active.len(), Some(i));
   774	        }
   775	    }
   776	
   777	    for iteration in 0..max_iterations {
   778	        let compressed_working = compress_active_working_set(&x, constraints, &active)?;
   779	        let mut residualw = Array1::<f64>::zeros(compressed_working.constraints.a.nrows());
   780	        for r in 0..compressed_working.constraints.a.nrows() {
   781	            residualw[r] = compressed_working.constraints.b[r]
   782	                - compressed_working.constraints.a.row(r).dot(&x);
   783	        }
   784	        let (d, lambdaw) = solve_kkt_direction(
   785	            hessian,
   786	            &g_cur,
   787	            &compressed_working.constraints.a,
   788	            Some(&residualw),
   789	        )?;
   790	        let step_norm = d.iter().map(|v| v * v).sum::<f64>().sqrt();
   791	        if step_norm <= tol_step {
   792	            if compressed_working.groups.is_empty() {
   793	                direction_out.assign(&d_total);
   794	                return Ok(());
   795	            }
   796	            let mut remove_pos: Option<usize> = None;
   797	            let mut most_negative_true = -tol_dual;
   798	            for (group_pos, &lam_sys) in lambdaw.iter().enumerate() {
   799	                let lam_true = -lam_sys;
   800	                if lam_true < most_negative_true {
   801	                    most_negative_true = lam_true;
   802	                    remove_pos = Some(group_pos);
   803	                }
   804	            }
   805	            if let Some(group_pos) = remove_pos {
   806	                let mut removal_positions = compressed_working.groups[group_pos].clone();
   807	                removal_positions.sort_unstable_by(|left, right| right.cmp(left));
   808	                for active_pos in removal_positions {
   809	                    let idx = active.remove(active_pos);
   810	                    is_active[idx] = false;
   811	                    log_active_set_transition(
   812	                        "remove-negative-dual",
   813	                        iteration,
   814	                        active.len(),
   815	                        Some(idx),
   816	                    );
   817	                }
   818	                continue;
   819	            }
   820	            if let Some(hint) = active_hint {
   821	                hint.clear();
   822	                hint.extend(canonicalize_active_constraint_ids(
   823	                    &x,
   824	                    constraints,
   825	                    &active,
   826	                )?);
   827	            }
   828	            direction_out.assign(&d_total);
   829	            return Ok(());
   830	        }
   831	
   832	        let mut alpha = 1.0_f64;
   833	        for i in 0..m {
   834	            if is_active[i] {
   835	                continue;
   836	            }
   837	            let ai = constraints.a.row(i);
   838	            let slack = ai.dot(&x) - constraints.b[i];
   839	            let ai_d = ai.dot(&d);
   840	            if let Some(cand) = boundary_hit_step_fraction(slack, ai_d, alpha) {
   841	                alpha = cand;
   842	            }
   843	        }
   844	
   845	        ndarray::Zip::from(&mut x)
   846	            .and(&mut d_total)
   847	            .and(&d)
   848	            .for_each(|x_i, dt_i, &d_i| {
   849	                let alpha_d = alpha * d_i;
   850	                *x_i += alpha_d;
   851	                *dt_i += alpha_d;
   852	            });
   853	        g_cur = gradient + &hessian.dot(&d_total);
   854	
   855	        let mut added_new_active = false;
   856	        for i in 0..m {
   857	            if is_active[i] {
   858	                continue;
   859	            }
   860	            let slack = constraints.a.row(i).dot(&x) - constraints.b[i];
   861	            if slack <= tol_active {
   862	                active.push(i);
   863	                is_active[i] = true;
   864	                added_new_active = true;
   865	                log_active_set_transition("blocking-add", iteration, active.len(), Some(i));
   866	            }
   867	        }
   868	
   869	        if active.is_empty() && !added_new_active {
   870	            if let Some(hint) = active_hint {
   871	                hint.clear();
   872	            }
   873	            direction_out.assign(&d_total);
   874	            return Ok(());
   875	        }
   876	    }
   877	
   878	    let compressed_working = compress_active_working_set(&x, constraints, &active)?;
   879	    let mut residualw = Array1::<f64>::zeros(compressed_working.constraints.a.nrows());
   880	    for r in 0..compressed_working.constraints.a.nrows() {
   881	        residualw[r] =
   882	            compressed_working.constraints.b[r] - compressed_working.constraints.a.row(r).dot(&x);
   883	    }
   884	    let (_, lambdaw) = solve_kkt_direction(
   885	        hessian,
   886	        &g_cur,
   887	        &compressed_working.constraints.a,
   888	        Some(&residualw),
   889	    )?;
   890	    let lambda_true = lambdaw.mapv(|lam_sys| -lam_sys);
   891	    let (worst, row) = max_linear_constraint_violation(&x, constraints);
   892	    let working_kkt = working_set_kkt_diagnostics_from_multipliers(
   893	        &x,
   894	        &g_cur,
   895	        &compressed_working.constraints,
   896	        &lambda_true,
   897	        m,
   898	    )?;
   899	    let kkt = compute_constraint_kkt_diagnostics(&x, &g_cur, constraints);
   900	    let grad_inf = g_cur.iter().fold(0.0_f64, |acc, &v| acc.max(v.abs()));
   901	    let stationarity_rel = working_kkt.stationarity / grad_inf.max(1.0);
   902	    let step_inf = d_total.iter().fold(0.0_f64, |acc, &v| acc.max(v.abs()));
   903	    let hd_total = hessian.dot(&d_total);
   904	    let predicted_delta = gradient.dot(&d_total)
   905	        + 0.5
   906	            * d_total
   907	                .iter()
   908	                .zip(hd_total.iter())
   909	                .map(|(a, b)| a * b)
   910	                .sum::<f64>();
   911	    let kkt_strong_ok = (working_kkt.stationarity <= 2e-6 || stationarity_rel <= 2e-6)
   912	        && working_kkt.complementarity <= 1e-6;
   913	    let model_descent_ok = predicted_delta <= -1e-10 * (1.0 + grad_inf * step_inf);
   914	    let near_null_step_ok = step_inf <= 1e-10;
   915	    let degenerate_boundary_ok = compressed_working.is_degenerate_face()
   916	        && worst <= 1e-8
   917	        && working_kkt.primal_feasibility <= 1e-8
   918	        && working_kkt.complementarity <= 1e-6
   919	        && (working_kkt.stationarity <= 1e-3 || stationarity_rel <= 2e-6 || near_null_step_ok);
   920	    if worst <= 1e-8
   921	        && ((working_kkt.dual_feasibility <= 1e-8
   922	            && (kkt_strong_ok || model_descent_ok || near_null_step_ok))
   923	            || degenerate_boundary_ok)
   924	    {
   925	        if let Some(hint) = active_hint {
   926	            hint.clear();
   927	            hint.extend(canonicalize_active_constraint_ids(
   928	                &x,
   929	                constraints,
   930	                &active,
   931	            )?);
   932	        }
   933	        direction_out.assign(&d_total);
   934	        return Ok(());
   935	    }
   936	    if let Some((fallback_direction, fallback_active)) = fallback_projected_gradient_direction(
   937	        &x,
   938	        &d_total,
   939	        &g_cur,
   940	        &compressed_working.constraints,
   941	        constraints,
   942	    )? {
   943	        if let Some(hint) = active_hint {
   944	            hint.clear();
   945	            hint.extend(fallback_active);
   946	        }
   947	        direction_out.assign(&fallback_direction);
   948	        return Ok(());
   949	    }
   950	    Err(EstimationError::ParameterConstraintViolation(format!(
   951	        "linear-constrained Newton active-set failed to converge; max(Aβ-b violation)={worst:.3e} at row {row}; KKT[primal={:.3e}, dual={:.3e}, comp={:.3e}, stat={:.3e}, active={}/{}]; diagnostic-reconstruction[dual={:.3e}, stat={:.3e}]",
   952	        working_kkt.primal_feasibility,
   953	        working_kkt.dual_feasibility,
   954	        working_kkt.complementarity,
   955	        working_kkt.stationarity,
   956	        working_kkt.n_active,
   957	        working_kkt.n_constraints,
   958	        kkt.dual_feasibility,
   959	        kkt.stationarity
   960	    )))
   961	}
   962	
   963	pub(crate) fn solve_newton_direction_with_linear_constraints(
   964	    hessian: &Array2<f64>,
   965	    gradient: &Array1<f64>,
   966	    beta: &Array1<f64>,
   967	    constraints: &LinearInequalityConstraints,
   968	    direction_out: &mut Array1<f64>,
   969	    active_hint: Option<&mut Vec<usize>>,
   970	) -> Result<(), EstimationError> {
   971	    let max_iterations = (gradient.len() + constraints.a.nrows() + 8) * 4;
   972	    solve_newton_direction_with_linear_constraints_impl(
   973	        hessian,
   974	        gradient,
   975	        beta,
   976	        constraints,
   977	        direction_out,
   978	        active_hint,
   979	        max_iterations,
   980	    )
   981	}
   982	
   983	pub(crate) fn solve_quadratic_with_linear_constraints(
   984	    hessian: &Array2<f64>,
   985	    rhs: &Array1<f64>,
   986	    beta_start: &Array1<f64>,
   987	    constraints: &LinearInequalityConstraints,
   988	    warm_active_set: Option<&[usize]>,
   989	) -> Result<(Array1<f64>, Vec<usize>), EstimationError> {
   990	    if hessian.ncols() != hessian.nrows()
   991	        || rhs.len() != hessian.nrows()
   992	        || beta_start.len() != hessian.nrows()
   993	        || constraints.a.ncols() != hessian.nrows()
   994	    {
   995	        return Err(EstimationError::InvalidInput(
   996	            "constrained quadratic solve: system dimension mismatch".to_string(),
   997	        ));
   998	    }
   999	    let gradient = hessian.dot(beta_start) - rhs;
  1000	    let mut delta = Array1::<f64>::zeros(beta_start.len());
  1001	    let mut active_hint = warm_active_set.map_or_else(Vec::new, |active| active.to_vec());
  1002	    solve_newton_direction_with_linear_constraints(
  1003	        hessian,
  1004	        &gradient,
  1005	        beta_start,
  1006	        constraints,
  1007	        &mut delta,
  1008	        Some(&mut active_hint),
  1009	    )?;
  1010	    Ok((beta_start + &delta, active_hint))
  1011	}
