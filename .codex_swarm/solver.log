  1022	    #[test]
  1023	    fn maxiter_accepts_current_boundary_solution() {
  1024	        let hessian = array![[1.0]];
  1025	        let gradient = array![-1.0];
  1026	        let beta = array![0.0];
  1027	        let constraints = LinearInequalityConstraints {
  1028	            a: array![[-1.0]],
  1029	            b: array![-0.1],
  1030	        };
  1031	        let mut direction = Array1::zeros(1);
  1032	        let mut active_hint = Vec::new();
  1033	
  1034	        solve_newton_direction_with_linear_constraints_impl(
  1035	            &hessian,
  1036	            &gradient,
  1037	            &beta,
  1038	            &constraints,
  1039	            &mut direction,
  1040	            Some(&mut active_hint),
  1041	            1,
  1042	        )
  1043	        .expect("solver should accept the current boundary solution at the iteration limit");
  1044	
  1045	        assert_relative_eq!(direction[0], 0.1, epsilon = 1e-12);
  1046	        assert_eq!(active_hint, vec![0]);
  1047	    }
