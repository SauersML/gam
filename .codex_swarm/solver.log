  2670	impl DenseOuterState {
  2671	    /// Compute the upper triangle of XᵀWX = Σᵢ wᵢ · xᵢ xᵢᵀ into
  2672	    /// `self.xtwx_dense`.
  2673	    ///
  2674	    /// Decides serial vs parallel from a cost model on total estimated FLOPs
  2675	    /// and the number of available rayon workers. In parallel mode each
  2676	    /// worker accumulates into a thread-local p×p buffer (allocated once and
  2677	    /// reused across calls); the workers are summed into `xtwx_dense` in
  2678	    /// place, preserving its allocation rather than replacing it with a
  2679	    /// freshly-allocated reduction result.
  2680	    fn compute(
  2681	        &mut self,
  2682	        x_t: SparseColMatRef<'_, usize, f64>,
  2683	        weights: &Array1<f64>,
  2684	        n: usize,
  2685	        p: usize,
  2686	    ) {
  2687	        debug_assert_eq!(self.xtwx_dense.dim(), (p, p));
  2688	        self.xtwx_dense.fill(0.0);
  2689	        if n == 0 || p == 0 {
  2690	            return;
  2691	        }
  2692	        let xtwx_start = std::time::Instant::now();
  2693	
  2694	        // Cost model: per-row outer-product is nnz(xᵢ)². With avg_nnz ≈
  2695	        // nnz_total / n, total work ≈ nnz_total² / n. For designs with
  2696	        // uniform row support (e.g. B-splines) this proxy is tight; for
  2697	        // mixed-support designs it is an order-of-magnitude estimate, which
  2698	        // is all we need to gate parallel spawn.
  2699	        let nnz_total = x_t.symbolic().row_idx().len() as u64;
  2700	        let work = nnz_total
  2701	            .saturating_mul(nnz_total)
  2702	            .checked_div(n as u64)
  2703	            .unwrap_or(u64::MAX);
  2704	        let n_threads = rayon::current_num_threads();
  2705	        let parallelize = n_threads > 1 && work >= DENSE_OUTER_PARALLEL_FLOP_THRESHOLD;
  2706	
  2707	        if !parallelize {
  2708	            accumulate_outer_upper(&mut self.xtwx_dense, x_t, weights, 0..n);
  2709	            log::info!(
  2710	                "[STAGE] PIRLS dense XᵀWX assembly (serial) n={} p={} flops~{} elapsed={:.3}s",
  2711	                n,
  2712	                p,
  2713	                (n as u64).saturating_mul((p as u64).saturating_mul(p as u64)),
  2714	                xtwx_start.elapsed().as_secs_f64(),
  2715	            );
  2716	            return;
  2717	        }
  2718	
  2719	        // Bounded thread allocation: exactly `n_threads` p×p buffers, one
  2720	        // per worker, reused across calls.
  2721	        if self.thread_buffers.len() != n_threads {
  2722	            self.thread_buffers
  2723	                .resize_with(n_threads, || Array2::<f64>::zeros((p, p)));
  2724	        }
  2725	        let chunk = n.div_ceil(n_threads);
  2726	        self.thread_buffers
  2727	            .par_iter_mut()
  2728	            .enumerate()
  2729	            .for_each(|(t, buf)| {
  2730	                buf.fill(0.0);
  2731	                let start = t * chunk;
  2732	                let end = (start + chunk).min(n);
  2733	                if start < end {
  2734	                    accumulate_outer_upper(buf, x_t, weights, start..end);
  2735	                }
  2736	            });
  2737	
  2738	        // Reduce per-thread buffers into the cached output. The += preserves
  2739	        // `xtwx_dense`'s storage; we never reallocate it.
  2740	        for buf in &self.thread_buffers {
  2741	            self.xtwx_dense += buf;
  2742	        }
  2743	        log::info!(
  2744	            "[STAGE] PIRLS dense XᵀWX assembly (parallel, threads={}) n={} p={} flops~{} elapsed={:.3}s",
  2745	            rayon::current_num_threads(),
  2746	            n,
  2747	            p,
  2748	            (n as u64).saturating_mul((p as u64).saturating_mul(p as u64)),
  2749	            xtwx_start.elapsed().as_secs_f64(),
  2750	        );
  2751	    }
  2752	}
