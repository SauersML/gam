   653	    /// Cross-trace for the logdet Hessian:
   654	    /// `∂²_{ij} log|R_ε(H)| = tr(G_ε Ḧ_{ij}) + spectral_cross(Ḣ_i, Ḣ_j)`.
   655	    ///
   656	    /// This method computes the `spectral_cross(Ḣ_i, Ḣ_j)` part, which for
   657	    /// non-spectral backends equals `-tr(H⁻¹ Ḣ_j H⁻¹ Ḣ_i)`.
   658	    ///
   659	    /// For spectral regularization, the divided-difference kernel Γ_{ab} replaces
   660	    /// the simple product of inverses.
   661	    fn trace_logdet_hessian_cross(&self, h_i: &Array2<f64>, h_j: &Array2<f64>) -> f64 {
   662	        // Default: standard formula -tr(H⁻¹ Ḣ_j H⁻¹ Ḣ_i) = -⟨Y_j^T, Y_i⟩_F
   663	        // where Y_i = H⁻¹ Ḣ_i.
   664	        let y_i = self.solve_multi(h_i);
   665	        if std::ptr::eq(h_i, h_j) {
   666	            return -trace_matrix_product(&y_i, &y_i);
   667	        }
   668	        let y_j = self.solve_multi(h_j);
   669	        -trace_matrix_product(&y_j, &y_i)
