   587	pub fn component_inverse_link_jet(component: LinkComponent, eta: f64) -> InverseLinkJet {
   588	    canonicalize_jet(match component {
   589	        LinkComponent::Logit => {
   590	            let jet = logit_inverse_link_jet5(eta);
   591	            InverseLinkJet {
   592	                mu: jet.mu,
   593	                d1: jet.d1,
   594	                d2: jet.d2,
   595	                d3: jet.d3,
   596	            }
   597	        }
   598	        LinkComponent::Probit => probit_jet(eta),
   599	        LinkComponent::CLogLog => {
   600	            if eta.is_nan() {
   601	                return InverseLinkJet {
   602	                    mu: f64::NAN,
   603	                    d1: f64::NAN,
   604	                    d2: f64::NAN,
   605	                    d3: f64::NAN,
   606	                };
   607	            }
   608	            let t = eta.exp();
   609	            if !t.is_finite() {
   610	                return InverseLinkJet {
   611	                    mu: 1.0,
   612	                    d1: 0.0,
   613	                    d2: 0.0,
   614	                    d3: 0.0,
   615	                };
   616	            }
   617	            InverseLinkJet {
   618	                mu: -(-t).exp_m1(),
   619	                d1: stable_nonnegative_poly_times_exp_neg(t, &[0.0, 1.0]),
   620	                d2: stable_nonnegative_poly_times_exp_neg(t, &[0.0, 1.0, -1.0]),
   621	                d3: stable_nonnegative_poly_times_exp_neg(t, &[0.0, 1.0, -3.0, 1.0]),
   622	            }
   623	        }
   624	        LinkComponent::LogLog => {
   625	            if eta.is_nan() {
   626	                return InverseLinkJet {
   627	                    mu: f64::NAN,
   628	                    d1: f64::NAN,
   629	                    d2: f64::NAN,
   630	                    d3: f64::NAN,
   631	                };
   632	            }
   633	            let r = (-eta).exp();
   634	            if !r.is_finite() {
   635	                return InverseLinkJet {
   636	                    mu: 0.0,
   637	                    d1: 0.0,
   638	                    d2: 0.0,
   639	                    d3: 0.0,
   640	                };
   641	            }
   642	            InverseLinkJet {
   643	                mu: (-r).exp(),
   644	                d1: stable_nonnegative_poly_times_exp_neg(r, &[0.0, 1.0]),
   645	                d2: stable_nonnegative_poly_times_exp_neg(r, &[0.0, -1.0, 1.0]),
   646	                d3: stable_nonnegative_poly_times_exp_neg(r, &[0.0, 1.0, -3.0, 1.0]),
   647	            }
   648	        }
   649	        LinkComponent::Cauchit => {
   650	            if eta.is_nan() {
   651	                return InverseLinkJet {
   652	                    mu: f64::NAN,
   653	                    d1: f64::NAN,
   654	                    d2: f64::NAN,
   655	                    d3: f64::NAN,
   656	                };
   657	            }
   658	            let den = 1.0 + eta * eta;
   659	            let d1 = if eta.is_finite() {
   660	                1.0 / (std::f64::consts::PI * den)
   661	            } else {
   662	                0.0
   663	            };
   664	            let d2 = if eta.is_finite() {
   665	                -2.0 * eta / (std::f64::consts::PI * den * den)
   666	            } else {
   667	                0.0
   668	            };
   669	            let d3 = if eta.is_finite() {
   670	                (6.0 * eta * eta - 2.0) / (std::f64::consts::PI * den * den * den)
   671	            } else {
   672	                0.0
   673	            };
   674	            InverseLinkJet {
   675	                mu: 0.5 + eta.atan() / std::f64::consts::PI,
   676	                d1,
   677	                d2,
   678	                d3,
   679	            }
   680	        }
   681	    })
   682	}
