    41	        if rs_transformed.len() != k_count {
    42	            return Err(EstimationError::LayoutError(format!(
    43	                "Penalty root/lambda count mismatch in structural logdet derivatives: roots={}, lambdas={}",
    44	                rs_transformed.len(),
    45	                k_count
    46	            )));
