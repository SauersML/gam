  1085	fn validate_gaussian_reml_backward_upstreams(
  1086	    x: ArrayView2<'_, f64>,
  1087	    y: ArrayView2<'_, f64>,
  1088	    penalty: ArrayView2<'_, f64>,
  1089	    upstream_lambda: f64,
  1090	    upstream_coefficients: Option<ArrayView2<'_, f64>>,
  1091	    upstream_fitted: Option<ArrayView2<'_, f64>>,
  1092	    upstream_reml_score: f64,
  1093	    upstream_edf: f64,
  1094	) -> Result<(), EstimationError> {
  1095	    if !(upstream_lambda.is_finite() && upstream_reml_score.is_finite() && upstream_edf.is_finite())
  1096	    {
  1097	        return Err(EstimationError::InvalidInput(
  1098	            "Gaussian REML backward upstream scalars must be finite".to_string(),
  1099	        ));
  1100	    }
  1101	    if let Some(upstream_coefficients) = upstream_coefficients {
  1102	        if upstream_coefficients.dim() != (x.ncols(), y.ncols()) {
  1103	            return Err(EstimationError::InvalidInput(format!(
  1104	                "Gaussian REML backward coefficient upstream shape mismatch: expected {}x{}, got {}x{}",
  1105	                x.ncols(),
  1106	                y.ncols(),
  1107	                upstream_coefficients.nrows(),
  1108	                upstream_coefficients.ncols()
  1109	            )));
  1110	        }
  1111	        if upstream_coefficients.iter().any(|value| !value.is_finite()) {
  1112	            return Err(EstimationError::InvalidInput(
  1113	                "Gaussian REML backward coefficient upstream must be finite".to_string(),
  1114	            ));
  1115	        }
  1116	    }
  1117	    if let Some(upstream_fitted) = upstream_fitted {
  1118	        if upstream_fitted.dim() != y.dim() {
  1119	            return Err(EstimationError::InvalidInput(format!(
  1120	                "Gaussian REML backward fitted upstream shape mismatch: expected {}x{}, got {}x{}",
  1121	                y.nrows(),
  1122	                y.ncols(),
  1123	                upstream_fitted.nrows(),
  1124	                upstream_fitted.ncols()
  1125	            )));
  1126	        }
  1127	        if upstream_fitted.iter().any(|value| !value.is_finite()) {
  1128	            return Err(EstimationError::InvalidInput(
  1129	                "Gaussian REML backward fitted upstream must be finite".to_string(),
  1130	            ));
  1131	        }
  1132	    }
  1133	    validate_gaussian_reml_design(x, penalty, None)?;
  1134	    Ok(())
  1135	}
