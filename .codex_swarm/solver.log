  1276	#[inline]
  1277	fn effective_kkt_tolerance(options: &WorkingModelPirlsOptions) -> f64 {
  1278	    match options.adaptive_kkt_tolerance {
  1279	        Some(adaptive)
  1280	            if adaptive.eta.is_finite()
  1281	                && adaptive.floor.is_finite()
  1282	                && adaptive.ceiling.is_finite()
  1283	                && adaptive.outer_grad_norm.is_finite()
  1284	                && adaptive.eta >= 0.0
  1285	                && adaptive.floor > 0.0
  1286	                && adaptive.ceiling >= adaptive.floor
  1287	                && adaptive.outer_grad_norm >= 0.0 =>
  1288	        {
  1289	            (adaptive.eta * adaptive.outer_grad_norm).clamp(adaptive.floor, adaptive.ceiling)
  1290	        }
  1291	        _ => options.convergence_tolerance,
  1292	    }
  1293	}
