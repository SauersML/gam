    93	        .local
    94	        .eigh(Side::Lower)
    95	        .map_err(|e| format!("Penalty component eigendecomposition failed: {e}"))?;
    96	    let threshold = super::unified::positive_eigenvalue_threshold(evals.as_slice().unwrap());
