  9694	#[inline]
  9695	pub fn calculate_deviance(
  9696	    y: ArrayView1<f64>,
  9697	    mu: &Array1<f64>,
  9698	    likelihood: GlmLikelihoodSpec,
  9699	    priorweights: ArrayView1<f64>,
  9700	) -> f64 {
  9701	    const EPS: f64 = 1e-8;
  9702	    match likelihood.family {
  9703	        GlmLikelihoodFamily::BinomialLogit
  9704	        | GlmLikelihoodFamily::BinomialProbit
  9705	        | GlmLikelihoodFamily::BinomialCLogLog
  9706	        | GlmLikelihoodFamily::BinomialSas
  9707	        | GlmLikelihoodFamily::BinomialBetaLogistic
  9708	        | GlmLikelihoodFamily::BinomialMixture => {
  9709	            use rayon::iter::{IntoParallelIterator, ParallelIterator};
  9710	            let total_residual: f64 = (0..y.len())
  9711	                .into_par_iter()
  9712	                .map(|i| {
  9713	                    let yi = y[i];
  9714	                    let mui_c = mu[i];
  9715	                    let wi = priorweights[i];
  9716	                    let term1 = if yi > EPS {
  9717	                        yi * (yi.ln() - mui_c.ln())
  9718	                    } else {
  9719	                        0.0
  9720	                    };
  9721	                    let term2 = if yi < 1.0 - EPS {
  9722	                        (1.0 - yi) * ((1.0 - yi).ln() - (1.0 - mui_c).ln())
  9723	                    } else {
  9724	                        0.0
  9725	                    };
  9726	                    wi * (term1 + term2)
  9727	                })
  9728	                .sum();
  9729	            2.0 * total_residual
  9730	        }
  9731	        GlmLikelihoodFamily::GaussianIdentity => ndarray::Zip::from(y)
  9732	            .and(mu)
  9733	            .and(priorweights)
  9734	            .map_collect(|&yi, &mui, &wi| wi * (yi - mui) * (yi - mui))
  9735	            .sum(),
  9736	        GlmLikelihoodFamily::PoissonLog => {
  9737	            use rayon::iter::{IntoParallelIterator, ParallelIterator};
  9738	            let total: f64 = (0..y.len())
  9739	                .into_par_iter()
  9740	                .map(|i| {
  9741	                    let yi = y[i];
  9742	                    let mui_c = mu[i].max(EPS);
  9743	                    let term = if yi > EPS {
  9744	                        yi * (yi / mui_c).ln() - (yi - mui_c)
  9745	                    } else {
  9746	                        mui_c
  9747	                    };
  9748	                    priorweights[i] * term
  9749	                })
  9750	                .sum();
  9751	            2.0 * total
  9752	        }
  9753	        GlmLikelihoodFamily::GammaLog => {
  9754	            let shape = likelihood.gamma_shape().unwrap_or(1.0);
  9755	            use rayon::iter::{IntoParallelIterator, ParallelIterator};
  9756	            let total: f64 = (0..y.len())
  9757	                .into_par_iter()
  9758	                .map(|i| {
  9759	                    let yi_c = y[i].max(EPS);
  9760	                    let mui_c = mu[i].max(EPS);
  9761	                    let ratio = yi_c / mui_c;
  9762	                    priorweights[i] * shape * (ratio - 1.0 - ratio.ln())
  9763	                })
  9764	                .sum();
  9765	            2.0 * total
  9766	        }
  9767	    }
  9768	}
  9769	
  9770	#[inline]
  9771	pub(crate) fn calculate_loglikelihood_omitting_constants(
  9772	    y: ArrayView1<f64>,
  9773	    mu: &Array1<f64>,
  9774	    likelihood: GlmLikelihoodSpec,
  9775	    priorweights: ArrayView1<f64>,
  9776	) -> f64 {
  9777	    const EPS: f64 = 1e-8;
  9778	    use rayon::iter::{IntoParallelIterator, ParallelIterator};
  9779	    let n = y.len();
  9780	    match likelihood.family {
  9781	        GlmLikelihoodFamily::GaussianIdentity => (0..n)
  9782	            .into_par_iter()
  9783	            .map(|i| {
  9784	                let resid = y[i] - mu[i];
  9785	                -0.5 * priorweights[i] * resid * resid
  9786	            })
  9787	            .sum(),
  9788	        GlmLikelihoodFamily::BinomialLogit
  9789	        | GlmLikelihoodFamily::BinomialProbit
  9790	        | GlmLikelihoodFamily::BinomialCLogLog
  9791	        | GlmLikelihoodFamily::BinomialSas
  9792	        | GlmLikelihoodFamily::BinomialBetaLogistic
  9793	        | GlmLikelihoodFamily::BinomialMixture => (0..n)
  9794	            .into_par_iter()
  9795	            .map(|i| {
  9796	                let mui_c = mu[i].clamp(EPS, 1.0 - EPS);
  9797	                priorweights[i] * (y[i] * mui_c.ln() + (1.0 - y[i]) * (1.0 - mui_c).ln())
  9798	            })
  9799	            .sum(),
  9800	        GlmLikelihoodFamily::PoissonLog => (0..n)
  9801	            .into_par_iter()
  9802	            .map(|i| {
  9803	                let mui_c = mu[i].max(EPS);
  9804	                let log_term = if y[i] > 0.0 { y[i] * mui_c.ln() } else { 0.0 };
  9805	                priorweights[i] * (log_term - mui_c)
  9806	            })
  9807	            .sum(),
  9808	        GlmLikelihoodFamily::GammaLog => gamma_loglikelihood_with_shape(
  9809	            y,
  9810	            mu,
  9811	            priorweights,
  9812	            likelihood.gamma_shape().unwrap_or(1.0),
  9813	        ),
  9814	    }
  9815	}
