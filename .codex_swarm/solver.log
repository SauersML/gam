  1251	#[inline]
  1252	pub fn mixture_inverse_link_jet(state: &MixtureLinkState, eta: f64) -> InverseLinkJet {
  1253	    let mut mu = 0.0_f64;
  1254	    let mut d1 = 0.0_f64;
  1255	    let mut d2 = 0.0_f64;
  1256	    let mut d3 = 0.0_f64;
  1257	    let k = state.components.len().min(state.pi.len());
  1258	    for i in 0..k {
  1259	        let jet = component_inverse_link_jet(state.components[i], eta);
  1260	        let w = state.pi[i];
  1261	        mu += w * jet.mu;
  1262	        d1 += w * jet.d1;
  1263	        d2 += w * jet.d2;
  1264	        d3 += w * jet.d3;
  1265	    }
  1266	    InverseLinkJet { mu, d1, d2, d3 }
  1267	}
