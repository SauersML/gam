   395	pub(crate) fn compress_active_working_set(
   396	    x: &Array1<f64>,
   397	    constraints: &LinearInequalityConstraints,
   398	    active: &[usize],
   399	) -> Result<CompressedActiveWorkingSet, EstimationError> {
   400	    let p = constraints.a.ncols();
   401	    if x.len() != p {
   402	        return Err(EstimationError::InvalidInput(
   403	            "active working-set compression dimension mismatch".to_string(),
   404	        ));
   405	    }
   406	
   407	    let mut a_out = Array2::<f64>::zeros((active.len(), p));
   408	    let mut b_out = Array1::<f64>::zeros(active.len());
   409	    let mut groups_out: Vec<Vec<usize>> = Vec::with_capacity(active.len());
   410	    for (pos, &idx) in active.iter().enumerate() {
   411	        if idx >= constraints.a.nrows() {
   412	            return Err(EstimationError::InvalidInput(format!(
   413	                "active working-set index {} out of bounds for {} constraints",
   414	                idx,
   415	                constraints.a.nrows()
   416	            )));
   417	        }
   418	        a_out.row_mut(pos).assign(&constraints.a.row(idx));
   419	        b_out[pos] = constraints.b[idx];
   420	        groups_out.push(vec![pos]);
   421	    }
   422	
   423	    let (a_out, b_out, groups_out) = rank_reduce_rows_pivoted_qr(a_out, b_out, groups_out);
   424	
   425	    Ok(CompressedActiveWorkingSet {
   426	        constraints: LinearInequalityConstraints::from_paired(a_out, b_out),
   427	        groups: groups_out,
   428	        original_active_count: active.len(),
   429	    })
   430	}
   431	
   432	pub(crate) fn rank_reduce_rows_pivoted_qr(
   433	    a: Array2<f64>,
   434	    b: Array1<f64>,
   435	    groups: Vec<Vec<usize>>,
   436	) -> (Array2<f64>, Array1<f64>, Vec<Vec<usize>>) {
   437	    let k = a.nrows();
   438	    let p = a.ncols();
   439	    if k <= 1 {
   440	        return (a, b, groups);
   441	    }
   442	
   443	    let mut at_faer = faer::Mat::<f64>::zeros(p, k);
   444	    for i in 0..k {
   445	        for j in 0..p {
   446	            at_faer[(j, i)] = a[[i, j]];
   447	        }
   448	    }
   449	
   450	    let qr = at_faer.as_ref().col_piv_qr();
   451	    let r_mat = qr.thin_R();
   452	    let diag_len = r_mat.nrows().min(r_mat.ncols());
   453	    let leading_diag = if diag_len > 0 {
   454	        r_mat[(0, 0)].abs()
   455	    } else {
   456	        0.0
   457	    };
   458	
   459	    const RANK_ALPHA: f64 = 100.0;
   460	    let tol = RANK_ALPHA * f64::EPSILON * (k.max(p).max(1) as f64) * leading_diag.max(1.0);
   461	
   462	    let rank = (0..diag_len).filter(|&i| r_mat[(i, i)].abs() > tol).count();
   463	    if rank >= k {
   464	        return (a, b, groups);
   465	    }
   466	    if rank == 0 {
   467	        log::debug!(
   468	            "rank-reduced active constraints from {} to 0 rows (all active rows numerically zero)",
   469	            k
   470	        );
   471	        return (
   472	            Array2::<f64>::zeros((0, p)),
   473	            Array1::<f64>::zeros(0),
   474	            Vec::new(),
   475	        );
   476	    }
   477	
   478	    let (perm_fwd, _) = qr.P().arrays();
   479	    let kept_orig: Vec<usize> = (0..rank).map(|j| perm_fwd[j].unbound()).collect();
   480	    let dropped_orig: Vec<usize> = (rank..k).map(|j| perm_fwd[j].unbound()).collect();
   481	
   482	    let mut orig_to_out = std::collections::HashMap::with_capacity(rank);
   483	    let mut a_out = Array2::<f64>::zeros((rank, p));
   484	    let mut b_out = Array1::<f64>::zeros(rank);
   485	    let mut groups_out: Vec<Vec<usize>> = Vec::with_capacity(rank);
   486	    for (out_idx, &orig_idx) in kept_orig.iter().enumerate() {
   487	        a_out.row_mut(out_idx).assign(&a.row(orig_idx));
   488	        b_out[out_idx] = b[orig_idx];
   489	        groups_out.push(groups[orig_idx].clone());
   490	        orig_to_out.insert(orig_idx, out_idx);
   491	    }
   492	
   493	    for &dropped_idx in &dropped_orig {
   494	        let dropped_row = a.row(dropped_idx);
   495	        let dropped_norm = dropped_row.dot(&dropped_row).sqrt();
   496	        let mut best_align = -1.0_f64;
   497	        let mut best_target = kept_orig[0];
   498	        for &kept_idx in &kept_orig {
   499	            let kept_row = a.row(kept_idx);
   500	            let kept_norm = kept_row.dot(&kept_row).sqrt();
   501	            let dot = kept_row.dot(&dropped_row).abs();
   502	            let align = if kept_norm > 0.0 && dropped_norm > 0.0 {
   503	                dot / (kept_norm * dropped_norm)
   504	            } else {
   505	                dot
   506	            };
   507	            if align > best_align {
   508	                best_align = align;
   509	                best_target = kept_idx;
   510	            }
   511	        }
   512	        let &out_idx = orig_to_out
   513	            .get(&best_target)
   514	            .expect("merge target must be a kept row");
   515	        groups_out[out_idx].extend_from_slice(&groups[dropped_idx]);
   516	    }
   517	
   518	    for group in &mut groups_out {
   519	        group.sort_unstable();
   520	        group.dedup();

