   288	
   289	// Phase 2 sparse-native PIRLS will reuse this cache for symbolic structure and
   290	// repeated numeric assembly of H = X'WX + S_lambda + ridge I.
   291	//
   292	// This is the natural insertion point for any future selected-inversion /
   293	// Takahashi trace backend. In original spline coefficient order, the assembled
   294	// penalized system can remain sparse/banded, so exact traces like
   295	// tr(H^{-1} S_k) can be computed from a sparse factorization without ever
   296	// materializing a dense inverse. That is not true after the REML
   297	// reparameterization rotates the problem into the dense Qs basis.
   298	//
   299	// Algebra:
   300	//   H = X'WX + sum_k lambda_k S_k + delta I
   301	// and the REML/LAML first-order trace terms have the form
   302	//   T_k = tr(H^{-1} S_k).
   303	// Since tr(AB) = sum_ij A_ij B_ji, for symmetric sparse S_k we only need
   304	// inverse entries on the support of S_k:
   305	//   T_k = sum_{(i,j) in nz(S_k), i>=j} (2 - 1{i=j}) (H^{-1})_{ij} (S_k)_{ij}.
   306	// Takahashi/selected inversion exploits exactly this fact. Given a sparse
   307	// Cholesky-type factorization H = LDL', it computes only those entries of
   308	// H^{-1} that lie on the filled graph of L, which contains the structural
   309	// nonzeros needed for spline penalties. For banded spline systems with
   310	// half-bandwidth b, the work scales like sum_j |N(j)|^2 = O(p b^2) instead of
   311	// dense O(p^3), where N(j) is the subdiagonal nonzero pattern of column j of L.
   312	struct SparsePenalizedSystemCache {
   313	    xtwx_cache: SparseXtWxCache,
   314	    penalty_pattern: SparsePenaltyPattern,
   315	    h_upper_symbolic: SymbolicSparseColMat<usize>,
   316	    h_uppervalues: Vec<f64>,
   317	    h_upper_col_ptr: Vec<usize>,
   318	    h_upperrow_idx: Vec<usize>,
   319	    p: usize,
   320	}
   321	
   322	impl SparsePenalizedSystemCache {
   323	    fn new(
   324	        x: &SparseColMat<usize, f64>,
   325	        penalty_pattern: SparsePenaltyPattern,
   326	    ) -> Result<Self, EstimationError> {
   327	        let xtwx_cache = SparseXtWxCache::new(x)?;
   328	        let p = x.ncols();
   329	        let h_upper_symbolic = build_penalized_symbolic(
   330	            p,
   331	            xtwx_cache.xtwx_symbolic.col_ptr(),
   332	            xtwx_cache.xtwx_symbolic.row_idx(),
   333	            &penalty_pattern.upper_triplets,
   334	        )?;
   335	        let h_uppervalues = vec![0.0; h_upper_symbolic.row_idx().len()];
   336	        Ok(Self {
   337	            xtwx_cache,
   338	            penalty_pattern,
   339	            h_upper_col_ptr: h_upper_symbolic.col_ptr().to_vec(),
   340	            h_upperrow_idx: h_upper_symbolic.row_idx().to_vec(),
   341	            h_upper_symbolic,
   342	            h_uppervalues,
   343	            p,
   344	        })
   345	    }
   346	
   347	    fn matches(
   348	        &self,
   349	        x: &SparseColMat<usize, f64>,
   350	        penalty_pattern: &SparsePenaltyPattern,
   351	    ) -> bool {
   352	        self.xtwx_cache.matches(x)
   353	            && self.penalty_pattern.nnz_upper == penalty_pattern.nnz_upper
   354	            && self.penalty_pattern.upper_triplets == penalty_pattern.upper_triplets
   355	    }
   356	
   357	    fn stats(&self) -> SparsePenalizedSystemStats {
   358	        let upper_total = self.p.saturating_mul(self.p + 1) / 2;
   359	        SparsePenalizedSystemStats {
   360	            nnz_xtwx_symbolic: self.xtwx_cache.xtwx_symbolic.row_idx().len(),
   361	            nnz_s_lambda_upper: self.penalty_pattern.nnz_upper,
   362	            nnz_h_upper: self.h_upper_symbolic.row_idx().len(),
   363	            density_upper: if upper_total == 0 {
   364	                0.0
   365	            } else {
   366	                self.h_upper_symbolic.row_idx().len() as f64 / upper_total as f64
   367	            },
   368	        }
   369	    }
   370	
   371	    fn assemble_upper(
   372	        &mut self,
   373	        x: &SparseColMat<usize, f64>,
   374	        weights: &Array1<f64>,
   375	        ridge: f64,
   376	        precomputed_xtwx: Option<&SparseXtwxPrecomputed>,
   377	    ) -> Result<SparseColMat<usize, f64>, EstimationError> {
   378	        if weights.len() != self.xtwx_cache.nrows {
   379	            return Err(EstimationError::InvalidInput(format!(
   380	                "weights length {} does not match design rows {}",
   381	                weights.len(),
   382	                self.xtwx_cache.nrows
   383	            )));
   384	        }
   385	        // Gaussian-Identity fast path: when the caller has pre-built the
   386	        // `XᵀWX` numerical values (weights are constant across the outer
   387	        // loop), install them into the inner cache and skip the SpGEMM.
   388	        // We verify symbolic-pattern equivalence first; on mismatch we
   389	        // fall back to the regular per-call recomputation rather than
   390	        // installing values keyed to a different sparsity layout.
   391	        let use_precomputed = match precomputed_xtwx {
   392	            Some(pre) => {
   393	                let col_ptr_ok =
   394	                    pre.xtwx_symbolic_col_ptr.as_slice() == self.xtwx_cache.xtwx_symbolic.col_ptr();
   395	                let row_idx_ok =
   396	                    pre.xtwx_symbolic_row_idx.as_slice() == self.xtwx_cache.xtwx_symbolic.row_idx();
   397	                let values_ok = pre.xtwxvalues.len() == self.xtwx_cache.xtwxvalues.len();
   398	                if col_ptr_ok && row_idx_ok && values_ok {
   399	                    self.xtwx_cache.xtwxvalues.copy_from_slice(&pre.xtwxvalues);
   400	                    true
   401	                } else {
   402	                    log::warn!(
   403	                        "[sparse-xtwx-cache] precomputed XᵀWX pattern mismatch; \
   404	                         falling back to per-call recompute"
   405	                    );
   406	                    false
   407	                }
   408	            }
   409	            None => false,
   410	        };
   411	        if !use_precomputed {
   412	            self.xtwx_cache.compute_numeric(x, weights)?;
   413	        }
   414	        self.h_uppervalues.fill(0.0);
   415	
   416	        let mut cursor = self.h_upper_col_ptr[..self.p].to_vec();
   417	
   418	        let xtwx_col_ptr = self.xtwx_cache.xtwx_symbolic.col_ptr();
   419	        let xtwxrow_idx = self.xtwx_cache.xtwx_symbolic.row_idx();
   420	        for col in 0..self.p {
   421	            let start = xtwx_col_ptr[col];
   422	            let end = xtwx_col_ptr[col + 1];
   423	            for idx in start..end {
   424	                let row = xtwxrow_idx[idx];
   425	                if row <= col {
   426	                    let cursor_idx = &mut cursor[col];
   427	                    while *cursor_idx < self.h_upper_col_ptr[col + 1]
   428	                        && self.h_upperrow_idx[*cursor_idx] < row
   429	                    {
   430	                        *cursor_idx += 1;
   431	                    }
   432	                    if *cursor_idx >= self.h_upper_col_ptr[col + 1]
   433	                        || self.h_upperrow_idx[*cursor_idx] != row
   434	                    {
   435	                        return Err(EstimationError::InvalidInput(
   436	                            "penalized symbolic pattern missing XtWX entry".to_string(),
   437	                        ));
   438	                    }
   439	                    self.h_uppervalues[*cursor_idx] += self.xtwx_cache.xtwxvalues[idx];
   440	                }
   441	            }
   442	        }
   443	
   444	        cursor.copy_from_slice(&self.h_upper_col_ptr[..self.p]);
   445	        for &(row, col, value) in &self.penalty_pattern.upper_triplets {
   446	            let cursor_idx = &mut cursor[col];
   447	            while *cursor_idx < self.h_upper_col_ptr[col + 1]
   448	                && self.h_upperrow_idx[*cursor_idx] < row
   449	            {
   450	                *cursor_idx += 1;
   451	            }
   452	            if *cursor_idx >= self.h_upper_col_ptr[col + 1]
   453	                || self.h_upperrow_idx[*cursor_idx] != row
   454	            {
   455	                return Err(EstimationError::InvalidInput(
   456	                    "penalized symbolic pattern missing penalty entry".to_string(),
   457	                ));
   458	            }
   459	            self.h_uppervalues[*cursor_idx] += value;
   460	        }
   461	
   462	        if ridge > 0.0 {
   463	            cursor.copy_from_slice(&self.h_upper_col_ptr[..self.p]);
   464	            for col in 0..self.p {
   465	                let cursor_idx = &mut cursor[col];
   466	                while *cursor_idx < self.h_upper_col_ptr[col + 1]
   467	                    && self.h_upperrow_idx[*cursor_idx] < col
   468	                {
   469	                    *cursor_idx += 1;
   470	                }
   471	                if *cursor_idx >= self.h_upper_col_ptr[col + 1]
   472	                    || self.h_upperrow_idx[*cursor_idx] != col
   473	                {
   474	                    return Err(EstimationError::InvalidInput(
   475	                        "penalized symbolic pattern missing diagonal entry".to_string(),
   476	                    ));
   477	                }
   478	                self.h_uppervalues[*cursor_idx] += ridge;
   479	            }
   480	        }
   481	
   482	        Ok(SparseColMat::new(
   483	            self.h_upper_symbolic.clone(),
   484	            self.h_uppervalues.clone(),
   485	        ))
   486	    }
   487	}
   488	
   489	fn build_penalized_symbolic(
   490	    p: usize,
   491	    xtwx_col_ptr: &[usize],
   492	    xtwxrow_idx: &[usize],
   493	    penalty_triplets: &[(usize, usize, f64)],
   494	) -> Result<SymbolicSparseColMat<usize>, EstimationError> {
   495	    let mut cols: Vec<BTreeSet<usize>> = (0..p).map(|_| BTreeSet::new()).collect();
   496	    for col in 0..p {
   497	        cols[col].insert(col);
   498	        let start = xtwx_col_ptr[col];
   499	        let end = xtwx_col_ptr[col + 1];
   500	        for &row in &xtwxrow_idx[start..end] {
   501	            if row <= col {
   502	                cols[col].insert(row);
   503	            }
   504	        }
   505	    }
   506	    for &(row, col, _) in penalty_triplets {
   507	        if row > col || col >= p {
   508	            return Err(EstimationError::InvalidInput(
   509	                "penalty sparse pattern must be upper-triangular within bounds".to_string(),
   510	            ));
   511	        }
   512	        cols[col].insert(row);
   513	    }
   514	
   515	    let mut col_ptr = Vec::with_capacity(p + 1);
   516	    let mut row_idx = Vec::new();
   517	    col_ptr.push(0);
   518	    for rows in cols {
   519	        row_idx.extend(rows.into_iter());
   520	        col_ptr.push(row_idx.len());
   521	    }
   522	    Ok(unsafe { SymbolicSparseColMat::new_unchecked(p, p, col_ptr, None, row_idx) })
   523	}
