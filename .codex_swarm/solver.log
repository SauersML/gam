  1342	#[inline]
  1343	fn logistic_uwith_derivatives(eta: f64) -> (f64, f64) {
  1344	    let u = logistic_stable(eta);
  1345	    let u_clamped = u.clamp(BETA_LOGISTIC_U_EPS, 1.0 - BETA_LOGISTIC_U_EPS);
  1346	    let clamp_active = !eta.is_finite() || u_clamped != u;
  1347	    let du = if clamp_active {
  1348	        0.0
  1349	    } else {
  1350	        u_clamped * (1.0 - u_clamped)
  1351	    };
  1352	    let u = u_clamped;
  1353	    (u, du)
  1354	}
  1355	
  1356	/// Beta-Logistic inverse-link jet for:
  1357	///   u = logistic(eta)
  1358	///   a = exp(delta - epsilon), b = exp(delta + epsilon)
  1359	///   mu = I_u(a, b)
  1360	pub fn beta_logistic_inverse_link_jet(eta: f64, delta: f64, epsilon: f64) -> InverseLinkJet {
  1361	    let (u, du) = logistic_uwith_derivatives(eta);
  1362	    let a = (delta - epsilon).exp();
  1363	    let b = (delta + epsilon).exp();
  1364	    let mu = beta_reg(a, b, u);
  1365	    if du == 0.0 {
  1366	        return InverseLinkJet {
  1367	            mu,
  1368	            d1: 0.0,
  1369	            d2: 0.0,
  1370	            d3: 0.0,
  1371	        };
  1372	    }
  1373	    let log_d1 = a * u.ln() + b * (1.0 - u).ln() - ln_beta(a, b);
  1374	    let d1 = log_d1.exp();
  1375	    let t = a * (1.0 - u) - b * u;
  1376	    let d2 = d1 * t;
  1377	    let d3 = d1 * (t * t - (a + b) * du);
  1378	    InverseLinkJet { mu, d1, d2, d3 }
  1379	}
  1380	
  1381	pub fn beta_logistic_inverse_link_pdfthird_derivative(eta: f64, delta: f64, epsilon: f64) -> f64 {
  1382	    // Beta-logistic link:
  1383	    //
  1384	    //   u = logistic(eta),
  1385	    //   d1 = C * u^a (1-u)^b,
  1386	    //   t  = a(1-u) - b u,
  1387	    //   c  = a + b,
  1388	    //
  1389	    // so
  1390	    //
  1391	    //   d2 = d1 * t
  1392	    //   d3 = d1 * (t² - c u')
  1393	    //
  1394	    // with `u' = u(1-u)`.
  1395	    //
  1396	    // Differentiate once more:
  1397	    //
  1398	    //   d4 = d/deta[d1 (t² - c u')]
  1399	    //      = d1' (t² - c u') + d1 (2 t t' - c u'')
  1400	    //      = d1 [ t(t² - c u') - 2 c t u' - c u'' ]
  1401	    //      = d1 [ t³ - 3 c t u' - c u'' ],
  1402	    //
  1403	    // since `t' = -c u'`.
  1404	    let (u, du) = logistic_uwith_derivatives(eta);
  1405	    if du == 0.0 {
  1406	        return 0.0;
  1407	    }
  1408	    let a = (delta - epsilon).exp();
  1409	    let b = (delta + epsilon).exp();
  1410	    let log_d1 = a * u.ln() + b * (1.0 - u).ln() - ln_beta(a, b);
  1411	    let d1 = log_d1.exp();
  1412	    let c = a + b;
  1413	    let t = a * (1.0 - u) - b * u;
  1414	    let u2 = du * (1.0 - 2.0 * u);
  1415	    d1 * (t * t * t - 3.0 * c * t * du - c * u2)
  1416	}
  1417	
  1418	/// Fifth derivative of the beta-logistic inverse-link CDF (= 4th deriv of PDF).
  1419	///
  1420	/// With `P_4 = t^3 - 3ct*u' - c*u''` giving `d4 = d1 * P_4`, the next order is:
  1421	///
  1422	///   d5 = d1 * [t^4 - 6c*t^2*u' - 4c*t*u'' + 3c^2*u'^2 - c*u''']
  1423	///
  1424	/// where u' = u(1-u), u'' = u'(1-2u), u''' = u''(1-2u) - 2*u'^2.
  1425	pub fn beta_logistic_inverse_link_pdffourth_derivative(eta: f64, delta: f64, epsilon: f64) -> f64 {
  1426	    let (u, du) = logistic_uwith_derivatives(eta);
  1427	    if du == 0.0 {
  1428	        return 0.0;
  1429	    }
  1430	    let a = (delta - epsilon).exp();
  1431	    let b = (delta + epsilon).exp();
  1432	    let log_d1 = a * u.ln() + b * (1.0 - u).ln() - ln_beta(a, b);
  1433	    let d1 = log_d1.exp();
  1434	    let c = a + b;
  1435	    let t = a * (1.0 - u) - b * u;
  1436	    let u2 = du * (1.0 - 2.0 * u);
  1437	    let u3 = u2 * (1.0 - 2.0 * u) - 2.0 * du * du;
  1438	    let t2 = t * t;
  1439	    d1 * (t2 * t2 - 6.0 * c * t2 * du - 4.0 * c * t * u2 + 3.0 * c * c * du * du - c * u3)
  1440	}
  1441	
  1442	pub fn beta_logistic_inverse_link_jetwith_param_partials(
  1443	    eta: f64,
  1444	    delta: f64,
  1445	    epsilon: f64,
  1446	) -> SasJetWithParamPartials {
  1447	    let (u, du) = logistic_uwith_derivatives(eta);
  1448	    let a = (delta - epsilon).exp();
