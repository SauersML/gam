   996	fn mixture_inverse_link_mu_d1(state: &MixtureLinkState, eta: f64) -> (f64, f64) {
   997	    let mut mu = 0.0_f64;
   998	    let mut d1 = 0.0_f64;
   999	    let k = state.components.len().min(state.pi.len());
  1000	    for i in 0..k {
  1001	        let (mu_i, d1_i) = component_inverse_link_mu_d1(state.components[i], eta);
  1002	        let w = state.pi[i];
  1003	        mu += w * mu_i;
  1004	        d1 += w * d1_i;
  1005	    }
  1006	    (mu, d1)
  1007	}
