   738	pub fn gaussian_reml_multi_closed_form_backward_from_fit(
   739	    x: ArrayView2<'_, f64>,
   740	    y: ArrayView2<'_, f64>,
   741	    penalty: ArrayView2<'_, f64>,
   742	    weights: Option<ArrayView1<'_, f64>>,
   743	    fit: &GaussianRemlMultiResult,
   744	    upstream_lambda: f64,
   745	    upstream_coefficients: Option<ArrayView2<'_, f64>>,
   746	    upstream_fitted: Option<ArrayView2<'_, f64>>,
   747	    upstream_reml_score: f64,
   748	    upstream_edf: f64,
   749	) -> Result<GaussianRemlBackwardResult, EstimationError> {
   750	    validate_gaussian_reml_backward_upstreams(
   751	        x,
   752	        y,
   753	        penalty,
   754	        upstream_lambda,
   755	        upstream_coefficients,
   756	        upstream_fitted,
   757	        upstream_reml_score,
   758	        upstream_edf,
   759	    )?;
   760	    validate_gaussian_reml_forward_fit(x, y, penalty, weights, fit)?;
   761	    let lambda = fit.lambda;
   762	    let n = x.nrows();
   763	    let p = x.ncols();
   764	    let d = y.ncols();
   765	    if !(fit.reml_hess_rho.is_finite() && fit.reml_hess_rho.abs() > 1.0e-14) {
