   195	pub(crate) fn compute_constraint_kkt_diagnostics(
   196	    beta: &Array1<f64>,
   197	    gradient: &Array1<f64>,
   198	    constraints: &LinearInequalityConstraints,
   199	) -> ConstraintKktDiagnostics {
   200	    let m = constraints.a.nrows();
   201	    let active_tolerance = 1e-8;
   202	
   203	    let mut slack = Array1::<f64>::zeros(m);
   204	    let mut primal_feasibility: f64 = 0.0;
   205	    for i in 0..m {
   206	        let s_i = constraints.a.row(i).dot(beta) - constraints.b[i];
   207	        slack[i] = s_i;
   208	        primal_feasibility = primal_feasibility.max((-s_i).max(0.0));
   209	    }
   210	
   211	    let active_idx: Vec<usize> = (0..m).filter(|&i| slack[i] <= active_tolerance).collect();
   212	    let mut lambda = Array1::<f64>::zeros(m);
   213	    if !active_idx.is_empty() {
   214	        let n_active = active_idx.len();
   215	        let p = constraints.a.ncols();
   216	        let mut a_active = Array2::<f64>::zeros((n_active, p));
   217	        for (r, &idx) in active_idx.iter().enumerate() {
   218	            a_active.row_mut(r).assign(&constraints.a.row(idx));
   219	        }
   220	        let mut gram = a_active.dot(&a_active.t());
   221	        let mut rhs = a_active.dot(gradient);
   222	        let ridge_scale = gram.diag().iter().fold(0.0_f64, |acc, &v| acc.max(v.abs()));
   223	        // The ridge only exists to let the SPD solve succeed when active
   224	        // rows of A are linearly dependent (singular Gram). A larger ridge
   225	        // biases the Lagrange multipliers and manifests as a stationarity
   226	        // residual of the same magnitude at perfectly-conditioned active
   227	        // constraints. Use a ULP-scale floor instead so stationarity
   228	        // vanishes to machine precision when Gram is well-conditioned.
   229	        let ridge = f64::EPSILON * ridge_scale.max(1.0);
   230	        for i in 0..n_active {
   231	            gram[[i, i]] += ridge;
   232	        }
   233	        let mut lambda_active = Array1::<f64>::zeros(n_active);
   234	        if solve_symmetric_system(&gram, &rhs, &mut lambda_active).is_ok() {
   235	            for (r, &idx) in active_idx.iter().enumerate() {
   236	                lambda[idx] = lambda_active[r];
   237	            }
   238	        } else {
   239	            rhs.fill(0.0);
   240	        }
   241	    }
   242	
   243	    let mut dual_feasibility: f64 = 0.0;
   244	    let mut complementarity: f64 = 0.0;
   245	    for i in 0..m {
   246	        dual_feasibility = dual_feasibility.max((-lambda[i]).max(0.0));
   247	        complementarity = complementarity.max((lambda[i] * slack[i]).abs());
   248	    }
   249	    let stationarity = {
   250	        let mut resid = gradient.to_owned();
   251	        resid -= &constraints.a.t().dot(&lambda);
   252	        resid.iter().fold(0.0_f64, |acc, &v| acc.max(v.abs()))
   253	    };
   254	
   255	    ConstraintKktDiagnostics {
   256	        n_constraints: m,
   257	        n_active: active_idx.len(),
   258	        primal_feasibility,
   259	        dual_feasibility,
   260	        complementarity,
   261	        stationarity,
   262	        active_tolerance,
   263	    }
   264	}
