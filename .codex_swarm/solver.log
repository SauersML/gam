   707	        for i in 0..n {
   708	            for j in i..n {
   709	                let value = self.trace_logdet_hessian_cross(matrices[i], matrices[j]);
   710	                out[[i, j]] = value;
   711	                out[[j, i]] = value;
   712	            }
   713	        }
   714	        out
   715	    }
