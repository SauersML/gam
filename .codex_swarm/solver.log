   163	fn probit_jet(eta: f64) -> InverseLinkJet {
   164	    // Exact probit semantics:
   165	    //
   166	    //   mu(eta) = Phi(eta),
   167	    //   mu'     = phi(eta),
   168	    //   mu''    = -eta * phi(eta),
   169	    //   mu'''   = (eta^2 - 1) * phi(eta).
   170	    //
   171	    // `normal_cdf` now evaluates the exact special-function form
   172	    // Phi(x) = 0.5 * erfc(-x / sqrt(2)), so the jet can and should use the
   173	    // matching closed-form Gaussian identities directly.
   174	    if eta.is_nan() {
   175	        return InverseLinkJet {
   176	            mu: f64::NAN,
   177	            d1: f64::NAN,
   178	            d2: f64::NAN,
   179	            d3: f64::NAN,
   180	        };
   181	    }
   182	    if eta == f64::INFINITY {
   183	        return InverseLinkJet {
   184	            mu: 1.0,
   185	            d1: 0.0,
   186	            d2: 0.0,
   187	            d3: 0.0,
   188	        };
   189	    }
   190	    if eta == f64::NEG_INFINITY {
   191	        return InverseLinkJet {
   192	            mu: 0.0,
   193	            d1: 0.0,
   194	            d2: 0.0,
   195	            d3: 0.0,
   196	        };
   197	    }
   198	    let x = eta;
   199	    let phi = normal_pdf(x);
   200	    InverseLinkJet {
   201	        mu: normal_cdf(x),
   202	        d1: phi,
   203	        d2: -x * phi,
   204	        d3: (x * x - 1.0) * phi,
   205	    }
   206	}
