  1118	pub fn inverse_link_jet_for_link_function(
  1119	    link: LinkFunction,
  1120	    eta: f64,
  1121	    mixture_link_state: Option<&MixtureLinkState>,
  1122	    sas_link_state: Option<&SasLinkState>,
  1123	) -> Result<InverseLinkJet, EstimationError> {
  1124	    if let Some(state) = mixture_link_state {
  1125	        return state.jet(eta);
  1126	    }
  1127	    if let Some(sas) = sas_link_state {
  1128	        return match link {
  1129	            LinkFunction::BetaLogistic => BetaLogisticKernel {
  1130	                delta: sas.log_delta,
  1131	                epsilon: sas.epsilon,
  1132	            }
  1133	            .jet(eta),
  1134	            _ => sas.jet(eta),
  1135	        };
  1136	    }
  1137	    link.jet(eta)
  1138	}
