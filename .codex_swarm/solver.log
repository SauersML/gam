    47	/// Canonicalize a penalty matrix to its symmetric average.
    48	///
    49	/// Closed-form Gaussian REML treats `S` as symmetric throughout — the
    50	/// eigendecomposition, the pseudo-determinant `log|S|₊`, the rank detector,
    51	/// and every per-helper VJP all assume `S = Sᵀ`. To make that contract
    52	/// explicit (rather than implicit in `eigh(Side::Lower)` reading the lower
    53	/// triangle and silently ignoring the upper), every entry point that takes a
    54	/// penalty matrix replaces it with `0.5 (S + Sᵀ)` before any downstream use.
    55	/// For symmetric input this is a numerical no-op; for asymmetric input it
    56	/// defines the function as operating on the symmetric average.
    57	fn canonicalize_penalty(penalty: ArrayView2<'_, f64>) -> Array2<f64> {
    58	    let p = penalty.nrows();
    59	    let mut out = penalty.to_owned();
    60	    for i in 0..p {
    61	        for j in (i + 1)..p {
    62	            let avg = 0.5 * (out[[i, j]] + out[[j, i]]);
    63	            out[[i, j]] = avg;
    64	            out[[j, i]] = avg;
    65	        }
    66	    }
    67	    out
    68	}
