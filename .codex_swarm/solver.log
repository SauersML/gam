   797	/// Which curvature surface is used for the Hessian-side weights in PIRLS.
   798	///
   799	/// The **inner** P-IRLS solver can use either Fisher or observed curvature ---
   800	/// both find the same mode (any convergent algorithm works).
   801	///
   802	/// The **outer** REML/LAML criterion MUST use the observed Hessian for the
   803	/// exact Laplace approximation. For canonical links (logit-Binomial, log-Poisson),
   804	/// observed = Fisher so both are correct. For non-canonical links (including
   805	/// probit, cloglog, SAS, mixture, flexible, and Gamma-log), the observed weight includes a residual-dependent
   806	/// correction W_obs = W_Fisher - (y-mu)*B, and using Fisher weights would yield
   807	/// a PQL-type surrogate instead of the true Laplace criterion.
   808	///
   809	/// See response.md Section 3 for the mathematical justification.
   810	#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
   811	pub enum HessianCurvatureKind {
   812	    /// Expected (Fisher) information: W_Fisher = h'^2 / (phi * V(mu)).
   813	    /// Used as the inner iteration matrix when observed curvature fails (non-SPD).
   814	    Fisher,
   815	    /// Observed information: W_obs = W_Fisher - (y - mu) * B.
   816	    /// Required for the outer REML log|H| and trace terms (exact Laplace).
   817	    Observed,
   818	}
