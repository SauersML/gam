  1023	/// shares the same eigen-cache layout (uniform `p`), so the scaled
  1024	/// coefficient bases form a fixed-shape stack. Returns `None` when shapes
  1025	/// disagree, the policy declines (small aggregate FLOPs), or the device
  1026	/// path fails — caller then falls back to per-fit
  1027	/// `gaussian_reml_inverse_hessian_from_cache` calls.
  1028	fn batched_inverse_hessians_from_caches<'a>(
  1029	    problems: &[GaussianRemlMultiBackwardProblem<'a>],
  1030	) -> Option<Vec<Array2<f64>>> {
  1031	    if problems.is_empty() {
  1032	        return None;
  1033	    }
  1034	    let p = problems[0].fit.cache.penalty_eigenvalues.len();
  1035	    if p == 0 {
  1036	        return None;
  1037	    }
  1038	    if !problems
  1039	        .iter()
  1040	        .all(|prob| prob.fit.cache.coefficient_basis.dim() == (p, p))
  1041	    {
  1042	        return None;
  1043	    }
  1044	    if !crate::gpu::GpuRuntime::global()
  1045	        .policy()
  1046	        .route_gemm(p, p, p)
  1047	    {
  1048	        return None;
  1049	    }
  1050	    let k = problems.len();
  1051	    let mut scaled_stack = Array3::<f64>::zeros((k, p, p));
  1052	    let mut basis_stack = Array3::<f64>::zeros((k, p, p));
  1053	    for (b, problem) in problems.iter().enumerate() {
  1054	        let cache = &problem.fit.cache;
  1055	        let lambda = problem.fit.lambda;
  1056	        let mut scaled = cache.coefficient_basis.clone();
  1057	        for eig in 0..p {
  1058	            let denom = 1.0 + lambda * cache.penalty_eigenvalues[eig];
  1059	            if !denom.is_finite() || denom.abs() <= 0.0 {
  1060	                return None;
  1061	            }
  1062	            let scale = 1.0 / denom;
  1063	            for row in 0..p {
  1064	                scaled[[row, eig]] *= scale;
  1065	            }
  1066	        }
  1067	        scaled_stack.slice_mut(s![b, .., ..]).assign(&scaled);
  1068	        basis_stack
  1069	            .slice_mut(s![b, .., ..])
  1070	            .assign(&cache.coefficient_basis);
  1071	    }
  1072	    let result_stack =
  1073	        crate::gpu::try_fast_abt_strided_batched(scaled_stack.view(), basis_stack.view())?;
  1074	    let mut per_fit = Vec::with_capacity(k);
  1075	    for b in 0..k {
  1076	        per_fit.push(result_stack.slice(s![b, .., ..]).to_owned());
  1077	    }
  1078	    Some(per_fit)
  1079	}
