    32	    ///
    33	    /// where Aₖ = λₖ Sₖ and S⁺ is the pseudoinverse on the positive eigenspace.
    34	    pub(super) fn structural_penalty_logdet_derivatives(
    35	        &self,
    36	        rs_transformed: &[Array2<f64>],
    37	        lambdas: &Array1<f64>,
    38	        ridge: f64,
    39	    ) -> Result<(Array1<f64>, Array2<f64>), EstimationError> {
