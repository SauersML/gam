   326	pub(crate) fn solve_kkt_direction(
   327	    hessian: &Array2<f64>,
   328	    gradient: &Array1<f64>,
   329	    active_a: &Array2<f64>,
   330	    active_residual: Option<&Array1<f64>>,
   331	) -> Result<(Array1<f64>, Array1<f64>), EstimationError> {
   332	    let p = hessian.nrows();
   333	    let m = active_a.nrows();
   334	    if hessian.ncols() != p || gradient.len() != p || active_a.ncols() != p {
   335	        return Err(EstimationError::InvalidInput(
   336	            "KKT solve dimension mismatch".to_string(),
   337	        ));
   338	    }
   339	    if let Some(residual) = active_residual
   340	        && residual.len() != m
   341	    {
   342	        return Err(EstimationError::InvalidInput(format!(
   343	            "KKT active residual length mismatch: got {}, expected {}",
   344	            residual.len(),
   345	            m
   346	        )));
   347	    }
   348	    if m == 0 {
   349	        let mut d = Array1::<f64>::zeros(p);
   350	        solve_newton_direction_dense(hessian, gradient, &mut d)?;
   351	        return Ok((d, Array1::zeros(0)));
   352	    }
   353	    let mut kkt = Array2::<f64>::zeros((p + m, p + m));
   354	    kkt.slice_mut(s![0..p, 0..p]).assign(hessian);
   355	    kkt.slice_mut(s![0..p, p..(p + m)]).assign(&active_a.t());
   356	    kkt.slice_mut(s![p..(p + m), 0..p]).assign(active_a);
   357	
   358	    let mut rhs = Array1::<f64>::zeros(p + m);
   359	    for i in 0..p {
   360	        rhs[i] = -gradient[i];
   361	    }
   362	    if let Some(residual) = active_residual {
   363	        for i in 0..m {
   364	            rhs[p + i] = residual[i];
   365	        }
   366	    }
   367	    let rhs_target = rhs.clone();
   368	
   369	    let kkt_view = FaerArrayView::new(&kkt);
   370	    let factor = FaerLblt::new(kkt_view.as_ref(), Side::Lower);
   371	    let mut rhs_col = array1_to_col_matmut(&mut rhs);
   372	    factor.solve_in_place(rhs_col.as_mut());
   373	    if !rhs.iter().all(|v| v.is_finite()) {
   374	        solve_dense_system_via_pseudoinverse(&kkt, &rhs_target, &mut rhs)?;
   375	    }
   376	    let d = rhs.slice(s![0..p]).to_owned();
   377	    let lambda = rhs.slice(s![p..(p + m)]).to_owned();
   378	    Ok((d, lambda))
   379	}
