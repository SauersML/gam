            p_order,
            s_order,
            dim,
            Some(&coeffs),
        )
        .expect("fp");
        let fm = duchon_matern_kernel_general_from_distance(
            r - h,
            Some(length_scale),
            p_order,
            s_order,
            dim,
            Some(&coeffs),
        )
        .expect("fm");
        let firstfd = (fp - fm) / (2.0 * h);
        let secondfd = (fp - 2.0 * phi + fm) / (h * h);
