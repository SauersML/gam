   294	/// `Xᵀ · M` where `M` is a tall-skinny dense matrix (`n × r`). Routes
   295	/// through `DesignMatrix::transpose_vector_multiply` column by column,
   296	/// which preserves the sparse / operator-backed fast paths. Returns a
   297	/// dense `p × r` matrix.
   298	fn transpose_design_times_dense(
   299	    design: &DesignMatrix,
   300	    m: &ArrayView2<'_, f64>,
   301	) -> Result<Array2<f64>, String> {
   302	    let n = design.nrows();
   303	    let p = design.ncols();
   304	    let r = m.ncols();
   305	    if m.nrows() != n {
   306	        return Err(format!(
   307	            "transpose_design_times_dense: design has {} rows but M has {}",
   308	            n,
   309	            m.nrows()
   310	        ));
   311	    }
   312	    let mut out = Array2::<f64>::zeros((p, r));
   313	    if r == 0 {
   314	        return Ok(out);
   315	    }
   316	    // Dense fast path: a single GEMM `Xᵀ M` if X is materialised dense.
   317	    if let Some(dense) = design.as_dense() {
   318	        // Xᵀ · M  ≡  fast_atb(X, M)
   319	        let xt_m = fast_atb(&dense.to_owned(), &m.to_owned());
   320	        return Ok(xt_m);
   321	    }
   322	    // Generic path: column-by-column applies — preserves whatever
   323	    // operator-backed apply_transpose the design supplies.
   324	    for (k, col) in m.axis_iter(Axis(1)).enumerate() {
   325	        let col_owned = col.to_owned();
   326	        let xt_col = design.transpose_vector_multiply(&col_owned);
   327	        out.column_mut(k).assign(&xt_col);
   328	    }
   329	    Ok(out)
