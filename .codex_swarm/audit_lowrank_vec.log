//! Structured low-rank working weight: `W = D + U V·µÄ`.
//!
//! The PIRLS inner solve assembles a working weight `W ‚àà ‚Ñù^{n√ón}` and forms
//! the normal equations `(X·µÄWX + S) Œ≤ = X·µÄWz`. Most working models supply a
//! diagonal `W` (one scalar per observation), but Fisher-Rao / behavioral
//! metrics that come from an *external* backward pass through a downstream
//! model are not diagonal ‚Äî they are diagonal **plus a structured low-rank
//! correction** `U V·µÄ`, where `U, V ‚àà ‚Ñù^{n√ór}` are tall-skinny and the rank
//! `r ‚â™ n`. For symmetric metrics (the usual case) `U == V`, but the API
//! does not assume it so we can support nonsymmetric weighting in IRLS
//! corrections too.
//!
//! Crucially: the metric is supplied by the caller. This module never
//! estimates a covariance internally.
//!
//! ## Composition with the existing signed-Gram API
//!
//! The diagonal part `D` flows through the existing `xt_diag_x_signed` /
//! `xt_diag_x_psd` kernels exactly as before, so the rank-0 specialisation
//! coincides with the legacy diagonal path. The low-rank correction adds
//! `(X·µÄU)(V·µÄX)` ‚Äî a `p √ó p` outer product of two tall-skinny matrices ‚Äî
//! computed in `O(n ¬∑ p ¬∑ r)` and *never* materialising an `n √ó n` weight.
//!
//! ## Woodbury / matrix-determinant lemma
//!
//! Solving with `W` directly:
//!   (D + U V·µÄ)‚Åª¬π = D‚Åª¬π ‚àí D‚Åª¬πU (I_r + V·µÄ D‚Åª¬π U)‚Åª¬π V·µÄD‚Åª¬π
//!
//! Solving with the *Gram* `A + √õ VÃÇ·µÄ` where `√Ç = X·µÄDX + S`, `√õ = X·µÄU`,
//! `VÃÇ = X·µÄV`:
//!   (A + √õ VÃÇ·µÄ)‚Åª¬π b = A‚Åª¬π b ‚àí A‚Åª¬π √õ (I_r + VÃÇ·µÄ A‚Åª¬π √õ)‚Åª¬π VÃÇ·µÄ A‚Åª¬π b
//!
//! The latter is the form PIRLS uses: one factorisation of the diagonal-W
//! penalised system `A` (Cholesky, as today), then a rank-r capacitance
//! solve of size `r √ó r`. The dimensionality of the corrected normal
//! equation is `p √ó p`; nothing blows up to `n`.

use ndarray::{Array1, Array2, ArrayView1, ArrayView2, Axis};

use crate::faer_ndarray::{fast_ab, fast_atb, fast_atv};
use crate::matrix::DesignMatrix;

/// `W = diag(diag) + u ¬∑ v·µÄ`. Rows: `n`. Rank of correction: `u.ncols()`.
///
/// For a symmetric metric (the default in Fisher-Rao fits) the caller
/// supplies `u == v` (use [`LowRankWeight::symmetric`]). Asymmetric
/// weights are supported because observed-information IRLS can produce
/// signed off-diagonal contributions.
#[derive(Clone, Copy, Debug)]
pub struct LowRankWeight<'a> {
    pub diag: ArrayView1<'a, f64>,
    pub u: ArrayView2<'a, f64>,
    pub v: ArrayView2<'a, f64>,
}

impl<'a> LowRankWeight<'a> {
    /// Construct a low-rank weight, validating shapes.
    pub fn new(
        diag: ArrayView1<'a, f64>,
        u: ArrayView2<'a, f64>,
        v: ArrayView2<'a, f64>,
    ) -> Result<Self, String> {
        let n = diag.len();
        if u.nrows() != n {
            return Err(format!(
                "LowRankWeight: u has {} rows but diag has {} entries",
                u.nrows(),
                n
            ));
        }
        if v.nrows() != n {
            return Err(format!(
                "LowRankWeight: v has {} rows but diag has {} entries",
                v.nrows(),
                n
            ));
        }
        if u.ncols() != v.ncols() {
            return Err(format!(
                "LowRankWeight: u has rank {} but v has rank {}",
                u.ncols(),
                v.ncols()
            ));
        }
        Ok(LowRankWeight { diag, u, v })
    }

    /// Symmetric metric: `W = D + U U·µÄ`.
    pub fn symmetric(
        diag: ArrayView1<'a, f64>,
        u: ArrayView2<'a, f64>,
    ) -> Result<Self, String> {
        Self::new(diag, u, u)
    }

    #[inline]
    pub fn nrows(&self) -> usize {
        self.diag.len()
    }

    #[inline]
    pub fn rank(&self) -> usize {
        self.u.ncols()
    }

    #[inline]
    pub fn is_rank_zero(&self) -> bool {
        self.rank() == 0
    }

    /// `W ¬∑ x` without materialising the `n √ó n` weight.
    ///
    /// Cost: `O(n) + O(n ¬∑ r)`.
    pub fn apply(&self, x: ArrayView1<'_, f64>) -> Array1<f64> {
        let n = self.nrows();
        assert_eq!(
            x.len(),
            n,
            "LowRankWeight::apply: x has {} entries but W has {} rows",
            x.len(),
            n
        );
        // diag(D) ¬∑ x
        let mut out = Array1::<f64>::zeros(n);
        for i in 0..n {
            out[i] = self.diag[i] * x[i];
        }
        if self.is_rank_zero() {
            return out;
        }
        // U (V·µÄ x): V·µÄ x is r-dim, then U times r-vector.
        let vtx = fast_atv(&self.v.to_owned(), &x.to_owned());
        let uvtx = self.u.dot(&vtx);
        out += &uvtx;
        out
    }

    /// `X·µÄ W X = X·µÄDX + (X·µÄU)(V·µÄX)`. The diagonal part is delegated to the
    /// caller (so it can reuse the existing `xt_diag_x_signed` / `_psd`
    /// kernels and any BLAS / sparse fast paths). This function adds the
    /// rank-r correction in place into `xtwx`.
    ///
    /// Cost (correction only): `O(n ¬∑ p ¬∑ r) + O(p ¬∑ p ¬∑ r)` ‚Äî the second
    /// term is the final `p √ó p` outer-product accumulation and is the
    /// dominant cost only when `n ‚âà p`.
    pub fn add_low_rank_xtwx_correction(
        &self,
        design: &DesignMatrix,
        xtwx: &mut Array2<f64>,
    ) -> Result<(), String> {
        if self.is_rank_zero() {
            return Ok(());
        }
        let n = self.nrows();
        if design.nrows() != n {
            return Err(format!(
                "add_low_rank_xtwx_correction: design has {} rows but weight has {}",
                design.nrows(),
                n
            ));
        }
        let p = design.ncols();
        if xtwx.nrows() != p || xtwx.ncols() != p {
            return Err(format!(
                "add_low_rank_xtwx_correction: xtwx is {}√ó{} but design has p={}",
                xtwx.nrows(),
                xtwx.ncols(),
                p
            ));
        }

        let xtu = transpose_design_times_dense(design, &self.u)?; // p √ó r
        let xtv = if std::ptr::eq(self.u.as_ptr(), self.v.as_ptr())
            && self.u.shape() == self.v.shape()
        {
            xtu.clone()
        } else {
            transpose_design_times_dense(design, &self.v)?
        };

        // xtwx += X·µÄU ¬∑ (X·µÄV)·µÄ
        let correction = fast_ab(&xtu, &xtv.t().to_owned());
        *xtwx += &correction;
        Ok(())
    }

    /// `X·µÄ W y = X·µÄ D y + (X·µÄU)(V·µÄ y)`. Returns a fresh `p`-vector.
    pub fn xtw_y(
        &self,
        design: &DesignMatrix,
        y: ArrayView1<'_, f64>,
    ) -> Result<Array1<f64>, String> {
        let n = self.nrows();
        if y.len() != n {
            return Err(format!(
                "xtw_y: y has {} entries but W has {} rows",
                y.len(),
                n
            ));
        }
        // X·µÄ (D y)
        let mut dy = Array1::<f64>::zeros(n);
        for i in 0..n {
            dy[i] = self.diag[i] * y[i];
