     ) -> Result<Option<DriftDerivResult>, String> {
         let Some(d2h) = self.compute_d2h.as_ref() else {
             return Ok(None);
         };
         let Some(term1) = (self.compute_dh)(u_kl)? else {
             return Ok(None);
         };
         let neg_v_k = -v_k;
         let neg_v_l = -v_l;
         let Some(term2) = d2h(&neg_v_l, &neg_v_k)? else {
