+                let p1 = (*a).clamp(1e-8, 1.0 - 1e-8);
+                let q1 = (*b).clamp(1e-8, 1.0 - 1e-8);
+                let p0 = 1.0 - p1;
+                let q0 = 1.0 - q1;
+                kl_sum += p0 * (p0 / q0).ln() + p1 * (p1 / q1).ln();
+            }
+            _ => {
+                let pa: Vec<f32> = match &prev[i] {
+                    AllelePosteriors::Biallelic(v) => vec![1.0 - *v, *v],
+                    AllelePosteriors::Multiallelic(p) => p.to_vec(),
