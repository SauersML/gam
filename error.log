+            values.extend(arr.values().iter().copied());
+        }
+        DataType::Float32 => {
+            let arr = col.as_any().downcast_ref::<Float32Array>().unwrap();
+            values.extend(arr.values().iter().map(|&v| v as f64));
+        }
+        DataType::Int64 => {
+            let arr = col.as_any().downcast_ref::<Int64Array>().unwrap();
