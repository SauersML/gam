 fn rademacher_probe_into(mut z: ArrayViewMut1<'_, f64>, rng: &mut Xoshiro256SS) {
     let mut bits: u64 = 0;
     let mut remaining_bits = 0u32;
 
     for i in 0..z.len() {
         if remaining_bits == 0 {
             bits = rng.next_u64();
             remaining_bits = 64;
         }
         z[i] = if bits & 1 == 0 { 1.0 } else { -1.0 };
         bits >>= 1;
         remaining_bits -= 1;
     }
 }
 
