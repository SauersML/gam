 fn window_boundaries_from_handoff(handoff: &[(f64, f64)]) -> Vec<f64> {
     if handoff.len() < 2 {
         return Vec::new();
     }
     let mut out = Vec::with_capacity(handoff.len() - 1);
     for i in 0..handoff.len() - 1 {
         let (prev_start, _) = handoff[i];
         let (next_start, _) = handoff[i + 1];
