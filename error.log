 ) -> Result<(), String> {
     let dense_bytes = checked_dense_nbytes(n, p, context)?;
     let limit = policy.max_single_materialization_bytes;
     if dense_bytes > limit {
         let gib = dense_bytes as f64 / (1024.0 * 1024.0 * 1024.0);
         return Err(format!(
