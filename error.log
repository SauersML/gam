         Ok(self
             .hessian_derivative_correction_result(v_k)?
             .map(|result| result.into_operator().to_dense()))
     }
 
     fn hessian_derivative_correction_result(
         &self,
         v_k: &Array1<f64>,
     ) -> Result<Option<DriftDerivResult>, String> {
         let neg_v = -v_k;
         (self.compute_dh)(&neg_v)
