 #[inline]
 fn softplus(x: f64) -> f64 {
     if x.is_nan() {
         f64::NAN
     } else if x == f64::INFINITY {
         f64::INFINITY
     } else if x == f64::NEG_INFINITY {
         0.0
     } else if x >= 0.0 {
         x + (-x).exp().ln_1p()
     } else {
         x.exp().ln_1p()
     }
 }
 
