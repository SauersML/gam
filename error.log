+        const PAR_MIN_CELLS: usize = 64 * 1024;
+        let cells = out.nrows().saturating_mul(ncols);
+        if cells >= PAR_MIN_CELLS && rayon::current_num_threads() > 1 && out.is_standard_layout() {
+            if let Some(slice) = out.as_slice_memory_order_mut() {
